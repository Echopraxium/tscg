      "owl:versionInfo": "15.3.9",
      "dcterms:created": "2026-02-23"
    },
    {
      "@id": "m2:MetaConcept",
      "@type": "owl:Class",
      "rdfs:label": "M2 Metaconcept",
      "rdfs:comment": "A systemic pattern emerging from tensor product of M3 dimensions"
    },
    {
      "@id": "m2:MetaconceptFamily",
