      },
      "rdfs:comment": "Morphism composition: if f: A→B and g: B→C, then f composedWith g yields g∘f: A→C."
    },
    {
      "@id": "m3:functorSourceCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "functor source category",
