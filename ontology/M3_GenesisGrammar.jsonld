    {
      "@id": "m3:SymbolicSystemGrammar",
      "@type": [
        "owl:Class",
        "skos:Concept"
      ],
      "skos:inScheme": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:topConceptOf": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:prefLabel": "Symbolic System Grammar",
      "skos:altLabel": [
        "Combinatoric Symbolic System",
        "Interpretive Grammar",
        "Formal Symbolic Language"
      ],
      "skos:definition": "Ontologies representing formal symbolic systems defined by a finite set of primitives and combination rules, whose value lies in the multiplicity of legitimate interpretations they generate. Neither prescriptive nor empirically arbitrated — interpretation is symbolic, cultural, or contextual.",
      "rdfs:comment": "Symbolic System Grammars are complete symbolic languages with combinatorial structure. Unlike SystemicFrameworks (which converge toward solutions) or Poclets (which validate observable systems), SymbolicSystemGrammars are productive engines of legitimate interpretive diversity. Examples span divination systems, generative alphabets, and musical notation.",
      "skos:notation": "M3_SystemSymbolicGrammar",
      "skos:example": [
        "M0_IChing.jsonld (64 hexagrams from Yin/Yang binary grammar)",
        "M0_Tarot.jsonld (78 arcanes, positional combination rules)",
        "M0_AlchemyGame.jsonld (4 elements → 173 compounds by binary combination)",
        "M0_ChineseGlyphs.jsonld (~200 radicals → ~50,000 sinograms)",
        "M0_MusicalNotation.jsonld (notes + rhythm rules → infinite interpretations)"
      ],
      "skos:scopeNote": "Open-ended set. Any formal symbolic system with finite primitives, explicit combination rules, and multiple legitimate interpretations qualifies. Arbitration is symbolic/cultural/contextual, never purely physical or empirical.",
      "m3:expectedCount": "5-15",
      "m3:layerOrder": 3,
      "m3:semanticSignature": "finite_primitives + combination_rules + multiple_legitimate_interpretations(symbolic_arbitration)",
      "m3:distinguishingFeatures": {
        "vs_SystemicFramework": "SystemicFramework = prescriptive, convergent toward solution. SymbolicSystemGrammar = generative, divergent toward interpretive multiplicity.",
        "vs_Poclet": "Poclet = minimal observable system validated empirically. SymbolicSystemGrammar = complete symbolic language, culturally/contextually arbitrated.",
        "vs_RealWorldSystem": "RealWorldSystem = deployed with stakeholders and physical constraints. SymbolicSystemGrammar = purely symbolic, no physical arbitration.",
        "coreProperty": "The arbitration of interpretation is symbolic/cultural/contextual — never physical or empirical. This is the defining discriminant."
      },
      "skos:broader": {
        "@id": "m3:GenericConcepts"
      },
      "skos:related": [
        {
          "@id": "m3:SystemicFramework"
        },
        {
          "@id": "m3:Poclet"
        }
      ],
      "rdfs:subClassOf": {
        "@id": "m3:TscgOntologyType"
      }
    },
    {
      "@id": "m3:TscgTool",
      "@type": [
        "owl:Class",
        "skos:Concept"
      ],
      "skos:inScheme": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:topConceptOf": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:prefLabel": "TSCG Tool",
      "skos:altLabel": [
        "Framework Tool",
        "Ontology Tool",
        "Meta-Level Application",
        "Reflexive Tool"
      ],
      "skos:definition": "Software tools that operate reflexively ON the TSCG framework itself. Unlike Poclets (which model external systems), TscgTools model and operate on TSCG artifacts: ontologies, GenericConcepts, poclets, formulas. They are M0-level concrete instantiations whose subject matter is the framework.",
      "rdfs:comment": "TscgTools are meta-level applications: visualizers, explorers, validators, converters, simulators that take TSCG ontologies as input and produce analysis, navigation, or transformation as output. They can themselves be characterized by ASFID/REVOI (as any system), but their primary purpose is operating on the TSCG knowledge graph.",
      "m3:semanticSignature": "operates_on_tscg_artifacts + reflexive_meta_level + software_tool + framework_self_analysis",
      "m3:distinguishingFeatures": {
        "vs_Poclet": "Poclet = minimal model of an EXTERNAL system (biology, mythology, engineering). TscgTool = software application whose input IS the TSCG framework itself.",
        "vs_SystemicFramework": "SystemicFramework = established external methodology mapped into TSCG. TscgTool = tool built to navigate/analyze TSCG artifacts.",
        "vs_CaseStudy": "CaseStudy = pedagogical M0 example. TscgTool = operational software with concrete functionality.",
        "coreProperty": "The subject matter of a TscgTool is TSCG itself — it exhibits framework reflexivity."
      },
      "skos:notation": "M0_TscgTool",
      "skos:example": [
        "M0_TscgExplorer.jsonld (interactive GenericConcept net visualizer, 3 projection modes)",
        "M0_TscgValidator.jsonld (ontology consistency checker — planned)",
        "M0_TscgRagSearch.jsonld (RAG-based semantic search over TSCG — planned)"
      ],
      "skos:scopeNote": "Open-ended set. Any software tool whose primary input/subject is TSCG ontological artifacts qualifies. Instantiated at M0 level but typed as TscgTool rather than Poclet.",
      "m3:expectedCount": "3-10",
      "m3:layerOrder": 4,
      "skos:related": [
        {
          "@id": "m3:Poclet"
        },
        {
          "@id": "m3:Genesis"
        }
      ],
      "rdfs:subClassOf": {
        "@id": "m3:TscgOntologyType"
      }
    },
    {
      "@id": "m3:TransDisclet",
      "@type": [
        "owl:Class",
        "skos:Concept"
      ],
      "skos:inScheme": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:topConceptOf": {
        "@id": "m3:TscgOntologyTypeScheme"
      },
      "skos:prefLabel": "TransDisclet",
      "skos:altLabel": [
        "Transdisciplinary System Instance",
        "Cross-Domain System",
        "Multi-Domain Native System"
      ],
      "skos:definition": "M0-level ontologies modeling systems that exist natively and autonomously across multiple disciplines simultaneously. Unlike Poclets (which validate a single system in one domain), a TransDisclet captures a system concept whose existence is inherently multi-disciplinary — the same system arises independently in each discipline, not by analogy but by native instantiation.",
      "rdfs:comment": "A TransDisclet (from 'Transdisciplinary' + diminutive suffix '-let', analogous to 'Poclet') is a minimal yet complete cross-domain system model. The defining criterion is that the system is not merely analogous across domains — it is the SAME system concept natively instantiated in each discipline. Example: Transducer exists natively in Electronics (sensor/actuator), Biology (sensory receptor), Acoustics (microphone/speaker), and Physics (piezoelectric effect).",
      "m3:semanticSignature": "multi_domain_native + same_system_concept + independent_disciplinary_instantiation + M0_level",
      "m3:distinguishingFeatures": {
        "vs_Poclet": "Poclet = minimal model of ONE system in ONE domain (e.g. RAAS in biology). TransDisclet = same system concept existing natively in 2+ disciplines simultaneously (e.g. Transducer in electronics AND biology AND acoustics).",
        "vs_CaseStudy": "CaseStudy = pedagogical example, may be incomplete. TransDisclet = rigorous multi-domain model with validated instances in each discipline.",
        "vs_DomainExtension": "DomainExtension = disciplinary vocabulary (M1 layer). TransDisclet = concrete M0 instance whose scope spans multiple M1 domains.",
        "vs_SystemicFramework": "SystemicFramework = established external methodology mapped into TSCG. TransDisclet = concrete system natively present across disciplines.",
        "coreProperty": "The same system concept arises INDEPENDENTLY in multiple disciplines — not by metaphor or analogy, but by native disciplinary instantiation."
      },
      "skos:notation": "M0_TransDisclet",
      "skos:example": [
        "M0_Transducer.jsonld (Electronics: sensor/actuator; Biology: sensory receptor; Acoustics: microphone/speaker; Physics: piezoelectric effect)",
        "M0_Oscillator.jsonld (Electronics: LC circuit; Biology: circadian rhythm; Physics: pendulum; Neuroscience: neural oscillation)",
        "M0_Filter.jsonld (Electronics: RC/LC filter; Biology: kidney glomerulus; Acoustics: resonator; Signal Processing: digital filter)"
      ],
      "skos:scopeNote": "Open-ended set. A system qualifies as a TransDisclet when: (1) it exists natively in at least 2 distinct disciplines, (2) the same GenericConcept structure (ASFID) is identifiable in each disciplinary instance, and (3) the cross-domain homology is structural, not merely metaphorical. Stored in instances/transdisclet/ folder.",
      "m3:storageConvention": {
        "folder": "instances/transdisclet/",
        "fileNaming": "M0_SystemName.jsonld",
        "example": "instances/transdisclet/M0_Transducer.jsonld"
      },
      "m3:validationCriteria": {
        "minimum_domains": 2,
        "structural_homology": "Same ASFID structural formula identifiable in each disciplinary instance",
        "native_existence": "System exists autonomously in each discipline, not derived by analogy",
        "m2_grounding": "All instances share the same root GenericConcept structural type from M2 layer"
      },
      "m3:expectedCount": "5-20",
      "m3:layerOrder": 4,
      "skos:broader": {
        "@id": "m3:Poclet"
      },
      "skos:related": [
        {
          "@id": "m3:Poclet"
        },
        {
          "@id": "m3:DomainExtension"
        }
      ],
      "rdfs:subClassOf": {
        "@id": "m3:TscgOntologyType"
      }
    },
    {
      "@id": "m3:CouplingStructure",
      "@type": "owl:Class",
      "rdfs:label": "Bicephalous Coupling (Natural Transformations)",
      "rdfs:comment": "Natural transformations Φ and Ψ encoding bidirectional connection between Territory Grammar Gt and Map Grammar Gm.",
      "skos:definition": "Æ’ᵢⱼ represents coupling strength between ASFID types i and REVOI types j",
      "m3:mathematicalForm": "Φ : Gt → Gm, Ψ : Gm → Gt (natural transformations), δ₁ = ||ASFID_mean − REVOI_mean|| / √2",
      "m3:role": "Encodes Map/Territory bidirectional epistemological connection"
    },
    {
      "@id": "m3:AlignmentLoop",
      "@type": "owl:Class",
      "rdfs:label": "Territory \" Map Alignment Loop",
      "rdfs:comment": "Bidirectional iterative process aligning Territory observations with Map construction: Eagle Eye measures phenomena (ASFID), Sphinx Eye constructs representations (REVOI), and the Φ/Ψ operators drive progressive convergence between the two. Distinct from systemic feedback loops (biological, mechanical) \" this is an epistemological alignment mechanism intrinsic to TSCG architecture.",
      "skos:definition": "Epistemological alignment loop between empirical observations (Territory/ASFID) and conceptual representations (Map/REVOI), driven by Φ and Ψ operators until Map-Territory coherence is achieved.",
      "m3:operators": {
        "Phi": {
          "symbol": "Φ",
          "signature": "Φ : Gt → Gm  (natural transformation)",
          "description": "Observation operator - transforms Territory data into Map representations"
        },
        "Psi": {
          "symbol": "Ψ",
          "signature": "Ψ : Gm → Gt  (natural transformation)",
          "description": "Interpretation operator - Map predictions guide Territory measurement strategies"
        }
      },
      "m3:iteration": "iterative refinement via Φ/Ψ until δ₁ converges toward epistemic equilibrium"
    },
    {
      "@id": "m3:KorzybskiPrinciple",
      "@type": "owl:Class",
      "rdfs:label": "Korzybski Principle Formalization",
      "rdfs:comment": "Mathematical formalization of 'The map is not the territory' extended to 'The map influences how we observe the territory'",
      "skos:definition": "Epistemological principle recognizing Map and Territory as distinct yet mutually influential through bidirectional coupling Σ",
      "m3:classicStatement": "The map is not the territory (Alfred Korzybski, 1933)",
      "m3:tscgExtension": "The map influences how we observe the territory, and observations refine the map",
      "m3:formalization": "Φ : Gt → Gm is never a perfect isomorphism — δ₁ > 0 for all real systems"
    },
    {
      "@id": "m3:MathematicalCategory",
      "@type": "owl:Class",
      "rdfs:label": "Mathematical Category",
      "rdfs:comment": "A category in the mathematical sense: a collection of objects (Ob(C)) and morphisms (Mor(C)) between them, satisfying identity and associativity axioms. In TSCG: Cat_M3 (ASFID types), Cat_M2 (metaconcepts), Cat_M1 (concepts), Cat_KnowledgeField (Chemistry, Biology, Optics...).",
      "m3:structure": {
        "objects": "Collection Ob(C) of category objects",
        "morphisms": "Collection Mor(C) of arrows between objects",
        "identity": "For each object A ∈ Ob(C), exists id_A: A → A",
        "composition": "For f: A → B and g: B → C, exists g∘f: A → C",
        "associativity": "(h∘g)∘f = h∘(g∘f)",
        "identity_law": "f∘id_A = f = id_B∘f for f: A → B"
      },
      "m3:categoryAxioms": [
        "Identity: ∀A ∈ Ob(C), ∃ id_A ∈ Mor(A,A)",
        "Composition: ∀f ∈ Mor(A,B), g ∈ Mor(B,C), ∃ g∘f ∈ Mor(A,C)",
        "Associativity: (h∘g)∘f = h∘(g∘f)",
        "Unit law: f∘id_A = f, id_B∘f = f"
      ],
      "m3:tscgExamples": [
        "Cat_KnowledgeField: Ob = {Chemistry, Biology, Optics...}, Mor = knowledge transfers",
        "Cat_M2: Ob = {Link, Processor, Component...}, Mor = metaconcept inclusions",
        "Cat_M3_ASFID: Ob = {A, S, F, I, D} (Gt primitives), Mor = × structural products",
        "Cat_TSCG: Ob = {M3, M2, M1, M0}, Mor = functors F_×, F_inst"
      ]
    },
    {
      "@id": "m3:CategoryObject",
      "@type": "owl:Class",
      "rdfs:label": "Category Object",
      "rdfs:comment": "An object within a mathematical category. Objects are the 'things' in a category; morphisms are the 'relationships' between them. In TSCG: Chemistry is an object in Cat_KnowledgeField, Link is an object in Cat_M2, ASFID is an object in Cat_M3.",
      "m3:formalDefinition": "An element A ∈ Ob(C) for some category C",
      "m3:properties": [
        "Every object has an identity morphism id_A: A → A",
        "Objects are sources and targets of morphisms",
        "Objects themselves have no internal structure in category theory",
        "Structure comes from morphisms TO and FROM the object"
      ],
      "m3:tscgReification": {
        "description": "In TSCG, metaconcepts (M2) are reified as Category Objects when viewed categorically",
        "example": "KnowledgeField (M2 metaconcept) IS ALSO a mathematical category with Chemistry, Biology... as objects",
        "doubleRole": "Chemistry is BOTH an object in Cat_KnowledgeField AND potentially a category itself (Cat_Chemistry with subconcepts as objects)"
      }
    },
    {
      "@id": "m3:Morphism",
      "@type": "owl:Class",
      "rdfs:label": "Category Morphism",
      "rdfs:comment": "An arrow (morphism) between category objects. Morphisms represent structure-preserving transformations. In TSCG: structural composition (M3→M2), instantiation (M2→M1), concept application (M1→M0), knowledge transfer between domains.",
      "m3:formalDefinition": "An element f ∈ Mor(A,B) for objects A,B ∈ Ob(C)",
      "m3:notation": {
        "arrow": "f: A → B",
        "source": "dom(f) = A (domain)",
        "target": "cod(f) = B (codomain)",
        "composition": "g∘f for f: A → B, g: B → C"
      },
      "m3:morphismTypes": {
        "identity": "id_A: A → A (trivial morphism)",
        "isomorphism": "f: A → B with inverse f⁻¹: B → A",
        "monomorphism": "injective morphism",
        "epimorphism": "surjective morphism",
        "endomorphism": "f: A → A (same source and target)",
        "automorphism": "isomorphic endomorphism"
      },
      "m3:tscgMorphisms": {
        "inclusion": "↪ (e.g., Homeostasis ↪ Regulation)",
        "composition": "∘ (e.g., Learning = Memory ∘ Adaptation)",
        "duality": "op (e.g., Divergence = Convergence^op)",
        "emergence": "⇒ (e.g., MetaconceptCombo: M_A × M_B ⇒ M_C)",
        "structuralComposition": "× or + (combination of objects)",
        "instantiation": "inst (M2 concept → M1 concept → M0 instance)"
      }
    },
    {
      "@id": "m3:Functor",
      "@type": "owl:Class",
      "rdfs:label": "Functor",
      "rdfs:comment": "A structure-preserving map between categories. Functors map objects to objects and morphisms to morphisms, preserving identity and composition. In TSCG: F_× (structural composition M3→M2), F_inst (instantiation M2→M1), domain projection functors.",
      "m3:formalDefinition": "F: C → D mapping Ob(C) → Ob(D) and Mor(C) → Mor(D)",
      "m3:functorLaws": [
        "Object mapping: F: Ob(C) → Ob(D)",
        "Morphism mapping: F: Mor_C(A,B) → Mor_D(F(A),F(B))",
        "Identity preservation: F(id_A) = id_F(A)",
        "Composition preservation: F(g∘f) = F(g)∘F(f)"
      ],
      "m3:functorTypes": {
        "covariant": "Preserves direction of morphisms",
        "contravariant": "Reverses direction of morphisms",
        "endofunctor": "F: C → C (same category)",
        "identity_functor": "Id_C: C → C (trivial functor)",
        "forgetful": "Forgets structure (e.g., from algebra to set)",
        "free": "Builds free structure (left adjoint to forgetful)"
      },
      "m3:tscgFunctors": {
        "F_structuralFormula_examples": {
          "signature": "F_×: Cat_M3 → Cat_M2",
          "description": "Maps ASFID types to metaconcepts via structural composition",
          "example": "F_×(S × F) = Link (metaconcept from structural composition of Structure and Flow)"
        },
        "F_instantiation": {
          "signature": "F_inst: Cat_M2 → Cat_M1",
          "description": "Maps metaconcepts to domain-specific concepts",
          "example": "F_inst(Link) = ChemicalLink (in Chemistry domain)"
        },
        "F_domain_projection": {
          "signature": "F_proj: Cat_M1 → Cat_KnowledgeField",
          "description": "Projects M1 concepts onto their parent knowledge field",
          "example": "F_proj(ChemicalLink) = Chemistry"
        }
      }
    },
    {
      "@id": "m3:NaturalTransformation",
      "@type": "owl:Class",
      "rdfs:label": "Natural Transformation",
      "rdfs:comment": "A morphism between functors. Natural transformations relate two functors F,G: C → D via a family of morphisms. In TSCG: transformations between different observer perspectives (human vs AI), translations between knowledge representations.",
      "m3:formalDefinition": "η: F ⇒ G is a family η_A: F(A) → G(A) for each A ∈ Ob(C)",
      "m3:naturality": {
        "description": "Naturality square commutes",
        "diagram": "For f: A → B, the square F(A) \"η_A→ G(A), F(B) \"η_B→ G(B) commutes",
        "law": "η_B ∘ F(f) = G(f) ∘ η_A"
      },
      "m3:tscgApplications": [
        "Observer transformations: different perspectives on same territory",
        "Knowledge transfer: translation between disciplines",
        "Representation changes: different encodings of same concept"
      ]
    },
    {
      "@id": "m3:Adjunction",
      "@type": "owl:Class",
      "rdfs:label": "Adjunction",
      "rdfs:comment": "A relationship between two functors F: C → D and G: D → C where F is left adjoint to G (F ⊣ G). Adjunctions capture the idea of 'best approximation'. In TSCG: observation-interpretation duality (Φ ⊣ Ψ), free-forgetful pairs.",
      "m3:formalDefinition": "F ⊣ G iff Mor_D(F(A),B) ≈ Mor_C(A,G(B)) naturally in A,B",
      "m3:components": {
        "unit": "η: Id_C ⇒ G∘F",
        "counit": "ε: F∘G ⇒ Id_D"
      },
      "m3:tscgAdjunctions": {
        "observation_interpretation": {
          "description": "Φ (Territory→Map) ⊣ Ψ (Map→Territory)",
          "interpretation": "Best map given territory \" Best territory interpretation given map"
        }
      }
    },
    {
      "@id": "m3:belongsToCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "belongs to category",
      "rdfs:domain": {
