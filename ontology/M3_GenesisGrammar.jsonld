      "m3:objects": [
        "Representable",
        "Evolvable",
        "Verifiable",
        "Observable",
        "Interoperable"
      ]
    },
    {
      "@id": "m3:F_structuralFormula",
      "@type": [
        "owl:NamedIndividual",
        "m3:Functor"
      ],
      "rdfs:label": "Structural Composition Functor",
      "rdfs:comment": "Functor mapping M3 dimensions to M2 metaconcepts via structural composition.",
      "m3:functorType": "covariant",
      "m3:functorSourceCategory": "m3:Cat_M3_ASFID",
      "m3:signature": "F_×: Cat_M3 → Cat_M2",
      "m3:examples": [
        "F_×(S × F) = Link",
        "F_×(A × S × F) = Reservoir",
        "F_×(S × I × D × F) = Processor (v3.9.0)",
        "F_×(F × S × I) = Transducer (v3.9.0)",
        "F_×(F × I × D) = Entropy (v3.9.0)",
        "F_×(S × A) = Stase — F-absent ground state (v3.9.0)",
        "F_×(A × S × I | R + O) = Coherence (v3.9.0)"
      ]
    },
    {
      "@id": "m3:F_instantiation",
      "@type": [
        "owl:NamedIndividual",
        "m3:Functor"
      ],
      "rdfs:label": "Instantiation Functor",
      "rdfs:comment": "Functor mapping M2 metaconcepts to M1 domain-specific concepts.",
      "m3:functorType": "covariant",
      "m3:signature": "F_inst: Cat_M2 → Cat_M1",
      "m3:examples": [
        "F_inst(Link) = ChemicalLink (in Chemistry)",
        "F_inst(Processor) = BiologicalProcessor (in Biology)",
        "F_inst(Component) = MechanicalComponent (in Mechanics)"
      ]
    },
    {
      "@id": "m3:F_ArchitecturalAmendments",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Flow Type Architectural Amendments v3.9.0",
      "rdfs:comment": "Three amendments to the Flow (F) type of ASFID, emerging from the Ranaora & Yii poclet session (2026-03-23). Amendments 1 (structural optionality) and 2 (morphic capacity) are additive and non-destructive. Amendment 3 was REDUCED on 2026-06-29: its continuous numeric F-spectrum (F_crit, F_max, F_total conservation) was removed as a scalar residue inconsistent with m3:MonoidalType; the qualitative latent/active distinction is retained via m2:Potentialization poles. Existing M2 structural compositions remain valid (no concept references the removed spectrum).",
      "dcterms:date": "2026-03-23",
      "dcterms:source": "DOI: 10.5281/zenodo.19160047",
      "m3:amendmentType": "additive",
      "m3:targetType": "F (Flow) — Eagle Eye / ASFID",
      "m3:amendment_1": {
        "id": "F_axiom_relaxation",
        "title": "F Axiom Relaxed: F structurally optional in ground states",
        "status": "DECIDED",
        "before": "F ≠ 0 — F structurally necessary condition for system existence",
        "after": "F structurally optional in boundary/ground states (e.g., vacuum, degenerate systems where F is absent from the structural formula). Replaces numeric F≥0 with qualitative structural optionality.",
        "rationale": "F=0 represents the lowest degraded energy level of a system, not its absence. Examples: tardigrade cryptobiosis, quantum ground state |0⟩, suspended thread, dormant seed. The old axiom was over-restrictive — it excluded legitimate resting states from TSCG modeling.",
        "groundState": {
          "name": "Stase",
          "m2Formula": "S×A",
          "m2Reference": "m2:Stase",
          "reversibility": "necessarily reversible — D absent from structural formula by construction"
        },
        "sealedGroundState": {
          "name": "Absorbing State",
          "m2Formula": "S×A×F×I×D",
          "m2Reference": "m2:AbsorbingState",
          "reversibility": "irreversible — Entropy seals return path"
        }
      },
      "m3:amendment_2": {
        "id": "F_morphic_annotation",
        "title": "F Morphic Capacity: F ∈ Mor(Cat_M3) ∩ Ob(Cat_M3)",
        "status": "DECIDED",
        "formalAxiom": "F ∈ Mor(Cat_M3) ∩ Ob(Cat_M3)",
        "rationale": "F is the only ASFID types whose definition structurally requires a source AND a target. A flux cannot exist without transport direction. A, S, I, D can describe static states — F is intrinsically relational. This emergent asymmetry was not designed but discovered through analysis.",
        "consequence_forM2": "Any M2 structural formula containing F is a natural candidate for dual entity/morphism ontological nature. M2 property m2:ontologicalNature='entity_and_morphism' applies to all F-containing structural formulas.",
        "consequence_forF0": "F=0 means no active morphisms: Mor_active(Cat_M3) = ∅. System in Stase (ground state) — valid per Amendment 1.",
        "dimensionRoles": {
          "A_S_I_D": "object types — describe system states",
          "F": "morphism type — describes transitions between states"
        }
      },
      "m3:amendment_3": {
        "id": "F_activation_modes",
        "title": "F Activation Modes: latent / active as qualitative pole states (not a numeric spectrum)",
        "status": "REDUCED",
        "supersedes": "F_potential_active_spectrum (v3.9.0) — the continuous numeric spectrum (F_crit, F_max, the 0<F<F_crit band, and F_total conservation) is removed as a scalar residue inconsistent with m3:MonoidalType (qualitative, no metric at M3). Reduced 2026-06-29.",
        "rationale": "When present, F has two qualitative activation modes — latent and active — connected by the poles of m2:Potentialization (_^ mobilization, _$ depletion). This is NOT a numeric continuum: F is a generator, present or absent in a structural formula (per Amendment 1), and when present it is qualitatively latent or active. Any magnitude ('how much flow') is an M0 instance score (F_score in the M0 ValueSpace), never an M3 axiom — per m3:MonoidalType.",
        "activationModes": {
          "absent": "F omitted from the structural formula — Stase (m2:Stase, S×A); the degenerate case of Amendment 1",
          "latent": "F present but dormant — structural flow capacity not currently transporting",
          "active": "F present and mobilized — effective morphism / transport operator"
        },
        "category3Resolution": {
          "concepts": [
            "Resource",
            "Storage",
            "Hub",
            "Stateful",
            "Environment"
          ],
          "interpretation": "These M2 concepts carry F in the latent activation mode (dormant Potentialization state) — not a contradiction. Their formulas legitimately contain F as structural flow capacity; whether a given instance is actively flowing is an M0 score, not an M3 property."
        },
        "transitionOperators": {
          "Potentialization_plus": "latent/absent → active (mobilization) — m2:Potentialization pole _^",
          "Potentialization_minus": "active → latent/absent (depletion) — m2:Potentialization pole _$"
        },
        "magnitudeNote": "Flow magnitude lives at M0 as F_score (xsd:float in [0,1]); the M3 grammar carries only the qualitative present/absent and latent/active distinctions."
      }
    },
    {
      "@id": "m3:F_CategoryTheoryNote",
      "@type": "owl:Annotation",
      "rdfs:label": "M3 Categorical Structure — Theoretical Note on F Asymmetry",
      "rdfs:comment": "The F_morphic amendment (v3.9.0) reveals that M3 has richer categorical structure than a pure homogeneous metric space. ASFID types are not equivalent: {A,S,I,D} describe objects, {F} describes morphisms. This suggests M3 is closer to an enriched category or fibered space than to a simple cartesian product of homogeneous dimensions.",
      "m3:status": "HYPOTHESIS — requires expert mathematical review",
      "m3:currentModel": "M3 as Structural Grammar G_T (Territory) + G_M (Map) — free commutative monoidal (post-reform)",
      "m3:proposedModel": "M3 as enriched category Cat_M3 with Ob={A,S,I,D}-described states and Mor={F}-described transitions",
      "m3:fiberBundleInterpretation": {
        "base": "{A,S,I,D} — object-space (states)",
        "fiber": "{F} — morphism-space (flows over each state)",
