    {
      "@id": "m3:Cat_M3_ASFID",
      "@type": [
        "owl:NamedIndividual",
        "m3:MathematicalCategory"
      ],
      "rdfs:label": "Category of ASFID Types",
      "rdfs:comment": "Category whose objects are ASFID types and morphisms are structural compositions.",
      "m3:categoryName": "Cat_M3_ASFID",
      "m3:objects": [
        "Attractor",
        "Structure",
        "Flow",
        "Information",
        "Dynamics"
      ],
      "m3:typeAsymmetryNote": {
        "date": "2026-03-23",
        "discovery": "emergent",
        "statement": "ASFID types are NOT homogeneous — Flow (F) has a unique dual ontological nature absent from the other 4.",
        "objectDimensions": {
          "types": [
            "Attractor (A)",
            "Structure (S)",
            "Information (I)",
            "Dynamics (D)"
          ],
          "nature": "describe states/objects of the system — Ob(Cat_M3)",
          "question": "A: toward what? S: how organized? I: what known? D: how evolving?"
        },
        "morphismDimension": {
          "type": "Flow (F)",
          "nature": "describes transformations between states — Mor(Cat_M3) AND Ob(Cat_M3)",
          "question": "F: what is transported? (requires source AND target — intrinsically relational)",
          "formalAxiom": "F ∈ Mor(Cat_M3) ∩ Ob(Cat_M3)",
          "consequence": "Any M2 structural formula containing F inherits latent morphic capacity (entity_and_morphism)"
        },
        "fiberBundleInterpretation": {
          "status": "hypothesis — requires expert mathematical review",
          "base": "{A,S,I,D} — object-space types",
          "fiber": "{F} — morphism-space type over each state",
          "model": "M3 as fibered space rather than a homogeneous metric space (see Structural Grammar reform)"
        },
        "riskLevel": "low — additive annotation, does not invalidate existing ASFID structural composition"
      }
    },
    {
      "@id": "m3:Cat_M3_REVOI",
      "@type": [
        "owl:NamedIndividual",
        "m3:MathematicalCategory"
      ],
      "rdfs:label": "Category of REVOI Types",
