      "skos:definition": "Foundational structural grammar providing the bicephalous type system (Gt + Gm) upon which all other TSCG layers are built. Rooted in Lambek Calculus and free commutative monoidal categories.",
      "rdfs:comment": "M3 layer ontologies that define the bicephalous architecture: Eagle Eye (ASFID - Territory measurement) and Sphinx Eye (REVOI - Map construction). These ontologies have zero dependencies.",
      "m3:semanticSignature": "structural_grammar_apex + bicephalous(Gt+Gm) + Lambek_calculus_foundation",
      "skos:notation": "M3",
      "skos:example": [
        "M3_GrammarFoundation.jsonld",
        "M3_GenesisGrammar.jsonld",
        "M3_EagleEye.jsonld",
        "M3_SphinxEye.jsonld"
      ],
      "skos:scopeNote": "Exactly 3 ontologies in this category. Closed set.",
      "m3:expectedCount": 3,
      "m3:layerOrder": 1,
      "rdfs:subClassOf": {
        "@id": "m3:TscgOntologyType"
      }
    },
    {
      "@id": "m3:GenesisExtension",
