        "M0 Layer",
        "Minimal Complete System",
        "Validation Instance"
      ],
      "skos:definition": "Minimal yet complete system instances that serve the triple role of (1) framework proof-of-concept, (2) M2 metaconcept identification, and (3) M1 core concept population.",
      "rdfs:comment": "M0 layer ontologies representing concrete, well-understood systems used to validate TSCG framework. Must be minimal (no unnecessary components) yet complete (all ASFID types present). Examples: Fire Triangle, Butterfly Metamorphosis, Four-Stroke Engine.",
      "m3:semanticSignature": "minimal + complete(all_ASFID_dimensions) + triple_role(validation+M2_discovery+M1_population)",
      "skos:notation": "M0_Poclet",
      "skos:example": [
        "M0_FireTriangle.jsonld",
        "M0_ExposureTriangle.jsonld",
        "M0_ButterflyMetamorphosis.jsonld",
        "M0_FourStrokeEngine.jsonld",
        "M0_Yggdrasil.jsonld"
      ],
      "skos:scopeNote": "Open-ended set. Goal is 20+ poclets spanning 10+ domains. Currently ~16 validated poclets.",
      "m3:expectedCount": "16+",
      "m3:layerOrder": 4,
      "skos:broader": {
        "@id": "m3:DomainExtension"
      },
      "skos:related": [
