      ],
      "skos:definition": "Domain-specific ontologies that specialize M2 metaconcepts for particular scientific or professional fields. Each is an instance of the m2:Domain metaconcept with specific 5D structural composition.",
      "rdfs:comment": "M1 layer ontologies that bridge transdisciplinary metaconcepts (M2) with concrete systems (M0). Examples include Biology, Chemistry, Optics, Photography, Mythology. Each domain has characteristic ASFID|REVOI coupling.",
      "m3:semanticSignature": "domain_specific + specializes_M2_metaconcepts + bridges_M2_to_M0",
