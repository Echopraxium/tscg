{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:GenesisGrammar",
      "@type": "owl:Ontology",
      "owl:versionInfo": "4.4.0",
      "dcterms:created": "2026-01-21",
      "dcterms:modified": "2026-06-29",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:title": "TSCG M3 Genesis Grammar - Bicephalous Structural Grammar",
      "dcterms:description": "Complete orthogonal basis for the TSCG framework, consisting of two complementary perspectives: Eagle Eye (ASFID) for Territory measurement and Sphinx Eye (REVOI) for Map construction. Integrates Category Theory formalization as mathematical foundation (definitions included in this file) for functors, morphisms, and categorical structure of TSCG layers.",
      "owl:imports": [
        "M3_GrammarFoundation.jsonld",
        "M3_EagleEye.jsonld",
        "M3_SphinxEye.jsonld",
        "M3_BicephalousPerspective.jsonld"
      ],
      "rdfs:label": "Genesis Grammar - Bicephalous Structural Grammar",
      "rdfs:comment": "M3 Genesis Grammar provides the bicephalous structural grammar for TSCG: Territory Grammar Gt (Eagle Eye / ASFID) and Map Grammar Gm (Sphinx Eye / REVOI), connected via natural transformations Φ and Ψ",
      "metadata": {
        "layer": "M3",
        "name": "Genesis Grammar - Bicephalous Structural Grammar",
        "version": "4.4.0",
        "architecture": "bicephalous",
        "date_created": "2026-01-21",
        "date_modified": "2026-06-29",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "description": "Complete orthogonal basis for the TSCG framework, consisting of two complementary perspectives: Eagle Eye (ASFID) for Territory measurement and Sphinx Eye (REVOI) for Map construction. Integrates Category Theory formalization as mathematical foundation (definitions included in this file) for functors, morphisms, and categorical structure of TSCG layers.",
        "changelog": {
          "v4.3.0": "BASE16 EXTENSION: Gs alphabet extended from {T} to {T,_^,_$,K,Ss,L} — 6 primitives, TKSL acronym. grammar_foundation.grammars, Cat_M3_Gs, validation updated. Notation convention: St/It/O in hybrid formulas.",
          "v4.2.0": "STEREOPSIS GRAMMAR: Added M3_BicephalousPerspective.jsonld to owl:imports. Added Gs to grammar_foundation.grammars. Added Cat_M3_Gs. Updated TypeSystem T0 to 11 primitives. Gs declared as reification of stereopsic synergy.",
          "v4.1.0": "OPERATOR REFORM: ⊗ᵗ → ×, ⊗ᵐ → +, ⊕ → |. All formulas and examples updated."
        }
      },
      "grammar_foundation": {
        "formalism": "Lambek Calculus / Free Commutative Monoidal Categories",
        "architecture": "Bicephalous Structural Grammar: Gt (Territory) + Gm (Map) — Gs is the reification of their stereopsic synergy",
        "grammars": {
          "Gt": "Territory Grammar — primitives {A,St,F,It,D} — ASFID (5) — Eagle Eye — ontological — operator ×",
          "Gm": "Map Grammar     — primitives {R,E,V,O,Im} — REVOI (5) — Sphinx Eye — epistemic — operator +",
          "Gs": "Stereopsis Grammar — primitives {T,_^,_$,K,Ss,L} — TKSL+poles (6) — Bicephalous — relational — operator | — Base16 extension"
        },
        "connection": {
          "Phi": "Φ : Gt → Gm  (natural transformation — observation: Territory → Map)",
          "Psi": "Ψ : Gm → Gt  (natural transformation — interpretation: Map → Territory)",
          "epistemic_gap": "δ₁ = ||ASFID_mean − REVOI_mean|| / √2",
          "korzybski": "Φ is never a perfect isomorphism — the map is not the territory"
        },
        "see_also": "M3_GrammarFoundation.jsonld for operators, type system, intersubjectiveBenchmark"
      },
      "bicephalous_architecture": {
        "description": "Dual complementary perspectives forming complete basis",
        "rationale": "Territory-Map distinction requires both observation (Eagle) and construction (Sphinx)",
        "eagle_eye": {
          "@id": "m3:eagle_eye:EagleEye",
          "basis": "ASFID",
          "basis_expansion": "Attractor, Structure, Flow, Information, Dynamics",
          "dimensions": 5,
          "role": "Territory measurement",
          "perspective": "Analysis",
          "orientation": "Model → Reality",
          "operation": "Observation and decomposition",
          "metaphor": "Eagle sees the Territory from above with penetrating vision",
          "rdfs:seeAlso": "M3_EagleEye.jsonld"
        },
        "sphinx_eye": {
          "@id": "m3:sphinx_eye:SphinxEye",
          "basis": "REVOI",
          "basis_expansion": "Representable, Evolvable, Verifiable, Observable, Interoperable",
          "dimensions": 5,
          "role": "Map construction",
          "perspective": "Synthesis",
          "orientation": "Reality → Model",
          "operation": "Integration and construction",
          "metaphor": "Sphinx poses riddles and constructs Maps through enigmatic wisdom",
          "rdfs:seeAlso": "M3_SphinxEye.jsonld"
        },
        "complementarity": {
          "relationship": "structurally_complementary",
          "independence": "verified (no ASFID primitive derivable from REVOI and vice versa)",
          "completeness": "all systems characterisable via Gt primitives (empirical) and Gm primitives (epistemic)",
          "duality": {
            "territory_map": "Eagle observes Territory, Sphinx constructs Map",
            "analysis_synthesis": "Eagle decomposes, Sphinx composes",
            "model_reality": "Eagle measures Reality, Sphinx builds Model"
          },
          "feedback_loop": {
            "forward": "Φ: ASFID → REVOI (observation)",
            "backward": "Ψ: REVOI → ASFID (interpretation)",
            "iteration": "iterative refinement via Φ/Ψ natural transformations until epistemic equilibrium",
            "convergence": "δ₁ → 0 represents epistemic equilibrium (Map ≈ Territory)",
            "korzybski_principle": "Map influences how we observe Territory, Territory observations refine Map"
          }
        },
        "stereopsis_reification": {
          "description": "Gs (Stereopsis Grammar) is the reification of the stereopsic synergy between Eagle Eye and Sphinx Eye. TSCG remains bicephalous — Gs does not add a third head but formalizes what the two heads produce together.",
          "grammar": "Gs over {T}",
          "operator": "|",
          "see_also": "M3_BicephalousPerspective.jsonld"
        }
      },
      "category_theory_foundation": {
        "description": "Category Theory provides mathematical foundation for TSCG structure",
        "category_theory": {
          "@id": "m3:CategoryTheory",
          "rdfs:seeAlso": "Definitions below in this @graph",
          "role": "Mathematical foundation",
          "provides": [
            "MathematicalCategory class",
            "CategoryObject class",
            "Morphism class",
            "Functor class",
            "NaturalTransformation class",
            "Adjunction class",
            "Properties for categorical annotations"
          ]
        },
        "tscg_as_categories": {
          "Cat_TSCG": "Category of TSCG layers {M3, M2, M1, M0}",
          "Cat_M3_ASFID": "Category of Territory Grammar Gt primitives {A, St, F, It, D} — ASFID (5)",
          "Cat_M3_REVOI": "Category of Map Grammar Gm primitives {R, E, V, O, Im} — REVOI (5)",
          "Cat_M2": "Category of metaconcepts (defined in M2)",
          "Cat_KnowledgeField": "Category of knowledge fields (defined in M2)",
          "Cat_M3_Gs": "Category of Stereopsis Grammar Gs primitives {T,_^,_$,K,Ss,L} — TKSL+poles (6) — bicephalous relational types — Base16"
        },
        "functors": {
          "F_structuralFormula": "F_×: Cat_M3 → Cat_M2 (structural grammar operators create GenericConcept types)",
          "F_instantiation": "F_inst: Cat_M2 → Cat_M1 (metaconcepts → domain concepts)",
          "F_concretize": "Cat_M1 → Cat_M0 (concepts → concrete instances)"
        },
        "morphisms": {
          "inclusion": "↪ (e.g., Homeostasis ↪ Regulation)",
          "composition": "∘ (e.g., Learning = Memory ∘ Adaptation)",
          "duality": "op (e.g., Divergence = Convergence^op)",
          "emergence": "⇒ (e.g., MetaconceptCombo: M_A × M_B ⇒ M_C)"
        },
        "reification": {
          "description": "Objects in categories are reifications (concrete instances)",
          "example": "Chemistry is an object in Cat_KnowledgeField (reification of KnowledgeField category)"
        },
        "integration_note": "Category Theory definitions integrated directly in this file (not imported)"
      },
      "dual_axes_framework": {
        "axis_1": {
          "name": "Model vs Reality",
          "eagle_position": "Reality (measures the Territory as-is)",
          "sphinx_position": "Model (constructs the Map representation)"
        },
        "axis_2": {
          "name": "Analysis vs Synthesis",
          "eagle_position": "Analysis (decomposes into ASFID types)",
          "sphinx_position": "Synthesis (composes via REVOI operations)"
        },
        "quadrants": [
          "Analysis of Reality (Eagle dominant)",
          "Synthesis of Reality (Eagle-Sphinx bridge)",
          "Analysis of Model (Eagle-Sphinx bridge)",
          "Synthesis of Model (Sphinx dominant)"
        ]
      },
      "derived_layers": [
        {
          "@id": "M2_MetaConcepts.jsonld",
          "layer": "M2",
          "relationship": "foundation_of",
          "description": "M3 primitive types generate M2 derived types via structural grammar operators",
          "mechanisms": [
            {
              "source": "m3:eagle_eye:EagleEye",
              "operation": "projects_onto",
              "formula": "Gt primitives → 𝕋₁ type expressions via ×",
              "description": "Each ASFID types projects onto all M2 metaconcepts, creating 5D analytical perspective on each metaconcept"
            },
            {
              "source": "m3:sphinx_eye:SphinxEye",
              "operation": "constructs_from",
              "formula": "Gm primitives → 𝕋₁ type expressions via +",
              "description": "REVOI operations compose M2 metaconcepts into domain-specific patterns through synthetic construction"
            }
          ],
          "mathematical_relationship": "M2 types are derived from M3 primitive types via ×, + and | (including Gs bicephalous primitives from M3_BicephalousPerspective.jsonld)",
          "structural_grammar": "M2 GenericConcepts are named product types in the TSCG type system (𝕋₁)"
        }
      ],
      "validation": {
        "primitive_independence_test": {
          "status": "passed",
          "method": "Conceptual independence check — no primitive reducible to others",
          "result": "All 16 primitive types are analytically independent (Base16: 5 ASFID + 5 REVOI + 6 TKSL+poles)"
        },
        "completeness_test": {
          "status": "passed",
          "method": "Verification across multiple poclets (Fire Triangle, Exposure Triangle, etc.)",
          "result": "All system aspects expressible in ASFID | REVOI"
        },
        "independence_test": {
          "status": "passed",
          "method": "Linear independence check",
          "result": "No ASFID types expressible via REVOI and vice versa"
        },
        "spanning_test": {
          "status": "passed",
          "method": "Domain coverage analysis",
          "result": "Physical, biological, social, abstract systems all representable"
        },
        "consistency_check": {
          "status": "passed",
          "method": "Cross-validation with established frameworks (TRIZ, Systems Theory)",
          "result": "No contradictions found"
        }
      },
      "evolution_history": {
        "v1.0": {
          "architecture": "tricephalous",
          "components": [
            "Genesis",
            "Eagle Eye",
            "Sphinx Eye"
          ],
          "date": "2020-2025",
          "issue": "Genesis role overlapped with Eagle Eye ASFID basis"
        },
        "v2.0": {
          "architecture": "bicephalous",
          "components": [
            "Eagle Eye (ASFID)",
            "Sphinx Eye (REVOI)"
          ],
          "date": "2026-01-21",
          "resolution": "Genesis merged into Eagle Eye, clarifying pure duality",
          "advantages": [
            "Cleaner mathematical structure",
            "Eliminated redundancy",
            "Stronger Territory-Map metaphor",
            "Better alignment with dual axes framework"
          ]
        },
        "v3.0": {
          "date": "2026-02-10",
          "changes": [
            "REVOI simplification (ability → able)",
            "Feedback loop formalization",
            "Coupling matrix Σ explicit"
          ]
        },
        "v3.0.1": {
          "date": "2026-02-16",
          "changes": [
            "Factorized MonoidalType class into GenesisSpace",
            "Centralized common type properties",
            "Improved architectural coherence"
          ]
        }
      },
      "epistemological_foundation": {
        "constructivism": "Knowledge constructed through interaction (REVOI)",
        "cybernetics": "Systems observed through feedback and control (ASFID)",
        "radical_constructivism": "Territory unknowable directly, only Map constructible",
        "second_order_cybernetics": "Observer part of observed system",
        "enaction": "Cognition arises through dynamic interaction"
      },
      "philosophical_commitments": {
        "territory_map_distinction": "Fundamental separation between reality and representation",
        "complementarity": "Both perspectives necessary and irreducible",
        "pragmatism": "Utility of representations over correspondence to reality",
        "holism": "Emergent properties not reducible to components",
        "process_philosophy": "Systems as processes not static entities"
      },
      "m3:ontologyType": {
        "@id": "m3:Genesis"
      },
      "m2:changelog": [
        {
          "version": "4.4.0",
          "date": "2026-06-29",
          "changes": "F AMENDMENT 3 REDUCED: removed the F continuous numeric spectrum (F_crit, F_max, the 0<F<F_crit band, F_total conservation) as a scalar residue inconsistent with m3:MonoidalType (qualitative at M3; magnitude belongs to the M0 ValueSpace as F_score). F activation retained as qualitative latent/active modes via m2:Potentialization poles (_^/_$). Resolves the Amendment 1 vs 3 contradiction. Functor example 'F=0 ground state' relabeled 'F-absent'. Amendments 1 and 2 unchanged; zero downstream impact (no corpus concept references the removed spectrum)."
        },
        {
          "version": "4.3.0",
          "date": "2026-05-27",
          "changes": "BASE16 EXTENSION: Gs alphabet extended from {T} to {T,_^,_$,K,Ss,L} — 6 primitives. TKSL acronym for 4 nominal Gs primitives. grammar_foundation.grammars updated: Gt→ASFID(5), Gm→REVOI(5), Gs→TKSL+poles(6). Cat_M3_Gs updated. validation: 10→16 analytically independent primitives. Notation convention: St/It/O in hybrid formulas."
        },
        {
          "version": "4.2.0",
          "date": "2026-05-18",
          "changes": "STEREOPSIS GRAMMAR: M3_BicephalousPerspective.jsonld imported. Gs added to grammars. Cat_M3_Gs added. TypeSystem T0 updated to 11 primitives ({A,S,F,I,D,R,E,V,O,Im,T})."
        }
      ]
    },
    {
      "@id": "m3:MonoidalType",
      "@type": "owl:Class",
      "rdfs:label": "M3 MonoidalType",
      "rdfs:comment": "A primitive type in the TSCG Structural Grammar. At M2/M3: generator of type expressions (qualitative, no metric). At M0: instantiation functors map structural primitives to observable instance values (quantitative scoring belongs to the M0 ValueSpace, not to the M3 structural grammar). Belongs to either Territory Grammar Gt (ASFID) or Map Grammar Gm (REVOI).",
      "rdfs:subClassOf": {
        "@id": "owl:Thing"
      },
      "skos:definition": "A primitive type generator of the TSCG Structural Grammar. Independence verified (analytical, not metric). Two roles: (1) type generator at M2 level; (2) structural primitive instantiated at M0 level, where observable values are produced by evaluation functors belonging to the M0 ValueSpace (not to the M3 structural grammar).",
      "skos:scopeNote": "This class has exactly 10 instances: 5 ASFID types (Attractor, Structure, Flow, Information, Dynamics) defined in M3_EagleEye.jsonld, and 5 REVOI types (Representable, Evolvable, Verifiable, Observable, Interoperable) defined in M3_SphinxEye.jsonld.",
      "dcterms:created": "2026-02-16",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "skos:example": [
        "m3:eagle_eye:Attractor (ASFID/Territory)",
        "m3:eagle_eye:Structure (ASFID/Territory)",
        "m3:sphinx_eye:Representable (REVOI/Map)",
        "m3:sphinx_eye:Verifiable (REVOI/Map)"
      ]
    },
    {
      "@id": "m3:typeSymbol",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Type Symbol",
      "rdfs:comment": "Single-letter type atom identifying an M3 structural primitive in the Structural Grammar. Used as generator in monoidal type expressions (e.g., A × S × F). Replaces the ket notation |X⟩ of the former Hilbert space formalism.",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Symbolic identifier for a M3 primitive type (e.g., A, S, R, V). Used in structural formulas and evaluation functor notation.",
      "skos:example": [
        "A  for Attractor  (ASFID/Territory)",
        "S  for Structure  (ASFID/Territory)",
        "F  for Flow       (ASFID/Territory)",
        "I  for Information (ASFID/Territory)",
        "D  for Dynamics   (ASFID/Territory)",
        "R  for Representable (REVOI/Map)",
        "E  for Evolvable     (REVOI/Map)",
        "V  for Verifiable    (REVOI/Map)",
        "O  for Observable    (REVOI/Map)",
        "Iₘ for Interoperable (REVOI/Map)"
      ],
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:typeIndex",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Type Index",
      "rdfs:comment": "Numerical index of the type within its basis (1-5 for ASFID, 1-5 for REVOI)",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:integer"
      },
      "skos:definition": "Position index within the grammar primitive set (1-5 within Gt or Gm). Used for ordered enumeration and reference.",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:typeExamples",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Type Examples",
      "rdfs:comment": "Concrete system instances illustrating the type with typical measurement or quality values",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Real-world examples showing how the type applies across different domains and scales (for ASFID) or different types of Maps and representations (for REVOI)",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:semanticSignature",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Semantic Signature",
      "rdfs:comment": "Minimal sufficient characterization of an entity's identity within the TSCG framework. Constitutive (positive) rather than differential (negative). Applicable at all layers: M3 (ontology types), M2 (metaconcepts), M1 (domain concepts), M0 (system instances).",
      "skos:definition": "A compact, positive, minimal-yet-sufficient description of what an entity IS, expressed as a conjunction of necessary components. Distinct from m3:distinguishingFeatures which is differential (what an entity is NOT). Structure: component_1 + component_2 + ... where all components are necessary and together sufficient.",
      "rdfs:domain": {
        "@id": "owl:Thing"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:example": [
        "M3 type: 'primitives(finite) + combination_rules + multiple_legitimate_interpretations' (SymbolicSystemGrammar)",
        "M2 metaconcept: 'output → input + regulation + attractor_convergence' (FeedbackLoop)",
        "M1 concept: 'setpoint + sensor + effector + correction' (Homeostasis)",
        "M0 poclet: 'Renin→Angiotensin→Aldosterone + pressure_regulation + negative_loop' (RAAS)"
      ],
      "skos:scopeNote": "Layer-agnostic property defined at M3 level for universal applicability. At M2 level, semanticSignature is the human-readable counterpart of structuralFormula — both express the same identity at different levels of formalization.",
      "skos:editorialNote": "Supersedes m3:distinguishingFeatures (differential, informal) with a constitutive, formally defined alternative. Existing distinguishingFeatures blocks may be progressively replaced or complemented.",
      "dcterms:created": "2026-02-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:ontologyType",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "Ontology Type",
      "rdfs:comment": "Specifies the architectural type of a TSCG ontology. Value must be an instance of m3:TscgOntologyType (e.g. m3:Poclet, m3:Genesis, m3:DomainExtension). Enables both OWL reasoning (subClassOf hierarchy) and SKOS navigation (ConceptScheme). Renamed from m3:ontologyCategory in v3.3.0.",
      "skos:definition": "A framework-level architectural property that specifies the position and role of an ontology within the TSCG metamodel hierarchy through reference to a controlled vocabulary defined as a skos:ConceptScheme.",
      "rdfs:domain": {
        "@id": "owl:Ontology"
      },
      "rdfs:range": {
        "@id": "m3:TscgOntologyType"
      },
      "dcterms:created": "2026-01-27",
      "dcterms:modified": "2026-01-27",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "skos:editorialNote": "Defined in M3 (Genesis Space) because it is a foundational metamodel property needed by all layers. M3 has no dependencies, ensuring m3:ontologyCategory is always available without creating circular dependencies.",
      "skos:changeNote": "v3.3.0: Renamed from m3:ontologyCategory to m3:ontologyType for clarity. Range changed from m3:OntologyCategoryScheme (incorrect — was the ConceptScheme, not a concept) to m3:TscgOntologyType (correct — the abstract class).",
      "skos:example": [
        "M3_GenesisGrammar.jsonld uses m3:Genesis",
        "M2_MetaConcepts.jsonld uses m3:TransdisciplinaryPattern",
        "M1_Biology.jsonld uses m3:DomainExtension",
        "M0_Yggdrasil.jsonld uses m3:Poclet"
      ]
    },
    {
      "@id": "m3:TscgOntologyType",
      "@type": "owl:Class",
      "rdfs:label": "TSCG Ontology Type",
      "rdfs:comment": "Abstract OWL class representing the architectural types of ontologies in the TSCG framework. Each TSCG ontology belongs to exactly one type. Instances (subclasses) are: Genesis, GenesisExtension, GenericConcepts, DomainExtension, SystemicFramework, Poclet, CaseStudy, RealWorldSystem, SymbolicSystemGrammar, TscgTool, TransDisclet. Each type is simultaneously an owl:Class (for OWL reasoning and Protégé class hierarchy) and a skos:Concept (for SKOS vocabulary navigation). Replaces the former m3:OntologyCategoryScheme/m3:OntologyCategoryScheme pattern (v3.3.0).",
      "rdfs:isDefinedBy": "m3:TscgOntologyTypeScheme",
      "owl:isAbstract": true,
      "dcterms:created": "2026-02-19",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:TscgOntologyTypeScheme",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "TSCG Ontology Type Scheme",
      "rdfs:comment": "SKOS controlled vocabulary listing all TSCG ontology types. Each concept in this scheme is simultaneously an owl:Class subClassOf m3:TscgOntologyType (OWL) and a skos:Concept (SKOS). Use m3:ontologyType property (range: m3:TscgOntologyType) to annotate ontologies with their type.",
      "skos:definition": "A controlled vocabulary defining the eleven architectural types of TSCG ontologies, organized from foundational mathematical basis (Genesis) to concrete real-world instantiations (RealWorldSystem, TransDisclet). Each type serves as both an OWL class (enabling reasoning) and a SKOS concept (enabling vocabulary navigation).",
      "dcterms:created": "2026-01-27",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "skos:hasTopConcept": [
        {
          "@id": "m3:Genesis"
        },
        {
          "@id": "m3:GenesisExtension"
        },
        {
          "@id": "m3:GenericConcepts"
        },
        {
          "@id": "m3:DomainExtension"
        },
        {
          "@id": "m3:SystemicFramework"
        },
        {
          "@id": "m3:Poclet"
        },
        {
          "@id": "m3:CaseStudy"
        },
        {
          "@id": "m3:RealWorldSystem"
        },
        {
          "@id": "m3:SymbolicSystemGrammar"
        },
        {
          "@id": "m3:TscgTool"
        },
        {
          "@id": "m3:TransDisclet"
        }
      ],
      "skos:scopeNote": "This scheme is extensible upon framework revision. Each category represents a fundamental architectural distinction in the TSCG metamodel."
    },
    {
      "@id": "m3:Genesis",
