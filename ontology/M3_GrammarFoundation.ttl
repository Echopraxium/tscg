@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m3gf: <http://www.w3.org/2002/07/owl#M3_GrammarFoundation.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

m3gf:GrammarFoundation a owl:Ontology ;
    rdfs:label "M3 Grammar Foundation — TSCG Apex Ontology" ;
    dcterms:created "2026-05-12" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:description "Apex ontology of the TSCG hierarchy — no imports, no dependencies. Defines the Lambek Calculus mathematical foundation (free commutative monoidal categories), the six indexed operators (⊗ᵗ, ⊗ᵐ, ⊗ᵗ⇒, ⊗ᵐ⇒, ^opᵗ, ^opᵐ), abstract classes M3Grammar and M3Dimension, the TSCG type system hierarchy (𝕋₀→𝕄₀), and the intersubjective benchmark properties. Imported by M3_EagleEye, M3_SphinxEye, and M3_GenesisGrammar." ;
    dcterms:modified "2026-05-13" ;
    dcterms:title "TSCG M3 Grammar Foundation" ;
    rdfs:comment "Foundational definitions for the TSCG Structural Grammar. Rooted in Lambek Calculus (Lambek 1958) and free commutative monoidal categories (MacLane 1963). The ⊗ operator is a monoidal product — NOT an algebraic tensor product. No metric, no Hilbert space, no scalar multiplication required or assumed." ;
    owl:mathematical_foundation [ owl:formalism "Lambek Calculus / Free Commutative Monoidal Categories" ;
            owl:operator_disclaimer "⊗ shares notation with the algebraic tensor product but operates in a distinct context: a typed combinatorial grammar without metric structure. Analogous to how × denotes both scalar multiplication and vector cross product — same symbol, different mathematical contexts." ;
            owl:references "Lambek, J. (1958). The mathematics of sentence structure. American Mathematical Monthly 65(3): 154-170.",
                "MacLane, S. (1963). Natural associativity and commutativity. Rice University Studies.",
                "MacLane, S. (1971). Categories for the Working Mathematician. Springer." ;
            owl:see_also "ontology/StructuralGrammar/TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md" ] ;
    owl:metadata [ owl:architecture "apex — no owl:imports" ;
            owl:authors "Echopraxium with the collaboration of Claude AI" ;
            owl:changelog [ owl:v1.0.0 "Initial skeleton: M3Grammar and M3Dimension abstract classes, grammarType and monoidalProduct properties." ;
                    owl:v1.1.0 "MAJOR UPDATE: Added dcterms metadata, skos namespace. Fixed owl:versionInfo prefix. Added 6 indexed operators (⊗ᵗ, ⊗ᵐ, ⊗ᵗ⇒, ⊗ᵐ⇒, ^opᵗ, ^opᵐ). Added type system hierarchy (𝕋₀/𝕋₁/𝕋₂/𝕄₀). Added m3gf:intersubjectiveBenchmark and m3gf:defeasibilityStatus. Confirmed apex position: no owl:imports." ] ;
            owl:date_created "2026-05-12" ;
            owl:date_modified "2026-05-13" ;
            owl:imported_by "M3_EagleEye.jsonld",
                "M3_GenesisGrammar.jsonld",
                "M3_SphinxEye.jsonld" ;
            owl:layer "M3" ;
            owl:name "Grammar Foundation" ;
            owl:version "1.1.0" ] ;
    owl:versionInfo "1.1.0" .

m3gf:M3Dimension a owl:Class ;
    rdfs:label "M3 Dimension (Abstract)" ;
    rdfs:comment "Abstract base class for M3 primitive types. At M2/M3: generators of structural formulas (qualitative, no metric). At M0: evaluation functors F_x : System → [0,1] (quantitative, metric)." ;
    skos:definition "A primitive type in the TSCG Structural Grammar. Plays two roles: (1) generator of type expressions at M2 level; (2) evaluation functor at M0 level via norm-referenced scoring against intersubjective benchmarks." ;
    skos:note "The word 'dimension' is used in the analytical sense (independent axis of characterisation), NOT in the metric/Hilbert sense." .

m3gf:TypeSystem a owl:NamedIndividual ;
    rdfs:label "TSCG Type System" ;
    rdfs:comment "Complete type hierarchy of the TSCG Structural Grammar across all layers." ;
    m3gf:levels [ owl:M0 [ owl:curry_howard "Poclet = proof term. δ₁ = degree of proof (Curry-Howard correspondence)." ;
                    owl:label "Terms (Proof Terms)" ;
                    owl:layer "M0" ;
                    owl:notation "𝕄₀ = { poclets inhabiting a type τ ∈ 𝕋₁ ∪ 𝕋₂ }" ;
                    owl:role "Instances that prove a system inhabits a conceptual type" ] ;
            owl:T0 [ owl:cardinality 10 ;
                    owl:label "Primitive Types" ;
                    owl:layer "M3" ;
                    owl:notation "𝕋₀ = {A, S, F, I, D, R, E, V, O, I}" ;
                    owl:role "generators of the TSCG Structural Grammar" ;
                    owl:subsets [ owl:map "{R, E, V, O, I}  — Gm primitives (Sphinx Eye)" ;
                            owl:territory "{A, S, F, I, D}  — Gt primitives (Eagle Eye)" ] ] ;
            owl:T1 [ owl:examples "Coherence  = A ⊗ᵗ S ⊗ᵗ I ⊗ᵐ R ⊗ᵐ O",
                        "Entropy    = D ⊗ᵗ F^opᵗ",
                        "Process    = D ⊗ᵗ I ⊗ᵗ F" ;
                    owl:label "Derived Types (Named Product Types)" ;
                    owl:layer "M2" ;
                    owl:notation "𝕋₁ = { τ₁ ⊗ᵢ τ₂ ⊗ᵢ ... ⊗ᵢ τₙ  |  τᵢ ∈ 𝕋₀ }" ;
                    owl:role "M2 GenericConcepts — named structural formulas" ] ;
            owl:T2 [ owl:examples "ModelQuality     = ⊗ᵐ⇒(Representable, Verifiable)",
                        "SelfOrganization = ⊗ᵗ⇒(Emergence, Coherence)" ;
                    owl:label "Compound Types (Emergent Combos)" ;
                    owl:layer "M1" ;
                    owl:notation "𝕋₂ = { τ₁ ⊗ⁱ⇒ τ₂  |  τᵢ ∈ 𝕋₁ }" ;
                    owl:role "M1 GenericConceptCombos — emergent compound concepts" ] ] ;
    skos:definition "Four-level type hierarchy derived from 10 primitive types via 3 operators." .

m3gf:defeasibilityStatus a owl:DatatypeProperty ;
    rdfs:label "Defeasibility Status" ;
    rdfs:comment "Explicit declaration that a benchmark or canonical reference is provisional — valid until superseded by broader consensus. Makes revisability a first-class property of TSCG measurements." ;
    rdfs:range xsd:string ;
    m3gf:structure [ owl:revisionTrigger "corpus_maturation",
                "domain_expansion",
                "expert_consensus_challenged",
                "new_canonical_poclet_identified" ;
            owl:status [ owl:default "provisional" ;
                    owl:values "deprecated",
                        "established",
                        "provisional" ] ;
            owl:validUntil "superseded_by_better_consensus" ] ;
    skos:definition "Defeasible knowledge: held as valid until defeated by stronger evidence or broader consensus. The normal epistemic status of scientific, legal, and practical knowledge." ;
    skos:note "Analogous to stare decisis in law (precedent holds until overruled) and scientific paradigms (Kuhn: valid until anomalies accumulate)." .

m3gf:dualityOperator a owl:DatatypeProperty ;
    rdfs:label "Duality Operator ^opⁱ" ;
    rdfs:comment "Structural duality (opposition) operator. Produces the polar opposite of a concept type within the same dimensional space. Indexed: ^opᵗ (Territory), ^opᵐ (Map)." ;
    rdfs:domain m3gf:M3Grammar ;
    rdfs:range xsd:string ;
    m3gf:indexed_forms [ owl:general "^opⁱ  — general form, i ∈ {t, m}" ;
            owl:map "^opᵐ  — Map duality" ;
            owl:territory "^opᵗ  — Territory duality" ] ;
    skos:definition "Dual type operator: maps a concept type to its structural opposite. Corresponds to negation in propositional logic via the Curry-Howard correspondence." ;
    skos:example "Coherence^opᵗ = Incoherence  |  Observable^opᵐ = Unobservable" .

m3gf:emergenceOperator a owl:DatatypeProperty ;
    rdfs:label "Emergence Operator ⊗ⁱ⇒" ;
    rdfs:comment "Structural emergence operator. Produces a derived concept whose properties are irreducible to the sum of its parts. Indexed: ⊗ᵗ⇒ (Territory), ⊗ᵐ⇒ (Map)." ;
    rdfs:domain m3gf:M3Grammar ;
    rdfs:range xsd:string ;
    m3gf:indexed_forms [ owl:general "⊗ⁱ⇒  — general form, i ∈ {t, m}" ;
            owl:map "⊗ᵐ⇒  — Map emergence (epistemic)" ;
            owl:territory "⊗ᵗ⇒  — Territory emergence (ontological)" ] ;
    skos:definition "Type function operator: takes two existing concept types and produces an emergent derived type. Corresponds to function type (→) in the Curry-Howard correspondence." ;
    skos:example "⊗ᵗ⇒(Memory, Entropy) = Inertia  |  ⊗ᵐ⇒(Representable, Verifiable) = ModelQuality" .

m3gf:grammarType a owl:DatatypeProperty ;
    rdfs:label "Grammar Type" ;
    rdfs:comment "Type of grammar — prevents collision between M3 structural grammar and M0 instance grammar (e.g. SHACL validation grammars)." ;
    rdfs:domain m3gf:M3Grammar ;
    rdfs:range xsd:string ;
    skos:example "free_commutative_monoidal" .

m3gf:intersubjectiveBenchmark a owl:ObjectProperty ;
    rdfs:label "Intersubjective Benchmark" ;
    rdfs:comment "Domain-contextualized canonical poclet(s) used as scoring reference for M0 instances. Grounds TSCG measurement in norm-referenced intersubjective consensus. Defeasible by design — valid until superseded by broader consensus." ;
    rdfs:range xsd:string ;
    m3gf:resolutionOrder "1. DomainSpecific benchmark  (M1 domain of the poclet)  <- DEFAULT",
        "2. CrossDomain benchmark     (adjacent M1 domain)",
        "3. Universal benchmark       (e.g. M0_AdaptiveImmuneResponse)",
        "4. Free scoring + justification                         <- last resort" ;
    m3gf:structure [ owl:benchmarkRefs [ owl:items [ owl:canonType "DomainSpecific | CrossDomain | Universal" ;
                            owl:domain "M1 domain  (e.g. m1:Biology, m1:Electronics)" ;
                            owl:uri "IRI of canonical poclet" ;
                            owl:weight "xsd:float  [0.0, 1.0]" ] ;
                    owl:type "array" ] ;
            owl:epistemicScore [ owl:formula "||ASFID_mean - REVOI_mean|| / sqrt(2)" ;
                    owl:property "m0:epistemicGap" ;
                    owl:range "[0.0, 1.0]" ] ;
            owl:expertConsensus [ owl:convergenceScore "xsd:float  (ICC / Cohen kappa)" ;
                    owl:method "comparative | absolute | hybrid" ;
                    owl:numberOfExperts "xsd:integer" ] ;
            owl:objectivityLevel [ owl:default "ContextualizedBenchmark" ;
                    owl:values "CanonCalibrated",
                        "ContextualizedBenchmark",
                        "MultiExpertConsensus",
                        "Subjective" ] ] ;
    skos:definition "A provisional structural attractor of a conceptual domain, identified by multi-cook convergence, domain-contextualized by default, explicitly defeasible, and self-improving through corpus growth." ;
    skos:note "Philosophical grounding: Popper (falsifiability), Kuhn (paradigm shifts), Peirce (limit of inquiry). Mathematical grounding: norm-referenced measurement (Stevens 1946), inter-rater reliability (ICC, Cohen kappa)." .

m3gf:monoidalProduct a owl:DatatypeProperty ;
    rdfs:label "Monoidal Product ⊗ⁱ" ;
    rdfs:comment "Free commutative monoidal product following Lambek Calculus. General indexed form ⊗ⁱ where i ∈ {t, m}." ;
    rdfs:domain m3gf:M3Grammar ;
    rdfs:range xsd:string ;
    m3gf:axioms [ owl:associativity "(A ⊗ B) ⊗ C = A ⊗ (B ⊗ C)" ;
            owl:commutativity "A ⊗ B = B ⊗ A" ;
            owl:neutral_element "A ⊗ 1 = A" ;
            owl:no_metric "no norm, no inner product, no scalar multiplication" ] ;
    m3gf:indexed_forms [ owl:general "⊗ⁱ  — general form, i ∈ {t, m}" ;
            owl:map "⊗ᵐ  — Map Grammar Gm co-activation" ;
            owl:territory "⊗ᵗ  — Territory Grammar Gt co-activation" ] ;
    skos:definition "The structural co-activation operator of the TSCG Concept Grammar. Encodes simultaneous presence of multiple primitive types in a concept signature." .

m3gf:M3Grammar a owl:Class ;
    rdfs:label "M3 Grammar (Abstract)" ;
    rdfs:comment "Abstract base class for M3-level structural grammars. Concrete subclasses: TerritoryGrammar (Gt, ASFID primitives) and MapGrammar (Gm, REVOI primitives)." ;
    skos:definition "A free commutative monoidal grammar over a finite set of primitive types. Characterized by: primitives (generators), monoidal product (⊗ⁱ), emergence operator (⊗ⁱ⇒), and duality operator (^opⁱ)." .

