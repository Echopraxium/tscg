{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:eagle_eye:EagleEye",
      "@type": "owl:Ontology",
      "owl:versionInfo": "2.8.0",
      "dcterms:created": "2026-01-21",
      "dcterms:modified": "2026-05-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:description": "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A, S, F, I, D} (Territory types 𝕋₀(×)). Provides the ontological/empirical perspective on systems-as-territory. Each primitive type instantiates at M0 as an evaluation functor F_x : System → [0,1].",
      "m3:ontologyCategory": {
        "@id": "m3:GenesisExtension"
      },
      "owl:imports": [
        "M3_GrammarFoundation.jsonld"
      ],
      "rdfs:label": "Eagle Eye - Territory Grammar Gt",
      "rdfs:comment": "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A,S,F,I,D}. Provides the ontological/empirical perspective on systems-as-territory. At M0, each primitive type instantiates as a structural grammar (qualitative, no numeric scoring at this level). Part of the TSCG bicephalous architecture (Gt + Gm). See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
      "metadata": {
        "layer": "M3",
        "name": "Eagle Eye - ASFID Basis",
        "version": "2.8.0",
        "date_created": "2026-01-21",
        "date_modified": "2026-05-20",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "description": "ASFID basis for Territory measurement through analytical decomposition",
        "changelog": {
          "v2.5.0": "IMPORT UPDATE: owl:imports changed from M3_GenesisSpace.jsonld to M3_GrammarFoundation.jsonld (apex ontology). m3: namespace updated to M3_GenesisGrammar.jsonld. Aligns with new M3 architecture: GrammarFoundation (apex) → EagleEye/SphinxEye → GenesisGrammar.",
          "v2.4.0": "FORMALISM REFORM: Replaced Hilbert space / orthonormal basis framing with Structural Grammar (Lambek calculus). basis_properties → grammar_properties (Territory Grammar Gt). Removed hilbert_space, orthonormality fields. coupling_with_REVOI reframed: SVD/Sigma removed, Phi/Psi recast as natural transformations. orthogonality_matrix → independence_matrix. See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
          "v2.3.0": "REFACTORING: Removed m3:eagle_eye:M3Dimension class (now m3:MonoidalType in GenesisSpace). Removed common properties (symbol, index, examples - now m3:dimensionSymbol, m3:dimensionIndex, m3:dimensionExamples in GenesisSpace). Kept ASFID-specific properties (physicalInterpretation, rangeAnalog, criticalAxiom)."
        }
      },
      "parent_ontology": {
        "@id": "m3:genesis_space:GenesisSpace",
        "relationship": "component_of",
        "description": "Eagle Eye is the ASFID component of M3 Genesis Space, providing the analytical perspective on systems"
      },
      "grammar_properties": {
        "grammar_name": "Territory Grammar Gt",
        "grammar_type": "free_commutative_monoidal",
        "primitives": [
          "A",
          "S",
          "F",
          "I",
          "D"
        ],
        "product": "×",
        "primitive_role": "generators of Territory type expressions (M2 structural formulas)",
        "functor_role": "F_A, F_S, F_F, F_I, F_D : System → (M0 numeric ValueSpace)  (evaluation morphisms at M0)",
        "perspective": "ontological / empirical",
        "independence": "verified  (no primitive derivable from others)",
        "mathematical_foundation": "Lambek Calculus / free commutative monoidal categories (Lambek 1958, MacLane 1963)",
        "operator": "× (Territory structural product — intra-ASFID)",
        "neutral_element": "m3:grammar_foundation:EmptyTerritory",
        "neutral_element_label": "Empty Territory (neutral of ×)",
        "neutral_element_semantic": "Black — absence of all ASFID types"
      },
      "coupling_with_MapGrammar": {
        "description": "Territory Grammar Gt and Map Grammar Gm are connected via natural transformations (category theory). Gt and Gm are structurally separate grammars — their separation is fundamental, not a consequence of orthogonality.",
        "natural_transformations": {
          "Phi": {
            "symbol": "Φ",
            "signature": "Φ : Gt → Gm",
            "role": "Observation — Territory measurements inform Map construction",
            "example": "Nuclear reactor: neutron flux measurements (ASFID) → diffusion model coefficients (REVOI)"
          },
          "Psi": {
            "symbol": "Ψ",
            "signature": "Ψ : Gm → Gt",
            "role": "Interpretation — Map predictions guide Territory measurement strategies",
            "example": "Nuclear reactor: xenon oscillation model (REVOI) → install in-core detectors (ASFID)"
          }
        },
        "epistemic_gap": {
          "symbol": "δ₁",
          "formula": "||ASFID_mean − REVOI_mean|| / √2",
          "meaning": "Measure of non-isomorphism of Φ — Korzybski principle: Φ is never a perfect isomorphism"
        },
        "korzybski": "The map is not the territory — Gt ≠ Gm structurally, δ₁ > 0 in all real systems",
        "see_also": "M3_GenesisGrammar.jsonld for complete bicephalous architecture"
      },
      "metaphor": {
        "image": "Eagle soaring above the territory",
        "vision": "Penetrating sight that perceives reality as-is",
        "action": "Observes, measures, analyzes",
        "domain": "Territory (Reality)",
        "perspective": "From above, comprehensive view",
        "visual_acuity": "8× human vision - precision at distance"
      },
      "dual_axes_position": {
        "model_reality_axis": "Reality",
        "analysis_synthesis_axis": "Analysis",
        "quadrant": "Analysis of Reality (Territory)"
      },
      "independence_matrix": {
        "description": "The 5 primitive types {A,S,F,I,D} are analytically independent — no primitive type is derivable from the others",
        "verified": "true",
        "note": "Independence here means conceptual non-redundancy, not metric orthogonality. No inner product is defined or required."
      },
      "complementary_grammar": {
        "@id": "m3:sphinx_eye:SphinxEye",
        "description": "Sphinx Eye provides Map Grammar Gm over primitive types {R,E,V,O,I}, complementing Eagle's Territory Grammar Gt",
        "relationship": "structurally_complementary",
        "complete_architecture": "TSCG Bicephalous Grammar = Gt (Territory) + Gm (Map)"
      },
      "m2:changelog": [
        {
          "version": "2.8.0",
          "date": "2026-05-20",
          "changes": "CLEANUP: dimensionSymbol→typeSymbol, dimensionIndex→typeIndex, dimensions→types. Removed Hilbert-space refs, scalar axioms (F≥0.1), numeric rangeAnalog. Aligned with Lambek/structural grammar formalism."
        },
        {
          "version": "2.7.0",
          "date": "2026-05-18",
          "changes": "complete_architecture updated to reference Gs as reification of stereopsic synergy."
        },
        {
          "version": "2.6.0",
          "date": "2026-05-13",
          "changes": "OPERATOR REFORM: product notation ⊗ᵗ → × (structural product, Territory)."
        }
      ]
    },
    {
      "@id": "m3:eagle_eye:physicalInterpretation",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Physical Interpretation (ASFID)",
      "rdfs:comment": "Concrete physical manifestations or analogues of the ASFID types in Territory",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Description of how the ASFID types manifests in physical, biological, or social systems as observable Territory phenomena",
      "skos:example": "Attractor → Stability basin, homeostatic set-point",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:eagle_eye:rangeAnalog",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Qualitative Range (ASFID)",
      "rdfs:comment": "Qualitative structural domain of the ASFID types in Territory — expressed as a spectrum, not a numeric scale.",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Description of the structural domain of this ASFID dimension as a qualitative spectrum from minimal/absent structural expression to maximal/dominant. Replaces the numeric [0,1] scale of the former Hilbert-space formalism with qualitative anchors compatible with the Structural Grammar formalism.",
      "skos:example": "Structure (S): minimal structural bonding (gas-like, no stable organisation) ↔ maximal structural order (crystalline, fully constrained lattice)",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:eagle_eye:criticalAxiom",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Structural Axiom (ASFID)",
      "rdfs:comment": "Universal structural principle or necessity governing the presence and role of this ASFID types in any non-degenerate system.",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "A structural necessity or universal principle — expressed as a qualitative rule, not a numeric inequality — that must hold for this ASFID dimension in any observable system. Replaces scalar constraints (e.g., F ≥ 0.1) of the former Hilbert-space formalism with structural grammar rules.",
      "skos:example": "Flow (F) — Universal Openness Axiom: F is structurally necessary in any observable system; no real system is perfectly isolated from its environment. Expressed structurally: F cannot be absent from the structural formula of any non-degenerate system.",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:eagle_eye:typeA",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Attractor (A)",
      "m3:typeSymbol": "A",
      "m3:typeIndex": 1,
      "rdfs:comment": "𝕋₀(×) generator — Convergence points, stable states, equilibria.",
      "rdfs:domain": {
