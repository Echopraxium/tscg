      }
    },
    {
      "@id": "m3:eagle_eye:operator",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Operator × (Territory product)",
      "rdfs:comment": "Monoidal operator of Gt. Intra-ASFID — closed within Territory. Precedence: highest (× > + > |).",
      "skos:example": "A × S × It × F = Homeostasis",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      }
    },
    {
      "@id": "m3:eagle_eye:neutralElement",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Neutral Element (EmptyTerritory)",
      "rdfs:comment": "Neutral element of ×: EmptyTerritory. Symbolic: Black (absence of all ASFID types). A × EmptyTerritory = A.",
      "rdfs:domain": {
