  "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
  "@graph": [
    {
      "@id": "M1_Domains.jsonld",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG Knowledge Domains Registry",
      "rdfs:comment": "Centralized, evolving registry of knowledge domains identified through TSCG poclet corpus analysis. Each domain entry documents subdomains, related domains, and poclet usage statistics. Domains are M1-level concepts (disciplinary extensions) that bridge M2 transdisciplinary GenericConcepts and M0 concrete poclet instances.",
      "owl:versionInfo": "1.1.0",
      "dcterms:created": "2026-04-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m1:changelog": [
        {
          "version": "1.1.0",
          "date": "2026-04-19",
          "changes": "Added Blockchain domain with 6 subdomains (Cryptography, Distributed Systems, Consensus Algorithms, Decentralized Networks, Peer-to-Peer Systems, Byzantine Fault Tolerance). Related to ComputerScience, Economics, GameTheory. First poclet: M0_NakamotoConsensus."
        },
        {
          "version": "1.0.0",
          "date": "2026-04-18",
          "changes": "Initial complete registry extracted from full corpus: 24 poclets + 2 other instances (26 total). 18 primary domains identified with subdomains, cross-references, and exact poclet counts. Based on exhaustive analysis of all M0 files."
        }
      ],
      "m1:domainCount": 19,
      "m1:totalPoclets": 24,
      "m1:otherInstances": 2,
      "m1:corpusComplete": true,
      "m1:usageNote": "Domains are referenced in M0 instances via m1:domain property (migrated from m0:domain). Accepts single string ('Biology') or array for multi-domain poclets (['Biology', 'Chemistry']). Subdomains are defined here (M1 level), not in individual M0 instances.",
      "m1:evolutionPolicy": "This registry evolves as new poclets are analyzed. New domains are added when identified. Subdomains are consolidated from M0 instances and enriched through domain expertise. Version bumps when domains are added/removed or major subdomain restructuring occurs."
    },
    {
      "@id": "m1domain:Biology",
      "@type": "m1:Domain",
      "rdfs:label": "Biology",
      "rdfs:comment": "Science of living organisms, their structure, function, growth, evolution, and interactions with their environment",
      "skos:definition": "Study of life and living systems at all scales from molecules to ecosystems",
      "m1:subdomains": [
        "Developmental Biology",
        "Cell Biology",
        "Physiology",
        "Endocrinology",
        "Renal Physiology",
        "Cardiovascular Physiology",
        "Nephrology",
        "Homeostasis",
        "Immunology",
        "Neuroscience",
        "Cellular Communication",
        "Pharmacology"
      ],
      "m1:relatedDomains": [
        {"@id": "m1domain:Chemistry"},
        {"@id": "m1domain:Physics"},
        {"@id": "m1domain:Ecology"},
        {"@id": "m1domain:Neurobiology"}
      ],
      "m1:pocletExamples": [
        "M0_AdaptiveImmuneResponse",
        "M0_BloodPressureControl",
        "M0_ButterflyMetamorphosis",
