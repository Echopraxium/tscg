{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:eagle_eye:EagleEye",
      "@type": "owl:Ontology",
      "owl:versionInfo": "2.5.0",
      "dcterms:created": "2026-01-21",
      "dcterms:modified": "2026-05-13",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:description": "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A, S, F, I, D}. Provides the ontological/empirical perspective on systems-as-territory. Each primitive type instantiates at M0 as an evaluation functor F_x : System → [0,1].",
      "m3:ontologyCategory": {
        "@id": "m3:GenesisExtension"
      },
      "owl:imports": [ "M3_GrammarFoundation.jsonld" ],
      "rdfs:label": "Eagle Eye - Territory Grammar Gt",
      "rdfs:comment": "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A,S,F,I,D}. Provides the ontological/empirical perspective on systems-as-territory. At M0, each primitive type instantiates as an evaluation functor F_x : System → [0,1]. Part of the TSCG bicephalous architecture (Gt + Gm). See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
      "metadata": {
        "layer": "M3",
        "name": "Eagle Eye - ASFID Basis",
        "version": "2.3.0",
        "date_created": "2026-01-21",
        "date_modified": "2026-02-16",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "description": "ASFID basis for Territory measurement through analytical decomposition",
        "changelog": {
          "v2.5.0": "IMPORT UPDATE: owl:imports changed from M3_GenesisSpace.jsonld to M3_GrammarFoundation.jsonld (apex ontology). m3: namespace updated to M3_GenesisGrammar.jsonld. Aligns with new M3 architecture: GrammarFoundation (apex) → EagleEye/SphinxEye → GenesisGrammar.",
          "v2.4.0": "FORMALISM REFORM: Replaced Hilbert space / orthonormal basis framing with Structural Grammar (Lambek calculus). basis_properties → grammar_properties (Territory Grammar Gt). Removed hilbert_space, orthonormality fields. coupling_with_REVOI reframed: SVD/Sigma removed, Phi/Psi recast as natural transformations. orthogonality_matrix → independence_matrix. See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
          "v2.3.0": "REFACTORING: Removed m3:eagle_eye:M3Dimension class (now m3:M3Dimension in GenesisSpace). Removed common properties (symbol, index, examples - now m3:dimensionSymbol, m3:dimensionIndex, m3:dimensionExamples in GenesisSpace). Kept ASFID-specific properties (physicalInterpretation, rangeAnalog, criticalAxiom)."
        }
      },
      "parent_ontology": {
        "@id": "m3:genesis_space:GenesisSpace",
        "relationship": "component_of",
        "description": "Eagle Eye is the ASFID component of M3 Genesis Space, providing the analytical perspective on systems"
      },
      "grammar_properties": {
        "grammar_name":   "Territory Grammar Gt",
        "grammar_type":   "free_commutative_monoidal",
        "primitives":     ["A", "S", "F", "I", "D"],
        "product":        "⊗ᵗ  (structural co-activation, Territory)",
        "primitive_role": "generators of Territory type expressions (M2 structural formulas)",
        "functor_role":   "F_A, F_S, F_F, F_I, F_D : System → [0,1]  (evaluation morphisms at M0)",
        "perspective":    "ontological / empirical",
        "independence":   "verified  (no primitive derivable from others)",
        "mathematical_foundation": "Lambek Calculus / free commutative monoidal categories (Lambek 1958, MacLane 1963)"
      },
      "coupling_with_MapGrammar": {
        "description": "Territory Grammar Gt and Map Grammar Gm are connected via natural transformations (category theory). Gt and Gm are structurally separate grammars — their separation is fundamental, not a consequence of orthogonality.",
        "natural_transformations": {
          "Phi": {
            "symbol": "Φ",
            "signature": "Φ : Gt → Gm",
            "role": "Observation — Territory measurements inform Map construction",
            "example": "Nuclear reactor: neutron flux measurements (ASFID) → diffusion model coefficients (REVOI)"
          },
          "Psi": {
            "symbol": "Ψ",
            "signature": "Ψ : Gm → Gt",
            "role": "Interpretation — Map predictions guide Territory measurement strategies",
            "example": "Nuclear reactor: xenon oscillation model (REVOI) → install in-core detectors (ASFID)"
          }
        },
        "epistemic_gap": {
          "symbol": "δ₁",
          "formula": "||ASFID_mean − REVOI_mean|| / √2",
          "meaning": "Measure of non-isomorphism of Φ — Korzybski principle: Φ is never a perfect isomorphism"
        },
        "korzybski": "The map is not the territory — Gt ≠ Gm structurally, δ₁ > 0 in all real systems",
        "see_also": "M3_GenesisSpace.jsonld for complete bicephalous architecture"
      },
      "metaphor": {
        "image": "Eagle soaring above the territory",
        "vision": "Penetrating sight that perceives reality as-is",
        "action": "Observes, measures, analyzes",
        "domain": "Territory (Reality)",
        "perspective": "From above, comprehensive view",
        "visual_acuity": "8× human vision - precision at distance"
      },
      "dual_axes_position": {
        "model_reality_axis": "Reality",
        "analysis_synthesis_axis": "Analysis",
        "quadrant": "Analysis of Reality (Territory)"
      },
      "dimensions": [
        {
          "@id": "m3:eagle_eye:Attractor",
          "@type": [
            "owl:NamedIndividual",
            "m3:M3Dimension"
          ],
          "rdfs:label": "Attractor",
          "m3:dimensionSymbol": "|A⟩",
          "m3:dimensionIndex": 1,
          "rdfs:comment": "Asymptotic convergence tendency. Measures stability landscape and equilibrium attraction.",
          "m3:eagle_eye:physicalInterpretation": "Stability basin, attractor state, homeostatic set-point",
          "m3:eagle_eye:rangeAnalog": "[0,1] where 0=chaos/instability, 1=perfect stability",
          "m3:dimensionExamples": [
            "Thermostat set-point (high A)",
            "Strange attractor in chaos (low A)",
            "Biological homeostasis (medium-high A)"
          ]
        },
        {
          "@id": "m3:eagle_eye:Structure",
          "@type": [
            "owl:NamedIndividual",
            "m3:M3Dimension"
          ],
          "rdfs:label": "Structure",
          "m3:dimensionSymbol": "|S⟩",
          "m3:dimensionIndex": 2,
          "rdfs:comment": "Topological organization and connectivity. Measures internal arrangement and relational patterns.",
          "m3:eagle_eye:physicalInterpretation": "Network topology, crystalline order, organizational hierarchy",
          "m3:eagle_eye:rangeAnalog": "[0,1] where 0=gas (no structure), 1=crystal (perfect lattice)",
          "m3:dimensionExamples": [
            "Gas molecules (S≈0.1)",
            "Liquid water (S≈0.4)",
            "Biological cell (S≈0.7)",
            "Diamond crystal (S≈0.95)"
          ]
        },
        {
          "@id": "m3:eagle_eye:Flow",
          "@type": [
            "owl:NamedIndividual",
            "m3:M3Dimension"
          ],
          "rdfs:label": "Flow",
          "m3:dimensionSymbol": "|F⟩",
          "m3:dimensionIndex": 3,
          "rdfs:comment": "Exchange rate with environment. Measures openness and dissipation. AXIOM: F ≥ 0.1 (Universal Openness).",
          "m3:eagle_eye:physicalInterpretation": "Matter/energy/information flux across boundary",
          "m3:eagle_eye:rangeAnalog": "[0.1,1] where 0.1=quasi-closed, 1=maximally dissipative",
          "m3:eagle_eye:criticalAxiom": "F ≥ 0.1 (no perfectly isolated system exists)",
          "m3:dimensionExamples": [
            "Thermos flask (F≈0.15 - quasi-closed)",
            "Human body (F≈0.6 - moderate exchange)",
            "Tornado (F≈0.95 - highly dissipative)"
          ]
        },
        {
          "@id": "m3:eagle_eye:Information",
          "@type": [
            "owl:NamedIndividual",
            "m3:M3Dimension"
          ],
          "rdfs:label": "Information",
          "m3:dimensionSymbol": "|I⟩",
          "m3:dimensionIndex": 4,
          "rdfs:comment": "State complexity (synchronic). Measures variety, diversity, Shannon entropy at fixed time.",
          "m3:eagle_eye:physicalInterpretation": "Configurational entropy, state-space volume, variety",
          "m3:eagle_eye:rangeAnalog": "[0,1] where 0=trivial/simple, 1=maximally complex",
          "m3:dimensionExamples": [
            "Single atom (I≈0.05)",
            "Binary switch (I≈0.1)",
            "Human genome (I≈0.8)",
            "Brain neural state (I≈0.9)"
          ]
        },
        {
          "@id": "m3:eagle_eye:Dynamics",
          "@type": [
            "owl:NamedIndividual",
            "m3:M3Dimension"
          ],
          "rdfs:label": "Dynamics",
          "m3:dimensionSymbol": "|D⟩",
          "m3:dimensionIndex": 5,
          "rdfs:comment": "State evolution (diachronic). Measures temporal change and transformation rate.",
          "m3:eagle_eye:physicalInterpretation": "Phase velocity, reaction rate, evolutionary trajectory",
          "m3:eagle_eye:rangeAnalog": "[0,1] where 0=static/frozen, 1=rapid change",
          "m3:dimensionExamples": [
            "Geological processes (D≈0.1 - slow)",
            "Chemical reactions (D≈0.5 - moderate)",
            "Neural firing (D≈0.9 - rapid)"
          ]
        }
      ],
      "independence_matrix": {
        "description": "The 5 primitive types {A,S,F,I,D} are analytically independent — no primitive type is derivable from the others",
        "verified": "true",
        "note": "Independence here means conceptual non-redundancy, not metric orthogonality. No inner product is defined or required."
      },
      "complementary_grammar": {
        "@id": "m3:sphinx_eye:SphinxEye",
        "description": "Sphinx Eye provides Map Grammar Gm over primitive types {R,E,V,O,I}, complementing Eagle's Territory Grammar Gt",
        "relationship": "structurally_complementary",
        "complete_architecture": "TSCG Bicephalous Grammar = Gt (Territory) + Gm (Map)"
      }
    },
    {
      "@id": "m3:eagle_eye:physicalInterpretation",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Physical Interpretation (ASFID)",
      "rdfs:comment": "Concrete physical manifestations or analogues of the ASFID dimension in Territory",
      "rdfs:domain": "m3:M3Dimension",
      "rdfs:range": "xsd:string",
      "skos:definition": "Description of how the ASFID dimension manifests in physical, biological, or social systems as observable Territory phenomena",
      "skos:example": "Attractor → Stability basin, homeostatic set-point",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:eagle_eye:rangeAnalog",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Range Analog (ASFID)",
      "rdfs:comment": "Typical measurement range and interpretation scale for ASFID dimension in Territory",
      "rdfs:domain": "m3:M3Dimension",
      "rdfs:range": "xsd:string",
      "skos:definition": "Normalized scale [0,1] with semantic anchors describing extreme and typical values for Territory measurements",
      "skos:example": "Structure: [0,1] where 0=gas (no structure), 1=crystal (perfect lattice)",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:eagle_eye:criticalAxiom",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Critical Axiom (ASFID)",
      "rdfs:comment": "Fundamental constraint or axiom that applies to this ASFID dimension",
      "rdfs:domain": "m3:M3Dimension",
      "rdfs:range": "xsd:string",
      "skos:definition": "Theoretical or empirical constraint that must be satisfied in Territory measurements (e.g., Flow ≥ 0.1 Universal Openness axiom)",
      "skos:example": "F ≥ 0.1 (no perfectly isolated system exists)",
      "dcterms:created": "2026-02-16"
    }
  ]
}
