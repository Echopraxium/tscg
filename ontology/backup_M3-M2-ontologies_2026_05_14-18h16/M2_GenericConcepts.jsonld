              "formula": "G = 1",
              "examples": [
                "Buffer amplifier (impedance matching)",
                "Isolation transformer (1:1 ratio)",
                "Digital repeater (signal regeneration)"
              ],
              "characteristics": "Output = Input, preserves magnitude while potentially changing other properties (impedance, isolation)"
            }
          ],
          "m2:default": "Amplifying",
          "m2:usageGuidelines": "Select based on gain magnitude. Use Amplifying for RAAS enzymatic stages (G>1), Attenuating for inhibitory pathways (G<1)."
        }
      },
      "m3:semanticSignature": "signal_gain + polarity(amplification|attenuation)"
    },
    {
      "@id": "m2:Alignment",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Alignment",
      "rdfs:comment": "Bidirectional dynamic process by which two entities, representations, or systems progressively reduce their mutual discrepancy toward a coherent correspondence. Distinct from Representation (static mapping A→B), Balance (static equilibrium), and Convergence (geometric focusing of trajectories): Alignment is an active, iterative, bidirectional reconciliation process.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "I ⊗ A ⊗ S",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Structure"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "dual",
      "m2:hasExample": [
        "DNA sequence alignment (bioinformatics)",
        "Wheel alignment (mechanics)",
        "Organizational strategic alignment (management)",
        "AI alignment (computer science)",
        "Planetary alignment (astronomy)",
        "Territory↔Map alignment via Φ/Ψ operators (TSCG - see m3:AlignmentLoop)"
      ],
      "m2:distinctFrom": {
        "m2:Representation": "Representation is a static structural mapping (A→B); Alignment is an iterative bidirectional process reducing discrepancy (A↔B)",
        "m2:Balance": "Balance is a static equilibrium state; Alignment is an active process toward coherence",
        "m2:Convergence": "Convergence concerns geometric focusing of trajectories; Alignment concerns structural/semantic correspondence between entities"
      },
      "m3:semanticSignature": "information_coherence + attractor_convergence + structural_correspondence"
    },
    {
      "@id": "m2:FeedbackLoop",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Feedback Loop",
      "rdfs:comment": "Cyclic regulatory process where a system compares its current state to a target (Homeostasis), reduces the discrepancy (Alignment), and evolves over time (Process). Encompasses both negative feedback (stabilizing, error-correcting) and positive feedback (amplifying, self-reinforcing). Universal systemic pattern found across biology, engineering, economics, ecology and social systems.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "m2:Process ⊗ m2:Alignment ⊗ m2:Homeostasis",
      "m2:tensorExpansion": "(D ⊗ F) ⊗ (I ⊗ A ⊗ S) ⊗ (A ⊗ S ⊗ F) = A ⊗ S ⊗ F ⊗ I ⊗ D",
      "m2:tensorNote": "Expanded formula covers all 5 ASFID dimensions, reflecting that a feedback loop engages the full phenomenology of a system: Attractor (set point), Structure (circuit), Flow (signal), Information (error signal), Dynamics (temporal evolution).",
      "m2:componentGenericConcepts": [
        {
          "@id": "m2:Process",
          "formula": "D ⊗ F",
          "contribution": "Temporal unfolding of the loop - the cyclic sequence of sense→compare→act"
        },
        {
          "@id": "m2:Alignment",
          "formula": "I ⊗ A ⊗ S",
          "contribution": "Error detection and reduction - comparison between actual state and target (set point)"
        },
        {
          "@id": "m2:Homeostasis",
          "formula": "A ⊗ S ⊗ F",
          "contribution": "The regulatory target - maintains stable internal state despite perturbations"
        }
      ],
      "m2:hasDominantM3": [
