    {
      "@id": "m2:ValueSpace",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "ValueSpace (Hybrid Variety Model)",
      "rdfs:comment": "Space of possible values for a property or object. Can be scalar (e.g., temperature range), vector (e.g., RGB 3D color components), tensor product (e.g., 5D ASFID genericConcept formulas), or symbolic (e.g., alphabet symbols). Values can be discrete or continuous. Characterized both by intrinsic information content (Territory) and epistemic model quality (Map). Foundation for Ashby's Law of Requisite Variety in cybernetics. Mnemonic: ItVORIm (subscripts t/m mark Territory/Map boundary).",
      "m2:hasFamily": "m2:Informational",
      "m2:hasTensorFormula": "It → V → O → R → Im",
      "m2:hasTensorFormulaTeX": "I_t \\otimes V \\otimes O \\otimes R \\otimes I_m",
      "m2:hasTensorFormulaASCII": "I_t (x) V (x) O (x) R (x) I_m",
      "m2:hasDominantM3": [
        "HYBRID: It from ASFID (Eagle Eye) + V → O → R → Im from REVOI (Sphinx Eye)"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "hybrid",
      "m2:polarityDescription": {
        "territory": "Information content of value space (cardinality, dimension)",
        "map": "Epistemic quality of variety model (verifiability, observability, reproducibility, interoperability)"
      },
      "m2:hasExample": [
        "Scalar continuous: Temperature [0,100]°C (It=continuous, VORI=high)",
        "Vector 3D discrete: RGB color [0,255]³ (It=24 bits, VORI=perfect digital)",
        "Tensor product 5D: Process genericConcept D → I → F (It=tensor dimension, VORI contextual)",
        "Symbolic discrete: Alphabet {A-Z} (It=log₂(26)≈4.7 bits, VORI=standard encoding)",
        "Hybrid: VSM S1 state = Mode×Performance (It=discrete×continuous, VORI varies)",
        "Cybernetics: S1 operational variety in VSM (It=state count, VORI=model quality)"
      ],
      "m2:perspective": "hybrid",
      "m2:hybridView": {
        "description": "Bicephalous fusion - variety exists in Territory AND is modeled in Map. Mnemonic order: ItVORIm (subscripts explicitly mark Territory/Map boundary: It=territory, Im=map)",
        "territoryComponent": {
          "basis": "ASFID",
          "dimension": "It (Information)",
          "role": "Measured cardinality/dimension of value space (Eagle Eye)",
          "measure": "Discrete: |S| (count) | Continuous: measure(S)/Π• (volume÷resolution)",
          "examples": {
            "scalar_discrete": "Bit: |{0,1}| = 2 → I_t = 1 bit",
            "scalar_continuous": "Temperature [0,100]°C at 0.1°C → I_t ≈ 10 bits",
            "vector_discrete": "RGB: 256³ → I_t = 24 bits",
            "symbolic": "Alphabet 26 letters → I_t ≈ 4.7 bits",
            "tensor": "D → I → F → It = dim(H_D → H_I → H_F)"
          }
        },
        "mapComponent": {
          "basis": "REVOI (partial)",
          "dimensions": "V → O → R → Im",
          "dimensionOrder": "Epistemic progression: Existence → Perception → Reliability → Communication",
          "role": "Epistemic quality of variety model (Sphinx Eye)",
          "measures": {
            "V": "Verifiability: Can we test value existence? (empirical testability)",
            "O": "Observability: Can we perceive values? (measurement access)",
            "R": "Reproducibility: Are measures reliable? (measurement stability)",
            "Im": "Interoperability: Can we communicate values? (encoding compatibility)"
          }
        },
        "notation": {
          "It": "Information measured in Territory (ASFID - Eagle Eye)",
          "V": "Verifiability (REVOI - first epistemic test)",
          "O": "Observability (REVOI - perceptual access)",
          "R": "Reproducibility (REVOI - measurement reliability)",
          "Im": "Interoperability in Map models (REVOI - Sphinx Eye - encoding standards)"
        },
        "mnemonicOrder": "ItVORIm ensures logical epistemic flow + subscripts t/m mark Territory/Map boundary"
      },
      "m2:ashbyPrinciple": {
        "lawOfRequisiteVariety": "Only variety can absorb variety (W. Ross Ashby, 1956)",
        "territoryFormulation": "V_controller(I_t) ≠  V_disturbance(I_t) - Controller must match disturbance variety",
        "mapFormulation": "Effective variety = V_T(It) × Q_M(V,O,R,Im) - Model quality determines usable variety",
        "epistemicProgression": "V (verify existence) → O (observe) → R (reliable measures) → Im (communicate)",
        "vsmApplication": {
          "s1_variety": "Operational state space has high It (many possible states)",
          "s2_amplification": "Increases Im (interoperability) to match S1 variety complexity",
          "s3_attenuation": "Decreases O (observability transmitted to S5) while maintaining V (verifiability)",
          "s5_variety": "Policy decision space has low It but high V (few verified options)",
          "requisite_variety_principle": "Each level must have sufficient ValueSpace (It×VORI) to regulate subordinate variety"
        }
      },
      "m2:valueSpaceTypes": {
        "scalar": {
          "definition": "Single dimension (1D)",
          "examples": [
            "Temperature interval",
            "pH scale",
            "Age in years",
            "Binary bit"
          ],
          "measure_It_discrete": "It = log₂(n) where n = number of values",
          "measure_It_continuous": "I_t = log(Δx/ε) where Δx = range, ε = resolution"
        },
        "vector": {
          "definition": "Multiple dimensions (nD cartesian product)",
          "examples": [
            "RGB color [0,255]³",
            "3D position (x,y,z) ∈ ℝ³",
            "Velocity vector"
          ],
          "measure_It_discrete": "It = ∏ᵢ log₁₀(nᵢ) = log₁₀(∏ᵢ nᵢ)",
          "measure_It_continuous": "It = log₁₀[∏ᵢ (Δxᵢ/εᵢ)]"
        },
        "tensor": {
          "definition": "Tensor product space (like TSCG M2 formulas)",
          "examples": [
            "Process = D → I → F",
            "Domain = ASFID → REVOI (before SVD)"
          ],
          "measure_It": "It = log₁₀(dim( ⊗ ᵢ Hᵢ)) where Hᵢ are Hilbert spaces"
        },
        "symbolic": {
          "definition": "Discrete set without order/metric (pure list)",
          "examples": [
            "Alphabet {A-Z}",
            "Amino acids {Ala, Cys, ...}",
            "Magic colors {W,U,B,R,G}",
            "Weekdays"
          ],
          "measure_It": "It = log₂(|S|) where |S| = set cardinality"
        },
        "hybrid": {
          "definition": "Mixed discrete + continuous dimensions",
          "examples": [
            "Quantum state: Spin{↑, ↓} × Position(ℝ³)",
            "VSM S1: Mode{Active,Standby,Error} × Performance[0,1]"
          ],
          "measure_It": "It = log₂(|S_discrete|) + log₂(measure(S_continuous)/ε)"
        }
      },
      "m2:mathematicalProperties": {
        "territoryMeasure": "V_T(S) = |{s ∈ S : distinguishable values}| (cardinality or measure)",
        "entropyRelation_discrete": "H(S) = log₂(V_T(S)) if equiprobable",
        "entropyRelation_continuous": "H(S) = ∫ p(x) log p(x) dx (differential entropy)",
        "compositionRule": "V_T(S₁ × S₂) = V_T(S₁) × V_T(S₂) (cartesian product)",
        "mapQuality": "Q_M(ValueSpace) = f(V, O, R, Im) ∈ [0,1]",
        "effectiveVariety": "V_eff = V_T(It) × Q_M(V,O,R,Im) - Ashby's usable variety"
      },
      "m2:distinctionFromRelated": {
        "vs_Information": "Information (pure ASFID I) = content only; ValueSpace (It → VORI) = content + epistemic quality of model",
        "vs_Domain": "Domain (full ASFID → REVOI) = entire knowledge field; ValueSpace (It → VORI partial) = value set of one property",
        "vs_Space": "Space (S → I) = pure topology/structure; ValueSpace (It → VORI) = topology + epistemic accessibility",
        "vs_Cardinality": "Cardinality = pure counting |S|; ValueSpace = counting (It) + model quality (VORI)",
        "vs_State": "State (S → A) = configuration at instant t; ValueSpace = all possible configurations (timeless set)"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Cybernetics: VSM requisite variety (Ashby 1956) - S1 operational states",
          "Information Theory: Shannon alphabet, channel capacity - discrete symbol sets",
          "Thermodynamics: Phase space volume, Boltzmann entropy - continuous state spaces",
          "Biology: Genetic diversity (allele combinations), phenotype space",
          "Control Theory: State space dimension, controllability/observability",
          "Linguistics: Vocabulary size (lexicon), translatability between encodings",
          "Economics: Strategic option space, market predictability",
          "Quantum Mechanics: Hilbert space dimension, observable operator spectrum",
          "Computer Science: Data types (int, float, enum, struct), value domains",
          "Color Science: RGB/CMYK/HSL color spaces - vector value spaces"
        ],
        "validatedDomains": 10,
        "transdisciplinaryStrength": "Universal - Ashby's variety principle applies across all formal and natural systems with distinguishable states"
      },
      "dcterms:created": "2026-01-31",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Required for VSM modeling to formalize Ashby's Law of Requisite Variety. Emerged from need to represent value/state spaces with bicephalous perspective: Territory (what values exist - It) AND Map (how we model them - VORI). The ItVORIm mnemonic order provides epistemic progression where subscripts t/m explicitly mark the Territory/Map boundary. Generalizes beyond system states to any property's value domain (scalar, vector, tensor, symbolic, hybrid). Essential for variety amplification (S2) and attenuation (S3) in VSM.",
      "m3:semanticSignature": "territory_information + variety + observability + representability + map_interoperability"
    },
    {
      "@id": "m2:Amplification",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Amplification (Amplification/Attenuation)",
      "rdfs:comment": "Bidirectional process: increase (amplification) or decrease (attenuation) of signal, flow, quantity, or variety. Fundamental cybernetic operation for gain control and variety management. Characterized by measurable flux/dynamics/information (Territory) and representability/observability in models (Map). Direction (Amplifying/Attenuating/Unity) specified via direction attribute.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "Ft → D → It → R → O",
      "m2:hasTensorFormulaTeX": "F_t \\otimes D \\otimes I_t \\otimes R \\otimes O",
      "m2:hasTensorFormulaASCII": "F_t (x) D (x) I_t (x) R (x) O",
      "m2:hasDominantM3": [
