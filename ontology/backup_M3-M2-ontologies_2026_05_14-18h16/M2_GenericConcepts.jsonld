              "Git clone"
            ]
          },
          {
            "domain": "Epidemiology / Virology",
            "examples": [
              "Viral replication",
              "Bacterial binary fission"
            ]
          },
          {
            "domain": "Physics",
            "examples": [
              "Stimulated emission / laser",
              "Phonon replication"
            ]
          },
          {
            "domain": "Social Sciences / Memetics",
            "examples": [
              "Cultural transmission",
              "Legal precedent citation"
            ]
          },
          {
            "domain": "Developmental Biology",
            "examples": [
              "Stem cell self-renewal",
              "Clonal expansion"
            ]
          }
        ],
        "count": 6
      },
      "m2:discoveryContext": "Identified as missing M2 gap during construction of m2:Propagation as GenericConceptCombo ⊗⇒(Cascade, Duplication, Network). Duplication provides the branching parent: each node receiving a copy becomes a new emitter. The fidelity spectrum (V axis) formally connects Duplication to Bifurcation (degenerate V→0 case).",
      "m3:semanticSignature": "faithful_copy_production + informational_preservation + flux_driven + temporal_dynamics + fidelity_verifiable"
    },
