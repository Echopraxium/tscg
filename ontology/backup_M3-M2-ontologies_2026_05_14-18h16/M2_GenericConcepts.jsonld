              "description": "Nodes arranged in closed loop (each connects to 2 neighbors)",
              "examples": [
                "Token ring network",
                "Circular DNA (plasmid)",
                "Periodic boundary conditions (1D)"
              ],
              "characteristics": "Regular, periodic, 1D topology",
              "robustness": "Vulnerable (single break disconnects)",
              "clustering": 0,
              "diameter": "N/2 (worst case)",
              "degree": "k = 2 (constant)"
            },
            {
              "value": "Fully-connected",
              "alternative_names": [
                "Complete graph",
                "All-to-all",
                "Mesh"
              ],
              "description": "Every node connected to every other node",
              "formula": "Number of edges = N(N-1)/2",
              "examples": [
                "Small group communication (everyone knows everyone)",
                "Fully connected neural layer",
                "Mesh network (high redundancy)"
              ],
              "characteristics": "Maximum connectivity, maximum redundancy",
              "robustness": "Extremely robust (N-1 redundant paths)",
              "clustering": 1,
              "diameter": 1,
              "degree": "k = N-1 (maximum)",
              "scalability": "Poor (edges scale as N²)"
            }
          ],
          "m2:default": "Random",
          "m2:usageGuidelines": "Use Scale-free for biological/social networks with hubs. Use Small-world for clustered networks with shortcuts (neural, social). Use Lattice for spatial systems (grid, crystal). Use Hierarchical for modular/nested systems (taxonomy, organization).",
          "m2:network_metrics": {
            "clustering_coefficient": "C = (# of triangles) / (# of connected triples)",
            "characteristic_path_length": "L = average shortest path between all pairs",
            "degree_distribution": "P(k) = probability a node has degree k",
            "modularity": "Q = strength of division into modules"
          }
        }
      },
      "m3:semanticSignature": "structural_topology + information_routing + flow_distribution"
    },
    {
      "@id": "m2:Symmetry",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Symmetry",
      "rdfs:comment": "Invariance under transformation.",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S",
      "m2:hasDominantM3": [
