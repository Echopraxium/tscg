    {
      "@id": "m2:GenericConceptCombo",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "GenericConceptCombo",
      "rdfs:comment": "Class of synergistic N-ary combinations of M2 GenericConcepts that produce emergent semantics irreducible to any single parent. Operator: ⊗ⁿ⇒(M₁,…,Mₙ) = lattice_join(dims(M₁) ∪ … ∪ dims(Mₙ)). Shared dimensions are contracted (Fᵢ⊔Fⱼ = F). Emergent contributions are the dimensions unique to each parent. Subclass of m2:GenericConcept. Instances are defined in M1_CoreConcepts.jsonld. Co-mobilisation rule: if the combination produces NO emergent semantics beyond its parents, it is NOT a GenericConceptCombo.",
      "m2:hasFamily": "m2:Combo",
      "dcterms:created": "2026-01-15",
      "dcterms:modified": "2026-03-13",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:KnowledgeFieldConceptCombo",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptCombo",
      "rdfs:label": "KnowledgeFieldConceptCombo",
      "rdfs:comment": "Subclass of GenericConceptCombo restricted to combinations that span knowledge field boundaries — i.e. whose parent GenericConcepts originate from distinct epistemological domains (e.g. physical + semiotic, biological + informational). A KnowledgeFieldConceptCombo is transdisciplinary by construction: its emergent semantics cannot be expressed within any single knowledge field. Instances are defined in M1_CoreConcepts.jsonld.",
      "m2:hasFamily": "m2:Combo",
      "dcterms:created": "2026-03-13",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Layer",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Segmentation"
      ],
      "rdfs:label": "Layer",
      "rdfs:comment": "Stable, ordered positional partition in a stack: each layer has a characteristic content (I) and occupies a fixed rank defined by an attractor (A). Subclass of Segmentation (S ⊗ I ⊗ D): the D dimension is replaced by A — partition is positional-stable rather than dynamically produced. No subordination (unlike Hierarchy): layers are co-equal strata. Representability (R) ensures the stacking order is semantically encodable.",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S ⊗ I ⊗ A ⊗ R",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes A \\otimes R",
      "m2:hasTensorFormulaASCII": "S (x) I (x) A (x) R",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor",
        "m3:sphinx_eye:Representability"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S ⊗ I ⊗ A ⊗ R",
        "role": "Measure the stack architecture (S), characteristic content of each stratum (I), positional attractor maintaining stacking order (A), and representability of stratum identity (R)",
        "status": "IMMUTABLE",
        "dimensionSemantics": {
          "S": "Structure — spatial/logical partition (the stratum as a bounded region)",
          "I": "Information — characteristic content distinguishing this layer from others",
          "A": "Attractor — positional stability: the rank in the stack (ordinal position)",
          "R": "Representability — the stacking order is semantically encodable and nameable"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Segmentation": "Segmentation (S ⊗ I ⊗ D) is the dynamic act of cutting; Layer (S ⊗ I ⊗ A ⊗ R) is the stable positional result — D (dynamic cut) replaced by A (positional attractor)",
        "vs_Hierarchy": "Hierarchy implies vertical power/subordination (A ⊗ S); Layer implies positional order without dominance",
        "vs_Modularity": "Modularity (S ⊗ I ⊗ Im) decomposes into functionally independent units; Layers are positionally ordered and often coupled",
        "vs_Step": "Step (S ⊗ I ⊗ D ⊗ Im) is a dynamic stage in a process; Layer is a static structural stratum"
      },
      "m2:hasExample": [
        "Ecology — trophic levels (producers, herbivores, predators, apex predators)",
        "Geology — stratigraphic layers (sediment strata ordered by age)",
        "Computer Science — OSI network model (physical, data link, network … application)",
        "Atmospheric Science — atmospheric layers (troposphere, stratosphere, mesosphere …)",
        "Materials Science — composite laminates (fibre plies, resin layers)",
        "Software Architecture — 3-tier architecture (presentation, business logic, data)",
        "Painting — glazing technique (ground, underpainting, colour glazes, varnish)"
      ],
      "m2:transdisciplinaryValidation": {
        "validated": true,
        "minDomainsRequired": 6,
        "actualDomains": 7,
        "domains": [
          "Ecology",
          "Geology",
          "Computer Science",
          "Atmospheric Science",
          "Materials Science",
          "Software Architecture",
          "Painting"
        ]
      },
      "dcterms:created": "2026-03-13",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Context",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Environment"
      ],
      "rdfs:label": "Context",
      "rdfs:comment": "Epistemic frame — subclass of Environment — that delimits what is observable (O), how it is encodable/nameable (R), within which shared interpretive space between observers (Im), and how that frame can reconfigure (E). Pure Map concept (all four dimensions are REVOI): unlike its parent Environment (F ⊗ I — Territory), Context describes HOW a system is known rather than WHAT it is. A context can be linguistic, computational, legal, biological or mathematical — in every case it is the epistemic scaffolding that conditions observation.",
      "m2:hasFamily": "m2:Ontological",
      "m2:hasTensorFormula": "O ⊗ R ⊗ Im ⊗ E",
      "m2:hasTensorFormulaTeX": "O \\otimes R \\otimes I_m \\otimes E",
      "m2:hasTensorFormulaASCII": "O (x) R (x) Im (x) E",
      "m2:hasDominantM3": [
        "m3:sphinx_eye:Observability",
        "m3:sphinx_eye:Representability",
        "m3:sphinx_eye:Interoperability",
        "m3:sphinx_eye:Evolvability"
      ],
      "m2:hasEpistemicGap": 0.15,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "map",
      "m2:sphinxView": {
        "basis": "REVOI",
        "formula": "O ⊗ R ⊗ Im ⊗ E",
        "role": "Evaluate the observable field bounded by this context (O), its semantic encodability (R), the shared interpretive frame enabling inter-observer agreement (Im), and the frame's capacity to reconfigure (E)",
        "status": "IMMUTABLE",
        "dimensionSemantics": {
          "O": "Observability — what is visible/measurable from within this context (bounded field of observation)",
          "R": "Representability — how this context can be named, encoded, described (semantic decodability)",
          "Im": "Interoperability — shared interpretive frame: different observers can exchange meaning within this context",
          "E": "Evolvability — the context can shift, expand or contract over time (paradigm shifts, scope changes)"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Environment": "Environment (F ⊗ I — Territory) is the external system that exchanges with an entity; Context (O ⊗ R ⊗ Im ⊗ E — Map) is the epistemic framing of that environment. rdfs:subClassOf m2:Environment.",
        "vs_System": "System (S ⊗ F) is the Territory entity; Context is the Map scaffolding that shapes how any system is observed and interpreted",
        "vs_Observer": "Observer (I ⊗ A) is the agent performing observation; Context is the epistemic frame within which that observation is meaningful",
        "vs_Space": "Space (S ⊗ I) is a structural container; Context is an interpretive frame — purely epistemic, not spatial"
      },
      "m2:hasExample": [
        "Linguistics — context of utterance (pragmatics: who speaks to whom, when, where)",
        "Computing — execution context / scope (variables, bindings, environment at runtime)",
        "Philosophy — Kuhnian paradigm (epistemic frame shared by a scientific community)",
        "Law — legal jurisdiction (which norms apply, which court has authority)",
        "Biology — cellular microenvironment (signalling molecules, pH, oxygen tension)",
        "Mathematics — Grothendieck topos (categorical context determining which logic applies)"
      ],
      "m2:transdisciplinaryValidation": {
        "validated": true,
        "minDomainsRequired": 6,
        "actualDomains": 6,
        "domains": [
          "Linguistics",
          "Computing",
          "Philosophy",
          "Law",
          "Biology",
          "Mathematics"
        ]
      },
      "dcterms:created": "2026-03-13",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:GenericConcept",
      "@type": "owl:Class",
      "rdfs:label": "M2 GenericConcept",
      "rdfs:comment": "A systemic pattern emerging from tensor product of M3 dimensions. Represents a recognizable organizational motif found across multiple domains."
    },
    {
      "@id": "m2:GenericConceptFamily",
      "@type": "owl:Class",
      "rdfs:label": "GenericConcept Family",
      "rdfs:comment": "A family grouping of genericConcepts based on dominant M3 dimensions and functional role in system behavior. Renamed from Category to GenericConceptFamily to avoid confusion with Category Theory (mathematical category theory)."
    },
    {
      "@id": "m2:GenericConceptPair",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "GenericConcept Pair",
      "rdfs:comment": "A genericConcept whose semantics are constituted by two named, structurally opposed poles sharing the same base tensor formula. The two poles are related by a parametric operator (p ∈ {0,1}) or by a structural reversal (direction, cardinality). Subclasses: DimensionPair (dimension present/absent via A^p), SignPair (sign reversal via (-1)^p), StructuralPair (direction or cardinality reversal). Distinct from m2:dualCounterpart which links two DIFFERENT genericConcepts (e.g. LALI ↔ ButterflyEffect sharing a parent but with different structures).",
      "rdfs:seeAlso": "m2:GenericConceptDimensionPair, m2:GenericConceptSignPair, m2:GenericConceptStructuralPair",
      "dcterms:created": "2026-02-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:GenericConceptDimensionPair",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptPair",
      "rdfs:label": "Dimension Pair",
      "rdfs:comment": "A GenericConceptPair where the two poles differ by the PRESENCE or ABSENCE of one ASFID dimension, formalized as A^p (p=1: dimension present; p=0: A⁰=1, neutral tensor element, dimension absent). The pole with p=1 has strictly more expressive power than the pole with p=0. Example: Composition (S ⊗ I ⊗ A^p): p=1 → Composition (emergent property A present), p=0 → Decomposition (A dissolved, only S ⊗ I remains).",
      "m2:parametricOperator": "A^{p}, p ∈ {0,1}",
      "m2:convention": "p=1: dimension present (richer pole); p=0: dimension absent (A⁰=1 neutral)",
      "dcterms:created": "2026-02-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:GenericConceptSignPair",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptPair",
      "rdfs:label": "Sign Pair",
      "rdfs:comment": "A GenericConceptPair where the two poles differ by a SIGN REVERSAL on the base formula, formalized as (-1)^p · F(ASFID) where F is the shared base formula. p=0 → positive pole (enabling, amplifying, constructive); p=1 → negative pole (inhibiting, attenuating, destructive). Examples: Activation/Inhibition = (-1)^p (A ⊗ D); Convergence/Divergence = (-1)^p ∇·D; Synergy+/Synergy− = (-1)^p (I ⊗ D).",
      "m2:parametricOperator": "(-1)^{p}, p ∈ {0,1}",
      "m2:convention": "p=0: positive pole (enabling/amplifying); p=1: negative pole (inhibiting/attenuating)",
      "dcterms:created": "2026-02-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:GenericConceptStructuralPair",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptPair",
      "rdfs:label": "Structural Pair",
      "rdfs:comment": "A GenericConceptPair where the two poles differ by a STRUCTURAL REVERSAL that cannot be reduced to a scalar parametric operator (dimension presence or sign). Two subtypes: (1) Direction reversal: same dimensions, opposite flow direction (e.g. Encoding I_src→I_coded vs Decoding I_coded→I_src). (2) Cardinality reversal: N:1 vs 1:N structural aggregation (e.g. Fusion {S₁⊗...⊗Sₙ}→S vs Fission S→{S₁⊗...⊗Sₙ}). In both cases m2:expression is replaced by explicit m2:poleMapping with pole1/pole2 formulas.",
      "m2:parametricOperator": "None (structural reversal: direction or cardinality)",
      "dcterms:created": "2026-02-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:hasFamily",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has family",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConceptFamily",
      "owl:functionalProperty": true,
      "rdfs:comment": "Associates a genericConcept with its GenericConceptFamily. Renamed from hasCategory to hasFamily to align with the renaming of m2:Category to m2:GenericConceptFamily."
    },
    {
      "@id": "m2:hasTensorFormula",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has tensor formula",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:hasDominantM3",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has dominant M3 dimension",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m3:M3Dimension"
    },
    {
      "@id": "m2:hasEpistemicGap",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has epistemic gap",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:decimal",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:hasPolarity",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has polarity",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string",
      "m2:allowedValues": [
        "neutral",
        "dual"
      ],
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:shortName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "short name",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:fullName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "full name",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:dualAspects",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "dual aspects",
      "rdfs:domain": "m2:GenericConcept"
    },
    {
      "@id": "m2:hasExample",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has example",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "m2:Structural",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Structural Family",
      "rdfs:comment": "Topology, organization, spatial arrangement. High S, low D.",
      "m2:genericConceptCount": 12
    },
    {
      "@id": "m2:Dynamic",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Dynamic Family",
      "rdfs:comment": "Processes, transformations, temporal evolution. High D.",
      "m2:genericConceptCount": 15
    },
    {
      "@id": "m2:Regulatory",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Regulatory Family",
      "rdfs:comment": "Control, stabilization, constraint. High A, tensor couplings.",
      "m2:genericConceptCount": 7
    },
    {
      "@id": "m2:Adaptive",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Adaptive Family",
      "rdfs:comment": "Learning, evolution, environmental response. High I, medium F.",
      "m2:genericConceptCount": 4
    },
    {
      "@id": "m2:Energetic",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Energetic Family",
      "rdfs:comment": "Energy, matter, information flows. High F, high D.",
      "m2:genericConceptCount": 2
    },
    {
      "@id": "m2:Informational",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Informational Family",
      "rdfs:comment": "Data, representation, communication. High I.",
      "m2:genericConceptCount": 6
    },
    {
      "@id": "m2:Ontological",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Ontological Family",
      "rdfs:comment": "Fundamental system entities and boundaries. S → F patterns.",
      "m2:genericConceptCount": 8
    },
    {
      "@id": "m2:Teleonomic",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Teleonomic Family",
      "rdfs:comment": "Goal-directedness, purpose, optimization. High A.",
      "m2:genericConceptCount": 1
    },
    {
      "@id": "m2:Relational",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Relational Family",
      "rdfs:comment": "Interactions between entities and roles. S → I patterns.",
      "m2:genericConceptCount": 5
    },
    {
      "@id": "m2:Combo",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConceptFamily",
      "rdfs:label": "Combo Family",
      "rdfs:comment": "GenericConcepts produced by synergistic combination of N parent GenericConcepts (N ≥ 2) via the n-ary tensor assembly and emergence morphism (⊗ⁿ⇒). The resulting concept has semantic identity irreducible to any subset of its parents. Shared dimensions between parents are contracted via lattice join (F ⊔ F = F). Members: GenericConceptCombo (abstract pattern), Cascade, Processor, LocalActivationLateralInhibition, ButterflyEffect, Oscillator, Propagation, Narration.",
      "m2:genericConceptCount": 8,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:NaryAttribute",
      "@type": "owl:Class",
      "rdfs:label": "N-ary Attribute",
      "rdfs:comment": "Descriptor for a ValueSpace attribute of a GenericConcept or GenericConceptCombo. An N-ary attribute has an arity (number of simultaneous values it can hold), a value space specification, and optional constraint notes. Used to define the configurable parameters of composite genericConcepts (e.g. hasKnowledgeField, hasCombinedGenericConcept in KnowledgeFieldGenericCombo).",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:categoryTheory",
      "@type": "owl:AnnotationProperty",
      "rdfs:label": "category theory",
      "rdfs:comment": "Annotation documenting the category-theoretic structure of an M2 ontology. Value is a JSON object describing functors (tensorization, instantiation) and morphisms (inclusion, composition, duality, emergence) between TSCG layers.",
      "rdfs:domain": "m2:M2_GenericConcepts",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:morphism_emergence",
      "@type": "owl:AnnotationProperty",
      "rdfs:label": "morphism emergence",
      "rdfs:comment": "Annotation string describing the emergence morphism operator (⇒) used in category-theoretic formalism of the TSCG M2 layer. Example: '⇒ (e.g., multiple ⇒ emergent)'.",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:eagleView",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "eagle view",
      "rdfs:comment": "Associates a GenericConcept with its Eagle Eye (Territory-Space) measurement characterization. Value is a structured object containing: basis (always 'ASFID'), formula (ASFID directional formula), role, and status ('IMMUTABLE'). Eagle Eye perspective uses ASFID dimensions to measure observable phenomena.",
      "rdfs:domain": "m2:GenericConcept",
      "owl:functionalProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:sphinxView",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "sphinx view",
      "rdfs:comment": "Associates a GenericConcept with its Sphinx Eye (Map-Space) interpretation characterization. Value is a structured object containing a primary formula (REVOI basis, PROPOSITION status) and a fallback formula (ASFID basis, GUARANTEED). Sphinx Eye perspective uses REVOI dimensions to evaluate map quality.",
      "rdfs:domain": "m2:GenericConcept",
      "owl:functionalProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:dualCounterpart",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "dual counterpart",
      "rdfs:comment": "Links two GenericConcepts that are structural duals of each other: they share a common parent genericConcept but differ in their operational polarity. Distinguished from m2:GenericConceptPair: dualCounterpart links two DIFFERENT top-level GenericConcepts (e.g. LALI ↔ ButterflyEffect), whereas a GenericConceptPair encapsulates both poles within a single GenericConcept.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "owl:symmetricProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:poleMapping",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "pole mapping",
      "rdfs:comment": "Defines the explicit semantic mapping of each pole in a GenericConceptPair (StructuralPair subtype). Value is an object with 'pole1' and 'pole2' entries, each specifying name, formula, cardinality and semantics. Used when m2:expression is insufficient (StructuralPairs: direction/cardinality reversals).",
      "rdfs:domain": "m2:GenericConceptPair",
      "owl:functionalProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:polaritySemantics",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "polarity semantics",
      "rdfs:comment": "Describes the semantic content of each pole in a dual or N-ary GenericConcept. Value is an object with named poles (pole1/pole2 or p=0/p=1), each containing name, description, formula and examples. Used for GenericConceptPairs and dual genericConcepts like LALI/ButterflyEffect.",
      "rdfs:domain": "m2:GenericConcept",
      "owl:functionalProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:componentOf",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "component of",
      "rdfs:comment": "States that a GenericConcept is a structural component of another GenericConcept. Inverse of m2:decomposedInto. Example: m2:Node componentOf m2:Network.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "owl:inverseOf": "m2:decomposedInto",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:decomposedInto",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "decomposed into",
      "rdfs:comment": "States that a GenericConcept can be analytically decomposed into another. Inverse of m2:componentOf. Example: m2:Network decomposedInto m2:Node.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "owl:inverseOf": "m2:componentOf",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:implementsProcess",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "implements process",
      "rdfs:comment": "Associates a structural GenericConcept (e.g. m2:Processor) with a process-type GenericConcept it instantiates or executes (e.g. m2:Process, m2:Workflow). Models the relationship between structural containers and the dynamic processes they carry out.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:triggeredBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "triggered by",
      "rdfs:comment": "States that a GenericConcept (event, process, or state transition) is initiated or caused by another GenericConcept. Captures causal and temporal precedence between systemic patterns. Inverse of m2:triggers.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "owl:inverseOf": "m2:triggers",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:triggers",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "triggers",
      "rdfs:comment": "States that a GenericConcept initiates or causes another GenericConcept (event, process, or state change). Inverse of m2:triggeredBy.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:GenericConcept",
      "owl:inverseOf": "m2:triggeredBy",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:hasGradient",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has gradient",
      "rdfs:comment": "Associates a GenericConcept with a Gradient genericConcept that drives its dynamics. A gradient is a scalar Flow dimension (F, 1D tensor product) representing the differential that causes directed movement or change. Example: m2:Transport hasGradient m2:Gradient.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:Gradient",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:expression",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "expression",
      "rdfs:comment": "Parametric formula string expressing the mathematical structure of a GenericConceptPair in terms of a scalar parameter p ∈ {0,1}. Examples: '(-1)^{p} (I ⊗ D)' for SignPairs, 'S ⊗ I ⊗ A^{p}' for DimensionPairs. Null or absent for StructuralPairs (use m2:poleMapping instead).",
      "rdfs:domain": "m2:GenericConceptPair",
      "rdfs:range": "xsd:string",
      "owl:functionalProperty": true,
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:hasComboComponent",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has combo component",
      "rdfs:comment": "Associates a GenericConceptCombo with one of its constituent parent GenericConcepts. Each component value is a structured object with '@id' (the parent GenericConcept) and 'm2:comboRole' (the semantic role of that component in the combo). The set of hasComboComponent values fully determines the combo's tensor formula via union of the parent dimension sets.",
      "rdfs:domain": "m2:GenericConceptCombo",
      "rdfs:range": "m2:GenericConcept",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:comboRole",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "combo role",
      "rdfs:comment": "Describes the semantic role of a GenericConcept within a GenericConceptCombo. Used inside m2:hasComboComponent structured objects. Examples: 'core_mechanism', 'medium', 'material', 'constraint', 'trigger', 'context', 'amplifier', 'regulator'.",
      "rdfs:range": "xsd:string",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:characterizedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "characterized by",
      "rdfs:comment": "Associates a M1 KnowledgeFieldConcept with the M2 GenericConcept(s) that characterize its systemic structure. Replaces the heterogeneous m2Basis fields (m1:biology:m2Basis, m1:M2_basis, m1core:m2Basis, m1:chemistry:instantiatesGenericConcept) across M1 files with a single normalized ObjectProperty. Semantics: 'this M1 concept EXHIBITS the pattern of / is characterized by this M2 GenericConcept'. Distinct from rdfs:subClassOf (IS-A) — a ChemicalReaction is not IS-A Process in the strict OWL sense across all inferred properties, but IS characterized-by m2:Process.",
      "rdfs:domain": "owl:Class",
      "rdfs:range": "m2:GenericConcept",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:KnowledgeFieldConceptNote",
      "@type": "owl:AnnotationProperty",
      "rdfs:label": "KnowledgeField Concept Note",
      "rdfs:comment": "Annotation documenting that KnowledgeFieldConcept, KnowledgeField, and KnowledgeFieldGenericCombo are defined in M1 (M1_CoreConcepts.jsonld), not in M2. M2 is restricted to universally transdisciplinary GenericConcepts. M1 KnowledgeFieldConcepts are owl:Class nodes with rdfs:subClassOf m2:GenericConcept (direct, no intermediate class) and m2:characterizedBy pointing to their M2 basis GenericConcepts.",
      "m2:m1Location": "M1_CoreConcepts.jsonld",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:ConceptContract",
      "@type": "owl:Class",
      "rdfs:subClassOf": "owl:Thing",
      "rdfs:label": "Concept Contract",
      "rdfs:comment": "Abstract class defining a behavioral contract that a GenericConcept can implement. Analogous to interfaces in object-oriented programming: a ConceptContract specifies a capability or behavioral obligation without prescribing implementation. GenericConcepts implement contracts via multiple rdfs:subClassOf (mixin pattern), e.g. m2:Event rdfs:subClassOf [m2:GenericConcept, m2:Triggerable]. The m2:implements AnnotationProperty documents the intent explicitly. ConceptContracts are orthogonal to GenericConceptFamilies: a contract cuts across multiple families (Dynamic, Structural, Regulatory...) to group concepts by shared behavioral capability rather than structural similarity.",
      "m2:designNote": "ConceptContracts are NOT GenericConcepts — they have no tensor formula. They are purely behavioral specifications. A GenericConcept may implement 0..N ConceptContracts. Current contracts: Triggerable, Observable, Composable, Stateful.",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:implements",
      "@type": "owl:AnnotationProperty",
      "rdfs:label": "implements",
      "rdfs:comment": "Documents that a GenericConcept implements a ConceptContract. Complementary to the rdfs:subClassOf mixin — provides explicit, human-readable declaration of intent. Example: m2:Event m2:implements m2:Triggerable. The structural inference (IS-A Triggerable) is carried by rdfs:subClassOf; this annotation carries the semantic intent.",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:ConceptContract",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Triggerable",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:ConceptContract",
      "rdfs:label": "Triggerable",
      "rdfs:comment": "ConceptContract: the implementing GenericConcept can be initiated by an external Trigger (m2:Trigger) when a Threshold (m2:Threshold) condition is met. Implies: (1) an idle/waiting state before initiation, (2) a transition to active state upon trigger reception, (3) a defined execution or unfolding following initiation. Implementors: Event (discrete triggered occurrence), Action (atomic triggered operation), Process (triggered sequence of state changes), Cascade (triggered multi-stage propagation), Transformation (triggered state conversion).",
      "m2:contractCapabilities": [
        "m2:triggeredBy — receives trigger stimulus",
        "m2:triggers — can in turn trigger other Triggerables",
        "Threshold condition — specifies when triggering occurs"
      ],
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Observable",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:ConceptContract",
      "rdfs:label": "Observable",
      "rdfs:comment": "ConceptContract: the implementing GenericConcept can be measured, detected or recorded by an Observer (m2:Observer) in the Territory (Eagle Eye / ASFID). Implies: (1) produces a signal or measurable signature, (2) accessible to an Observer without modifying its essential nature, (3) representable in the Map (Sphinx Eye / REVOI). Directly linked to the ASFID Information (I) and Attractor (A) dimensions. Implementors: State (measurable configuration), Trajectory (observable path), Behavior (observable pattern), Gradient (measurable differential), Observer (observes itself as meta-observable).",
      "m2:contractCapabilities": [
        "Produces measurable signal accessible to m2:Observer",
        "Has Representability (R in REVOI) — can be encoded in a Map",
        "Has Observability (O in REVOI) — degree of accessibility to Observer"
      ],
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Composable",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:ConceptContract",
      "rdfs:label": "Composable",
      "rdfs:comment": "ConceptContract: the implementing GenericConcept can serve as a structural building block in a larger assembly (m2:Composition, m2:System, m2:Network). Implies: (1) has a defined interface boundary (Structure S), (2) carries identity-preserving information (Information I), (3) can be connected to other Composables via m2:Link or m2:Relation. Implementors: Component (structural part), Node (graph vertex), Step (sequential unit in Behavior/Workflow).",
      "m2:contractCapabilities": [
        "Structural boundary — identifiable as a distinct unit (S dimension)",
        "Connectable — can be linked to other Composables",
        "Part-whole — can participate in m2:componentOf / m2:decomposedInto relations"
      ],
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Stateful",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:ConceptContract",
      "rdfs:label": "Stateful",
      "rdfs:comment": "ConceptContract: the implementing GenericConcept maintains a persistent internal state that evolves over time and influences future behavior. Implies: (1) has an internal State (m2:State) that persists between interactions, (2) state transitions are governed by Dynamics (D) and Attractors (A), (3) current state depends on history (memory effect). Implementors: State (IS the state — self-referential), Memory (encodes past state), Storage (persists accumulated state), Homeostasis (maintains target state via regulation).",
      "m2:contractCapabilities": [
        "Persistent internal state — survives between interactions",
        "State history — current state influenced by past transitions",
        "State transitions — governed by Dynamics (D) and Attractor (A)"
      ],
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Resource",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Resource",
      "rdfs:comment": "A quantifiable entity available to, consumed by, or produced by a system. Characterised by three coupled dimensions: Flow (F) — the resource moves or circulates through the system; Information (I) — it carries encoded state or content (energy level, chemical concentration, data payload); Representability (R, REVOI) — it can be described, measured and modelled. Transdisciplinary instances: nutrients/waste (Biology), electrical power (Electronics), raw materials (Engineering), memory/CPU cycles (Computing), capital (Economics).",
      "m2:hasFamily": "m2:Ontological",
      "m2:hasTensorFormula": "F ⊗ I ⊗ R",
      "m2:hasTensorFormulaTeX": "F \\otimes I \\otimes R",
      "m2:hasTensorFormulaASCII": "F (x) I (x) R",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information"
      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "F → I",
        "role": "Measure observable resource in Territory — quantifiable flow of encoded content",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → V",
          "role": "Evaluate map quality — is the resource representable and verifiable?",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasExample": [
        "Nutrients (Biology) — flow of chemical energy carriers with encoded molecular info",
        "Electrical power (Electronics) — flow of charge with encoded voltage/current state",
        "Memory allocation (Computing) — flow of addressable storage with encoded data",
        "Capital (Economics) — flow of value with encoded purchasing power"
      ],
      "m2:distinctionFromRelated": {
        "vs_Flow": "Flow (m3:eagle_eye:Flow) is the M3 dimension — the bare fact of movement. Resource is an M2 GenericConcept — a specific ENTITY that moves and carries information. Flow answers 'is there movement?'; Resource answers 'what moves?'.",
        "vs_Substrate": "Substrate (S ⊗ F) is the passive medium through which something passes. Resource is what IS being passed — the active content.",
        "vs_Storage": "Storage (A ⊗ F ⊗ I) captures accumulated resource. Resource is the entity itself, Storage is one of its possible states."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Biology: nutrients, oxygen, hormones — all flow (F) with molecular information (I) and are representable via concentration measurements (R)",
          "Electronics: power, signal — flow of charge (F) with amplitude/frequency encoding (I), measurable via instruments (R)",
          "Computing: memory, bandwidth, CPU cycles — resource flows (F) with data payloads (I), monitored via system calls (R)",
          "Engineering: fuel, coolant, raw materials — mass flow (F) with thermal/chemical state (I), quantifiable via sensors (R)",
          "Economics: capital, labour, commodities — value flow (F) with price/quantity encoding (I), representable via financial models (R)"
        ]
      },
      "m3:semanticSignature": "quantifiable_entity + flow_carrier + information_bearing",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m2:Interoperability",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Interoperability",
      "rdfs:comment": "The structural capacity of a system to exchange, process and use information with other systems according to shared protocols or standards, while remaining evolvable. Combines: Structure (S) — the interface architecture; Information (I) — the format and encoding of exchanged content; Flow (F) — the actual exchange protocol; Verifiability (V, REVOI) — testability of interface contracts; Evolvability (E, REVOI) — adaptability to new formats and standards. Note: distinct from the REVOI dimension I (Interoperability as a map-quality axis) — this GenericConcept models the observable STRUCTURAL PATTERN of interoperation, whereas REVOI-I measures the degree of interoperability of a conceptual model.",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S ⊗ I ⊗ F ⊗ V ⊗ E",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes F \\otimes V \\otimes E",
      "m2:hasTensorFormulaASCII": "S (x) I (x) F (x) V (x) E",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S → I → F",
        "role": "Measure observable interface structure — how information flows between systems",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "V → E",
          "role": "Evaluate map quality — are interface contracts verifiable and evolvable?",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasExample": [
        "USB protocol (Electronics) — structural interface, encoded data format, flow standard",
        "REST API (Computing) — resource structure, JSON/XML encoding, HTTP flow protocol",
        "HL7 FHIR (Medicine) — clinical data structure, coding systems, exchange format",
        "Synaptic interface (Biology) — receptor structure, neurotransmitter encoding, ion flow"
      ],
      "m2:distinctionFromRelated": {
        "vs_REVOI_I": "REVOI dimension I = a measurement axis for MAP quality (how interoperable is this model?). m2:Interoperability = a TERRITORY pattern (observable structural capacity of a real system to interoperate).",
        "vs_Link": "Link (S ⊗ I ⊗ F ⊗ V) captures the existence of a connection. Interoperability captures the CAPACITY and STANDARDS governing how that connection operates across heterogeneous systems.",
        "vs_Mediator": "Mediator (S ⊗ I ⊗ F ⊗ O) enables interaction between parties. Interoperability is a property of the interface itself, not of a third-party intermediary."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Computing: API standards, data formats, communication protocols",
          "Electronics: bus protocols (USB, I2C, SPI), signal encoding standards",
          "Medicine: HL7 FHIR, DICOM — clinical data interoperability",
          "Biology: receptor-ligand compatibility, synaptic transmission standards",
          "Engineering: mechanical interfaces, ISO tolerancing standards"
        ]
      },
      "m3:semanticSignature": "interface_structure + information_exchange + protocol_flow + evolvable_contract",
      "dcterms:created": "2026-02-24",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
