      "m2:hasAttribute": {
        "topology": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Structural pattern of network connectivity (graph topology)",
          "m2:possibleValues": [
            {
              "value": "Scale-free",
              "alternative_names": [
                "Power-law",
                "Preferential attachment"
              ],
              "description": "Degree distribution follows power law P(k) ~ k^(-γ), hubs exist",
              "formula": "P(k) = Ck^(-γ), typically γ ∈ [2, 3]",
              "examples": [
                "Internet (router connectivity)",
                "World Wide Web (hyperlinks)",
                "Protein interaction networks",
                "Social networks (Twitter, Facebook follows)",
                "Citation networks (papers citing papers)",
                "Metabolic networks"
              ],
              "characteristics": "Few highly connected hubs, many low-degree nodes, no characteristic scale",
              "formation": "Preferential attachment (Barabási-Albert model): 'rich get richer'",
              "robustness": "Robust to random failures, vulnerable to targeted hub attacks",
              "clustering": "Moderate clustering coefficient",
              "diameter": "Small (logarithmic scaling)",
              "degree_distribution": "Heavy-tailed (power law, not Poisson)"
            },
            {
              "value": "Small-world",
              "alternative_names": [
                "Watts-Strogatz"
              ],
              "description": "High clustering + short path length (six degrees of separation)",
              "formula": "L ~ log(N) (small characteristic path length), C >> C_random (high clustering)",
              "examples": [
