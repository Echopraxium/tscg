    {
      "@id": "m2:Processor",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Processor",
      "rdfs:comment": "Entity that transforms a flow (F) of information or energy according to a defined internal structure (S), producing a specified informational output (I), unfolding temporally (D). The most general transformation agent — Transducer and Dissipation are specializations. Processor is both entity (a system component) and morphism (a transformation operator) due to F in its tensor.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "S ⊗ I ⊗ F ⊗ D",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes F \\otimes D",
      "m2:hasTensorFormulaASCII": "S (x) I (x) F (x) D",
      "m2:hasDominantM3": [
