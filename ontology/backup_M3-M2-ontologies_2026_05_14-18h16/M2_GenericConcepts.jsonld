    {
      "@id": "m2:Dissipation",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Dissipation",
      "rdfs:comment": "Degrading Transducer that channels an active flow (F_active) toward a lower-energy state — the physical mechanism of energy degradation. Dissipation is the PRODUCER of Entropy (F⊗I⊗D), not Entropy itself. FEYNMAN NOTE: Dissipation's governing equations are time-reversible; irreversibility emerges only through the Entropy it generates, not from Dissipation itself. Dissipation is the morphism F_active → F_degraded; Entropy is its cumulative irreversibility measure.",
      "m2:hasFamily": "m2:Energetic",
      "rdfs:subClassOf": "m2:Transducer",
      "m2:ontologicalNature": "entity_and_morphism",
      "m2:morphicRole": {
        "description": "Dissipation as morphism: channels F_active → Entropy production",
        "source": "F_active (available exergy)",
        "target": "m2:Entropy",
        "irreversibility": "NOT intrinsic — equations are time-reversible (Feynman)",
        "irreversibilitySource": "Emerges from produced Entropy (F⊗I⊗D)"
      },
      "m2:produces": {
        "@id": "m2:Entropy",
        "relation": "Dissipation is the generative mechanism of Entropy",
        "formula": "Dissipation(F⊗D) →generates→ Entropy(F⊗I⊗D)",
        "note": "I dimension emerges from accumulation of F⊗D — not present in Dissipation itself"
      },
      "m2:hasTensorFormula": "F ⊗ D",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Dynamics"
      ],
      "m2:hasEpistemicGap": 0.15,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Heat loss in engines",
        "Friction"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "F → D",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "F \\otimes D",
      "m2:hasTensorFormulaASCII": "F (x) D",
      "m2:distinctFrom": {
        "m2:Entropy": "Entropy (F⊗I⊗D) is the MEASURE of disorder produced; Dissipation (F⊗D) is the MECHANISM of production. Dissipation equations are time-reversible; Entropy encodes irreversibility (Feynman).",
        "m2:Process": "Process (D⊗F) is a generic temporal sequence; Dissipation specifically implies energy degradation toward lower states.",
        "m2:Transducer": "Dissipation is a subclass of Transducer — the degrading specialization (F_active → F_degraded). General Transducer converts between flux types without implying energy loss."
      },
      "m3:semanticSignature": "energy_flow + directed_degradation + entropy_generator"
    },
    {
      "@id": "m2:Regulation",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Regulation",
      "rdfs:comment": "Control mechanisms maintaining system parameters within acceptable ranges. Feedback polarity (Negative/Positive/Mixed) specified via feedback_polarity attribute.",
      "m2:hasFamily": "m2:Regulatory",
      "m2:hasTensorFormula": "A ⊗ S ⊗ F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.35,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Hormonal feedback loops",
        "Traffic light systems"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "A → S → F",
        "role": "Measure territory perspective",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → V → E",
          "role": "Evaluate map perspective",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasTensorFormulaTeX": "A \\otimes S \\otimes F",
      "m2:hasTensorFormulaASCII": "A (x) S (x) F",
      "m2:hasAttribute": {
        "feedback_polarity": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Polarity of feedback loop: negative (stabilizing), positive (amplifying), or mixed",
          "m2:possibleValues": [
            {
              "value": "Negative",
              "description": "Stabilizing feedback, reduces deviation from setpoint",
              "formula": "Error reduction: e(t+1) < e(t)",
              "examples": [
                "Thermostat (temperature control)",
                "RAAS homeostasis (blood pressure regulation)",
                "Predator-prey regulation",
                "PID controller",
                "Enzyme feedback inhibition"
              ],
              "characteristics": "Error-correcting, stabilizing, convergence to setpoint, damping"
            },
            {
              "value": "Positive",
              "description": "Reinforcing feedback, amplifies deviation",
              "formula": "Error amplification: e(t+1) > e(t)",
              "examples": [
                "Nuclear chain reaction",
                "Viral/epidemic spread",
                "Financial bubble",
                "Resonance (mechanical/acoustic)",
                "Ice-albedo feedback (climate)"
              ],
              "characteristics": "Self-amplifying, destabilizing, divergence from initial state, runaway"
            },
            {
              "value": "Mixed",
              "description": "Combination of positive and negative feedback (context-dependent)",
              "formula": "Polarity switches based on state/threshold",
              "examples": [
                "Hysteresis loop (bistability)",
                "Schmitt trigger",
                "Gene regulatory network (toggle switch)",
                "Action potential (Na⁺/K⁺ dynamics)"
              ],
              "characteristics": "Context-dependent switching, bistability, memory effect"
            }
          ],
          "m2:default": "Negative",
          "m2:usageGuidelines": "Most homeostatic and control systems use Negative feedback. Use Positive for growth/cascade phenomena. Use Mixed for bistable or switching systems."
        },
        "control_type": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Control law type: how error is processed to generate corrective action",
          "m2:possibleValues": [
            {
              "value": "Proportional",
              "abbreviation": "P",
              "description": "Output proportional to current error",
              "formula": "u(t) = Kₚ·e(t)",
              "examples": [
                "Simple thermostat (on when cold, off when hot)",
                "Spring restoring force (F = -kx)",
                "Basic voltage regulator",
                "Manual steering correction"
              ],
              "characteristics": "Simple, fast response, steady-state error possible",
              "pros": "Simple implementation, stable",
              "cons": "Cannot eliminate steady-state error for constant disturbances"
            },
            {
              "value": "Integral",
              "abbreviation": "I",
              "description": "Output proportional to accumulated error over time",
              "formula": "u(t) = Kᵢ·∫e(τ)dτ",
              "examples": [
                "Water tank level control (integral of flow error)",
                "Position control with zero steady-state error"
              ],
              "characteristics": "Eliminates steady-state error, slower response, can cause overshoot",
              "pros": "Eliminates steady-state error",
              "cons": "Can cause integral windup, oscillations"
            },
            {
              "value": "Derivative",
              "abbreviation": "D",
              "description": "Output proportional to rate of change of error",
              "formula": "u(t) = Kd·de/dt",
              "examples": [
                "Damper responding to velocity",
                "Anticipatory braking (responds to rate of approach)"
              ],
              "characteristics": "Improves transient response, reduces overshoot, sensitive to noise",
              "pros": "Anticipatory, reduces overshoot",
              "cons": "Amplifies measurement noise, rarely used alone"
            },
            {
              "value": "PI",
              "abbreviation": "PI",
              "description": "Proportional + Integral control",
              "formula": "u(t) = Kₚ·e(t) + Kᵢ·∫e(τ)dτ",
              "examples": [
                "Temperature control (most thermostats)",
                "Speed control (motor drives)"
              ],
              "characteristics": "Good steady-state accuracy, moderate transient response",
              "pros": "Zero steady-state error, good practical performance",
              "cons": "Can oscillate if not tuned properly"
            },
            {
              "value": "PD",
              "abbreviation": "PD",
              "description": "Proportional + Derivative control",
              "formula": "u(t) = Kₚ·e(t) + Kd·de/dt",
              "examples": [
                "Position control with damping",
                "Antenna tracking"
              ],
              "characteristics": "Fast response, good damping, steady-state error",
              "pros": "Fast, well-damped",
              "cons": "Steady-state error, noise sensitivity"
            },
            {
              "value": "PID",
              "abbreviation": "PID",
              "description": "Proportional + Integral + Derivative control (full 3-term)",
              "formula": "u(t) = Kₚ·e(t) + Kᵢ·∫e(τ)dτ + Kd·de/dt",
              "examples": [
                "Industrial process control (>95% of control loops)",
                "Cruise control (automotive)",
                "Flight control systems",
                "Chemical reactor temperature"
              ],
              "characteristics": "Excellent performance when properly tuned, industry standard",
              "pros": "Zero steady-state error, fast response, good damping",
              "cons": "Complex tuning, derivative noise sensitivity"
            },
            {
              "value": "Bang-bang",
              "abbreviation": "On-Off",
              "description": "Binary on/off control (discontinuous)",
              "formula": "u(t) = {U_max if e>0; U_min if e<0}",
              "examples": [
                "Refrigerator compressor (on when warm, off when cold)",
                "Simple home heating (furnace on/off)",
                "Relay control"
              ],
              "characteristics": "Simplest control, causes oscillation (limit cycle)",
              "pros": "Extremely simple, robust, cheap",
              "cons": "Oscillatory, chattering, wear on actuators"
            },
            {
              "value": "Adaptive",
              "description": "Controller parameters adjust based on system behavior",
              "examples": [
                "Model reference adaptive control (MRAC)",
                "Self-tuning regulator",
                "Gain scheduling"
              ],
              "characteristics": "Handles time-varying or uncertain systems",
              "pros": "Adapts to changing conditions",
              "cons": "Complex, stability proof required"
            },
            {
              "value": "Model Predictive",
              "abbreviation": "MPC",
              "description": "Optimizes future trajectory using system model",
              "examples": [
                "Chemical plant optimization",
                "Autonomous vehicle path planning"
              ],
              "characteristics": "Handles constraints, multivariable, computationally intensive",
              "pros": "Optimal, handles constraints",
              "cons": "Requires accurate model, computationally expensive"
            }
          ],
          "m2:default": "Proportional",
          "m2:usageGuidelines": "PID is the industrial standard for most applications. Use Bang-bang for simple on/off systems (HVAC). Use Adaptive/MPC for complex or time-varying systems. RAAS uses biological equivalent of negative feedback (closest to Proportional)."
        }
      },
      "m3:semanticSignature": "attractor_control + structural_constraints + flow_modulation"
    },
    {
      "@id": "m2:Memory",
