    },
    {
      "@id": "m2:Trade-off",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Trade-off",
      "rdfs:comment": "Deliberate exchange where improving one desirable property necessarily degrades another due to inherent constraints. A conscious decision-making concept in model/map space where observer accepts losses in one dimension to gain in another. Fundamental to optimization under constraints.",
      "m2:hasFamily": "m2:Regulatory",
      "m2:hasOntologicalNature": "ModelSpace",
      "m2:hasTensorFormula": "A ⊗ I ⊗ F",
      "m2:hasTensorFormulaTeX": "A \\otimes I \\otimes F",
      "m2:hasTensorFormulaASCII": "A (x) I (x) F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.3,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Photography: Shallow DoF (artistic blur) ⊗ Deep DoF (all sharp) via aperture",
        "Machine Learning: Bias → Variance (underfitting → overfitting)",
        "Engineering: Speed → Precision (fast but rough → slow but accurate)",
        "Project Management: Cost → Quality → Time (iron triangle)",
        "Economics: Inflation → Unemployment (Phillips curve)",
        "Computer Science: Time complexity → Space complexity",
        "Biology: r-strategy → K-strategy (many offspring vs few cared-for)",
        "Reinforcement Learning: Exploration → Exploitation"
      ],
      "m2:perspective": "map",
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → V → E",
          "role": "Evaluate map perspective on trade-offs",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Balance": "Balance is EQUILIBRIUM STATE (observable); Trade-off is DECISION CONCEPT (interpretative)",
        "vs_Constraint": "Constraint is HARD LIMIT (cannot violate); Trade-off is SOFT CHOICE (can choose different points on frontier)",
        "vs_Synergy": "Synergy is POSITIVE (1+1>2); Trade-off is NEGATIVE (improve A → degrade B)"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Photography (DoF, Grain, Motion Blur trade-offs)",
          "Machine Learning (Bias-Variance, Precision-Recall)",
          "Engineering (Speed-Accuracy, Cost-Quality)",
          "Economics (Inflation-Unemployment, Efficiency-Equity)",
          "Project Management (Cost-Quality-Time)",
          "Computer Science (Time-Space complexity)",
          "Biology (r-K selection)",
          "Reinforcement Learning (Exploration-Exploitation)"
        ],
        "count": 8,
        "discoveredFrom": "Exposure Triangle poclet - photographer's decision-making analysis"
      },
      "m2:discoveryContext": "Identified during analysis of Exposure Triangle poclet as fundamental Map-space genericConcept capturing photographer's decision-making under constraints",
      "dcterms:created": "2026-01-20",
      "dcterms:modified": "2026-02-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:changeLog": {
        "v1": {
          "date": "2026-01-20",
          "formula": "A ⊗ I ⊗ F ⊗ A ⊗ A",
          "issue": "Repetition of A has no tensor semantics — A cannot encode multiple competing attractors by repetition"
        },
        "v2": {
          "date": "2026-02-18",
          "formula": "A ⊗ I ⊗ F",
          "rationale": "A=target objective, I=knowledge of options and costs, F=resource allocation flux. Removes redundant A repetitions while preserving semantic intent."
        }
      },
      "m3:semanticSignature": "attractor_optimization + information_constraint + flow_cost"
    },
    {
      "@id": "m2:Polarity",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Polarity (N-ary)",
      "rdfs:comment": "Configuration of N distinct, mutually exclusive value poles or orientational axes organized in structured opposition or complementarity. Generalizes binary opposition to N-dimensional value spaces. N {1, 2, 3, 4, 5, ...} where N=1 (neutral/monopolar), N=2 (dual/bipolar), N3 (multipolar).",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S ⊗ I ⊗ A",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor"
      ],
      "m2:hasEpistemicGap": 0.3,
      "m2:hasPolarity": "nary",
      "m2:naryParameter": {
        "N": "variable",
        "range": "[1, inf)",
        "description": "Number of distinct poles in the system",
        "commonValues": {
          "N=1": "Neutral/Monopolar - Single unique state (e.g., Identity)",
          "N=2": "Dual/Bipolar - Binary opposition (e.g., Hot/Cold, Good/Evil, +/-)",
          "N=3": "Ternary/Tripolar - Triangular system (e.g., Rock-Paper-Scissors, RGB primary)",
          "N=4": "Quaternary/Quadripolar - Four-pole system (e.g., Political compass, Cardinal directions)",
          "N=5": "Pentagonal/Pentapolar - Five-pole system (e.g., Magic Color Wheel, Wu Xing)",
          "N>5": "Multipolar - Higher-order systems (e.g., Enneagram N=9, Chakras N=7)"
        }
      },
      "m2:hasExample": [
        "Magic Color Wheel (N=5: White-Blue-Black-Red-Green in pentagonal structure)",
        "Political Compass (N=4: Authoritarian-Libertarian Left-Right)",
        "Chinese Wu Xing (N=5: Wood-Fire-Earth-Metal-Water with generation/destruction cycles)",
        "Electromagnetic polarity (N=2: Positive-Negative)",
        "Enneagram personality types (N=9)",
        "Moral Foundations Theory (N=6: Care, Fairness, Loyalty, Authority, Sanctity, Liberty)",
        "Chakra system (N=7: Root through Crown)",
        "Compass directions (N=4: N-E-S-W, or N=8 with intercardinals)",
        "pH scale (N=3 effective: Acidic-Neutral-Basic)",
        "Musical modes (N=7: Ionian, Dorian, Phrygian, Lydian, Mixolydian, Aeolian, Locrian)"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "SIA",
        "role": "Measure territory perspective (observable oppositions/orientations)",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "OVE",
          "role": "Evaluate map perspective (conceptual distinction quality)",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:structuralProperties": {
        "topology": "Can be linear (N=2), triangular (N=3), square (N=4), pentagonal (N=5), or general N-gon",
        "relationships": "Allied (adjacent poles) vs Enemy (opposite poles) structure common for N3",
        "symmetry": "Often exhibits Crotational symmetry",
        "dimensionality": "N poles can span N-1 dimensional space (e.g., 3 colors span 2D chromaticity plane)"
      },
      "m2:distinctionFromRelated": {
        "vs_Opposition": "Opposition is BINARY specific case (N=2); Polarity is GENERAL (any N1)",
        "vs_Spectrum": "Spectrum is CONTINUOUS; Polarity is DISCRETE with finite N poles",
        "vs_Dimension": "Dimension is CONTINUOUS axis; Polarity is DISCRETE pole structure",
        "vs_Duality": "Duality is N=2 special case; Polarity generalizes to N2"
      },
      "m2:formalDefinition": {
        "poleSet": "P = {p₁, p₂, ..., pₙ} - Set of N distinct poles",
        "exclusivityConstraint": "∀j: pⱼ ⊗ |pⱼ⟩ = δⱼₖ (mutual exclusivity)",
        "completenessConstraint": "∑ⱼ |pⱼ⟩⟨pⱼ| = I (spans the relevant domain)",
        "structureGraph": "G = (P, E) where E encodes allied/enemy relationships",
        "binaryCase": "N=2 reduces to classical dual polarity"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Game Theory (Magic: The Gathering color system)",
          "Political Science (Political compass, Nolan chart)",
          "Chinese Philosophy (Wu Xing five-element theory)",
          "Physics (Electromagnetic poles, Spin states)",
          "Psychology (Personality typologies: Enneagram, Big Five)",
          "Ethics (Moral Foundations Theory)",
          "Spirituality (Chakra systems)",
          "Geography (Cardinal/intercardinal directions)",
          "Chemistry (pH classification)",
          "Music Theory (Modal systems)"
        ],
        "count": 10,
        "discoveredFrom": "Magic Color Wheel poclet analysis - revealed limitation of binary polarity restriction"
      },
      "m2:historicalNote": {
        "v1-v12": "M2 restricted polarity to neutral (N=1) or dual (N=2), explicitly rejecting N-ary",
        "v13": "Paradigm shift: N-ary polarity adopted based on empirical evidence from multiple domains",
        "rationale": "Real-world value systems (ethical, political, aesthetic) are naturally N-ary (N3). Binary restriction was theoretical overcaution, not empirical necessity.",
        "validation": "Switch and Mode genericConcepts were already implicitly N-ary (N-ary states/modes). Polarity genericConcept makes this explicit."
      },
      "m2:philosophicalImplication": "Most fundamental conceptual frameworks are N-ary (N>2), not binary. Binary thinking (dualism) is common but not universal. Pentagonal structures (N=5) appear repeatedly across cultures (Magic colors, Wu Xing, Platonic solids minus one). Suggests deep cognitive/cultural patterns in how humans organize complexity.",
      "dcterms:created": "2026-01-22",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Identified during Magic: The Gathering Color Wheel poclet analysis. Revealed that binary polarity restriction was limiting framework's ability to model real philosophical/value systems. Validated across 10 domains with N ranging from 2 to 9.",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes A",
      "m2:hasTensorFormulaASCII": "S (x) I (x) A",
      "m3:semanticSignature": "structural_opposition + informational_contrast + attractor_poles(N-ary)"
    },
    {
      "@id": "m2:Imbrication",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Imbrication (Nesting)",
      "rdfs:comment": "Structural relation where a system contains subsystems that reproduce the parent system's structure. Principle of self-similarity across hierarchical levels. Fundamental to VSM where each operational unit is itself a complete viable system.",
      "m2:hasFamily": "m2:Ontological",
      "m2:hasTensorFormula": "S → S",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Structure"
      ],
      "m2:hasEpistemicGap": 0.3,
      "m2:hasPolarity": "dual",
      "m2:polarityDescription": {
        "territory": "Observable finite nesting in physical systems (limited by material constraints)",
        "map": "Conceptual potentially infinite nesting in formal models (limited by logical constraints)"
      },
      "m2:hasExample": [
        "VSM: Each S1 operational unit is a complete viable system with its own S1-S5 structure",
        "Biology: Bronchial tree (airways branching ~23 levels deep)",
        "Mathematics: Mandelbrot set (infinite fractal self-similarity)",
        "Computer Science: Recursive function calls (limited by stack depth)",
        "Linguistics: Nested clauses in Chomsky grammar",
        "Geography: Nested watersheds (river basin → sub-basin → stream)",
        "Architecture: Matryoshka dolls (physical nesting)",
        "Organizations: Departments containing sub-departments with similar structure"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S → S",
        "role": "Measure observable self-similar nesting in Territory",
        "status": "PRIMARY",
        "constraint": "Finite depth (n_max < ∞) due to physical limits"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → I → V",
          "role": "Construct and verify nested patterns in Map",
          "status": "PROPOSITION (validation in progress)",
          "constraint": "Potentially infinite depth in formal systems"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Hierarchy": "Hierarchy = different levels with control relations; Imbrication = identical structure at each level",
        "vs_Modularity": "Modularity = decomposition into functionally different parts; Imbrication = parts are structural copies of whole",
        "vs_Composition": "Composition = assembly of heterogeneous components; Imbrication = embedding of homothetic components",
        "vs_Recursion": "Recursion is abstract principle; Imbrication is concrete structural realization"
      },
      "m2:mathematicalProperties": {
        "selfSimilarity": "∀n, structure(level_n) ≈ structure(level_0)",
        "depthConstraint_Territory": "n_max < ∞ (physically bounded)",
        "depthConstraint_Map": "n_max ≠ ∞ (logically bounded)",
        "scalingFactor": "Typically decreasing at each level (physical systems)"
      },
      "m2:vsmContext": {
        "coreArchitecturalPrinciple": "Every System 1 unit is itself a complete viable system",
        "recursiveProperty": "Each S1 contains its own implementation of S1-S5 functions",
        "relevance": "Enables organizational fractal structure with distributed autonomy"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Cybernetics (VSM recursive viability)",
          "Biology (Branching structures: trees, lungs, blood vessels)",
          "Mathematics (Fractals, recursive sets)",
          "Computer Science (Recursive algorithms, tree structures)",
          "Linguistics (Chomsky recursive grammar)",
          "Geography (Nested watersheds)",
          "Architecture (Nested spatial containment)",
          "Organizations (Fractal organizational structure)"
        ],
        "validatedDomains": 8,
        "transdisciplinaryStrength": "Strong - pattern appears across natural, formal, and social systems"
      },
      "dcterms:created": "2026-01-30",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Emerged from VSM analysis where recursive viability is fundamental architectural principle. Generalizes to any system exhibiting structural self-similarity across scales.",
      "m2:hasTensorFormulaTeX": "S \\otimes S",
      "m2:hasTensorFormulaASCII": "S (x) S",
      "m3:semanticSignature": "recursive_structural_nesting"
    },
    {
      "@id": "m2:Identity",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Identity",
      "rdfs:comment": "Persistent property that makes an entity distinguishable and self-restoring across transformations. An entity remains itself despite internal changes: its structure persists (S), its distinguishing information is maintained (I), and it returns to its characteristic state after perturbation (A). Identity is intrinsic it is not external recognition (vs Signature) nor a generic conserved quantity (vs Invariant), but the singular property binding persistence, uniqueness, and self-restoration into one coherent entity.",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S → I → A → V → E",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes A \\otimes V \\otimes E",
      "m2:hasTensorFormulaASCII": "S (x) I (x) A (x) V (x) E",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor",
        "m3:sphinx_eye:Verifiable",
        "m3:sphinx_eye:Evolvable"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "dual",
      "m2:shortName": "Identity",
      "m2:fullName": "Entity Identity (Persistence / Uniqueness)",
      "m2:polarityDescription": {
        "territory": "Observable persistent property of an entity that remains invariant despite internal transformations (e.g. genetic identity persisting through cell turnover, organizational mission persisting through personnel change)",
        "map": "Verified continuity of an entity across time, assessed for its capacity to evolve while remaining itself (e.g. confirming an organization is still the same entity after restructuring, evaluating how a species identity adapts under selection pressure)"
      },
      "m2:hasExample": [
        "Biology: Genetic identity DNA sequence defines organism identity despite continuous cell turnover and metabolic flux",
        "Chemistry: Molecular identity same molecule persists despite vibrational states and conformational changes",
        "Physics: Particle identity quantum topological properties preserved under interaction and transformation",
        "IT: Object identity UUID remains constant despite attribute mutations and state transitions",
        "Psychology: Self identity narrative continuity of 'me' across time, trauma, and developmental change",
        "Organization: Organizational identity mission, values, and legal continuity despite leadership and personnel turnover",
        "Mythology: Hero identity same character maintains coherence through ordeals, transformation, and return",
        "TRIZ: System identity conserved functional properties under inventive transformation (Principle of Conservation)",
        "Philosophy: Ship of Theseus the identity problem: what persists when all parts are replaced?"
      ],
      "m2:perspective": "hybrid",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S → I → A",
        "role": "Measure observable persistence of an entity in Territory",
        "status": "PRIMARY",
        "comment": "S = structure that persists (the unchanged thread); I = information that makes this entity unique among others; A = attractor toward which the entity returns after perturbation (self-restoration)"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "V → E → O",
          "role": "Evaluate identity continuity quality in Map",
          "status": "PROPOSITION (validation in progress)",
          "comment": "V = can we verify this is still the same entity after change? (Verifiability is the central Map question for Identity); E = can the identity evolve and adapt while remaining itself? (Evolvability captures identity under transformation); O = deduced from V (verification requires observability)"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Invariant": "Invariant (S → A) is a conserved property passive and generic (applies to all entities equally, e.g. conservation laws). Identity is a conserved property that IDENTIFIES a singular entity and is self-restoring. Identity adds I (uniqueness) and intrinsic scope.",
        "vs_Signature": "Signature (I → S) is external recognition how an entity is identified FROM OUTSIDE (fingerprint, spectral ID). Identity is intrinsic persistence how an entity remains ITSELF from the inside. Signature is a snapshot; Identity includes A (return-to-self after perturbation).",
        "vs_Pattern": "Pattern (S → It → A → R → Im) is a recurring motif reusable as template transdisciplinary by REPLICATION (many instances, same form). Identity is a singular persistence property transdisciplinary by SINGULARITY (one entity, across time). Same Eagle base (S → I → A) but divergent Map questions: Pattern asks 'can this be reused?' (R → Im), Identity asks 'can this be verified as continuous?' (V → E).",
        "vs_Homeostasis": "Homeostasis (A → S → F) is self-regulation maintaining a stable internal STATE. Identity is persistence of the entity ITSELF. An organism maintains homeostasis (body temperature) while its identity (genetic, organismal) is a separate, more fundamental property."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Biology (genetic identity across cell turnover)",
          "Chemistry (molecular identity under conformational change)",
          "Physics (particle identity under quantum transformation)",
          "IT (object identity across state mutations)",
          "Psychology (self-identity across developmental change)",
          "Organization (institutional identity across restructuring)",
          "Mythology (hero identity across narrative ordeals)",
          "TRIZ (system identity under inventive transformation)",
          "Philosophy (Ship of Theseus the identity problem)"
        ],
        "count": 9,
        "transdisciplinaryStrength": "Strong identity is a fundamental ontological property present in every domain where entities persist across time"
      },
      "dcterms:created": "2026-02-01",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Identified during M0_VSM (Viable System Model) validation. Cohesion concept required a genericConcept capturing 'shared organizational thread persisting despite S1 autonomy'. No existing M2 covered the combination of persistence (vs Invariant), uniqueness (vs Signature), and self-restoration (A). TRIZ validates Identity as a foundational principle (conserved property under transformation). Formalized as hybrid S → I → A → V → E to distinguish from Pattern (same Eagle base, divergent Map question).",
      "m3:semanticSignature": "persistent_distinguishing_signature + structural+informational+attractor+verifiable+evolvable"
    },
    {
