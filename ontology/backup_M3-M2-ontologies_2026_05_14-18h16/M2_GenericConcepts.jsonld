    {
      "@id": "m2:Representation",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Representation",
      "rdfs:comment": "Mapping between domains preserving structural relationships.",
      "m2:hasFamily": "m2:Informational",
      "m2:hasTensorFormula": "I ⊗ S",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Mathematical models",
        "Mental schemas",
        "Data structures"
      ],
      "m2:perspective": "map",
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "O → R → I",
          "role": "Evaluate map quality",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasTensorFormulaTeX": "I \\otimes S",
      "m2:hasTensorFormulaASCII": "I (x) S",
      "m3:semanticSignature": "information_structure + symbol_mapping + space_coverage_ratio",
      "m2:hasAttribute": {
        "spaceCoverage": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Continuous numeric",
          "m2:range": "[0.0, 1.0]",
          "m2:description": "Ratio of the symbolic/representational space actually covered by a grammar or alphabet over the theoretical target space. RSC = |space_covered| / |space_target|. RSC = 1.0 means the grammar is cognitively closed — every situation in the target domain has a representation. RSC < 1.0 reveals symbolic blind spots.",
          "m2:interpretations": {
            "1.0": "Generative Exhaustion — complete closure by construction (I Ching: 2⁶=64, DNA codons: 4³=64, Boolean NAND: all functions)",
            "0.8_to_0.99": "Near-complete — small blind spots, usually addressable by extension (Unicode 15.0: ~0.91, API phonetic: ~0.97)",
            "0.5_to_0.8": "Partial coverage — significant gaps, system useful but not universal in its domain (Elder Futhark runes: ~0.60)",
            "0.0_to_0.5": "Fragment — intentionally or structurally incomplete (ASCII vs Unicode: ~0.15)"
          },
          "m2:specialCase": {
            "value": 1.0,
            "name": "Generative Exhaustion",
            "definition": "Grammar produces exactly the complete target space: no gap, no redundancy. Completeness is structurally guaranteed, not empirically observed.",
            "signature": "finite_alphabet + deterministic_combination_rules + closed_target_space"
          },
          "m2:examples": [
            {
              "system": "I Ching hexagrams",
              "domain": "Symbolic divination",
              "spaceCoverage": 1.0,
              "rationale": "64 hexagrams = {Yin,Yang}⁶ = 2⁶ — bijection with all 6-bit binary strings, exhaustive by construction"
            },
            {
              "system": "DNA codons",
              "domain": "Molecular biology",
              "spaceCoverage": 1.0,
              "rationale": "64 codons = 4³ triplets of {A,T,G,C} — complete codon table, no triplet unassigned (including 3 stop codons)"
            },
            {
              "system": "12-tone chromatic scale (equal temperament)",
              "domain": "Music theory",
              "spaceCoverage": 1.0,
              "rationale": "12 semitones close the octave under cyclic transposition — all 12 keys reachable from any starting pitch"
            },
            {
              "system": "NAND gate (Boolean logic)",
              "domain": "Logic / Computer science",
              "spaceCoverage": 1.0,
              "rationale": "NAND is a functionally complete set — all Boolean functions expressible from NAND alone"
            },
            {
              "system": "International Phonetic Alphabet (IPA)",
              "domain": "Linguistics",
              "spaceCoverage": 0.97,
              "rationale": "~97% of attested human phonemes covered; rare clicks, tones, and marginal sounds remain outside standard IPA"
            },
            {
              "system": "Unicode 15.0",
              "domain": "Computer science / Writing systems",
              "spaceCoverage": 0.91,
              "rationale": "149,813 code points / ~165,000 estimated needed — archaeological scripts and rare variants not yet encoded"
            },
            {
              "system": "Tarot de Marseille (78 lames)",
              "domain": "Symbolic divination",
              "spaceCoverage": 0.88,
              "rationale": "Covers major archetypes but some situational nuances lack a direct card; interpretation must interpolate"
            },
            {
              "system": "Elder Futhark runes (24)",
              "domain": "Symbolic / Linguistic",
              "spaceCoverage": 0.6,
              "rationale": "24 runes cover Proto-Germanic phonemes but miss many phonemic distinctions of modern Germanic languages"
            },
            {
              "system": "ASCII (128 characters)",
              "domain": "Computer science",
              "spaceCoverage": 0.15,
              "rationale": "128 code points / ~800,000 Unicode — designed for English only, excludes virtually all non-Latin writing systems"
            }
          ],
          "m2:transdisciplinaryValidation": {
            "domains": [
              "Symbolic divination (I Ching, Tarot, Runes)",
              "Molecular biology (DNA codon table)",
              "Music theory (chromatic scale)",
              "Logic / Computer science (Boolean completeness, ASCII, Unicode)",
              "Linguistics (IPA phoneme coverage)"
            ],
            "validatedDomains": 5,
            "note": "RSC = 1.0 (Generative Exhaustion) appears independently in symbolic, biological, musical, and logical domains — strong transdisciplinary anchor"
          },
          "m2:architecturalNote": "RepresentationSpaceCoverage is a ValueSpace enrichment of m2:Representation (not a standalone M2 genericConcept). It quantifies the completeness dimension of the Map quality. Its special case RSC=1.0 (Generative Exhaustion) replaces the earlier M2 candidate of same name. The continuous range [0,1] subsumes GenerativeExhaustion as a limit case.",
          "m2:relatedAttributes": {
            "m2:Verifiability": "Verifiability concerns how a representation is validated; RSC concerns how much of the target space is covered",
            "m2:Scope": "Scope defines the boundary of applicability; RSC measures coverage density within that scope"
          }
        }
      }
    },
    {
      "@id": "m2:Language",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Language",
      "rdfs:comment": "Structured system for information exchange and meaning construction.",
      "m2:hasFamily": "m2:Informational",
