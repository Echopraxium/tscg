            "O": "Observability - Are stages visible? (nodes on schematic, intermediate states, traceable flow)"
          }
        },
        "notation": {
          "Ft": "Flow measured in Territory (ASFID - Eagle Eye)",
          "D": "Dynamics (ASFID - temporal evolution)",
          "It": "Information in Territory signal (ASFID - Eagle Eye)",
          "R": "Representability (REVOI - Sphinx Eye - can we encode in symbols?)",
          "O": "Observability (REVOI - Sphinx Eye - can we see stages in model?)"
        },
        "whyNotVEI": {
          "V_verifiability": "Verification compares Map⇒”Territory, not intrinsic to representation itself",
          "E_evolvability": "Useful but not essential - amplifiers can be fixed or adaptive",
          "I_interoperability": "Already captured in It (information in signal), not needed in Map"
        }
      },
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "Ft → D → It",
        "role": "Measure observable amplification/attenuation in Territory",
        "status": "PRIMARY",
        "examples": {
