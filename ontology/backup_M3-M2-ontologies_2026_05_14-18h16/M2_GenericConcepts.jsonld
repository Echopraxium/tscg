    },
    {
      "@id": "m2:Pattern",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Pattern (Recognition / Reuse)",
      "rdfs:comment": "Recurring structural motif identifiable across instances and reusable as a template. Exists as an observable regularity in Territory (Eagle Eye) and as a reusable archetype in Map (Sphinx Eye). The key discriminator vs related concepts is the combination of recurrence (vs Signature) and cross-domain reusability (vs Representation).",
      "m2:hasFamily": "m2:Informational",
      "m2:hasTensorFormula": "S → I → A",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "dual",
      "m2:shortName": "Pattern",
      "m2:fullName": "Pattern Recognition / Pattern Reuse",
      "m2:polarityDescription": {
        "territory": "Observable recurring regularity in a physical or natural system (e.g. repeated morphological motif, periodic behavioral sequence)",
        "map": "Identified structural archetype reusable as a template across domains (e.g. design pattern, structural motif in ontology)"
      },
      "m2:hasExample": [
        "Biology: Branching pattern (lungs, rivers, blood vessels, tree canopies) - observed regularity reusable as structural template",
        "Software Engineering: Design patterns (Observer, Strategy, Factory) - identified motifs reused across applications",
        "Architecture: Structural patterns (arch, vault, truss) - recurring forms applied across buildings and bridges",
        "Mathematics: Fibonacci sequence appearing in shell spirals, leaf arrangement, market fluctuations",
        "Music: Melodic motifs reused and transposed across movements of a symphony",
        "Mythology: Hero's journey pattern - recurring narrative structure identified and reusable as storytelling template",
        "Chemistry: Molecular recognition patterns (lock-and-key) - recurring binding motifs across biochemical systems",
        "Urban Planning: Grid pattern vs organic growth - recurring city layout motifs identifiable and replicable"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S → I → A",
        "role": "Measure observable recurring regularity in Territory",
        "status": "PRIMARY",
        "comment": "S = structural topology of the motif; I = informational content making it identifiable; A = attractor explaining recurrence (system returns to this configuration)"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "O → R → I",
          "role": "Evaluate reusable template quality in Map",
          "status": "PROPOSITION (validation in progress)",
          "comment": "O = pattern must be perceptible in the model; R = its semantics must be decodable; I = it must be reusable cross-domain (interoperability)"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Representation": "Representation (I → S) is a single static mapping between domains. Pattern is a recurring motif that repeats and is reusable as template.",
        "vs_Signature": "Signature (I → S) identifies uniquely. Pattern identifies AND is reusable cross-domain. Signature = fingerprint; Pattern = archetype.",
        "vs_Behavior": "Behavior (S → D → F) is a structured operational sequence (temporal). Pattern is a structural motif (not necessarily temporal), reusable across domains.",
        "vs_Topology": "Topology (S) captures structural invariants under deformation. Pattern captures recurring motifs with informational and attractor dimensions."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Biology (branching morphology, molecular recognition)",
          "Software Engineering (design patterns, architectural patterns)",
          "Architecture (structural and spatial patterns)",
          "Mathematics (recurring sequences, fractal motifs)",
          "Music (melodic and harmonic motifs)",
          "Mythology (narrative structure archetypes)",
          "Chemistry (molecular binding patterns)",
          "Urban Planning (city layout motifs)"
        ],
        "count": 8,
        "transdisciplinaryStrength": "Strong - pattern recognition and reuse is fundamental cognitive and systemic operation across natural and artificial systems"
      },
      "dcterms:created": "2026-01-31",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Identified as missing genericConcept during TO_DO review. Pattern occupies a unique niche: it bridges observation (Territory) and reuse (Map) through structural recurrence. No existing genericConcept captured both the recurring regularity aspect and the cross-domain template reusability in a single concept.",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes A",
      "m2:hasTensorFormulaASCII": "S (x) I (x) A",
      "m3:semanticSignature": "structural_regularity + information_recognition + attractor_reuse"
    },
    {
      "@id": "m2:Process",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Triggerable"
      ],
      "rdfs:label": "Process",
      "rdfs:comment": "Sequence of state changes over time. Time discretization (Continuous/Discrete/Hybrid) specified via time_discretization attribute.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "D ⊗ F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Manufacturing process",
        "Metabolic pathway",
        "Workflow"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "D → F",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "D \\otimes F",
      "m2:hasTensorFormulaASCII": "D (x) F",
      "m2:hasAttribute": {
        "time_discretization": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Temporal discretization: continuous-time, discrete-time, or hybrid dynamics",
          "m2:possibleValues": [
            {
              "value": "Continuous",
              "description": "Continuous-time evolution (differential equations)",
              "formula": "dx/dt = f(x,t) or ẋ = f(x)",
              "examples": [
                "Chemical reaction kinetics (RAAS cascade)",
                "Heat diffusion",
                "Population growth (Lotka-Volterra)",
                "Electrical circuit dynamics",
                "Mechanical motion"
              ],
              "characteristics": "Smooth evolution, differentiable, infinitesimal time steps (dt → 0)"
            },
            {
              "value": "Discrete",
              "description": "Discrete-time evolution (difference equations)",
              "formula": "x[n+1] = f(x[n]) or x_{k+1} = f(x_k)",
              "examples": [
                "Digital control system",
                "Generational biological evolution",
                "Batch chemical process",
                "Discrete-event simulation",
                "Cellular automaton"
              ],
              "characteristics": "Stepwise evolution, discrete time index (t = nΔt, n ∈ ℤ)"
            },
            {
              "value": "Hybrid",
              "description": "Mixed continuous and discrete dynamics",
              "formula": "Continuous between events, discrete jumps at events",
              "examples": [
                "Sampled-data control (continuous plant, discrete controller)",
                "Hybrid automaton",
                "Event-driven simulation",
                "Impulsive differential equations"
              ],
              "characteristics": "Continuous evolution with discrete events/transitions"
            }
          ],
          "m2:default": "Continuous",
          "m2:usageGuidelines": "Use Continuous for most physical/chemical/biological processes. Use Discrete for digital systems or generational models. Use Hybrid for systems with both smooth dynamics and discrete events."
        },
        "reversibility": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Whether process can be reversed (time-symmetry vs irreversibility)",
          "m2:possibleValues": [
            {
              "value": "Reversible",
              "description": "Process can be reversed, time-symmetric, no entropy increase",
              "thermodynamics": "ΔS_universe = 0 (isentropic)",
              "time_symmetry": "Process looks same forwards and backwards",
              "examples": [
                "Ideal elastic collision (Newton's cradle)",
                "Reversible chemical reaction at equilibrium (A ⇌ B)",
                "Adiabatic reversible expansion (ideal gas)",
                "Pendulum in vacuum (idealized)",
                "Quantum unitary evolution (Schrödinger equation)",
                "Lossless electrical circuit (ideal LC)"
              ],
              "characteristics": "Microscopically reversible, no dissipation, idealization",
              "thermodynamic_efficiency": "η = 100% (Carnot limit)",
              "entropy_change": "ΔS = 0",
              "information": "No information loss",
              "conditions": "Requires: no friction, no heat loss, quasi-static, equilibrium",
              "reality": "Idealization - real processes always have some irreversibility"
            },
            {
              "value": "Irreversible",
              "description": "Process cannot be reversed, time-asymmetric, entropy increases",
              "thermodynamics": "ΔS_universe > 0 (entropy production)",
              "time_symmetry": "Process has arrow of time",
              "examples": [
                "Combustion (fuel + O₂ → CO₂ + H₂O + heat)",
                "Biological aging and development",
                "Heat diffusion (hot → cold, never spontaneously cold → hot)",
                "Mixing (cream in coffee)",
                "Free expansion (gas into vacuum)",
                "RAAS cascade (enzymatic reactions with heat dissipation)",
                "Glass breaking",
                "Egg scrambling"
              ],
              "characteristics": "Entropy increases, dissipation, arrow of time, realistic",
              "thermodynamic_efficiency": "η < 100% (always)",
              "entropy_change": "ΔS > 0",
              "information": "Information loss (coarse-graining)",
              "second_law": "Follows 2nd law of thermodynamics",
              "reality": "ALL real processes are irreversible to some degree"
            },
            {
              "value": "Quasi-reversible",
              "description": "Nearly reversible (very slow, close to equilibrium)",
              "thermodynamics": "ΔS_universe ≈ 0 (minimal entropy production)",
              "examples": [
                "Very slow chemical reaction near equilibrium",
                "Isothermal compression (very slow, with heat reservoir)",
                "Carnot engine (idealized, quasi-static steps)"
              ],
              "characteristics": "Approaches reversibility in limit of infinite slowness",
              "conditions": "Quasi-static process, infinitesimal deviations from equilibrium",
              "practical": "Impractical (infinitely slow), but useful theoretical limit"
            }
          ],
          "m2:default": "Irreversible",
          "m2:usageGuidelines": "Most real processes (including RAAS) are Irreversible. Use Reversible only for idealized models (e.g., equilibrium thermodynamics, elastic collisions). Quasi-reversible is theoretical limit.",
          "m2:physicalPrinciple": "2nd Law of Thermodynamics: Isolated systems evolve toward maximum entropy (irreversibility is fundamental to nature)",
          "m2:timeArrow": "Irreversibility provides arrow of time: we remember past, not future; aging occurs; heat flows hot→cold"
        }
      },
      "m3:semanticSignature": "temporal_dynamics + flow_transformation",
      "m2:implements": {
        "@id": "m2:Triggerable"
      }
    },
    {
      "@id": "m2:Trajectory",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Observable"
      ],
      "rdfs:label": "Trajectory",
      "rdfs:comment": "Observable path through state space traced by system evolution over time. Empirical, measured evolution in territory - what actually happens. Distinguished from Path (planned route on conceptual map). Trajectory shape (linear, circular, spiral, etc.) can be specified via shape attribute.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "A ⊗ D ⊗ F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.15,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Projectile trajectory - observed ballistic motion",
        "Phase space trajectory of dynamical system",
        "Blood pressure trajectory in RAAS homeostasis",
        "Organism lifecycle trajectory through developmental stages",
        "Chemical reaction trajectory along reaction coordinate",
        "Population trajectory in Lotka-Volterra dynamics",
        "Aircraft flight trajectory - actual path flown"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "A → D → F",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:distinctionFromRelated": {
        "vs_Path": "Path is planned/computed route on map (structure-based); Trajectory is observed evolution in territory (attractor-driven)",
        "vs_Process": "Process (D ⊗ F) is generic temporal sequence; Trajectory (A ⊗ D ⊗ F) adds attractor dynamics and state-space geometry"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Physics (ballistics, orbits, phase space)",
          "Biology (development, RAAS dynamics, population ecology)",
          "Chemistry (reaction coordinates, titration curves)",
          "Engineering (control system response, flight paths)",
          "Dynamical Systems Theory (attractors, chaos)"
        ],
        "count": 5,
        "discoveredFrom": "RAAS analysis (M0_SRAA_Homeostasis)"
      },
      "dcterms:created": "2026-02-05",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Identified during RAAS analysis when distinguishing between biochemical pathway diagrams (Path on map) and actual blood pressure evolution over time (Trajectory in territory). Resolves Map-Territory confusion in Path genericConcept.",
      "m2:hasTensorFormulaTeX": "A \\otimes D \\otimes F",
      "m2:hasTensorFormulaASCII": "A (x) D (x) F",
      "m2:hasAttribute": {
        "shape": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Topological/geometric shape of trajectory through state space",
          "m2:possibleValues": [
            {
              "value": "Linear",
              "description": "Straight-line trajectory through state space",
              "examples": [
                "Ballistic projectile (parabola in position space, line in phase space)",
                "Free fall (linear in velocity-time)",
                "Constant velocity motion",
                "Linear chemical reaction coordinate"
              ],
              "characteristics": "Simplest trajectory, no curvature, monotonic progression"
            },
            {
              "value": "Circular",
              "description": "Closed periodic loop returning to initial state",
              "examples": [
                "Circular orbit (planet, satellite)",
                "Simple harmonic oscillator (phase space)",
                "AC current cycle",
                "Circadian rhythm"
              ],
              "characteristics": "Periodic, closed loop, constant distance from center"
            },
            {
              "value": "Elliptical",
              "description": "Closed periodic trajectory with varying radius",
              "examples": [
                "Planetary orbits (Kepler)",
                "Comet trajectories",
                "Elliptical phase portraits"
              ],
              "characteristics": "Periodic, closed, two foci, eccentricity ∈ [0,1)"
            },
            {
              "value": "Spiral",
              "description": "Helical path converging to or diverging from center",
              "examples": [
                "Damped oscillator (inward spiral to equilibrium)",
                "Galaxy spiral arms",
                "Vortex flow",
                "Growth/decay spiral (logistic growth approaching carrying capacity)"
              ],
              "characteristics": "Converging (stable) or diverging (unstable), asymptotic approach/escape"
            },
            {
              "value": "Hyperbolic",
              "description": "Open trajectory approaching asymptote, escaping to infinity",
              "examples": [
                "Comet flyby (escape trajectory)",
                "Saddle point escape",
                "Hyperbolic phase portrait"
              ],
              "characteristics": "Unbounded, approaches asymptote, never returns"
            },
            {
              "value": "Random",
              "description": "Stochastic trajectory without deterministic pattern",
              "examples": [
                "Brownian motion (particle diffusion)",
                "Random walk",
                "Stock price evolution (geometric Brownian motion)",
                "Molecular diffusion"
              ],
              "characteristics": "Stochastic, no predictable shape, characterized by probability distribution"
            },
            {
              "value": "Constrained",
              "description": "Trajectory confined to manifold or subject to holonomic constraints",
              "examples": [
                "Pendulum (constrained to circular arc)",
                "Bead on wire",
                "Rolling without slipping (constraint: v = ωr)",
                "Rigid body motion (distance constraints)"
              ],
              "characteristics": "Confined to lower-dimensional manifold, obeys constraint equations"
            },
            {
              "value": "Chaotic",
              "description": "Deterministic but sensitive to initial conditions, bounded but non-periodic",
              "examples": [
                "Lorenz attractor (weather/convection)",
                "Double pendulum",
                "Three-body problem",
                "Logistic map (r > 3.57)"
              ],
              "characteristics": "Deterministic, bounded, aperiodic, sensitive dependence on initial conditions"
            },
            {
              "value": "Piecewise",
              "description": "Trajectory composed of distinct segments with different characteristics",
              "examples": [
                "Rocket trajectory (powered ascent + coasting + re-entry)",
                "Biological development (larva → pupa → adult transitions)",
                "Manufacturing process (discrete stage transitions)"
              ],
              "characteristics": "Discontinuous derivatives at transitions, composed of simpler trajectory types"
            }
          ],
          "m2:default": "Linear",
          "m2:usageGuidelines": "Select based on observed or modeled state-space geometry. For RAAS blood pressure: Linear (convergence to setpoint). For oscillating system: Circular or Spiral. For stochastic system: Random."
        }
      },
      "m3:semanticSignature": "attractor_directed + dynamic_path + flow_sequence",
      "m2:implements": {
        "@id": "m2:Observable"
      }
    },
    {
      "@id": "m2:Event",
