        "Optics: Depth of field (zone of acceptable sharpness)",
        "Mathematics: Domain of function (ensemble de définition)",
        "Linguistics: Scope of quantifier in logic",
        "Network: Broadcast domain, routing scope"
      ],
      "m2:perspective": "map",
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → V → O",
          "role": "Evaluate scope definition quality in Map",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Constraint": "Constraint defines what is PROHIBITED (negative boundary, hard limit). Scope defines what is PERMITTED (positive boundary, domain of validity). Constraint: 'you cannot leave the garden' vs Scope: 'the garden is your playground'.",
        "vs_Boundary": "Boundary is a geometric/topological separation surface. Scope is a domain of applicability/authority (conceptual, not just spatial).",
        "vs_Domain": "Domain (full ASFID → REVOI hybrid) is an entire knowledge field. Scope is a limited region of validity within a domain.",
        "vs_Capacity": "Capacity is maximum structural limit (ceiling). Scope is extent of valid operation (floor plan)."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Programming (variable scope)",
          "Cybernetics (VSM S1 operational scope)",
          "Management (span of control)",
          "Juridical (jurisdiction)",
          "Project management (scope triangle)",
          "Biology (territorial scope)",
          "Optics (depth of field)",
          "Mathematics (function domain)",
          "Linguistics (quantifier scope)",
          "Networks (broadcast domain)"
        ],
        "validatedDomains": 10,
        "transdisciplinaryStrength": "Strong - scope appears across formal, natural, and social systems as fundamental organizational principle"
      },
      "dcterms:created": "2026-02-03",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Identified during VSM M0 modeling refinement. Required to properly model Autonomy as GenericConceptCombo(Agent, Scope) where Agent provides action capability and Scope provides bounded domain of authority. Fills semantic gap between Constraint (prohibition) and Domain (entire field). Essential for authorization, delegation, and jurisdictional concepts.",
      "m3:semanticSignature": "structural_boundary + information_range + attractor_reach + representational_extent"
    },
    {
      "@id": "m2:Bifurcation",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Duplication"
      ],
      "rdfs:label": "Bifurcation",
      "rdfs:comment": "Qualitative change in system behavior at critical parameter threshold. Semantic specialization of m2:Duplication where V→0: the copying process loses fidelity entirely and the two resulting branches diverge toward distinct attractors. Analogous to Homeostasis ↪ Regulation semantic inclusion precedent (morphism_inclusion, not dimensional inheritance).",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "∂D/∂F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.4,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Phase transitions",
        "Ecosystem regime shifts"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "∂D/∂F",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "\\partial D / \\partial F",
      "m2:hasTensorFormulaASCII": "dD/dF",
      "m2:hasAttribute": {
        "bifurcation_type": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Classification of bifurcation based on how system structure changes as parameter varies",
          "m2:possibleValues": [
            {
              "value": "Saddle-node",
              "alternative_names": [
                "Fold bifurcation",
                "Tangent bifurcation"
              ],
              "description": "Creation or annihilation of pair of fixed points (one stable, one unstable)",
              "codimension": 1,
              "normal_form": "dx/dt = μ + x²",
              "examples": [
                "Tipping point in climate system (ice-albedo feedback)",
                "Laser threshold (below: no lasing, above: lasing)",
                "Catastrophic shift in ecosystem",
                "Voltage collapse in power grid",
                "Hysteresis loop entry/exit points"
              ],
              "characteristics": "Sudden appearance/disappearance of equilibria, catastrophe",
              "stability_change": "Creation of stable+unstable pair OR annihilation",
              "reversibility": "Often hysteretic (different thresholds for forward/backward)"
            },
            {
              "value": "Transcritical",
              "description": "Exchange of stability between two branches (crossing)",
              "codimension": 1,
              "normal_form": "dx/dt = μx - x²",
              "examples": [
                "Laser threshold (continuous transition)",
                "Population model (extinction ↔ survival transition)",
                "Chemical reaction (reactant ↔ product dominance)"
              ],
              "characteristics": "Two equilibria exchange stability, continuous transition",
              "stability_change": "Stable ↔ Unstable (swap)",
              "continuity": "Both branches exist on both sides of bifurcation"
            },
            {
              "value": "Pitchfork",
              "subtypes": [
                "Supercritical",
                "Subcritical"
              ],
              "description": "Symmetry-breaking bifurcation (one equilibrium splits into three)",
              "codimension": 1,
              "normal_form_supercritical": "dx/dt = μx - x³",
              "normal_form_subcritical": "dx/dt = μx + x³",
              "examples": [
                "Euler buckling (beam under compression: straight ↔ bent)",
                "Ising ferromagnet (paramagnet ↔ ferromagnet, magnetization up/down)",
                "Taylor-Couette flow (circular ↔ spiral vortices)",
                "Rayleigh-Bénard convection (conduction ↔ convection cells)"
              ],
              "characteristics": "Spontaneous symmetry breaking, Z₂ symmetry",
              "stability_change": {
                "supercritical": "Stable equilibrium → unstable + 2 stable symmetric branches",
                "subcritical": "Unstable equilibrium + 2 unstable branches (dangerous)"
              },
              "symmetry": "System has mirror/rotation symmetry that gets broken"
            },
            {
              "value": "Hopf",
              "alternative_names": [
                "Andronov-Hopf bifurcation",
                "Poincaré-Andronov-Hopf"
              ],
              "description": "Transition from fixed point to limit cycle (oscillation onset)",
              "codimension": 1,
              "normal_form": "dz/dt = z(μ + iω - |z|²) (complex plane)",
              "examples": [
                "Predator-prey oscillations (Lotka-Volterra: equilibrium → cycles)",
                "Heart arrhythmia onset (normal rhythm → abnormal oscillation)",
                "Belousov-Zhabotinsky reaction (static → oscillating)",
                "Electronic oscillator (DC → AC)",
                "Neuronal spiking (quiescent → periodic firing)"
              ],
              "characteristics": "Birth of periodic orbit from equilibrium",
              "stability_change": {
                "supercritical": "Stable equilibrium → unstable equilibrium + stable limit cycle",
                "subcritical": "Unstable limit cycle collapses onto stable equilibrium"
              },
              "dimension_requirement": "Requires ≥2D system (complex eigenvalues)",
              "frequency": "Oscillation frequency ω at bifurcation point"
            },
            {
              "value": "Period-doubling",
              "alternative_names": [
                "Flip bifurcation",
                "Subharmonic bifurcation"
              ],
              "description": "Doubling of oscillation period (route to chaos)",
              "codimension": 1,
              "examples": [
                "Logistic map (r increases: period 1 → 2 → 4 → 8 → ... → chaos)",
                "Dripping faucet (slow drips → alternating intervals → chaotic)",
                "Forced pendulum (period T → 2T → 4T → chaos)",
                "Electronic circuit (period-doubling cascade to chaos)"
              ],
              "characteristics": "Period T → 2T (subharmonic oscillation)",
              "feigenbaum_constant": "δ ≈ 4.669... (universal scaling for cascade)",
              "route_to_chaos": "Infinite cascade: T → 2T → 4T → 8T → ... → chaos",
              "discrete_maps": "Common in iterative maps (Poincaré sections)"
            },
            {
              "value": "Homoclinic",
              "description": "Collision of limit cycle with saddle point",
              "codimension": 1,
              "examples": [
                "Shil'nikov chaos (spiral towards saddle)",
                "Van der Pol oscillator (relaxation oscillations)"
              ],
              "characteristics": "Limit cycle period → ∞ as approaches saddle",
              "chaos_onset": "Can lead to chaotic behavior"
            },
            {
              "value": "Heteroclinic",
              "description": "Connection between distinct saddle points",
              "examples": [
                "Lorenz attractor (heteroclinic connections)",
                "Multistable system transitions"
              ],
              "characteristics": "Trajectory connects different saddles"
            }
          ],
          "m2:default": "Saddle-node",
          "m2:usageGuidelines": "Saddle-node for catastrophic transitions (tipping points). Hopf for oscillation onset (RAAS pathological oscillations would be Hopf). Pitchfork for symmetry-breaking. Period-doubling for route to chaos.",
          "m2:mathematicalContext": "Bifurcation theory studies how dynamical system structure changes as parameters vary. Codimension indicates number of parameters needed to observe bifurcation generically."
        }
      },
      "m2:distinctionFromRelated": {
        "vs_Duplication": "Duplication (S⊗I⊗F⊗D⊗V) produces faithful copies (V→1). Bifurcation is the degenerate limit where V→0: the copying process loses fidelity entirely and the two branches diverge toward distinct attractors. See m2:Duplication fidelitySpectrum.V_low."
      },
      "m3:semanticSignature": "dynamics_sensitivity_to_flow + threshold_crossing + qualitative_state_change"
    },
    {
      "@id": "m2:Duplication",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:Process",
        "m2:Triggerable",
        "m2:Observable"
      ],
      "rdfs:label": "Duplication",
      "rdfs:comment": "Active process producing one or more faithful copies of a source structure, preserving its informational content through a transfer flux over time. Specialization of m2:Process (D⊗F): inherits temporal dynamics (D) and flux (F), adds source structure (S), copied content (I), and fidelity verifiability (V). The copy is recognizable as structurally and informationally equivalent to the original. V is the discriminant: V→1 = perfect copy; V→0 = copies diverge toward distinct attractors, degenerating into m2:Bifurcation. m2:Propagation (GenericConceptCombo) uses Duplication as its branching parent — each node that receives a copy becomes a new emitter.",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "S ⊗ I ⊗ F ⊗ D ⊗ V",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes F \\otimes D \\otimes V",
      "m2:hasTensorFormulaASCII": "S (x) I (x) F (x) D (x) V",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information"
      ],
      "m2:specializationOf": {
        "@id": "m2:Process",
        "m2:parentFormula": "D ⊗ F",
        "m2:inheritedDimensions": [
          "D",
          "F"
        ],
        "m2:addedDimensions": {
          "S": "Process is content-agnostic; Duplication specifically copies a Structure",
          "I": "Process transforms or transfers; Duplication preserves Information faithfully",
          "V": "Fidelity verifiability — the copy is equivalent to the original. Replaces R (Representability) of Process: what matters is copy equivalence, not external symbolic encoding"
        }
      },
      "m2:dimensionSemantics": {
        "D": "Temporal dynamics of the copying process — duration, rate, error accumulation (inherited from Process)",
        "F": "Transfer flux producing the copy — replication machinery, data stream, cultural transmission (inherited from Process)",
        "S": "Source structure being copied — organization, topology, architecture",
        "I": "Informational content preserved faithfully in the copy — genetic code, data payload, semantic message",
        "V": "Verifiability of fidelity — the copy is recognizable as equivalent to the original (checksum, genetic proofreading, source citation)"
      },
      "m2:hasEpistemicGap": 0.22,
      "m2:hasPolarity": "neutral",
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S → I → F → D → V",
        "role": "Measure observable duplication in Territory: source structure copied, informational content preserved, transfer flux active, temporal dynamics tracked, fidelity verifiable between original and copy",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → Im → V",
          "role": "Evaluate Map quality of a duplication model: is the copy representable as equivalent to the original (R), compatible with the receiving system (Im), verifiable as faithful (V)?",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:fidelitySpectrum": {
        "description": "V is the continuous axis unifying all copying phenomena, from perfect replication to complete divergence. Parameterizes the Duplication→Bifurcation transition.",
        "V_high": {
          "label": "Perfect duplication (V → 1)",
          "examples": [
            "DNA replication with proofreading (error rate ~10⁻⁹ per base)",
            "Lossless file copy with SHA-256 checksum",
            "Laser stimulated emission (phase-identical photon copy)"
          ]
        },
        "V_medium": {
          "label": "Imperfect duplication — mutation, drift (0.3 < V < 0.8)",
          "examples": [
            "RNA virus replication (mutation rate ~10⁻⁴ per base)",
            "Cultural transmission with semantic drift",
            "Analog audio tape dub (generation loss)"
          ]
        },
        "V_low": {
          "label": "Degenerate duplication → Bifurcation (V → 0)",
          "examples": [
            "Sympatric speciation (lineages diverge completely)",
            "Minsky Moment — speculative price diverges from fundamental value"
          ],
          "semantics": "Copies escape toward distinct attractors — Duplication degenerates into m2:Bifurcation"
        }
      },
      "m2:hasExample": [
        "Molecular Biology — DNA replication (S=double helix, I=nucleotide sequence, F=polymerase, D=S-phase duration, V=mismatch repair)",
        "Molecular Biology — Mitosis (S=cell architecture, I=genome, F=cytokinesis, D=cell cycle, V=spindle assembly checkpoint)",
        "Computing — File copy / RAID mirroring (S=file structure, I=data, F=read-write stream, D=transfer time, V=checksum)",
        "Computing — Git clone (S=directory tree, I=commit history, F=network transfer, D=clone duration, V=SHA hash)",
        "Epidemiology — Viral replication in host cell (S=capsid, I=viral genome, F=host machinery hijacking, D=replication cycle, V=phylogenetic traceability)",
        "Physics — Stimulated emission / laser (S=photon state, I=energy+phase, F=electromagnetic coupling, D=emission time, V=coherence)",
        "Sociology — Cultural transmission (S=behavioral pattern, I=semantic content, F=social learning, D=generational time, V=recognizability as 'the same')",
        "Law — Legal precedent citation (S=reasoning structure, I=ruling content, F=citation, D=jurisprudential time, V=verifiable reference to original case)"
      ],
      "m2:distinctionFromRelated": {
        "vs_Process": "Process (D⊗F) is content-agnostic: any sequence of state changes. Duplication specializes Process by specifying WHAT is copied (S, I) and requiring fidelity verification (V).",
        "vs_Transformation": "Transformation (S⊗I⊗D⊗F⊗V) changes content — output differs from input. Duplication preserves content: original and copy are equivalent.",
        "vs_Bifurcation": "Bifurcation (∂D/∂F) is the degenerate limit of Duplication when V→0: fidelity breaks entirely and the two branches diverge toward distinct attractors.",
        "vs_Signal": "Signal (F⊗I⊗R) is 1:1 information transfer — no independent persistent copy is produced. Duplication produces an autonomous copy (1→N).",
        "vs_Network": "Network (S⊗I⊗F⊗D⊗Im) is the structural substrate enabling propagation. Duplication is the copying operation occurring at each node. Together with Cascade and Network, Duplication forms m2:Propagation."
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          {
            "domain": "Molecular Biology",
            "examples": [
              "DNA replication",
              "RNA transcription",
              "Mitosis"
            ]
          },
          {
            "domain": "Computing / Information Theory",
            "examples": [
              "File copy",
