      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Crystal lattice symmetries",
        "Conservation laws (Noether)"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "S",
        "role": "Measure territory perspective",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "O → V",
          "role": "Evaluate map perspective",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasTensorFormulaASCII": "S",
      "m2:hasTensorFormulaTeX": "S",
      "m2:hasAttribute": {
        "symmetry_type": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Type of invariance transformation (group structure)",
          "m2:possibleValues": [
            {
              "value": "Translational",
              "description": "Invariance under spatial or temporal translation",
              "group": "Translation group T^n (Abelian)",
              "transformation": "x → x + a (shift by constant vector a)",
              "examples": [
                "Crystal lattice (periodic structure in space)",
                "Wallpaper patterns (2D periodic tiling)",
                "Stationary stochastic process (time-translation invariant)",
                "Homogeneous space (no preferred origin)"
              ],
              "conservation_law": "Conservation of momentum (Noether's theorem)",
              "breaking": "Localized defect, boundary, external field",
              "dimension": "Can be 1D (line), 2D (plane), 3D (space), or time"
            },
            {
              "value": "Rotational",
              "description": "Invariance under rotation around axis",
              "group": "Rotation group SO(n)",
              "transformation": "x → R(θ)·x (rotation by angle θ)",
              "examples": [
                "Snowflake (6-fold rotational symmetry)",
                "Circle (continuous rotational symmetry SO(2))",
                "Sphere (full 3D rotational symmetry SO(3))",
                "Cylindrical system (axial symmetry)",
                "Benzene ring (C₆ symmetry)"
              ],
              "conservation_law": "Conservation of angular momentum (Noether)",
              "discrete_vs_continuous": {
                "discrete": "Cn symmetry (n-fold: 120°, 90°, 60°, etc.)",
                "continuous": "SO(2) or SO(3) (arbitrary angle)"
              },
              "breaking": "External torque, anisotropic field"
            },
            {
              "value": "Reflective",
              "alternative_names": [
                "Mirror symmetry",
                "Parity"
              ],
              "description": "Invariance under mirror reflection",
              "group": "Reflection group (discrete, Z₂)",
              "transformation": "x → -x (or specific component sign flip)",
              "examples": [
                "Bilateral symmetry (most animals: left-right mirror)",
                "Palindrome (reads same forwards/backwards)",
                "Even function f(-x) = f(x)",
                "Crystal mirror planes"
              ],
              "parity": "Parity transformation P: (x,y,z) → (-x,-y,-z)",
              "biology": "Bilateral symmetry (vertebrates, arthropods)",
              "breaking": "Chirality (handedness), parity violation in weak force"
            },
            {
              "value": "Temporal",
              "alternative_names": [
                "Time-translation",
                "Stationarity"
              ],
              "description": "Invariance under time shift (stationarity)",
              "group": "Time-translation group T",
              "transformation": "t → t + τ (shift in time)",
              "examples": [
                "Steady-state process (properties don't change with time)",
                "Autonomous dynamical system (no explicit time dependence)",
                "Periodic signal (f(t) = f(t+T))",
                "Equilibrium thermodynamics"
              ],
              "conservation_law": "Conservation of energy (Noether's theorem)",
              "breaking": "External time-dependent forcing, aging, non-autonomous system",
              "reversibility": "Time-reversal T: t → -t (distinct from time-translation)"
            },
            {
              "value": "Scale",
              "alternative_names": [
                "Self-similarity",
                "Scale invariance",
                "Fractal"
              ],
              "description": "Invariance under scaling (dilation)",
              "group": "Scaling group (multiplicative)",
              "transformation": "x → λx (multiply by scale factor λ)",
              "examples": [
                "Fractal (Mandelbrot set, coastline, Brownian motion)",
                "Power law f(λx) = λ^α f(x)",
                "Critical phenomena (2nd order phase transitions)",
                "Turbulent cascade (energy across scales)",
                "Zipf's law (word frequency)"
              ],
              "scale_free": "No characteristic length/time scale",
              "dimension": "Fractal dimension D (non-integer possible)",
              "renormalization": "Renormalization group (statistical physics)",
              "breaking": "Cutoff (UV/IR), characteristic scale emerges"
            },
            {
              "value": "Gauge",
              "description": "Invariance under local phase rotation (quantum field theory)",
              "group": "Gauge group U(1), SU(2), SU(3), etc.",
              "transformation": "ψ(x) → e^(iα(x)) ψ(x) (local phase)",
              "examples": [
                "Electromagnetic gauge symmetry U(1) (QED)",
                "Electroweak symmetry SU(2)×U(1)",
                "Strong force (QCD) SU(3) color symmetry",
                "Superconductivity (broken U(1) gauge)"
              ],
              "gauge_field": "Requires gauge field (photon, W/Z, gluons) to maintain invariance",
              "local_vs_global": "Local (α depends on position) vs global (α constant)",
              "conservation": "Charge conservation, current conservation",
              "redundancy": "Gauge freedom = redundant degrees of freedom (unphysical)"
            },
            {
              "value": "Permutation",
              "description": "Invariance under particle exchange (identical particles)",
              "group": "Symmetric group Sₙ",
              "examples": [
                "Bosons (symmetric wavefunction)",
                "Fermions (antisymmetric wavefunction, Pauli exclusion)",
                "Statistical mechanics (partition function)"
              ],
              "quantum": "Spin-statistics theorem (bosons vs fermions)"
            },
            {
              "value": "Duality",
              "description": "Exchange of strong↔weak coupling, electric↔magnetic",
              "examples": [
                "Electromagnetic duality (E ↔ B)",
                "S-duality (string theory)",
                "Kramers-Wannier duality (Ising model)"
              ],
              "characteristics": "Maps one description to dual description"
            }
          ],
          "m2:default": "Translational",
          "m2:usageGuidelines": "Biological systems often have Reflective (bilateral) or Rotational (radial, like starfish). Physical laws exhibit Translational (space) and Temporal (time) symmetry. Scale symmetry appears in fractals and critical phenomena.",
          "m2:noether_theorem": "Continuous symmetries → conservation laws (Noether). Translation→momentum, Rotation→angular momentum, Time→energy, Gauge→charge.",
          "m2:spontaneous_breaking": "System Lagrangian has symmetry, but ground state doesn't (Higgs mechanism, ferromagnetism)"
        }
      },
      "m3:semanticSignature": "structural_invariance_under_transformation"
    },
