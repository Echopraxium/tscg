        }
      },
      "m2:mathematicalProperties": {
        "gainFactor": "G = Output / Input",
        "amplification": "G > 1 (increase)",
        "attenuation": "0 < G < 1 (decrease)",
        "unity": "G = 1 (buffer, no change)",
        "dB_scale": "G_dB = 20·log₁₀(G) for voltage/current, 10·log₁₀(G) for power",
        "cascaded_stages": "G_total = G₁ × G₂ × ... × G_n (product of individual gains)",
        "territory_measures": {
