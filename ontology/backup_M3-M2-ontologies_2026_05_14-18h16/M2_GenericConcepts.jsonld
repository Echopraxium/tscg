    {
      "@id": "m2:Convergence",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Convergence (Convergence/Divergence)",
      "rdfs:comment": "Focusing or dispersing of flows, trajectories, or information.",
      "m2:hasFamily": "m2:Dynamic",
      "m2:hasTensorFormula": "-∇·D (convergence) / ∇·D (divergence)",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.3,
      "m2:hasPolarity": "dual",
      "m2:shortName": "Convergence",
      "m2:fullName": "Convergence (Divergence)",
      "m2:dualAspects": {
        "convergenceAspect": {
          "name": "Convergence",
          "comment": "Focusing toward attractor"
        },
        "divergenceAspect": {
          "name": "Divergence",
          "comment": "Dispersing away from repeller"
        }
      },
      "m2:hasExample": [
        "Convergent/divergent evolution",
        "Beam focusing/spreading",
        "Opinion polarization"
      ],
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "-∇·D (convergence) / ∇·D (divergence)",
        "role": "Measure territory perspective",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "O → V",
          "role": "Evaluate map perspective",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:hasTensorFormulaTeX": "- \\nabla \\cdot D (convergence) / \\nabla \\cdot D (divergence)",
      "m2:hasTensorFormulaASCII": "-∇·D (convergence) / ∇·D (divergence)",
      "m2:hasAttribute": {
        "convergence_pattern": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Temporal pattern of approach toward attractor or equilibrium point",
          "m2:possibleValues": [
            {
              "value": "Monotonic",
              "description": "Steady approach without oscillation (overdamped)",
              "formula": "x(t) = x_eq + (x₀ - x_eq)·e^(-t/τ) (exponential decay, no overshoot)",
              "examples": [
                "Exponential decay (RC circuit discharge)",
                "First-order system step response",
                "Overdamped spring-mass-damper (ζ > 1)",
                "RAAS blood pressure convergence to setpoint",
                "Cooling coffee (Newton's law of cooling)"
              ],
              "characteristics": "No overshoot, smooth approach, slower than critical",
              "damping_ratio": "ζ > 1 (overdamped)",
              "pros": "Stable, no oscillation, predictable",
              "cons": "Slower than critical damping"
            },
            {
              "value": "Oscillatory",
              "description": "Damped oscillation around target (underdamped)",
              "formula": "x(t) = x_eq + A·e^(-ζωₙt)·cos(ωd·t + φ) (decaying sinusoid)",
              "examples": [
                "Underdamped spring-mass system (ζ < 1)",
                "RLC circuit (underdamped)",
                "Swinging pendulum (with air resistance)",
                "Tuning fork vibration (gradually decaying)",
                "Predator-prey population cycles (damped)"
              ],
              "characteristics": "Overshoot, multiple crossings, rings down",
              "damping_ratio": "0 < ζ < 1 (underdamped)",
              "pros": "Faster rise time than monotonic",
              "cons": "Overshoot can be problematic, settling time longer"
            },
            {
              "value": "Critical",
              "description": "Fastest non-oscillatory convergence (critically damped)",
              "formula": "x(t) = x_eq + (x₀ - x_eq)·(1 + t/τ)·e^(-t/τ) (no overshoot, fastest)",
              "examples": [
                "Critically damped shock absorber (car suspension)",
                "Analog meter needle (galvanometer)",
                "Door closer (optimal damping)",
                "Critically damped RLC circuit (ζ = 1)"
              ],
              "characteristics": "Boundary case: fastest approach without overshoot, optimal for many applications",
              "damping_ratio": "ζ = 1 (critically damped)",
              "pros": "Fastest settling without overshoot, ideal for many applications",
              "cons": "Difficult to achieve precisely (sensitive to parameters)"
            },
            {
              "value": "Undamped Oscillatory",
              "description": "Sustained oscillation without decay (conservative system)",
              "formula": "x(t) = A·cos(ω₀·t + φ) (constant amplitude)",
              "examples": [
                "Ideal pendulum (no friction)",
                "Ideal LC circuit (no resistance)",
                "Planetary orbit (Keplerian)",
                "Simple harmonic oscillator"
              ],
              "characteristics": "No convergence (periodic), no energy dissipation",
              "damping_ratio": "ζ = 0 (undamped)",
              "pros": "Energy conserving",
              "cons": "Not stable equilibrium, idealization (real systems always have damping)"
            },
            {
              "value": "Divergent",
              "description": "Moving away from equilibrium (unstable)",
              "formula": "x(t) = x_eq + (x₀ - x_eq)·e^(+t/τ) (exponential growth)",
              "examples": [
                "Inverted pendulum (uncontrolled)",
                "Positive feedback system",
                "Runaway nuclear reaction",
                "Financial bubble"
              ],
              "characteristics": "Anti-convergence, unstable equilibrium",
              "damping_ratio": "ζ < 0 (unstable, negative damping)",
              "pros": "None (undesirable in control systems)",
              "cons": "Unstable, requires active stabilization"
            }
          ],
          "m2:default": "Monotonic",
          "m2:usageGuidelines": "Most homeostatic biological systems (like RAAS) exhibit Monotonic convergence. Use Oscillatory for systems with inertia/capacitance. Use Critical for optimized control systems. Undamped/Divergent indicate lack of stability."
        }
      },
      "m2:expression": "(-1)^{p} ∇·D",
      "m2:expressionTeX": "(-1)^{p} \\nabla \\cdot D",
      "m2:poleMapping": {
        "p=1": {
          "name": "Convergence",
          "formula": "-∇·D",
          "semantics": "Negative divergence: flows/trajectories focus toward attractor"
        },
        "p=0": {
          "name": "Divergence",
          "formula": "∇·D",
          "semantics": "Positive divergence: flows/trajectories disperse away from repeller"
        }
      },
      "m3:semanticSignature": "trajectory_directed + polarity(convergence|divergence)"
    },
