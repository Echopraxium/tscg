          "dynamics": "Bandwidth, rise time, settling time",
          "information": "SNR_out/SNR_in ratio"
        }
      },
      "m2:ashbyRelevance": {
        "requisiteVariety": "Amplification/Attenuation controls variety flow in cybernetic systems",
        "s2_amplification": "Increase variety (specifically Im interoperability) to match S1 complexity",
        "s3_attenuation": "Decrease variety (specifically O observability) for S5 manageability",
        "principle": "Variety regulator must amplify/attenuate appropriately to maintain viability"
      },
      "m2:distinctionFromRelated": {
        "vs_Convergence": "Convergence/Divergence = spatial focusing/dispersing; Amplification/Attenuation = magnitude scaling",
        "vs_Transformation": "Transformation = qualitative change; Amplification/Attenuation = quantitative scaling with preserved structure",
        "vs_Regulation": "Regulation = homeostatic control toward setpoint; Amplification/Attenuation = gain operation",
        "vs_Process": "Process = generic temporal evolution; Amplification/Attenuation = specific scaling operation on flow",
        "vs_ValueSpace": "ValueSpace = space of possible values; Amplification = operation that changes value magnitude"
      },
      "m2:transdisciplinaryValidation": {
        "domains": [
          "Electronics: Operational amplifiers, voltage dividers, signal conditioning",
          "Biology: Enzymatic cascades (coagulation, complement), enzyme inhibition",
          "Cybernetics: VSM variety amplification (S2) and attenuation (S3)",
          "Optics: Lenses (magnification), filters (absorption), optical amplifiers (LASER)",
