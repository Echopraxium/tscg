      ],
      "m2:perspective": "hybrid",
      "m2:hybridView": {
        "description": "Bicephalous fusion - amplification/attenuation exists in Territory (Ft → D → It) AND is modeled in Map (R → O). Formula: Ft → D → It (ASFID) ⊗ R → O (REVOI).",
        "territoryComponent": {
          "basis": "ASFID",
          "dimensions": "Ft → D → It",
          "role": "Measured amplification/attenuation in physical systems (Eagle Eye)",
          "measures": {
