    {
      "@id": "m2:Threshold",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Threshold",
      "rdfs:comment": "Critical value triggering qualitative change in system behavior.",
      "m2:hasFamily": "m2:Regulatory",
      "m2:hasTensorFormula": "A ⊗ I",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Information"
      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Activation threshold",
        "Percolation threshold",
        "Tipping point"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "A → I",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "A \\otimes I",
      "m2:hasTensorFormulaASCII": "A (x) I",
      "m2:hasAttribute": {
        "threshold_behavior": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Sharpness and reversibility characteristics of threshold crossing",
          "m2:possibleValues": [
            {
              "value": "Sharp",
              "alternative_names": [
                "Step",
                "Discontinuous",
                "Bang-bang"
              ],
              "description": "Abrupt transition, near-zero transition width",
              "mathematical_form": "Heaviside step function H(x-x₀) or sgn(x-x₀)",
              "transition_width": "Δx → 0 (infinitesimal)",
              "examples": [
                "Digital logic gate (0V → 5V, sharp at ~2.5V)",
                "Neuron action potential (all-or-nothing spike)",
                "Phase transition (1st order: water→ice at 0°C)",
                "Comparator circuit (binary output)",
                "Relay switch (mechanical on/off)"
              ],
              "characteristics": "Binary output, no intermediate states, deterministic",
              "reversibility": "Typically reversible at same threshold (no hysteresis)",
              "sensitivity": "Infinite sensitivity at threshold (dOutput/dInput → ∞)",
              "noise": "Vulnerable to noise near threshold (chattering)"
            },
            {
              "value": "Smooth",
              "alternative_names": [
                "Graded",
                "Continuous",
                "Sigmoidal"
              ],
              "description": "Gradual transition over finite range",
              "mathematical_form": "Sigmoid σ(x) = 1/(1+e^(-k(x-x₀))) or tanh, erf",
              "transition_width": "Δx ~ 1/k (controlled by steepness k)",
              "examples": [
                "Fermi-Dirac distribution (electron occupation vs energy)",
                "Boltzmann probability (state occupation vs energy)",
                "Dose-response curve (pharmacology)",
                "Logistic growth (S-curve population)",
                "Analog activation function (neural networks)"
              ],
              "characteristics": "Graded response, intermediate states exist, continuous derivatives",
              "reversibility": "Typically reversible, same curve forward/backward",
              "sensitivity": "Maximum at midpoint, finite dOutput/dInput",
              "noise": "More robust to noise than sharp threshold",
              "temperature": "Physical smooth thresholds often from thermal fluctuations (kT)"
            },
            {
              "value": "Hysteretic",
              "alternative_names": [
                "Bistable",
                "Memory",
                "Toggle"
              ],
              "description": "Different thresholds for up-transition vs down-transition (memory effect)",
              "mathematical_form": "f(x, history) - output depends on past states",
              "transition_width": "Hysteresis loop width Δx = x_up - x_down",
              "examples": [
                "Ferromagnetic material (B-H curve with hysteresis loop)",
                "Schmitt trigger (electronics: different thresholds up/down)",
                "Mechanical latch/ratchet",
                "Gene regulatory bistable switch (lambda phage)",
                "Stick-slip friction",
                "Ecosystem regime shifts (different tipping points)"
              ],
              "characteristics": "Path-dependent, memory of history, bistable states",
              "reversibility": "Irreversible (different paths forward/backward)",
              "memory": "System 'remembers' previous state (even after input removed)",
              "energy_landscape": "Double-well potential with barrier",
              "stability": "Two stable states, resistant to small fluctuations",
              "applications": "Memory elements, debouncing switches, noise immunity"
            },
            {
              "value": "Stochastic",
              "alternative_names": [
                "Probabilistic",
                "Noisy"
              ],
              "description": "Threshold with probabilistic crossing due to noise",
              "mathematical_form": "P(cross|x) = distribution function with noise σ",
              "transition_width": "Determined by noise amplitude σ",
              "examples": [
                "Ion channel gating (stochastic opening/closing)",
                "Thermal activation over barrier (Arrhenius, Kramers rate)",
                "Noisy sensor with detection threshold",
                "Stochastic neuron firing (Poisson/Cox process)",
                "Brownian motion crossing barrier"
              ],
              "characteristics": "Probabilistic, noise-dominated, smooth probability profile",
              "reversibility": "Probabilistic (can cross back and forth randomly)",
              "kramers_rate": "Rate ~ exp(-ΔE/kT) for thermal activation",
              "noise_source": "Thermal fluctuations, quantum fluctuations, measurement noise",
              "ensemble": "Deterministic threshold + noise → probabilistic ensemble behavior",
              "first_passage": "First-passage time statistics (when threshold first crossed)"
            }
          ],
          "m2:default": "Sharp",
          "m2:usageGuidelines": "Use Sharp for digital/binary systems. Use Smooth for continuous biological/physical responses (RAAS receptor activation likely Smooth). Use Hysteretic for systems with memory/bistability (toggle switches). Use Stochastic for small-scale or noisy systems (ion channels).",
          "m2:comparison_table": {
            "Sharp": "Fast, binary, noise-sensitive, no memory",
            "Smooth": "Graded, continuous, noise-robust, no memory",
            "Hysteretic": "Binary, memory, noise-immune, slow",
            "Stochastic": "Probabilistic, ensemble, intrinsic noise"
          }
        }
      },
      "m3:semanticSignature": "attractor_boundary + information_criticality"
    },
    {
      "@id": "m2:Trigger",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Trigger",
