    {
      "@id": "m2:Gradient",
      "@type": "owl:Class",
      "rdfs:subClassOf": [
        "m2:GenericConcept",
        "m2:Observable"
      ],
      "rdfs:label": "Gradient",
      "rdfs:comment": "Spatial or temporal variation creating driving force for flows.",
      "m2:hasFamily": "m2:Ontological",
      "m2:hasTensorFormula": "⊗ ₂F or ⊗ ₂I",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information"
      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Temperature gradient",
        "Concentration gradient",
        "Potential difference"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "⊗ ₂F or ⊗ ₂I",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "\\otimes_2 F \\text{ ou } \\otimes_2 I",
      "m2:hasTensorFormulaASCII": "⊗₂F or ⊗₂I",
      "m2:hasAttribute": {
        "gradient_type": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Functional form of spatial or parametric variation",
          "m2:possibleValues": [
            {
              "value": "Linear",
              "description": "Constant rate of change (straight line)",
              "formula": "f(x) = mx + b, df/dx = m (constant slope)",
              "examples": [
                "Temperature gradient in metal rod (steady-state conduction)",
                "Concentration gradient (Fick's law diffusion)",
                "Gravitational potential near Earth surface (g·h)",
                "Voltage across resistor (Ohm's law)",
                "Linear color gradient (graphic design)"
              ],
              "characteristics": "Constant derivative, uniform rate of change, simplest gradient",
              "mathematics": "First-order polynomial, affine function",
              "diffusion": "Produces constant flux J = -D·(dc/dx)",
              "stability": "Stable (no inflection points)"
            },
            {
              "value": "Exponential",
              "description": "Rate of change proportional to current value (growth/decay)",
              "formula": "f(x) = A·e^(kx), df/dx = k·f(x) (proportional derivative)",
              "examples": [
                "Atmospheric pressure vs altitude (barometric formula)",
                "Radioactive decay (N(t) = N₀·e^(-λt))",
                "Population growth (unrestricted Malthusian)",
                "RC circuit charging/discharging",
                "Beer-Lambert law (light absorption: I(x) = I₀·e^(-μx))",
                "Neuronal membrane potential decay"
              ],
              "characteristics": "Self-similar, no characteristic scale, rapid growth/decay",
              "time_constant": "τ = 1/k (decay to 1/e ≈ 37%)",
              "asymptotic": "Approaches 0 (decay) or ∞ (growth)",
              "ubiquity": "Appears whenever df/dx ∝ f (natural processes)"
            },
            {
              "value": "Sigmoid",
              "alternative_names": [
                "S-curve",
                "Logistic",
                "Tanh"
              ],
              "description": "Smooth transition between two plateaus (saturation at extremes)",
              "formula": "f(x) = L/(1 + e^(-k(x-x₀))) (logistic) or tanh((x-x₀)/w)",
              "examples": [
                "Logistic growth (population with carrying capacity)",
                "Dose-response curve (pharmacology)",
                "Fermi-Dirac distribution (electron occupation)",
                "Hyperbolic tangent activation (neural networks)",
                "Phase transition smoothed by temperature (Ising model)",
                "Market penetration curve (technology adoption)"
              ],
              "characteristics": "Smooth, bounded, inflection point at midpoint, saturates",
              "parameters": {
                "L": "Upper asymptote (carrying capacity)",
                "k": "Steepness (inverse of transition width)",
                "x₀": "Midpoint (inflection point)",
                "w": "Width of transition region"
              },
              "symmetry": "Point-symmetric around (x₀, L/2)",
              "derivative_max": "At inflection point x = x₀",
              "limits": "lim_{x→-∞} f = 0, lim_{x→+∞} f = L"
            },
            {
              "value": "Step",
              "alternative_names": [
                "Heaviside",
                "Threshold",
                "Discontinuous"
              ],
              "description": "Abrupt jump from one level to another (discontinuous)",
              "formula": "f(x) = H(x - x₀) = {0 if x<x₀; 1 if x≥x₀} (Heaviside)",
              "examples": [
                "Phase transition (1st order: discontinuous jump at T_c)",
                "Digital logic threshold (low → high at V_th)",
                "Piecewise constant function",
                "Neuron firing threshold (all-or-nothing)",
                "Hydraulic jump (shock wave in fluid)"
              ],
              "characteristics": "Discontinuous, infinite derivative at transition, idealization",
              "reality": "Physical step always smoothed (finite width ~ 1/k)",
              "approximation": "Step ≈ lim_{k→∞} sigmoid",
              "distribution": "Derivative is Dirac delta: dH/dx = δ(x - x₀)",
              "processing": "Ideal comparator output"
            },
            {
              "value": "Power-law",
              "description": "Polynomial scaling f(x) = Ax^n",
              "formula": "f(x) = A·x^n, df/dx = nA·x^(n-1)",
              "examples": [
                "Gravitational/electrostatic potential (∝ 1/r)",
                "Diffusion profile (∝ x²)",
                "Fractals (self-similar with D ≠ integer)",
                "Zipf's law (word frequency)",
                "Kepler's 3rd law (T² ∝ r³)"
              ],
              "characteristics": "Scale-free (no characteristic length), self-similar",
              "exponent": "n > 0: growth; n < 0: decay; n = 1: linear"
            },
            {
              "value": "Gaussian",
              "alternative_names": [
                "Normal",
                "Bell curve"
              ],
              "description": "Bell-shaped curve centered at mean",
              "formula": "f(x) = A·exp(-(x-μ)²/(2σ²))",
              "examples": [
                "Normal distribution (statistics)",
                "Diffusion from point source (heat kernel)",
                "Beam profile (laser Gaussian beam)",
                "Error function (erf)"
              ],
              "characteristics": "Symmetric, localized, decays exponentially in tails"
            }
          ],
          "m2:default": "Linear",
          "m2:usageGuidelines": "Linear for uniform gradients (diffusion). Exponential for decay/growth processes. Sigmoid for transitions with saturation (dose-response, RAAS receptor saturation). Step for idealized thresholds. RAAS receptor activation: Sigmoid (saturates at high [Ang II], smooth response curve)"
        }
      },
      "m3:semanticSignature": "differential_variation + directional_flow_or_information",
      "m2:implements": {
        "@id": "m2:Observable"
      }
    },
