    {
      "@id": "m2:Signal",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Signal",
      "rdfs:comment": "Carrier of information through space or time, enabling communication between system components.",
      "m2:hasFamily": "m2:Informational",
      "m2:hasTensorFormula": "I ⊗ F",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Flow"
      ],
      "m2:hasEpistemicGap": 0.2,
      "m2:hasPolarity": "neutral",
      "m2:hasExample": [
        "Neural action potential",
        "Radio wave transmission",
        "Chemical messenger",
        "Digital signal (Shannon)"
      ],
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "I → F",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:hasTensorFormulaTeX": "I \\otimes F",
      "m2:hasTensorFormulaASCII": "I (x) F",
      "m2:hasAttribute": {
        "signal_type": {
          "@type": "m2:ValueSpace",
          "m2:valueType": "Discrete symbolic",
          "m2:description": "Representation and processing mode of information carrier",
          "m2:possibleValues": [
            {
              "value": "Analog",
              "description": "Continuous-valued signal in both time and amplitude",
              "mathematical_form": "s(t) ∈ ℝ, t ∈ ℝ (continuous everywhere)",
              "examples": [
                "Voltage in analog circuit (V(t) varies smoothly)",
                "Sound wave (pressure variation)",
                "Light intensity (photon flux)",
                "Temperature reading (analog thermometer)",
                "Hormonal concentration (RAAS: [Ang II](t))",
                "Analog telephone (voice on wire)"
              ],
              "characteristics": "Infinite resolution (in principle), subject to noise, continuous",
              "information_content": "Theoretically infinite (limited by noise in practice)",
              "noise": "Accumulates additively (SNR degrades with distance/processing)",
              "processing": "Operational amplifiers, filters, integrators, differentiators",
              "storage": "Difficult (capacitor leakage, tape degradation)",
              "bandwidth": "Limited by physical medium"
            },
            {
              "value": "Digital",
              "description": "Discrete-valued signal (quantized amplitude), typically discrete-time",
              "mathematical_form": "s[n] ∈ {0, 1, ..., 2^b-1}, n ∈ ℤ (discrete time and value)",
              "examples": [
                "Digital computer data (binary 0/1)",
                "Digital audio (CD: 16-bit samples at 44.1 kHz)",
                "Digital image (pixel values 0-255)",
                "Digital communication (binary modulation)",
                "Digital control (microcontroller output)"
              ],
              "characteristics": "Quantized amplitude (finite levels), discrete time (sampled)",
              "information_content": "Finite (b bits per sample)",
              "noise": "Immune below threshold (error correction possible), then hard failure",
              "processing": "Boolean logic, arithmetic, DSP algorithms",
              "storage": "Perfect (RAM, disk, flash - no degradation)",
              "sampling": "Nyquist theorem: f_sample ≥ 2f_max",
              "quantization_error": "Δ/2 RMS error (Δ = quantization step)"
            },
            {
              "value": "Discrete-event",
              "alternative_names": [
                "Event-driven",
                "Asynchronous",
                "Spike"
              ],
              "description": "Information encoded in discrete events (timing, not continuous amplitude)",
              "mathematical_form": "Sequence of events {t_i}, signal = Σ_i δ(t - t_i)",
              "examples": [
                "Neuronal action potentials (spike trains)",
                "Geiger counter (radioactive decay events)",
                "Customer arrivals (queueing theory)",
                "Network packets (asynchronous communication)",
                "Event-driven simulation (discrete-event systems)",
                "Photon counting (single-photon detectors)"
              ],
              "characteristics": "Information in event timing, asynchronous, sparse",
              "information_content": "In inter-event intervals (ISI distribution)",
              "encoding": {
                "rate_coding": "Information in firing rate (spikes/sec)",
                "temporal_coding": "Information in precise spike timing",
                "population_coding": "Information in synchronized ensemble"
              },
              "efficiency": "Energy-efficient (only transmit when event occurs)",
              "processing": "Event queues, integrate-and-fire, coincidence detection",
              "neuroscience": "All-or-nothing spikes, refractory period"
            },
            {
              "value": "Hybrid",
              "alternative_names": [
                "Mixed-signal",
                "Sampled-data"
              ],
              "description": "Combination of analog and digital components",
              "examples": [
                "Sampled-data control (analog plant, digital controller)",
                "ADC/DAC converters (analog ↔ digital interface)",
                "Mixed-signal IC (analog front-end + digital backend)",
                "Sigma-delta modulation (1-bit high-rate → multi-bit low-rate)",
                "RAAS with digital monitoring (analog biology + digital sensor)"
              ],
              "characteristics": "Analog + digital stages, interfaces between domains",
              "components": {
                "ADC": "Analog-to-Digital Converter (sampling + quantization)",
                "DAC": "Digital-to-Analog Converter (reconstruction + smoothing)",
                "sample_and_hold": "Capture analog value at instant"
              },
              "challenges": "Aliasing, quantization noise, timing jitter",
              "advantages": "Combines analog flexibility with digital precision"
            }
          ],
          "m2:default": "Analog",
          "m2:usageGuidelines": "Biological systems (RAAS) are typically Analog (continuous hormone concentrations) or Discrete-event (neuronal spikes). Digital for computer/communications. Hybrid for cyberphysical systems (sensors + digital control). Information Theory: analog_capacity C = B·log₂(1 + SNR) bits/sec (Shannon-Hartley); digital_reliability Error rates < 10^(-12) with coding; event_based_efficiency Only transmit when change occurs (sparse)."
        }
      },
      "m3:semanticSignature": "information_carrier + flow_transmission"
    },
