    {
      "@id": "m2:Composition",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Composition (Composition/Decomposition)",
      "rdfs:comment": "Bidirectional structural operation forming the fundamental duality of assembly and disassembly. Composition (bottom-up): aggregation of elementary parts into an emergent whole — the whole acquires properties (Attractor) absent from parts alone (S ⊗ I ⊗ A). Decomposition (top-down): partition of a whole into its elementary constituents — the Attractor (emergent property) dissolves, leaving only structure and interfaces (S ⊗ I). The asymmetry between the two poles is ontological: composition requires an Attractor (emergent property that justifies the assembly), while decomposition loses it.",
      "m2:hasFamily": "m2:Structural",
      "m2:hasTensorFormula": "S ⊗ I ⊗ A",
      "m2:hasTensorFormulaNote": "Decomposition pole: S ⊗ I — see m2:polaritySemantics",
      "m2:hasTensorFormulaExpanded": "Structure ⊗ Information ⊗ Attractor",
      "m2:hasTensorFormulaTeX": "S \\otimes I \\otimes A (composition)",
      "m2:hasTensorFormulaASCII": "S (x) I (x) A",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Attractor"
      ],
      "m2:hasEpistemicGap": 0.25,
      "m2:hasPolarity": "dual",
      "m2:polaritySemantics": {
        "pole1": {
          "name": "Composition",
          "direction": "Bottom-up (parts → whole)",
          "formula": "S ⊗ I ⊗ A",
          "formulaTeX": "S \\otimes I \\otimes A",
          "dimensionSemantics": {
            "S": "Structural arrangement of parts in the assembly",
            "I": "Interfaces and binding information between parts",
            "A": "Emergent property of the whole — absent from isolated parts"
          },
          "examples": [
            "LEGO bricks (S) + joints (I) → construction with form (A)",
            "H₂ + O (S, I) → H₂O with new chemical properties (A)",
            "R + G + B channels (S, I) → Color percept (A)",
            "Fuel + O₂ + Heat (S, I) → Flame with combustion dynamics (A)"
          ]
        },
        "pole2": {
          "name": "Decomposition",
          "direction": "Top-down (whole → parts)",
          "formula": "S ⊗ I",
          "formulaTeX": "S \\otimes I",
          "dimensionSemantics": {
            "S": "Structural inventory of recovered parts",
            "I": "Interface/bond information needed to identify parts"
          },
          "note": "Attractor (A) is absent from the Decomposition pole: the emergent property dissolves when the whole is partitioned. This asymmetry — Composition gains A, Decomposition loses A — is what distinguishes Composition from a mere bidirectional Transformation.",
          "examples": [
            "Construction → LEGO bricks (structure recovered, form lost)",
            "H₂O → H₂ + O (molecular structure recovered, liquid properties lost)",
            "Color → (R, G, B) triplet (channels recovered, percept lost)",
            "Flame → Fuel, O₂, Heat (forensics: components identified, combustion ceased)"
          ]
        },
        "dualityTension": "The asymmetry of the dual is ontological, not merely directional: Composition requires A (the emergent whole justifies the assembly); Decomposition loses A (no emergent property remains once the whole is partitioned). This makes Composition strictly irreversible in information terms: A cannot be reconstructed from S ⊗ I alone without re-performing the assembly."
      },
      "m2:perspective": "dual",
      "m2:eagleView": {
        "basis": "ASFID",
        "formulaComposition": "S ⊗ I ⊗ A",
        "formulaDecomposition": "S ⊗ I",
        "role": "Measure structural assembly (composition) or disassembly (decomposition) in Territory",
        "status": "IMMUTABLE"
      },
      "m2:sphinxView": {
        "formulaPrimary": {
          "basis": "REVOI",
          "formula": "R → I → V",
          "role": "Evaluate Map: is the assembled whole Representable (R), are interfaces Interoperable (I), is the composition Verifiable (V)?",
          "status": "PROPOSITION (validation in progress)"
        }
      },
      "m2:dimensionSemantics": {
        "S": "Structure — spatial/topological arrangement of components",
        "I": "Information — interfaces, bonds, binding protocols between parts",
        "A": "Attractor — emergent property of the whole (present in Composition, absent in Decomposition)"
      },
      "m2:couplingExplanation": "Structure (S) defines which parts exist and how they are arranged. Information (I) encodes the interfaces that bind parts together. Attractor (A) is the emergent outcome of the assembly — the property that 'the whole is more than the sum of its parts'. In Decomposition, S and I suffice to identify the parts, but A cannot be extracted since it is a property of the assembled whole.",
      "m2:distinctionFromRelated": {
        "vs_GenericConceptCombo": "GenericConceptCombo fuses genericConcepts (ontological level); Composition assembles structural PARTS into a whole (object level in Territory).",
        "vs_Imbrication": "Imbrication (S → S) = homothetic nesting of identical structures (self-similarity). Composition = assembly of HETEROGENEOUS parts into an emergent whole with distinct properties.",
        "vs_Modularity": "Modularity (S ⊗ I) = decomposition criterion for system design (how to partition). Composition includes the Attractor: WHY parts are assembled (emergent goal or property). Modularity ⊂ Composition (Modularity = Decomposition pole of Composition without the A dimension).",
        "vs_Transformation": "Transformation (S ⊗ F ⊗ D) = change of form/state over time. Composition = structural aggregation/partition — time (D) and flow (F) are not primary.",
        "vs_Hierarchy": "Hierarchy (S ⊗ A) = vertical control structure with levels. Composition = assembly operation (process); Hierarchy = the resulting structural relation (state)."
      },
      "m2:hasExample": [
        "Composition: LEGO bricks → construction (emergent form)",
        "Decomposition: Construction → LEGO bricks (form lost)",
        "Composition: Atoms → molecule (H₂ + O → H₂O)",
        "Decomposition: Molecule → atoms (H₂O → H₂ + O)",
        "Composition: Fuel + O₂ + Heat → Flame (combustion dynamics emerge)",
        "Decomposition: Flame → Fuel, O₂, Heat (forensics)",
        "Composition: R + G + B → Color percept (visual qualia emerges)",
        "Decomposition: Color → (R, G, B) triplet (spectral analysis)"
      ],
      "m2:shortName": "Composition",
      "m2:fullName": "Composition (Decomposition)",
      "dcterms:created": "2026-01-14",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m2:discoveryContext": "Fundamental structural operation identified during TSCG framework design. The asymmetric dual nature (Composition gains A, Decomposition loses A) distinguishes it from simple bidirectional Transformation. Corrected in v15.3.2: formula split from single concatenated string 'S ⊗ I ⊗ A (composition) / S ⊗ I (decomposition)' into proper m2:polaritySemantics structure with separate pole1/pole2 formulas.",
      "m2:versionHistory": {
        "v15_3_2_2026-02-18": "FORMAT CORRECTION: m2:hasTensorFormula was incorrectly encoding two pole formulas as a single concatenated string. Restructured using m2:polaritySemantics (pole1: S ⊗ I ⊗ A / pole2: S ⊗ I). Primary m2:hasTensorFormula now holds the Composition pole (S ⊗ I ⊗ A) as canonical reference. m2:eagleView and m2:sphinxView updated consistently."
      },
      "m2:expression": "S ⊗ I ⊗ A^{p}",
      "m2:expressionTeX": "S \\otimes I \\otimes A^{p}",
      "m2:poleMapping": {
        "p=1": {
          "name": "Composition",
          "formula": "S ⊗ I ⊗ A",
          "semantics": "A present: assembly produces emergent property absent from parts alone"
        },
        "p=0": {
          "name": "Decomposition",
          "formula": "S ⊗ I",
          "semantics": "A⁰ = 1 (neutral tensor element): emergent property dissolves, parts recovered"
        }
      },
      "m3:semanticSignature": "structural_assembly + polarity(composition|decomposition)"
    },
    {
      "@id": "m2:Balance",
