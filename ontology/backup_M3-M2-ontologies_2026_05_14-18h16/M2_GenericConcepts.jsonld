    {
      "@id": "m2:Entropy",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m2:GenericConcept",
      "rdfs:label": "Entropy (Entropy/Negentropy)",
      "rdfs:comment": "Measure of disorder, uncertainty, or irreversibility produced by a degrading flow. Entropy is the OUTPUT of Dissipation — it is the quantity that confers irreversibility on physical phenomena (Feynman: the equations of Dissipation are time-reversible; it is Entropy that makes processes effectively irreversible). Encompasses both thermodynamic entropy (Boltzmann: S=kB·lnΩ) and information entropy (Shannon: H=-Σp·logp). Pivot concept of the irreversibility chain: Dissipation→Entropy→Inertia→AbsorbingState.",
      "m2:hasFamily": "m2:Energetic",
      "m2:hasTensorFormula": "F ⊗ I ⊗ D",
      "m2:hasTensorFormulaTeX": "F \\otimes I \\otimes D",
      "m2:hasTensorFormulaASCII": "F (x) I (x) D",
      "m2:hasDominantM3": [
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Dynamics"
      ],
      "m2:hasEpistemicGap": 0.15,
      "m2:hasPolarity": "dual",
      "m2:shortName": "Entropy",
      "m2:fullName": "Entropy (Negentropy)",
      "m2:dualAspects": {
        "positiveAspect": {
          "name": "Entropy",
          "comment": "Disorder, uncertainty, irreversibility — ΔS > 0",
          "examples": ["Heat death", "Information erasure", "Ecosystem degradation"]
        },
        "negativeAspect": {
          "name": "Negentropy",
          "comment": "Order, structure, low uncertainty — ΔS < 0 locally (maintained by external exergy)",
          "examples": ["Living organisms", "Crystals", "Blockchain ordered phase"]
        }
      },
      "m2:perspective": "territory",
      "m2:eagleView": {
        "basis": "ASFID",
        "formula": "F → I → D",
        "role": "Measure observable phenomenon",
        "status": "IMMUTABLE"
      },
      "m2:feynmanNote": "Dissipation equations are time-reversible. Irreversibility is NOT intrinsic to Dissipation — it emerges from the Entropy it produces. Entropy is the quantity that breaks time-reversal symmetry at the macroscopic level.",
      "m2:reconciliationNote": "v6.5.0 noted 'Coherence^op = Entropy' — INCORRECT. Correct relations: Coherence^op = Incoherence (structural dual); Entropy^op = Negentropy (thermodynamic dual). Incoherence →[Dissipation]→ Entropy is a causal morphism, not a categorical duality.",
      "m2:generativeChain": "Dissipation(F⊗D) →produces→ Entropy(F⊗I⊗D) →[Memory]→ Inertia →[max]→ AbsorbingState",
      "m2:hasExample": [
        "Thermodynamic entropy: S = kB·ln(Ω) — Boltzmann",
        "Information entropy: H = -Σ p·log(p) — Shannon",
        "Blockchain immutability: ΔF(z) = z·kBTeff·ln(p/q) — Ranaora & Yii 2026",
        "Heat death of universe (max Entropy)",
        "Cellular negentropy: living organisms maintain local order via exergy input"
      ],
      "m2:distinctFrom": {
        "m2:Dissipation": "Dissipation (F⊗D) is the time-reversible MECHANISM; Entropy (F⊗I⊗D) is the irreversibility MEASURE it produces",
        "m2:Coherence": "Coherence (A⊗S⊗I⊗R⊗O) is structural/perceptual alignment; Entropy is thermodynamic disorder. Related causally: Incoherence→Entropy via Dissipation",
        "m2:Information": "Information (pure I) is content; Entropy is the measure of missing information / disorder in a flow"
      },
      "m3:semanticSignature": "degrading_flow + disorder_measure + irreversibility_via_feynman"
    },
    {
