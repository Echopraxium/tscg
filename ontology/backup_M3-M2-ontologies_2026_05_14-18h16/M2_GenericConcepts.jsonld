      "m2:poleMapping": {
        "p=0": {
          "name": "Positive Synergy",
          "formula": "+(I ⊗ D)",
          "semantics": "Combined effect > sum of parts: 1+1 > 2 (enhancement, amplification)"
        },
        "p=1": {
          "name": "Negative Synergy",
          "formula": "-(I ⊗ D)",
          "semantics": "Combined effect < sum of parts: 1+1 < 2 (antagonism, inhibition)"
        }
      },
      "m3:semanticSignature": "interaction_producing_emergent_value + polarity(positive|negative)"
    },
