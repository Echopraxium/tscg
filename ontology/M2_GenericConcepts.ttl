    m2:hasTensorFormulaTeX "S \\otimes I \\otimes A" ;
    m2:perspective "territory" ;
    m3:semanticSignature "structural_grouping + informational_cohesion + attractor_basin" ;
    rdfs:comment "Dense local grouping of nodes exhibiting synergistic cooperation and emergent functional properties (active processing role)." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Code> a owl:Class ;
    rdfs:label "Code" ;
    m2:eagleView [ ] ;
