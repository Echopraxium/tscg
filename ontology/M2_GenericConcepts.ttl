<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Teleonomic> a owl:Class ;
    rdfs:label "Teleonomic Family" ;
    m2:genericConceptCount 1 ;
