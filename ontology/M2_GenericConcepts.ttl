    m2:hasTensorFormula "⊗ ₂F or ⊗ ₂I" ;
    m2:hasTensorFormulaASCII "⊗₂F or ⊗₂I" ;
    m2:hasTensorFormulaTeX "\\otimes_2 F \\text{ ou } \\otimes_2 I" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Observable> ;
    m2:perspective "territory" ;
    m3:semanticSignature "differential_variation + directional_flow_or_information" ;
    rdfs:comment "Spatial or temporal variation creating driving force for flows." ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Observable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Hierarchy> a owl:Class ;
    rdfs:label "Hierarchy" ;
    m2:eagleView [ ] ;
