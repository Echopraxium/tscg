    m2:hasEpistemicGap 3.5e-01 ;
    m2:hasExample "Autonomous robot",
        "Economic actor",
        "Software agent" ;
    m2:hasFamily "m2:Relational" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I ⊗ D" ;
    m2:hasTensorFormulaASCII "S (x) I (x) D" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes D" ;
    m2:perspective "dual" ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "autonomous_structure + information_processing + dynamic_action" ;
    rdfs:comment "Active entity capable of autonomous action and interaction." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Balance> a owl:Class ;
    rdfs:label "Balance" ;
    m2:discoveryContext "Identified during analysis of Exposure Triangle poclet as fundamental genericConcept distinct from existing Homeostasis and Regulation" ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Accounting balance: Assets = Liabilities + Equity",
        "Chemical equilibrium: Reactants → Products at constant concentrations",
        "Energy balance: Heat input = Heat output (steady state)",
        "Nutritional balance: Proteins → Carbohydrates → Fats",
        "Photographic exposure: ISO → Aperture → Shutter Speed → correct exposure",
        "Tonal balance in audio: Bass → Mid → Treble frequencies",
        "Work-life balance: Professional commitments → Personal time" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "A ⊗ S ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) S (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes S \\otimes F" ;
    m2:perspective "territory" ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "attractor_equilibrium + structural_symmetry + flow_compensation" ;
    dcterms:created "2026-01-20" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "State of equilibrium between multiple interacting factors where variations compensate to maintain system stability. Distinct from Homeostasis (dynamic regulation) - Balance is a static equilibrium state achieved through mutual compensation of parameters." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Behavior> a owl:Class ;
    rdfs:label "Behavior" ;
    m2:decompositionProperty [ m2:cardinalityMin 1 ;
            m2:componentType "m2:Step" ;
            m2:relationProperty "m2:decomposedInto" ;
            rdfs:comment "Behavior decomposes into Steps" ] ;
    m2:discoveryContext "Emerged from need to model sequential yet decomposable patterns in poclets (Butterfly metamorphosis, Blood pressure control). Bridges Process (pure temporal) and Network (pure structural) by fusing both aspects." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "HTTP request handling (receive-parse-process-respond pattern)",
        "Learning algorithm (initialize-iterate-converge pattern)",
        "Photosynthesis (light-water-CO2 coordination pattern)",
        "Predator hunting sequence (stalk-chase-capture pattern)" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "S ⊗ D ⊗ F" ;
    m2:hasTensorFormulaASCII "S (x) D (x) F" ;
    m2:hasTensorFormulaTeX "S \\otimes D \\otimes F" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Observable> ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "structural_repertoire + dynamic_execution + flow_expression" ;
    dcterms:created "2026-01-28" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Network of coordinated Steps that can be decomposed and analyzed. Represents structured operational pattern observable in Territory and modelable in Map. Distinct from Process (pure temporal sequence) by adding structural decomposability." ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Observable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Bifurcation> a owl:Class ;
    rdfs:label "Bifurcation" ;
    m2:eagleView [ ] ;
    m2:hasAttribute [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow" ;
    m2:hasEpistemicGap 4e-01 ;
    m2:hasExample "Ecosystem regime shifts",
        "Phase transitions" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "∂D/∂F" ;
    m2:hasTensorFormulaASCII "dD/dF" ;
    m2:hasTensorFormulaTeX "\\partial D / \\partial F" ;
    m2:perspective "territory" ;
    m3:semanticSignature "dynamics_sensitivity_to_flow + threshold_crossing + qualitative_state_change" ;
    rdfs:comment "Qualitative change in system behavior at critical parameter threshold." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Capacity> a owl:Class ;
    rdfs:label "Capacity" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "Carrying capacity",
        "Channel bandwidth (Shannon)",
        "Memory size",
        "Throughput" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I" ;
    m2:hasTensorFormulaASCII "S (x) I" ;
    m2:hasTensorFormulaTeX "S \\otimes I" ;
    m2:perspective "territory" ;
    m3:semanticSignature "structural_volume + information_limit" ;
    rdfs:comment "Upper structural limit or maximal potential of system." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Cascade> a owl:Class ;
    rdfs:label "Cascade" ;
    m2:cascadeTypes [ ] ;
    m2:couplingExplanation "Dynamics (D) creates triplet coupling: temporal evolution (Process) + sequential ordering (Step) + goal-directed progression (Trajectory). Flow (F) couples material/energy transfer (Process) with state-space navigation (Trajectory). Result is a staged temporal evolution toward goal state." ;
    m2:dimensionSemantics [ ] ;
    m2:discoveryContext "Identified during RAAS analysis (poclet). Initially proposed as binary Process ⊗ Step (v14.3.5), lacking Attractor dimension. Michel identified need for Trajectory component to capture goal-directed evolution. Led to generalization of GenericConceptCombo to N-ary (N≥2) and first ternary genericConcept combo. Cascade now covers all 5 ASFID dimensions (S ⊗ I ⊗ A ⊗ D ⊗ F), making it the most complete GenericConceptCombo in M2." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasAttribute [ ] ;
    m2:hasComboComponent <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Process>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Step>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trajectory> ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Blood coagulation cascade: Factor XII → ... → Fibrin clot formation (goal: hemostasis)",
        "Compiler pipeline: Source → Lexer → Parser → Optimizer → Codegen (goal: executable)",
        "Developmental cascade: Zygote → Blastula → Gastrula → ... → Adult (goal: mature organism)",
        "MAPK signaling: MAPKKK → MAPKK → MAPK → Transcription (goal: gene expression)",
        "Nuclear chain reaction: Neutron → Fission → n Neutrons → ... (goal: critical mass)",
        "Photomultiplier tube: Photon → Dynode₁ → ... → Anode (amplifying cascade, goal: detectable signal)",
        "RAAS hormonal cascade: Renin → Angiotensin I → Angiotensin II → BP homeostasis (Linear trajectory to Attractor)",
        "Waterfall cascade: Upper pool → Drop → Pool → ... (goal: lower elevation equilibrium)" ;
    m2:hasFamily "m2:Combo" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "⊗⇒(Process, Step, Trajectory)" ;
    m2:hasTensorFormulaASCII "S (x) I (x) A (x) D (x) F" ;
    m2:hasTensorFormulaExpanded "S ⊗ I ⊗ A ⊗ D ⊗ F" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes A \\otimes D \\otimes F" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Triggerable> ;
    m2:mathematicalProperties [ ] ;
    m2:parentGenericConcepts <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Process>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Step>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trajectory> ;
    m2:perspective "dual" ;
    m2:sharedDimensions [ ] ;
    m2:significance "First GenericConceptCombo to achieve full ASFID coverage (5D). Demonstrates power of N-ary composition. Validates that ternary combinations can produce emergent genericConcepts with properties that no binary combination provides." ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "sequential_amplification + irreversible_propagation + trajectory_shaping" ;
    dcterms:created "2024-11-15" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:modified "2026-02-06" ;
    rdfs:comment "Sequential multi-stage process where output of each step becomes input of next step, following a trajectory toward goal state. Synergistic ternary combination: Process (temporal evolution with flow) + Step (structured stages with information transfer) + Trajectory (goal-directed path through state space). Covers ALL five ASFID dimensions. Distinguished from binary Process ⊗ Step by addition of Attractor dimension, enabling goal-directed cascades (e.g., homeostatic regulation, development toward mature state). May or may not include amplification at each stage." ;
    rdfs:subClassOf "m2:GenericConceptCombo",
        "m2:Triggerable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Channel> a owl:Class ;
    rdfs:label "Channel" ;
    m2:distinction [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 1.5e-01 ;
    m2:hasExample "Audio stereo channels (Left, Right)",
        "CMYK ink channels in printing (Cyan, Magenta, Yellow, Key/Black)",
        "Communication frequency bands (radio, wifi)",
        "Distribution channels in economics",
        "Ion channels in cell membranes (Na+, K+, Ca2+)",
        "RGB color channels (Red, Green, Blue in displays)" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I ⊗ F" ;
    m2:hasTensorFormulaASCII "S (x) I (x) F" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes F" ;
    m2:perspective "dual" ;
    m2:properties [ ] ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "structural_conduit + information_carrier + flow_direction" ;
    rdfs:comment "Structured conduit for signal transmission. Isolates one dimension, filters content, has finite capacity. Permanent structure independent of signals transmitted." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Cluster> a owl:Class ;
    rdfs:label "Cluster" ;
    m2:eagleView [ ] ;
