@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m2: <M2_GenericConcepts.jsonld#> .
@prefix m3: <M3_GenesisSpace.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Action> a owl:Class ;
    rdfs:label "Action" ;
    m2:atomicity [ m2:granularity "Elementary operational unit" ;
            rdfs:comment "Action is atomic - not further decomposable in behavioral context" ] ;
    m2:discoveryContext "Identified as atomic operational unit in behavioral decomposition. Represents finest-grained executable element triggered by Steps in Behavior/Workflow networks." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 1.5e-01 ;
    m2:hasExample "Baroreceptor activation (triggered by sense step)",
        "Cell division (triggered by egg stage step)",
        "Gradient descent update (triggered by training step)",
        "HTTP tokenize (triggered by parse step)",
        "Heat butter (triggered by make roux step)" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "D ⊗ I" ;
    m2:hasTensorFormulaASCII "D (x) I" ;
    m2:hasTensorFormulaTeX "D \\otimes I" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Triggerable> ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:sphinxView [ ] ;
    m2:triggeringProperty [ m2:relationProperty "m2:triggeredBy" ;
            m2:triggerSource "m2:Step" ;
            rdfs:comment "Action is triggered by Step" ] ;
    m3:semanticSignature "dynamic_execution + information_triggered" ;
    dcterms:created "2026-01-28" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Atomic operation triggered by a Step. Elementary executable unit with informational content. Represents indivisible operation in behavioral or workflow context." ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Triggerable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Activation> a owl:Class ;
    rdfs:label "Activation (Activation/Inhibition)" ;
    m2:dualAspects [ ] ;
    m2:eagleView [ ] ;
    m2:expression "(-1)^{p} (A ⊗ D)" ;
    m2:expressionTeX "(-1)^{p} (A \\otimes D)" ;
    m2:fullName "Activation (Inhibition)" ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Access control",
        "Enzyme activation/inhibition",
        "Neural excitation/inhibition" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "A ⊗ D" ;
    m2:hasTensorFormulaASCII "A (x) D" ;
    m2:hasTensorFormulaTeX "A \\otimes D" ;
    m2:perspective "dual" ;
    m2:poleMapping [ ] ;
    m2:shortName "Activation" ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "dynamic_state_change + polarity(activation|inhibition)" ;
    rdfs:comment "Enabling or blocking of processes or pathways." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Adaptation> a owl:Class ;
    rdfs:label "Adaptation" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 3e-01 ;
    m2:hasExample "Bacterial antibiotic resistance",
        "Neural plasticity" ;
    m2:hasFamily "m2:Adaptive" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "I ⊗ F ⊗ D" ;
    m2:hasTensorFormulaASCII "I (x) F (x) D" ;
    m2:hasTensorFormulaTeX "I \\otimes F \\otimes D" ;
    m2:perspective "territory" ;
    m3:semanticSignature "information_driven + flow_modification + dynamic_change" ;
    rdfs:comment "Progressive modification of structure or behavior in response to environmental changes." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Adaptive> a owl:Class ;
    rdfs:label "Adaptive Family" ;
    m2:genericConceptCount 4 ;
    rdfs:comment "Learning, evolution, environmental response. High I, medium F." ;
    rdfs:subClassOf "m2:GenericConceptFamily" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Agent> a owl:Class ;
    rdfs:label "Agent" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information",
