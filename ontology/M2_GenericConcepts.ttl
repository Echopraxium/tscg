<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Scope> a owl:Class ;
    rdfs:label "Scope" ;
    m2:discoveryContext "Identified during VSM M0 modeling refinement. Required to properly model Autonomy as GenericConceptCombo(Agent, Scope) where Agent provides action capability and Scope provides bounded domain of authority. Fills semantic gap between Constraint (prohibition) and Domain (entire field). Essential for authorization, delegation, and jurisdictional concepts." ;
    m2:distinctionFromRelated [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure",
        "m3:sphinx_eye:Representable" ;
    m2:hasEpistemicGap 3.5e-01 ;
    m2:hasExample "Biology: Animal territory (defended area)",
        "Juridical: Jurisdiction boundaries, territorial scope",
        "Linguistics: Scope of quantifier in logic",
        "Management: Span of control, delegation scope",
        "Mathematics: Domain of function (ensemble de définition)",
        "Network: Broadcast domain, routing scope",
        "Optics: Depth of field (zone of acceptable sharpness)",
        "Programming: Variable scope (lexical, global, block)",
        "Project management: Project scope definition",
        "VSM: S1 operational authority scope (Beer 1979)" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S → I → A → R" ;
    m2:hasTensorFormulaASCII "S (x) I (x) A (x) R" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes A \\otimes R" ;
    m2:perspective "map" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "structural_boundary + information_range + attractor_reach + representational_extent" ;
    dcterms:created "2026-02-03" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Domain of validity or applicability where an entity, rule, or authority has effect. Defines a positive boundary of what is permitted or possible, in contrast to Constraint (which defines what is prohibited). Fundamental to autonomy, jurisdiction, and authorization concepts across multiple domains." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Segmentation> a owl:Class ;
    rdfs:label "Segmentation" ;
    m2:distinctionNote "Segmentation partitions by structural/similarity criteria (homogeneous regions sharing properties), while Modularity decomposes by functional criteria (autonomous units with specific roles). Both are decomposition operations but differ in their partitioning logic." ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 3e-01 ;
    m2:hasExample "Body segmentation (metameres, somites) - developmental biology",
        "Genome segmentation (genes, regulatory regions) - genomics",
        "Image segmentation (edge detection, region growing) - computer vision",
        "Market segmentation (demographic, behavioral) - marketing",
        "Phonetic segmentation (speech-to-text) - linguistics",
        "Territorial segmentation (zoning) - urban planning" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I ⊗ D" ;
    m2:hasTensorFormulaASCII "S (x) I (x) D" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes D" ;
    m2:perspective "territory" ;
    m3:semanticSignature "structural_partition + informational_boundaries + dynamic_differentiation" ;
    rdfs:comment "Partition of a whole into homogeneous segments according to similarity, continuity, or structural criteria. Analytical decomposition producing distinct but exhaustive regions (vs functional decomposition in Modularity)." ;
    rdfs:seeAlso "m2:Cluster",
        "m2:Modularity" ;
    rdfs:subClassOf "m2:GenericConcept" .

