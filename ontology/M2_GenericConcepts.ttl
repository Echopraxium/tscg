<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Topology> a owl:Class ;
    rdfs:label "Topology" ;
    m2:distinctionNote "Topology classifies structures by connectivity properties (model-theoretic abstraction), while Network represents concrete structural instances (reality-theoretic). Structure (M3) is the raw arrangement, Topology extracts its invariant equivalence class." ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Cognitive maps and mental spaces - psychology",
        "DNA supercoiling and knotting - molecular biology",
        "Metro connectivity diagrams - urban planning",
        "Network topology types (star, ring, mesh) - computer science",
        "Social network structure patterns - sociology",
        "Topological invariants (genus, Euler characteristic) - mathematics" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I" ;
    m2:hasTensorFormulaASCII "S (x) I" ;
    m2:hasTensorFormulaTeX "S \\otimes I" ;
    m2:perspective "territory" ;
    m3:semanticSignature "structural_connectivity + informational_adjacency" ;
    rdfs:comment "Classification of structural properties preserved under continuous deformations: connectivity, compactness, genus. Captures the TYPE or CLASS of structure independent of metric, enabling structural pattern recognition across domains." ;
    rdfs:seeAlso "m2:Invariant",
        "m2:Network",
        "m2:Symmetry" ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trade-off> a owl:Class ;
    rdfs:label "Trade-off" ;
    m2:changeLog [ ] ;
    m2:discoveryContext "Identified during analysis of Exposure Triangle poclet as fundamental Map-space genericConcept capturing photographer's decision-making under constraints" ;
    m2:distinctionFromRelated [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 3e-01 ;
    m2:hasExample "Biology: r-strategy → K-strategy (many offspring vs few cared-for)",
        "Computer Science: Time complexity → Space complexity",
        "Economics: Inflation → Unemployment (Phillips curve)",
        "Engineering: Speed → Precision (fast but rough → slow but accurate)",
        "Machine Learning: Bias → Variance (underfitting → overfitting)",
        "Photography: Shallow DoF (artistic blur) ⊗ Deep DoF (all sharp) via aperture",
        "Project Management: Cost → Quality → Time (iron triangle)",
        "Reinforcement Learning: Exploration → Exploitation" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasOntologicalNature "ModelSpace" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "A ⊗ I ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) I (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes I \\otimes F" ;
    m2:perspective "map" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "attractor_optimization + information_constraint + flow_cost" ;
    dcterms:created "2026-01-20" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:modified "2026-02-18" ;
    rdfs:comment "Deliberate exchange where improving one desirable property necessarily degrades another due to inherent constraints. A conscious decision-making concept in model/map space where observer accepts losses in one dimension to gain in another. Fundamental to optimization under constraints." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trigger> a owl:Class ;
    rdfs:label "Trigger" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "Interrupt handler",
        "Reflex stimulus",
        "Signal transduction trigger" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "D ⊗ I" ;
    m2:hasTensorFormulaASCII "D (x) I" ;
    m2:hasTensorFormulaTeX "D \\otimes I" ;
    m2:perspective "territory" ;
    m3:semanticSignature "dynamic_activation + information_condition" ;
    rdfs:comment "Initiating stimulus for process activation." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Tropism> a owl:Class ;
    rdfs:label "Tropism" ;
    m2:discoveryContext "Recognized as specialized Behavior pattern prevalent in biological systems (phototropism, chemotaxis, geotropism). Extends Behavior by adding Attractor dimension to capture directional constraint." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:gradientProperty [ m2:relationProperty "m2:hasGradient" ;
            m2:sourceType "m3:eagle_eye:Attractor" ;
            rdfs:comment "Tropism is directed by an Attractor gradient" ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 1.8e-01 ;
    m2:hasExample "Chemotaxis (bacteria towards nutrient gradient)",
        "Geotropism (plant roots towards gravity)",
        "Negative phototropism (roots away from light)",
        "Phototropism (plant stem towards light source)",
        "Thermotaxis (organism towards optimal temperature)" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "A ⊗ S ⊗ D ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) S (x) D (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes S \\otimes D \\otimes F" ;
    m2:inheritedFrom "m2:Behavior" ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:specialization [ ] ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "attractor_directed + structural_orientation + dynamic_response + flow_driven" ;
    dcterms:created "2026-01-28" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Specialized Behavior directed by external gradient stimulus. Orientation or movement towards (positive) or away from (negative) an Attractor source. Inherits network decomposability from Behavior while adding directional constraint." ;
    rdfs:subClassOf "m2:Behavior" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#ValueSpace> a owl:Class ;
    rdfs:label "ValueSpace (Hybrid Variety Model)" ;
    m2:ashbyPrinciple [ ] ;
    m2:discoveryContext "Required for VSM modeling to formalize Ashby's Law of Requisite Variety. Emerged from need to represent value/state spaces with bicephalous perspective: Territory (what values exist - It) AND Map (how we model them - VORI). The ItVORIm mnemonic order provides epistemic progression where subscripts t/m explicitly mark the Territory/Map boundary. Generalizes beyond system states to any property's value domain (scalar, vector, tensor, symbolic, hybrid). Essential for variety amplification (S2) and attenuation (S3) in VSM." ;
    m2:distinctionFromRelated [ ] ;
    m2:hasDominantM3 "HYBRID: It from ASFID (Eagle Eye) + V → O → R → Im from REVOI (Sphinx Eye)" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "Cybernetics: S1 operational variety in VSM (It=state count, VORI=model quality)",
        "Hybrid: VSM S1 state = Mode×Performance (It=discrete×continuous, VORI varies)",
        "Scalar continuous: Temperature [0,100]°C (It=continuous, VORI=high)",
        "Symbolic discrete: Alphabet {A-Z} (It=log₂(26)≈4.7 bits, VORI=standard encoding)",
        "Tensor product 5D: Process genericConcept D → I → F (It=tensor dimension, VORI contextual)",
        "Vector 3D discrete: RGB color [0,255]³ (It=24 bits, VORI=perfect digital)" ;
    m2:hasFamily "m2:Informational" ;
    m2:hasPolarity "hybrid" ;
    m2:hasTensorFormula "It → V → O → R → Im" ;
    m2:hasTensorFormulaASCII "I_t (x) V (x) O (x) R (x) I_m" ;
    m2:hasTensorFormulaTeX "I_t \\otimes V \\otimes O \\otimes R \\otimes I_m" ;
    m2:hybridView [ ] ;
    m2:mathematicalProperties [ ] ;
    m2:perspective "hybrid" ;
    m2:polarityDescription [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m2:valueSpaceTypes [ ] ;
    m3:semanticSignature "territory_information + variety + observability + representability + map_interoperability" ;
    dcterms:created "2026-01-31" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Space of possible values for a property or object. Can be scalar (e.g., temperature range), vector (e.g., RGB 3D color components), tensor product (e.g., 5D ASFID genericConcept formulas), or symbolic (e.g., alphabet symbols). Values can be discrete or continuous. Characterized both by intrinsic information content (Territory) and epistemic model quality (Map). Foundation for Ashby's Law of Requisite Variety in cybernetics. Mnemonic: ItVORIm (subscripts t/m mark Territory/Map boundary)." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Workflow> a owl:Class ;
    rdfs:label "Workflow" ;
    m2:discoveryContext "Needed to distinguish prescriptive models (Workflow) from descriptive observations (Behavior). Both are structured networks of Steps, but serve different epistemic roles." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2.2e-01 ;
    m2:hasExample "Clinical protocol (diagnosis-treatment-followup procedure)",
        "Manufacturing process workflow (assembly steps)",
        "Recipe (cooking steps with dependencies)",
        "Software CI/CD pipeline (build-test-deploy sequence)" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "S ⊗ D ⊗ F" ;
    m2:hasTensorFormulaASCII "S (x) D (x) F" ;
    m2:hasTensorFormulaTeX "S \\otimes D \\otimes F" ;
    m2:implementationProperty [ m2:relationProperty "m2:implementsProcess" ;
            m2:semantics "One Process can have multiple Workflow implementations" ;
            m2:targetType "m2:Process" ;
            rdfs:comment "Workflow implements Process" ] ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "structured_sequence + dynamic_execution + flow_coordination" ;
    dcterms:created "2026-01-28" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Structured network implementation of a Process. Prescriptive representation (Map-oriented) of how a Process should be executed, distinct from Behavior (descriptive observation of what occurs). Can be simulated or prescribed." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#categoryTheory> a owl:AnnotationProperty ;
    rdfs:label "category theory" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Annotation documenting the category-theoretic structure of an M2 ontology. Value is a JSON object describing functors (tensorization, instantiation) and morphisms (inclusion, composition, duality, emergence) between TSCG layers." ;
    rdfs:domain "m2:M2_GenericConcepts" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#characterizedBy> a owl:ObjectProperty ;
    rdfs:label "characterized by" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a M1 KnowledgeFieldConcept with the M2 GenericConcept(s) that characterize its systemic structure. Replaces the heterogeneous m2Basis fields (m1:biology:m2Basis, m1:M2_basis, m1core:m2Basis, m1:chemistry:instantiatesGenericConcept) across M1 files with a single normalized ObjectProperty. Semantics: 'this M1 concept EXHIBITS the pattern of / is characterized by this M2 GenericConcept'. Distinct from rdfs:subClassOf (IS-A) — a ChemicalReaction is not IS-A Process in the strict OWL sense across all inferred properties, but IS characterized-by m2:Process." ;
    rdfs:domain "owl:Class" ;
    rdfs:range "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#comboRole> a owl:DatatypeProperty ;
    rdfs:label "combo role" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Describes the semantic role of a GenericConcept within a GenericConceptCombo. Used inside m2:hasComboComponent structured objects. Examples: 'core_mechanism', 'medium', 'material', 'constraint', 'trigger', 'context', 'amplifier', 'regulator'." ;
    rdfs:range "xsd:string" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#componentOf> a owl:ObjectProperty ;
    rdfs:label "component of" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "States that a GenericConcept is a structural component of another GenericConcept. Inverse of m2:decomposedInto. Example: m2:Node componentOf m2:Network." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" ;
    owl:inverseOf "m2:decomposedInto" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#decomposedInto> a owl:ObjectProperty ;
    rdfs:label "decomposed into" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "States that a GenericConcept can be analytically decomposed into another. Inverse of m2:componentOf. Example: m2:Network decomposedInto m2:Node." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" ;
    owl:inverseOf "m2:componentOf" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#dualAspects> a owl:ObjectProperty ;
    rdfs:label "dual aspects" ;
    rdfs:domain "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#dualCounterpart> a owl:ObjectProperty ;
    rdfs:label "dual counterpart" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Links two GenericConcepts that are structural duals of each other: they share a common parent genericConcept but differ in their operational polarity. Distinguished from m2:GenericConceptPair: dualCounterpart links two DIFFERENT top-level GenericConcepts (e.g. LALI ↔ ButterflyEffect), whereas a GenericConceptPair encapsulates both poles within a single GenericConcept." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" ;
    owl:symmetricProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#eagleView> a owl:ObjectProperty ;
    rdfs:label "eagle view" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a GenericConcept with its Eagle Eye (Territory-Space) measurement characterization. Value is a structured object containing: basis (always 'ASFID'), formula (ASFID directional formula), role, and status ('IMMUTABLE'). Eagle Eye perspective uses ASFID dimensions to measure observable phenomena." ;
    rdfs:domain "m2:GenericConcept" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#expression> a owl:DatatypeProperty ;
    rdfs:label "expression" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Parametric formula string expressing the mathematical structure of a GenericConceptPair in terms of a scalar parameter p ∈ {0,1}. Examples: '(-1)^{p} (I ⊗ D)' for SignPairs, 'S ⊗ I ⊗ A^{p}' for DimensionPairs. Null or absent for StructuralPairs (use m2:poleMapping instead)." ;
    rdfs:domain "m2:GenericConceptPair" ;
    rdfs:range "xsd:string" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#fullName> a owl:DatatypeProperty ;
    rdfs:label "full name" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:string" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasComboComponent> a owl:ObjectProperty ;
    rdfs:label "has combo component" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a GenericConceptCombo with one of its constituent parent GenericConcepts. Each component value is a structured object with '@id' (the parent GenericConcept) and 'm2:comboRole' (the semantic role of that component in the combo). The set of hasComboComponent values fully determines the combo's tensor formula via union of the parent dimension sets." ;
    rdfs:domain "m2:GenericConceptCombo" ;
    rdfs:range "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasDominantM3> a owl:ObjectProperty ;
    rdfs:label "has dominant M3 dimension" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m3:M3Dimension" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasEpistemicGap> a owl:DatatypeProperty ;
    rdfs:label "has epistemic gap" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:decimal" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasExample> a owl:DatatypeProperty ;
    rdfs:label "has example" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:string" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasFamily> a owl:ObjectProperty ;
    rdfs:label "has family" ;
    rdfs:comment "Associates a genericConcept with its GenericConceptFamily. Renamed from hasCategory to hasFamily to align with the renaming of m2:Category to m2:GenericConceptFamily." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConceptFamily" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasGradient> a owl:ObjectProperty ;
    rdfs:label "has gradient" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a GenericConcept with a Gradient genericConcept that drives its dynamics. A gradient is a scalar Flow dimension (F, 1D tensor product) representing the differential that causes directed movement or change. Example: m2:Transport hasGradient m2:Gradient." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:Gradient" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasPolarity> a owl:DatatypeProperty ;
    rdfs:label "has polarity" ;
    m2:allowedValues "dual",
        "neutral" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:string" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#hasTensorFormula> a owl:DatatypeProperty ;
    rdfs:label "has tensor formula" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:string" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#implements> a owl:AnnotationProperty ;
    rdfs:label "implements" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Documents that a GenericConcept implements a ConceptContract. Complementary to the rdfs:subClassOf mixin — provides explicit, human-readable declaration of intent. Example: m2:Event m2:implements m2:Triggerable. The structural inference (IS-A Triggerable) is carried by rdfs:subClassOf; this annotation carries the semantic intent." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:ConceptContract" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#implementsProcess> a owl:ObjectProperty ;
    rdfs:label "implements process" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a structural GenericConcept (e.g. m2:Processor) with a process-type GenericConcept it instantiates or executes (e.g. m2:Process, m2:Workflow). Models the relationship between structural containers and the dynamic processes they carry out." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#morphism_emergence> a owl:AnnotationProperty ;
    rdfs:label "morphism emergence" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Annotation string describing the emergence morphism operator (⇒) used in category-theoretic formalism of the TSCG M2 layer. Example: '⇒ (e.g., multiple ⇒ emergent)'." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#polaritySemantics> a owl:ObjectProperty ;
    rdfs:label "polarity semantics" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Describes the semantic content of each pole in a dual or N-ary GenericConcept. Value is an object with named poles (pole1/pole2 or p=0/p=1), each containing name, description, formula and examples. Used for GenericConceptPairs and dual genericConcepts like LALI/ButterflyEffect." ;
    rdfs:domain "m2:GenericConcept" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#poleMapping> a owl:ObjectProperty ;
    rdfs:label "pole mapping" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Defines the explicit semantic mapping of each pole in a GenericConceptPair (StructuralPair subtype). Value is an object with 'pole1' and 'pole2' entries, each specifying name, formula, cardinality and semantics. Used when m2:expression is insufficient (StructuralPairs: direction/cardinality reversals)." ;
    rdfs:domain "m2:GenericConceptPair" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#shortName> a owl:DatatypeProperty ;
    rdfs:label "short name" ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "xsd:string" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#sphinxView> a owl:ObjectProperty ;
    rdfs:label "sphinx view" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Associates a GenericConcept with its Sphinx Eye (Map-Space) interpretation characterization. Value is a structured object containing a primary formula (REVOI basis, PROPOSITION status) and a fallback formula (ASFID basis, GUARANTEED). Sphinx Eye perspective uses REVOI dimensions to evaluate map quality." ;
    rdfs:domain "m2:GenericConcept" ;
    owl:functionalProperty true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#triggeredBy> a owl:ObjectProperty ;
    rdfs:label "triggered by" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "States that a GenericConcept (event, process, or state transition) is initiated or caused by another GenericConcept. Captures causal and temporal precedence between systemic patterns. Inverse of m2:triggers." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" ;
    owl:inverseOf "m2:triggers" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#triggers> a owl:ObjectProperty ;
    rdfs:label "triggers" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "States that a GenericConcept initiates or causes another GenericConcept (event, process, or state change). Inverse of m2:triggeredBy." ;
    rdfs:domain "m2:GenericConcept" ;
    rdfs:range "m2:GenericConcept" ;
    owl:inverseOf "m2:triggeredBy" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Alignment> a owl:Class ;
    rdfs:label "Alignment" ;
    m2:distinctFrom [ m2:Balance "Balance is a static equilibrium state; Alignment is an active process toward coherence" ;
            m2:Convergence "Convergence concerns geometric focusing of trajectories; Alignment concerns structural/semantic correspondence between entities" ;
            m2:Representation "Representation is a static structural mapping (A→B); Alignment is an iterative bidirectional process reducing discrepancy (A↔B)" ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "AI alignment (computer science)",
        "DNA sequence alignment (bioinformatics)",
        "Organizational strategic alignment (management)",
        "Planetary alignment (astronomy)",
        "Territory↔Map alignment via Φ/Ψ operators (TSCG - see m3:AlignmentLoop)",
        "Wheel alignment (mechanics)" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "I ⊗ A ⊗ S" ;
    m2:perspective "dual" ;
    m3:semanticSignature "information_coherence + attractor_convergence + structural_correspondence" ;
    rdfs:comment "Bidirectional dynamic process by which two entities, representations, or systems progressively reduce their mutual discrepancy toward a coherent correspondence. Distinct from Representation (static mapping A→B), Balance (static equilibrium), and Convergence (geometric focusing of trajectories): Alignment is an active, iterative, bidirectional reconciliation process." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#ButterflyEffect> a owl:Class ;
    rdfs:label "ButterflyEffect (Sensitive Dependence on Initial Conditions)" ;
    m2:canonicalPoclet <m0:LorenzSystem> ;
    m2:chaoticAttractor [ ] ;
    m2:couplingExplanation "Dynamics (D) creates the coupling between Amplification (exponential growth of δ in time) and Trajectory (chaotic evolution in time). Flow (F) links the perturbation propagation (Amplification) with the state-space trajectory geometry (strange attractor). Result: bounded deterministic unpredictability - the system explores the attractor exhaustively but unpredictably." ;
    m2:discoveryContext "Identified as structural dual of LALI during TSCG analysis of Turing morphogenesis (M0_TuringMorphogenesis poclet, 2026-02-18). The question 'Is LALI related to the Butterfly Effect?' revealed a deep structural duality: both genericConcepts share the Amplification parent but diverge on whether a lateral Regulation constraint is present. This duality illuminates the fundamental bifurcation between self-organization (LALI → order) and chaos (ButterflyEffect → disorder) in complex systems." ;
    m2:distinctionFromRelated [ ] ;
    m2:dualCounterpart <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#LocalActivationLateralInhibition> ;
    m2:eagleView [ ] ;
    m2:emergentProperties [ ] ;
    m2:epistemicGapAnalysis [ ] ;
    m2:hasComboComponent <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Amplification>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trajectory> ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 8.5e-01 ;
    m2:hasFamily "m2:Combo" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "⊗⇒(Amplification, Trajectory) | trajectoryShape=Chaotic ∧ λ > 0" ;
    m2:hasTensorFormulaASCII "(x)=>(Amplification, Trajectory) | trajectoryShape=Chaotic AND lambda > 0" ;
    m2:hasTensorFormulaTeX "\\otimes\\Rightarrow(\\text{Amplification}, \\text{Trajectory}) \\;|\\; \\text{trajectoryShape}=\\text{Chaotic} \\wedge \\lambda > 0" ;
    m2:historicalNotes [ ] ;
    m2:parentGenericConcepts <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Amplification>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trajectory> ;
    m2:perspective "territory" ;
    m2:polaritySemantics [ ] ;
    m2:sharedDimensions [ ] ;
    m2:status "ACTIVE - New in v15.3.1" ;
    m2:structuralConstraint [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m2:versionHistory [ ] ;
    m3:semanticSignature "sensitive_dependence_on_initial_conditions + chaotic_trajectory + positive_lyapunov_exponent" ;
    dcterms:created "2026-02-18" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Binary GenericConceptCombo in which unconstrained local positive feedback (Amplification) is coupled with a chaotic system trajectory (Trajectory with trajectoryShape=Chaotic and Lyapunov exponent λ > 0), producing exponential divergence of initially nearby system trajectories and intrinsic long-term unpredictability. The essential structural property is the ABSENCE of a lateral Regulation constraint: amplification is unbounded in its range. Named after Lorenz (1963) sensitivity observation: a butterfly flapping its wings in Brazil could set off a tornado in Texas. The abstract pattern appears wherever unconstrained positive feedback operates within a nonlinear deterministic system. Structural dual of LALI: both share Amplification, but LALI adds lateral Regulation (range constraint) → order; ButterflyEffect lacks this constraint → chaos." ;
    rdfs:subClassOf "m2:GenericConceptCombo" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Homeostasis> a owl:Class ;
    rdfs:label "Homeostasis" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Body temperature regulation",
        "pH balance in cells" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "A ⊗ S ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) S (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes S \\otimes F" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Stateful> ;
    m2:perspective "dual" ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "attractor_maintenance + structural_stability + flow_regulation" ;
    rdfs:comment "Self-regulation maintaining stable internal state despite external perturbations." ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Stateful" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#LocalActivationLateralInhibition> a owl:Class ;
    rdfs:label "LocalActivationLateralInhibition (LALI)" ;
    m2:canonicalPoclet <m0:TuringMorphogenesis> ;
    m2:couplingExplanation "Flow (F) is the shared dimension that physically instantiates the range asymmetry: F_A diffuses slowly (short range), F_R diffuses rapidly (long range). This asymmetry is the irreducible structural constraint that transforms Amplification+Regulation co-presence into a self-organizing pattern-forming system." ;
    m2:discoveryContext "Identified during TSCG analysis of Turing morphogenesis (M0_TuringMorphogenesis poclet, 2026-02-18). Abstracted as transdisciplinary pattern after validation across 8 domains including 3 non-physical (Schelling segregation, industrial clusters, gentrification). Named after the core mechanism identified by Gierer & Meinhardt (1972) generalizing Turing's original formulation. Structural dual ButterflyEffect identified simultaneously via the question: 'Is LALI related to the Butterfly Effect?'" ;
    m2:distinctionFromRelated [ ] ;
    m2:dualCounterpart <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#ButterflyEffect> ;
    m2:eagleView [ ] ;
    m2:emergentProperties [ ] ;
    m2:epistemicGapAnalysis [ ] ;
    m2:hasComboComponent <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Amplification>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Regulation> ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasFamily "m2:Combo" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "⊗⇒(Amplification, Regulation) | range(F_A) << range(F_R)" ;
    m2:hasTensorFormulaASCII "(x)=>(Amplification, Regulation) | range(F_A) << range(F_R)" ;
    m2:hasTensorFormulaTeX "\\otimes\\Rightarrow(\\text{Amplification}, \\text{Regulation}) \\;|\\; \\|\\text{range}(F_A)\\| \\ll \\|\\text{range}(F_R)\\|" ;
    m2:parentGenericConcepts <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Amplification>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Regulation> ;
    m2:perspective "territory" ;
    m2:polaritySemantics [ ] ;
    m2:sharedDimensions [ ] ;
    m2:status "ACTIVE - New in v15.3.1" ;
    m2:structuralConstraint [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m2:versionHistory [ ] ;
    m3:semanticSignature "local_amplification + lateral_inhibition + range(activator)<<range(inhibitor)" ;
    dcterms:created "2026-02-18" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Binary GenericConceptCombo in which a local self-reinforcing process (Amplification, short range) is structurally coupled to a longer-range inhibitory process (Regulation), producing stable periodic spatial or functional patterns from an initially homogeneous state. The essential and irreducible structural constraint is the range asymmetry: range(F_Amplification) << range(F_Regulation). Without this asymmetry the combination reduces to simple Amplification+Regulation co-presence without emergent pattern formation. LALI explains spontaneous symmetry breaking into ordered patterns across 8+ disciplines. First identified in Turing reaction-diffusion systems (1952); the abstract principle recognized as transdisciplinary. Structural dual counterpart: ButterflyEffect (Amplification without lateral Regulation constraint → chaos instead of order)." ;
    rdfs:subClassOf "m2:GenericConceptCombo" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Resource> a owl:Class ;
    rdfs:label "Resource" ;
    m2:comboRole "material" ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Capital (Economics) — flow of value with encoded purchasing power",
        "Electrical power (Electronics) — flow of charge with encoded voltage/current state",
        "Memory allocation (Computing) — flow of addressable storage with encoded data",
        "Nutrients (Biology) — flow of chemical energy carriers with encoded molecular info" ;
    m2:hasFamily "m2:Ontological" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "F ⊗ I ⊗ R" ;
    m2:hasTensorFormulaASCII "F (x) I (x) R" ;
    m2:hasTensorFormulaTeX "F \\otimes I \\otimes R" ;
    m2:perspective "dual" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "quantifiable_entity + flow_carrier + information_bearing" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "A quantifiable entity available to, consumed by, or produced by a system. Characterised by three coupled dimensions: Flow (F) — the resource moves or circulates through the system; Information (I) — it carries encoded state or content (energy level, chemical concentration, data payload); Representability (R, REVOI) — it can be described, measured and modelled. Transdisciplinary instances: nutrients/waste (Biology), electrical power (Electronics), raw materials (Engineering), memory/CPU cycles (Computing), capital (Economics).",
        "What is consumed (inputs) and produced (outputs)" ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Transformation> a owl:Class ;
    rdfs:label "Transformation" ;
    m2:comboRole "core_mechanism" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 3e-01 ;
    m2:hasExample "Chemical reactions",
        "Metamorphosis" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "D ⊗ S ⊗ I" ;
    m2:hasTensorFormulaASCII "D (x) S (x) I" ;
    m2:hasTensorFormulaTeX "D \\otimes S \\otimes I" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Triggerable> ;
    m2:perspective "territory" ;
    m3:semanticSignature "dynamic_change + structural_mapping + information_preservation" ;
    rdfs:comment "Defines HOW inputs are converted to outputs (state transition rules)",
        "Fundamental change in system state, structure, or identity." ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Triggerable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld#eagle_eye:Flow> m2:comboRole "medium" ;
    rdfs:comment "Movement of matter/energy/information through the processor" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/docs/M2_GenericConcepts_README.md> dcterms:format "text/markdown" ;
    dcterms:type "Documentation" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Regulation> a owl:Class ;
    rdfs:label "Regulation" ;
    m2:comboRole "lateral_inhibitor" ;
    m2:eagleView [ ] ;
    m2:hasAttribute [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 3.5e-01 ;
    m2:hasExample "Hormonal feedback loops",
        "Traffic light systems" ;
    m2:hasFamily "m2:Regulatory" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "A ⊗ S ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) S (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes S \\otimes F" ;
    m2:perspective "dual" ;
    m2:sphinxView [ ] ;
    m3:semanticSignature "attractor_control + structural_constraints + flow_modulation" ;
    rdfs:comment "Control mechanisms maintaining system parameters within acceptable ranges. Feedback polarity (Negative/Positive/Mixed) specified via feedback_polarity attribute.",
        "Long-range negative feedback (range(F_R) >> range(F_A))" ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Step> a owl:Class ;
    rdfs:label "Step" ;
    m2:comboRole "unit" ;
    m2:containerProperty [ m2:containerTypes "m2:Behavior",
                "m2:Workflow" ;
            m2:relationProperty "m2:componentOf" ;
            rdfs:comment "Step is component of Behavior or Workflow" ] ;
    m2:discoveryContext "Emerged from analysis of sequential systems (Butterfly lifecycle, Blood pressure control). Needed specialized Node type for temporal contexts that can trigger atomic Actions." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Butterfly egg stage (triggers cell division actions)",
        "HTTP parse step (triggers tokenize, validate actions)",
        "Learning epoch (triggers forward, backward, update actions)",
        "Recipe step 'make roux' (triggers heat, stir, add actions)" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "S ⊗ I ⊗ D" ;
    m2:hasTensorFormulaASCII "S (x) I (x) D" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes D" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Composable> ;
    m2:inheritedFrom "m2:Node" ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:specialization [ ] ;
    m2:sphinxView [ ] ;
    m2:triggerProperty [ m2:cardinalityMin 1 ;
            m2:relationProperty "m2:triggers" ;
            m2:targetType "m2:Action" ;
            rdfs:comment "Step triggers one or more Actions" ] ;
    m3:semanticSignature "discrete_structural_unit + information_state + dynamic_transition" ;
    dcterms:created "2026-01-28" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Discrete unit of the cascade",
        "Node specialized for sequential/temporal contexts. Elementary unit in Behavior or Workflow network. Extends Node by adding temporal/sequential semantics and capability to trigger Actions." ;
    rdfs:subClassOf "m2:Composable",
        "m2:Node" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Composable> a owl:Class ;
    rdfs:label "Composable" ;
    m2:contractCapabilities "Connectable — can be linked to other Composables",
        "Part-whole — can participate in m2:componentOf / m2:decomposedInto relations",
        "Structural boundary — identifiable as a distinct unit (S dimension)" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "ConceptContract: the implementing GenericConcept can serve as a structural building block in a larger assembly (m2:Composition, m2:System, m2:Network). Implies: (1) has a defined interface boundary (Structure S), (2) carries identity-preserving information (Information I), (3) can be connected to other Composables via m2:Link or m2:Relation. Implementors: Component (structural part), Node (graph vertex), Step (sequential unit in Behavior/Workflow)." ;
    rdfs:subClassOf "m2:ConceptContract" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Process> a owl:Class ;
    rdfs:label "Process" ;
    m2:comboRole "core_mechanism" ;
    m2:eagleView [ ] ;
    m2:hasAttribute [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Manufacturing process",
        "Metabolic pathway",
        "Workflow" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "D ⊗ F" ;
    m2:hasTensorFormulaASCII "D (x) F" ;
    m2:hasTensorFormulaTeX "D \\otimes F" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Triggerable> ;
    m2:perspective "territory" ;
    m3:semanticSignature "temporal_dynamics + flow_transformation" ;
    rdfs:comment "Sequence of state changes over time. Time discretization (Continuous/Discrete/Hybrid) specified via time_discretization attribute.",
        "The sequential transformation chain" ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Triggerable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Amplification> a owl:Class ;
    rdfs:label "Amplification (Amplification/Attenuation)" ;
    m2:ashbyRelevance [ ] ;
    m2:comboRole "local_activator",
        "sensitivity_amplifier" ;
    m2:discoveryContext "Required for VSM modeling of variety management (S2 amplification, S3 attenuation). Emerges as fundamental dual operation for controlling flow magnitude. Observable in Territory (Ft → D → It: measurable flux, dynamics, information) AND representable in Map (R → O: symbolizable, observable stages). Essential prerequisite for M1_VSM concepts VarietyAmplification and VarietyAttenuation which combine with ValueSpace. Third hybrid genericConcept after Domain and ValueSpace." ;
    m2:distinctionFromRelated [ ] ;
    m2:dualAspects [ ] ;
    m2:eagleView [ ] ;
    m2:fullName "Amplification / Attenuation" ;
    m2:hasAttribute [ ] ;
    m2:hasDominantM3 "HYBRID: Ft → D → It from ASFID (Eagle Eye) + R → O from REVOI (Sphinx Eye)" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Acoustics: Speaker/microphone / Soundproofing material",
        "Biology: Enzymatic cascade → Competitive inhibition",
        "Cybernetics: VSM S2 variety amplification / S3 variety attenuation",
        "Economics: Credit expansion / Fiscal contraction",
        "Electronics: Op-amp (amplification) / Resistor network (attenuation)",
        "Immunology: Antibody production / Immune suppression",
        "Optics: Lens magnification / Neutral density filter",
        "Signal Processing: Gain stage / Low-pass filter" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "hybrid" ;
    m2:hasTensorFormula "Ft → D → It → R → O" ;
    m2:hasTensorFormulaASCII "F_t (x) D (x) I_t (x) R (x) O" ;
    m2:hasTensorFormulaTeX "F_t \\otimes D \\otimes I_t \\otimes R \\otimes O" ;
    m2:hybridView [ ] ;
    m2:mathematicalProperties [ ] ;
    m2:perspective "hybrid" ;
    m2:polarityDescription [ ] ;
    m2:shortName "Amplification" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "signal_gain + polarity(amplification|attenuation)" ;
    dcterms:created "2026-01-31" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Bidirectional process: increase (amplification) or decrease (attenuation) of signal, flow, quantity, or variety. Fundamental cybernetic operation for gain control and variety management. Characterized by measurable flux/dynamics/information (Territory) and representability/observability in models (Map). Direction (Amplifying/Attenuating/Unity) specified via direction attribute.",
        "Exponential amplification of initial condition difference (λ > 0)",
        "Short-range positive feedback (range(F_A) short)" ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Stateful> a owl:Class ;
    rdfs:label "Stateful" ;
    m2:contractCapabilities "Persistent internal state — survives between interactions",
        "State history — current state influenced by past transitions",
        "State transitions — governed by Dynamics (D) and Attractor (A)" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "ConceptContract: the implementing GenericConcept maintains a persistent internal state that evolves over time and influences future behavior. Implies: (1) has an internal State (m2:State) that persists between interactions, (2) state transitions are governed by Dynamics (D) and Attractors (A), (3) current state depends on history (memory effect). Implementors: State (IS the state — self-referential), Memory (encodes past state), Storage (persists accumulated state), Homeostasis (maintains target state via regulation)." ;
    rdfs:subClassOf "m2:ConceptContract" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Trajectory> a owl:Class ;
    rdfs:label "Trajectory" ;
    m2:comboRole "chaotic_path",
        "path" ;
    m2:discoveryContext "Identified during RAAS analysis when distinguishing between biochemical pathway diagrams (Path on map) and actual blood pressure evolution over time (Trajectory in territory). Resolves Map-Territory confusion in Path genericConcept." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasAttribute [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow" ;
    m2:hasEpistemicGap 1.5e-01 ;
    m2:hasExample "Aircraft flight trajectory - actual path flown",
        "Blood pressure trajectory in RAAS homeostasis",
        "Chemical reaction trajectory along reaction coordinate",
        "Organism lifecycle trajectory through developmental stages",
        "Phase space trajectory of dynamical system",
        "Population trajectory in Lotka-Volterra dynamics",
        "Projectile trajectory - observed ballistic motion" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "A ⊗ D ⊗ F" ;
    m2:hasTensorFormulaASCII "A (x) D (x) F" ;
    m2:hasTensorFormulaTeX "A \\otimes D \\otimes F" ;
    m2:implements <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Observable> ;
    m2:perspective "territory" ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "attractor_directed + dynamic_path + flow_sequence" ;
    dcterms:created "2026-02-05" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Directed path through state space connecting cascade stages",
        "Observable path through state space traced by system evolution over time. Empirical, measured evolution in territory - what actually happens. Distinguished from Path (planned route on conceptual map). Trajectory shape (linear, circular, spiral, etc.) can be specified via shape attribute.",
        "State-space trajectory with chaotic shape (Lyapunov exponent λ > 0)" ;
    rdfs:subClassOf "m2:GenericConcept",
        "m2:Observable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Observable> a owl:Class ;
    rdfs:label "Observable" ;
    m2:contractCapabilities "Has Observability (O in REVOI) — degree of accessibility to Observer",
        "Has Representability (R in REVOI) — can be encoded in a Map",
        "Produces measurable signal accessible to m2:Observer" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "ConceptContract: the implementing GenericConcept can be measured, detected or recorded by an Observer (m2:Observer) in the Territory (Eagle Eye / ASFID). Implies: (1) produces a signal or measurable signature, (2) accessible to an Observer without modifying its essential nature, (3) representable in the Map (Sphinx Eye / REVOI). Directly linked to the ASFID Information (I) and Attractor (A) dimensions. Implementors: State (measurable configuration), Trajectory (observable path), Behavior (observable pattern), Gradient (measurable differential), Observer (observes itself as meta-observable)." ;
    rdfs:subClassOf "m2:ConceptContract" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Triggerable> a owl:Class ;
    rdfs:label "Triggerable" ;
    m2:contractCapabilities "Threshold condition — specifies when triggering occurs",
        "m2:triggeredBy — receives trigger stimulus",
        "m2:triggers — can in turn trigger other Triggerables" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "ConceptContract: the implementing GenericConcept can be initiated by an external Trigger (m2:Trigger) when a Threshold (m2:Threshold) condition is met. Implies: (1) an idle/waiting state before initiation, (2) a transition to active state upon trigger reception, (3) a defined execution or unfolding following initiation. Implementors: Event (discrete triggered occurrence), Action (atomic triggered operation), Process (triggered sequence of state changes), Cascade (triggered multi-stage propagation), Transformation (triggered state conversion)." ;
    rdfs:subClassOf "m2:ConceptContract" .

