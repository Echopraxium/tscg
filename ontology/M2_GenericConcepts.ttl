<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Hub> a owl:Class ;
    rdfs:label "Hub" ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Flow",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Airport hub (Atlanta, Dubai)",
        "Distribution center in logistics",
        "Nerve plexus (brachial, solar)",
        "Network router/switch",
        "Train central station" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ F" ;
    m2:hasTensorFormulaASCII "S (x) F" ;
    m2:hasTensorFormulaTeX "S \\otimes F" ;
    m2:perspective "territory" ;
    m3:semanticSignature "high_connectivity_structure + flow_concentration" ;
    rdfs:comment "Highly connected node serving as central routing point for flow redistribution, without active processing (passive relay role)." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Identity> a owl:Class ;
    rdfs:label "Identity" ;
    m2:discoveryContext "Identified during M0_VSM (Viable System Model) validation. Cohesion concept required a genericConcept capturing 'shared organizational thread persisting despite S1 autonomy'. No existing M2 covered the combination of persistence (vs Invariant), uniqueness (vs Signature), and self-restoration (A). TRIZ validates Identity as a foundational principle (conserved property under transformation). Formalized as hybrid S → I → A → V → E to distinguish from Pattern (same Eagle base, divergent Map question)." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:fullName "Entity Identity (Persistence / Uniqueness)" ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure",
        "m3:sphinx_eye:Evolvable",
        "m3:sphinx_eye:Verifiable" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "Biology: Genetic identity DNA sequence defines organism identity despite continuous cell turnover and metabolic flux",
        "Chemistry: Molecular identity same molecule persists despite vibrational states and conformational changes",
        "IT: Object identity UUID remains constant despite attribute mutations and state transitions",
        "Mythology: Hero identity same character maintains coherence through ordeals, transformation, and return",
        "Organization: Organizational identity mission, values, and legal continuity despite leadership and personnel turnover",
        "Philosophy: Ship of Theseus the identity problem: what persists when all parts are replaced?",
        "Physics: Particle identity quantum topological properties preserved under interaction and transformation",
        "Psychology: Self identity narrative continuity of 'me' across time, trauma, and developmental change",
        "TRIZ: System identity conserved functional properties under inventive transformation (Principle of Conservation)" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "S → I → A → V → E" ;
    m2:hasTensorFormulaASCII "S (x) I (x) A (x) V (x) E" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes A \\otimes V \\otimes E" ;
    m2:perspective "hybrid" ;
    m2:polarityDescription [ ] ;
    m2:shortName "Identity" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "persistent_distinguishing_signature + structural+informational+attractor+verifiable+evolvable" ;
    dcterms:created "2026-02-01" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Persistent property that makes an entity distinguishable and self-restoring across transformations. An entity remains itself despite internal changes: its structure persists (S), its distinguishing information is maintained (I), and it returns to its characteristic state after perturbation (A). Identity is intrinsic it is not external recognition (vs Signature) nor a generic conserved quantity (vs Invariant), but the singular property binding persistence, uniqueness, and self-restoration into one coherent entity." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Imbrication> a owl:Class ;
    rdfs:label "Imbrication (Nesting)" ;
    m2:discoveryContext "Emerged from VSM analysis where recursive viability is fundamental architectural principle. Generalizes to any system exhibiting structural self-similarity across scales." ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 3e-01 ;
    m2:hasExample "Architecture: Matryoshka dolls (physical nesting)",
        "Biology: Bronchial tree (airways branching ~23 levels deep)",
        "Computer Science: Recursive function calls (limited by stack depth)",
        "Geography: Nested watersheds (river basin → sub-basin → stream)",
        "Linguistics: Nested clauses in Chomsky grammar",
        "Mathematics: Mandelbrot set (infinite fractal self-similarity)",
        "Organizations: Departments containing sub-departments with similar structure",
        "VSM: Each S1 operational unit is a complete viable system with its own S1-S5 structure" ;
    m2:hasFamily "m2:Ontological" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "S → S" ;
    m2:hasTensorFormulaASCII "S (x) S" ;
    m2:hasTensorFormulaTeX "S \\otimes S" ;
    m2:mathematicalProperties [ ] ;
    m2:perspective "dual" ;
    m2:polarityDescription [ ] ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m2:vsmContext [ ] ;
    m3:semanticSignature "recursive_structural_nesting" ;
    dcterms:created "2026-01-30" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Structural relation where a system contains subsystems that reproduce the parent system's structure. Principle of self-similarity across hierarchical levels. Fundamental to VSM where each operational unit is itself a complete viable system." ;
    rdfs:subClassOf "m2:GenericConcept" .

