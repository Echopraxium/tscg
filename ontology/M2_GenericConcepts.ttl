<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#FeedbackLoop> a owl:Class ;
    rdfs:label "Feedback Loop" ;
    m2:architecturalNote "m2:FeedbackLoop models systemic regulatory circuits across all domains. Distinct from m3:AlignmentLoop which is the epistemological Territory↔Map alignment mechanism intrinsic to TSCG architecture (see M3_GenesisSpace)." ;
    m2:componentGenericConcepts <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Alignment>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Homeostasis>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Process> ;
    m2:dualAspects [ ] ;
    m2:expression "(-1)^{p} · k · (Process ⊗ Alignment ⊗ Homeostasis)" ;
    m2:expressionTeX "(-1)^{p} \\cdot k \\cdot (\\text{Process} \\otimes \\text{Alignment} \\otimes \\text{Homeostasis})" ;
    m2:feedback_polarity [ ] ;
    m2:fullName "Feedback Loop (Negative / Positive)" ;
    m2:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Hormonal cascade with negative feedback (endocrinology)",
        "Insulin-glucose regulation (biology)",
        "PID controller (control theory)",
        "Predator-prey population dynamics (ecology)",
        "RAAS blood pressure control (physiology)",
        "Supply-demand price regulation (economics)",
        "Thermostat (engineering)" ;
    m2:hasFamily "m2:Dynamic" ;
    m2:hasPolarity "dual" ;
    m2:hasTensorFormula "m2:Process ⊗ m2:Alignment ⊗ m2:Homeostasis" ;
    m2:hasTensorFormulaASCII "Process (x) Alignment (x) Homeostasis" ;
    m2:perspective "dual" ;
    m2:poleMapping [ ] ;
    m2:tensorExpansion "(D ⊗ F) ⊗ (I ⊗ A ⊗ S) ⊗ (A ⊗ S ⊗ F) = A ⊗ S ⊗ F ⊗ I ⊗ D" ;
    m2:tensorNote "Expanded formula covers all 5 ASFID dimensions, reflecting that a feedback loop engages the full phenomenology of a system: Attractor (set point), Structure (circuit), Flow (signal), Information (error signal), Dynamics (temporal evolution)." ;
    m3:semanticSignature "output_fed_back_to_input + polarity(positive|negative) + dynamic_regulation" ;
    rdfs:comment "Cyclic regulatory process where a system compares its current state to a target (Homeostasis), reduces the discrepancy (Alignment), and evolves over time (Process). Encompasses both negative feedback (stabilizing, error-correcting) and positive feedback (amplifying, self-reinforcing). Universal systemic pattern found across biology, engineering, economics, ecology and social systems." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Fusion> a owl:Class ;
