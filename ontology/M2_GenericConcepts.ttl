<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Coding> a owl:Class ;
    rdfs:label "Coding (Encoding/Decoding)" ;
    m2:dualAspects [ ] ;
    m2:eagleView [ ] ;
    m2:fullName "Coding (Encoding / Decoding)" ;
    m2:hasDominantM3 "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "DNA transcription/translation",
        "Encryption/Decryption" ;
