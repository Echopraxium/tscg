        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2e-01 ;
    m2:hasExample "Chemical substrate",
        "Hardware platform",
        "Physical medium" ;
    m2:hasFamily "m2:Ontological" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ F" ;
    m2:hasTensorFormulaASCII "S (x) F" ;
    m2:hasTensorFormulaTeX "S \\otimes F" ;
    m2:perspective "territory" ;
    m3:semanticSignature "structural_support + flow_medium" ;
    rdfs:comment "Material or informational support enabling system existence." ;
    rdfs:subClassOf "m2:GenericConcept" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Symmetry> a owl:Class ;
