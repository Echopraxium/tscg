<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#Interoperability> a owl:Class ;
    rdfs:label "Interoperability" ;
    m2:distinctionFromRelated [ ] ;
    m2:eagleView [ ] ;
    m2:hasDominantM3 "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    m2:hasEpistemicGap 2.5e-01 ;
    m2:hasExample "HL7 FHIR (Medicine) — clinical data structure, coding systems, exchange format",
        "REST API (Computing) — resource structure, JSON/XML encoding, HTTP flow protocol",
        "Synaptic interface (Biology) — receptor structure, neurotransmitter encoding, ion flow",
        "USB protocol (Electronics) — structural interface, encoded data format, flow standard" ;
    m2:hasFamily "m2:Structural" ;
    m2:hasPolarity "neutral" ;
    m2:hasTensorFormula "S ⊗ I ⊗ F ⊗ V ⊗ E" ;
    m2:hasTensorFormulaASCII "S (x) I (x) F (x) V (x) E" ;
    m2:hasTensorFormulaTeX "S \\otimes I \\otimes F \\otimes V \\otimes E" ;
    m2:perspective "dual" ;
    m2:sphinxView [ ] ;
    m2:transdisciplinaryValidation [ ] ;
    m3:semanticSignature "interface_structure + information_exchange + protocol_flow + evolvable_contract" ;
    dcterms:created "2026-02-24" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "The structural capacity of a system to exchange, process and use information with other systems according to shared protocols or standards, while remaining evolvable. Combines: Structure (S) — the interface architecture; Information (I) — the format and encoding of exchanged content; Flow (F) — the actual exchange protocol; Verifiability (V, REVOI) — testability of interface contracts; Evolvability (E, REVOI) — adaptability to new formats and standards. Note: distinct from the REVOI dimension I (Interoperability as a map-quality axis) — this GenericConcept models the observable STRUCTURAL PATTERN of interoperation, whereas REVOI-I measures the degree of interoperability of a conceptual model." ;
    rdfs:subClassOf "m2:GenericConcept" .

