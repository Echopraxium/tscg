  "@graph": [
    {
      "@id": "m2:TSCG_M2_GenericConcepts_Ontology",
      "@type": "owl:Ontology",
      "dcterms:title": "TSCG M2 GenericConcepts Ontology",
      "dcterms:description": "Second layer of the TSCG framework. Defines 59 systemic patterns emerging from tensor products of M3 ASFID dimensions. Introduces N-ary polarity framework.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-14",
      "dcterms:modified": "2026-01-22",
      "owl:versionInfo": "13.0.0",
      "owl:imports": [
        "https://github.com/Echopraxium/tscg/blob/main/ontology/M3_Eagle_Eye.jsonld",
        "https://github.com/Echopraxium/tscg/blob/main/ontology/M3_Sphinx_Eye.jsonld"
      ],
      "m2:bicephalousArchitecture": {
        "description": "M2 GenericConcepts emerge from tensorization of M3 dimensions. M3 has bicephalous architecture: Eagle Eye (ASFID Territory-Space) for measurement + Sphinx Eye (ORIVE Map-Space) for interpretation.",
        "eagleEye": {
          "@id": "m3eagle:EagleEye",
          "rdfs:seeAlso": "https://github.com/Echopraxium/tscg/blob/main/ontology/M3_Eagle_Eye.jsonld",
