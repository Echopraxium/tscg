    {
      "@id": "m2:GenericConcept",
      "@type": "owl:Class",
      "rdfs:label": "M2 GenericConcept",
      "rdfs:comment": "A systemic pattern emerging from tensor product of M3 dimensions. Represents a recognizable organizational motif found across multiple domains."
    },
    {
      "@id": "m2:Category",
      "@type": "owl:Class",
      "rdfs:label": "GenericConcept Category",
      "rdfs:comment": "A taxonomic grouping of GenericConcepts based on dominant M3 dimensions and functional role in system behavior."
    },
    {
      "@id": "m2:hasCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has category",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m2:Category",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:hasTensorFormula",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "has tensor formula",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "xsd:string",
      "owl:functionalProperty": true
    },
    {
      "@id": "m2:hasDominantM3",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has dominant M3 dimension",
      "rdfs:domain": "m2:GenericConcept",
      "rdfs:range": "m3:M3Dimension"
