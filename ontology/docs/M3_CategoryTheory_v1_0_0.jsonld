{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisSpace.jsonld#",
    "m3:category_theory": "M3_CategoryTheory.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:category_theory:CategoryTheory",
      "@type": "owl:Ontology",
      "owl:versionInfo": "1.0.0",
      "dcterms:created": "2026-02-17",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:title": "TSCG M3 Category Theory - Mathematical Foundation",
      "dcterms:description": "Formal ontology encoding Category Theory as the mathematical foundation for TSCG. Defines categories, objects, morphisms, functors, and natural transformations. Provides the categorical structure underlying TSCG's layered architecture (M3ŌåÆM2ŌåÆM1ŌåÆM0) and enables formal reasoning about transformations, compositions, and reifications.",
      "rdfs:label": "Category Theory - Mathematical Foundation",
      "rdfs:comment": "M3 Category Theory provides the mathematical vocabulary for TSCG's categorical structure. This is the most fundamental layer (M3) as Category Theory describes the architecture of the entire framework. Imported by other TSCG ontologies to annotate their categorical properties.",
      "m3:category_theory:ontologyCategory": {
        "@id": "m3:category_theory:MathematicalFoundation"
      },
      "metadata": {
        "layer": "M3",
        "name": "Category Theory",
        "version": "1.0.0",
        "date_created": "2026-02-17",
        "authors": ["Echopraxium with the collaboration of Claude AI"],
        "description": "Mathematical foundation encoding Category Theory concepts for TSCG framework",
        "purpose": [
          "Formalize categorical structure of TSCG (M3ŌåÆM2ŌåÆM1ŌåÆM0 as functors)",
          "Enable reasoning about morphisms and transformations",
          "Provide vocabulary for reification (KnowledgeField objects)",
          "Support composition laws and categorical diagrams"
        ]
      },
      "rdfs:seeAlso": [
        "https://ncatlab.org/nlab/show/category+theory",
        "https://en.wikipedia.org/wiki/Category_theory"
      ]
    },

    {
      "@id": "m3:category_theory:MathematicalCategory",
      "@type": "owl:Class",
      "rdfs:label": "Mathematical Category",
      "rdfs:comment": "A category in the mathematical sense: a collection of objects (Ob(C)) and morphisms (Mor(C)) between them, satisfying identity and associativity axioms. In TSCG: Cat_M3 (ASFID dimensions), Cat_M2 (GenericConcepts), Cat_M1 (concepts), Cat_KnowledgeField (Chemistry, Biology, Optics...).",
      "m3:category_theory:structure": {
        "objects": "Collection Ob(C) of category objects",
        "morphisms": "Collection Mor(C) of arrows between objects",
        "identity": "For each object A Ōłł Ob(C), exists id_A: A ŌåÆ A",
        "composition": "For f: A ŌåÆ B and g: B ŌåÆ C, exists gŌłśf: A ŌåÆ C",
        "associativity": "(hŌłśg)Ōłśf = hŌłś(gŌłśf)",
        "identity_law": "fŌłśid_A = f = id_BŌłśf for f: A ŌåÆ B"
      },
      "m3:category_theory:categoryAxioms": [
        "Identity: ŌłĆA Ōłł Ob(C), Ōłā id_A Ōłł Mor(A,A)",
        "Composition: ŌłĆf Ōłł Mor(A,B), g Ōłł Mor(B,C), Ōłā gŌłśf Ōłł Mor(A,C)",
        "Associativity: (hŌłśg)Ōłśf = hŌłś(gŌłśf)",
        "Unit law: fŌłśid_A = f, id_BŌłśf = f"
      ],
      "m3:category_theory:tscgExamples": [
        "Cat_KnowledgeField: Ob = {Chemistry, Biology, Optics...}, Mor = knowledge transfers",
        "Cat_M2: Ob = {Link, Processor, Component...}, Mor = GenericConcept inclusions",
        "Cat_M3_ASFID: Ob = {A, S, F, I, D}, Mor = tensor products",
        "Cat_TSCG: Ob = {M3, M2, M1, M0}, Mor = functors F_ŌŖŚ, F_inst"
      ]
    },

    {
      "@id": "m3:category_theory:CategoryObject",
      "@type": "owl:Class",
      "rdfs:label": "Category Object",
      "rdfs:comment": "An object within a mathematical category. Objects are the 'things' in a category; morphisms are the 'relationships' between them. In TSCG: Chemistry is an object in Cat_KnowledgeField, Link is an object in Cat_M2, ASFID is an object in Cat_M3.",
      "m3:category_theory:formalDefinition": "An element A Ōłł Ob(C) for some category C",
      "m3:category_theory:properties": [
        "Every object has an identity morphism id_A: A ŌåÆ A",
        "Objects are sources and targets of morphisms",
        "Objects themselves have no internal structure in category theory",
        "Structure comes from morphisms TO and FROM the object"
      ],
      "m3:category_theory:tscgReification": {
        "description": "In TSCG, GenericConcepts (M2) are reified as Category Objects when viewed categorically",
        "example": "KnowledgeField (M2 GenericConcept) IS ALSO a mathematical category with Chemistry, Biology... as objects",
        "doubleRole": "Chemistry is BOTH an object in Cat_KnowledgeField AND potentially a category itself (Cat_Chemistry with subconcepts as objects)"
      }
    },

    {
      "@id": "m3:category_theory:Morphism",
      "@type": "owl:Class",
      "rdfs:label": "Category Morphism",
      "rdfs:comment": "An arrow (morphism) between category objects. Morphisms represent structure-preserving transformations. In TSCG: tensorization (M3ŌåÆM2), instantiation (M2ŌåÆM1), concept application (M1ŌåÆM0), knowledge transfer between domains.",
      "m3:category_theory:formalDefinition": "An element f Ōłł Mor(A,B) for objects A,B Ōłł Ob(C)",
      "m3:category_theory:notation": {
        "arrow": "f: A ŌåÆ B",
        "source": "dom(f) = A (domain)",
        "target": "cod(f) = B (codomain)",
        "composition": "gŌłśf for f: A ŌåÆ B, g: B ŌåÆ C"
      },
      "m3:category_theory:morphismTypes": {
        "identity": "id_A: A ŌåÆ A (trivial morphism)",
        "isomorphism": "f: A ŌåÆ B with inverse fŌü╗┬╣: B ŌåÆ A",
        "monomorphism": "injective morphism",
        "epimorphism": "surjective morphism",
        "endomorphism": "f: A ŌåÆ A (same source and target)",
        "automorphism": "isomorphic endomorphism"
      },
      "m3:category_theory:tscgMorphisms": {
        "inclusion": "Ōå¬ (e.g., Homeostasis Ōå¬ Regulation)",
        "composition": "Ōłś (e.g., Learning = Memory Ōłś Adaptation)",
        "duality": "op (e.g., Divergence = Convergence^op)",
        "emergence": "ŌćÆ (e.g., GenericConceptCombo: M_A ŌŖŚ M_B ŌćÆ M_C)",
        "tensorization": "ŌŖŚ (combination of objects)",
        "instantiation": "inst (M2 concept ŌåÆ M1 concept ŌåÆ M0 instance)"
      }
    },

    {
      "@id": "m3:category_theory:Functor",
      "@type": "owl:Class",
      "rdfs:label": "Functor",
      "rdfs:comment": "A structure-preserving map between categories. Functors map objects to objects and morphisms to morphisms, preserving identity and composition. In TSCG: F_ŌŖŚ (tensorization M3ŌåÆM2), F_inst (instantiation M2ŌåÆM1), domain projection functors.",
      "m3:category_theory:formalDefinition": "F: C ŌåÆ D mapping Ob(C) ŌåÆ Ob(D) and Mor(C) ŌåÆ Mor(D)",
      "m3:category_theory:functorLaws": [
        "Object mapping: F: Ob(C) ŌåÆ Ob(D)",
        "Morphism mapping: F: Mor_C(A,B) ŌåÆ Mor_D(F(A),F(B))",
        "Identity preservation: F(id_A) = id_F(A)",
        "Composition preservation: F(gŌłśf) = F(g)ŌłśF(f)"
      ],
      "m3:category_theory:functorTypes": {
        "covariant": "Preserves direction of morphisms",
        "contravariant": "Reverses direction of morphisms",
        "endofunctor": "F: C ŌåÆ C (same category)",
        "identity_functor": "Id_C: C ŌåÆ C (trivial functor)",
        "forgetful": "Forgets structure (e.g., from algebra to set)",
        "free": "Builds free structure (left adjoint to forgetful)"
      },
      "m3:category_theory:tscgFunctors": {
        "F_tensorization": {
          "signature": "F_ŌŖŚ: Cat_M3 ŌåÆ Cat_M2",
          "description": "Maps ASFID dimensions to GenericConcepts via tensor products",
          "example": "F_ŌŖŚ(S ŌŖŚ F) = Link (GenericConcept from tensor product of Structure and Flow)"
        },
        "F_instantiation": {
          "signature": "F_inst: Cat_M2 ŌåÆ Cat_M1",
          "description": "Maps GenericConcepts to domain-specific concepts",
          "example": "F_inst(Link) = ChemicalLink (in Chemistry domain)"
        },
        "F_domain_projection": {
          "signature": "F_proj: Cat_M1 ŌåÆ Cat_KnowledgeField",
          "description": "Projects M1 concepts onto their parent knowledge field",
          "example": "F_proj(ChemicalLink) = Chemistry"
        }
      }
    },

    {
      "@id": "m3:category_theory:NaturalTransformation",
      "@type": "owl:Class",
      "rdfs:label": "Natural Transformation",
      "rdfs:comment": "A morphism between functors. Natural transformations relate two functors F,G: C ŌåÆ D via a family of morphisms. In TSCG: transformations between different observer perspectives (human vs AI), translations between knowledge representations.",
      "m3:category_theory:formalDefinition": "╬Ę: F ŌćÆ G is a family ╬Ę_A: F(A) ŌåÆ G(A) for each A Ōłł Ob(C)",
      "m3:category_theory:naturality": {
        "description": "Naturality square commutes",
        "diagram": "For f: A ŌåÆ B, the square F(A) ŌåÆ^╬Ę_A G(A), F(B) ŌåÆ^╬Ę_B G(B) commutes",
        "law": "╬Ę_B Ōłś F(f) = G(f) Ōłś ╬Ę_A"
      },
      "m3:category_theory:tscgApplications": [
        "Observer transformations: different perspectives on same territory",
        "Knowledge transfer: translation between disciplines",
        "Representation changes: different encodings of same concept"
      ]
    },

    {
      "@id": "m3:category_theory:Adjunction",
      "@type": "owl:Class",
      "rdfs:label": "Adjunction",
      "rdfs:comment": "A relationship between two functors F: C ŌåÆ D and G: D ŌåÆ C where F is left adjoint to G (F ŌŖŻ G). Adjunctions capture the idea of 'best approximation'. In TSCG: observation-interpretation duality (╬” ŌŖŻ ╬©), free-forgetful pairs.",
      "m3:category_theory:formalDefinition": "F ŌŖŻ G iff Mor_D(F(A),B) Ōēģ Mor_C(A,G(B)) naturally in A,B",
      "m3:category_theory:components": {
        "unit": "╬Ę: Id_C ŌćÆ GŌłśF",
        "counit": "╬Ą: FŌłśG ŌćÆ Id_D"
      },
      "m3:category_theory:tscgAdjunctions": {
        "observation_interpretation": {
          "description": "╬” (TerritoryŌåÆMap) ŌŖŻ ╬© (MapŌåÆTerritory)",
          "interpretation": "Best map given territory Ōåö Best territory interpretation given map"
        }
      }
    },

    {
      "@id": "m3:category_theory:belongsToCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "belongs to category",
      "rdfs:domain": "m3:category_theory:CategoryObject",
      "rdfs:range": "m3:category_theory:MathematicalCategory",
      "rdfs:comment": "Relates an object to the category it belongs to. Example: Chemistry belongsToCategory Cat_KnowledgeField."
    },

    {
      "@id": "m3:category_theory:hasMorphism",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "has morphism",
      "rdfs:domain": "m3:category_theory:MathematicalCategory",
      "rdfs:range": "m3:category_theory:Morphism",
      "rdfs:comment": "Relates a category to one of its morphisms."
    },

    {
      "@id": "m3:category_theory:morphismSource",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "morphism source",
      "rdfs:domain": "m3:category_theory:Morphism",
      "rdfs:range": "m3:category_theory:CategoryObject",
      "rdfs:comment": "The source (domain) object of a morphism."
    },

    {
      "@id": "m3:category_theory:morphismTarget",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "morphism target",
      "rdfs:domain": "m3:category_theory:Morphism",
      "rdfs:range": "m3:category_theory:CategoryObject",
      "rdfs:comment": "The target (codomain) object of a morphism."
    },

    {
      "@id": "m3:category_theory:composedWith",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "composed with",
      "rdfs:domain": "m3:category_theory:Morphism",
      "rdfs:range": "m3:category_theory:Morphism",
      "rdfs:comment": "Morphism composition: if f: AŌåÆB and g: BŌåÆC, then f composedWith g yields gŌłśf: AŌåÆC."
    },

    {
      "@id": "m3:category_theory:functorSourceCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "functor source category",
      "rdfs:domain": "m3:category_theory:Functor",
      "rdfs:range": "m3:category_theory:MathematicalCategory",
      "rdfs:comment": "The source category of a functor."
    },

    {
      "@id": "m3:category_theory:functorTargetCategory",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "functor target category",
      "rdfs:domain": "m3:category_theory:Functor",
      "rdfs:range": "m3:category_theory:MathematicalCategory",
      "rdfs:comment": "The target category of a functor."
    },

    {
      "@id": "m3:category_theory:mapsObjectTo",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "maps object to",
      "rdfs:domain": "m3:category_theory:Functor",
      "rdfs:range": "m3:category_theory:CategoryObject",
      "rdfs:comment": "How a functor maps objects. F mapsObjectTo F(A) for object A."
    },

    {
      "@id": "m3:category_theory:mapsMorphismTo",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "maps morphism to",
      "rdfs:domain": "m3:category_theory:Functor",
      "rdfs:range": "m3:category_theory:Morphism",
      "rdfs:comment": "How a functor maps morphisms. F mapsMorphismTo F(f) for morphism f."
    },

    {
      "@id": "m3:category_theory:morphismType",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "morphism type",
      "rdfs:domain": "m3:category_theory:Morphism",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Type classification of morphism (identity, isomorphism, inclusion, etc.)."
    },

    {
      "@id": "m3:category_theory:functorType",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "functor type",
      "rdfs:domain": "m3:category_theory:Functor",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Type classification of functor (covariant, contravariant, endofunctor, etc.)."
    },

    {
      "@id": "m3:category_theory:categoryName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "category name",
      "rdfs:domain": "m3:category_theory:MathematicalCategory",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Name of the category (e.g., 'Cat_M2', 'Cat_KnowledgeField')."
    },

    {
      "@id": "m3:category_theory:Cat_TSCG",
      "@type": ["owl:NamedIndividual", "m3:category_theory:MathematicalCategory"],
      "rdfs:label": "Category of TSCG Layers",
      "rdfs:comment": "The category whose objects are TSCG layers {M3, M2, M1, M0} and morphisms are functors between them.",
      "m3:category_theory:categoryName": "Cat_TSCG",
      "m3:category_theory:objects": ["M3", "M2", "M1", "M0"],
      "m3:category_theory:morphisms": ["F_ŌŖŚ: M3ŌåÆM2", "F_inst: M2ŌåÆM1", "F_concretize: M1ŌåÆM0"]
    },

    {
      "@id": "m3:category_theory:Cat_M3_ASFID",
      "@type": ["owl:NamedIndividual", "m3:category_theory:MathematicalCategory"],
      "rdfs:label": "Category of ASFID Dimensions",
      "rdfs:comment": "Category whose objects are ASFID dimensions and morphisms are tensor products.",
      "m3:category_theory:categoryName": "Cat_M3_ASFID",
      "m3:category_theory:objects": ["Attractor", "Structure", "Flow", "Information", "Dynamics"]
    },

    {
      "@id": "m3:category_theory:Cat_M3_REVOI",
      "@type": ["owl:NamedIndividual", "m3:category_theory:MathematicalCategory"],
      "rdfs:label": "Category of REVOI Dimensions",
      "rdfs:comment": "Category whose objects are REVOI dimensions and morphisms are tensor products.",
      "m3:category_theory:categoryName": "Cat_M3_REVOI",
      "m3:category_theory:objects": ["Representable", "Evolvable", "Verifiable", "Observable", "Interoperable"]
    },

    {
      "@id": "m3:category_theory:F_tensorization",
      "@type": ["owl:NamedIndividual", "m3:category_theory:Functor"],
      "rdfs:label": "Tensorization Functor",
      "rdfs:comment": "Functor mapping M3 dimensions to M2 GenericConcepts via tensor products.",
      "m3:category_theory:functorType": "covariant",
      "m3:category_theory:functorSourceCategory": "m3:category_theory:Cat_M3_ASFID",
      "m3:category_theory:signature": "F_ŌŖŚ: Cat_M3 ŌåÆ Cat_M2",
      "m3:category_theory:examples": [
        "F_ŌŖŚ(S ŌŖŚ F) = Link",
        "F_ŌŖŚ(A ŌŖŚ S ŌŖŚ F) = Reservoir",
        "F_ŌŖŚ(S ŌŖŚ I ŌŖŚ D ŌŖŚ F ŌŖŚ V) = Processor"
      ]
    },

    {
      "@id": "m3:category_theory:F_instantiation",
      "@type": ["owl:NamedIndividual", "m3:category_theory:Functor"],
      "rdfs:label": "Instantiation Functor",
      "rdfs:comment": "Functor mapping M2 GenericConcepts to M1 domain-specific concepts.",
      "m3:category_theory:functorType": "covariant",
      "m3:category_theory:signature": "F_inst: Cat_M2 ŌåÆ Cat_M1",
      "m3:category_theory:examples": [
        "F_inst(Link) = ChemicalLink (in Chemistry)",
        "F_inst(Processor) = BiologicalProcessor (in Biology)",
        "F_inst(Component) = MechanicalComponent (in Mechanics)"
      ]
    }
  ]
}
