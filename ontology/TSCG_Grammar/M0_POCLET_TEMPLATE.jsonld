    },
    "F": {
      "@id": "M3_GenesisSpace.jsonld#eagle_eye:Flow",
      "@type": "xsd:float"
    },
    "It": {
      "@id": "M3_GenesisSpace.jsonld#eagle_eye:Information",
      "@type": "xsd:float"
    },
    "D": {
      "@id": "M3_GenesisSpace.jsonld#eagle_eye:Dynamics",
      "@type": "xsd:float"
    },
    "R": {
      "@id": "M3_GenesisSpace.jsonld#sphinx_eye:Representable",
      "@type": "xsd:float"
    },
    "E": {
      "@id": "M3_GenesisSpace.jsonld#sphinx_eye:Evolvable",
      "@type": "xsd:float"
    },
    "V": {
      "@id": "M3_GenesisSpace.jsonld#sphinx_eye:Verifiable",
      "@type": "xsd:float"
    },
    "O": {
      "@id": "M3_GenesisSpace.jsonld#sphinx_eye:Observable",
      "@type": "xsd:float"
    },
    "Im": {
      "@id": "M3_GenesisSpace.jsonld#sphinx_eye:Interoperable",
      "@type": "xsd:float"
    },
    "m0:epistemicGap": {
      "@id": "M0_Poclet#epistemicGap",
      "@type": "xsd:float"
    },
    "m0:mean": {
      "@id": "M0_Poclet#mean",
      "@type": "xsd:float"
    }
  },
  "@id": "",
  "@type": "owl:Ontology",
  "m3:ontologyType": {
    "@id": "m3:Poclet"
  },
  "rdfs:label": "POCLET_NAME - Short Descriptive Title",
  "rdfs:comment": "Detailed description of the poclet and its systemic properties. Explain what system/phenomenon is modeled and why it's a good TSCG candidate.",
  "owl:versionInfo": "1.0.0",
  "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
  "dcterms:created": "2026-04-18",
  "m1:domain": "DOMAIN_NAME",
  "owl:imports": [
    "M3_GenesisSpace.jsonld",
    "M2_GenericConcepts.jsonld",
    "M1_CoreConcepts.jsonld"
  ],
  "m2:changelog": [
    {
      "version": "1.0.0",
      "date": "2026-04-18",
      "changes": "Initial M0 poclet ontology with ASFID/REVOI bicephalous modeling"
    }
  ],
  "m0:epistemicGap": 0.000,
  "m0:asfidScores": {
    "A": 0.00,
    "S": 0.00,
    "F": 0.00,
    "It": 0.00,
    "D": 0.00,
    "m0:mean": 0.00,
    "m0:justification": "ASFID scoring justification:\n- A (Attractor): [explain]\n- S (Structure): [explain]\n- F (Flow): [explain]\n- It (Information/Territory): [explain]\n- D (Dynamics): [explain]"
  },
  "m0:revoiScores": {
