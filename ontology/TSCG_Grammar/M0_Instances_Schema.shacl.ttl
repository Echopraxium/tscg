# TSCG Instances - Complete Grammar SHACL Schema v1.2
# Based on complete corpus analysis: 24 Poclets + 2 other instances (26 total)
# Author: Echopraxium with the collaboration of Claude AI
# Date: 2026-04-13 (initial), 2026-04-18 (v1.1 - domain migration), 2026-04-19 (v1.2 - absolute URL requirements)
# Status: UPDATED - Domain migrated to M1, ASFID/REVOI dimensions migrated to M3, absolute URL requirements documented

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m0: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Poclet#> .
@prefix m1: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#> .
@prefix m2: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#> .
@prefix m3: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld#> .

# ============================================
# NAMESPACE POLICY (CRITICAL)
# ============================================
# ALLOWED NAMESPACES:
# - Standard: owl, rdf, rdfs, skos, dcterms, xsd, etc.
# - TSCG: m3, m2, m1 (+ extensions: m1bio, m1chem, m1optics, m1geo, etc.), m0
#
# FORBIDDEN NAMESPACES:
# - tscg: (source of confusion - use m0: for instance-specific properties)
#
# CANONICAL @base URL:
# - https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/
# - NOT: Echopraxium/tscg (obsolete repository - 3/26 violations detected)
#
# @CONTEXT URL REQUIREMENTS (CRITICAL FOR PYSHACL):
# ALL namespace URLs in @context MUST be ABSOLUTE, not relative.
# ✅ CORRECT:   "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld#"
# ❌ INCORRECT: "m3": "M3_GenesisSpace.jsonld#"
# 
# Reason: pyshacl cannot resolve relative URLs when validating. Relative URLs
# cause namespace resolution failures, making properties appear absent even when
# present (e.g., m3:ontologyType, m1:domain).
#
# Required absolute URLs:
# - "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld#"
# - "m2": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#"
# - "m1": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#"
# ============================================

# ============================================
# TSCG INSTANCE TYPES (3 validated types)
# ============================================
# All TSCG instances MUST use m3:ontologyType with one of these values:
# 1. m3:Poclet (24 instances) - Primary TSCG instance type
# 2. m3:SystemicFramework (1 instance: VSM) - Systemic framework modeling
# 3. m3:SymbolicSystemGrammar (1 instance: IChing) - Symbolic system modeling
#
# OBSOLETE PROPERTIES (NEVER USE):
# - m3:ontologyCategory (1 violation detected in VSM - must be corrected)
# - m2:ontologyCategory (5 violations detected in poclets - must be corrected)
# - m2:ontologyType (incorrect namespace)
# ============================================

# ============================================
# COMMON TSCG INSTANCE SHAPE
# ============================================
# Applies to ALL TSCG instances (Poclets + SystemicFrameworks + SymbolicSystemGrammars)
m0:TscgInstanceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:name "TSCG Instance Common Shape" ;
  sh:description "Common constraints for all TSCG instances. Based on 100% corpus analysis (26 instances: 24 Poclets + 2 other types)." ;
  
  # ===== MANDATORY PROPERTIES (Universal consensus ≥70%) =====
  
  # Type must be owl:Ontology (CRITICAL - only 58% conformance)
  sh:property [
    sh:path rdf:type ;
    sh:hasValue owl:Ontology ;
    sh:minCount 1 ;
    sh:message "CRITICAL: All TSCG instances MUST have @type: owl:Ontology (never owl:NamedIndividual or m0:Poclet). Current conformance: 58% (14/24 poclets) + 100% (2/2 other instances). 10 poclets to correct."
  ] ;
  
  # Ontology type MUST use m3:ontologyType (CRITICAL - only 38% poclet conformance)
  sh:property [
    sh:path m3:ontologyType ;
    sh:nodeKind sh:IRI ;
    sh:in ( m3:Poclet m3:SystemicFramework m3:SymbolicSystemGrammar ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "CRITICAL: m3:ontologyType MUST be one of: m3:Poclet (24), m3:SystemicFramework (1), m3:SymbolicSystemGrammar (1). This is the ONLY valid ontologyType property. Current conformance: 38% poclets (9/24) + 50% others (1/2). 15 poclets + VSM to correct. NEVER use m3:ontologyCategory or m2:ontologyCategory. IMPORTANT: If this validation fails but m3:ontologyType is present, check that 'm3:' namespace in @context uses ABSOLUTE URL (https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld#) not relative URL (M3_GenesisSpace.jsonld#) - pyshacl cannot resolve relative URLs."
  ] ;
  
  # Label (standard: rdfs:label - threshold reached at 71%)
  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "rdfs:label is MANDATORY (71% consensus on poclets + 100% other instances). Use rdfs:label, NOT dcterms:title."
  ] ;
  
  # Comment (standard: rdfs:comment - 79% consensus)
  sh:property [
    sh:path rdfs:comment ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "rdfs:comment is mandatory (79% consensus poclets + 100% other instances). Use rdfs:comment, NOT dcterms:description."
  ] ;
  
  # Version info (semver - 83% consensus)
  sh:property [
    sh:path owl:versionInfo ;
    sh:datatype xsd:string ;
    sh:pattern "^[0-9]+\\.[0-9]+\\.[0-9]+$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "owl:versionInfo MUST follow semantic versioning X.Y.Z (83% consensus). Use owl:versionInfo, NOT m0:version."
  ] ;
  
  # Creator (universal 100% consensus)
  sh:property [
    sh:path dcterms:creator ;
    sh:datatype xsd:string ;
    sh:hasValue "Echopraxium with the collaboration of Claude AI" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "dcterms:creator MUST be exactly 'Echopraxium with the collaboration of Claude AI' (100% consensus across all 26 instances). Variants like 'Claude Sonnet 4.6' are NOT accepted."
  ] ;
  
  # Created date (universal 100% consensus)
  sh:property [
    sh:path dcterms:created ;
    sh:or (
      [ sh:datatype xsd:date ]
      [ sh:datatype xsd:string ]
    ) ;
    sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "dcterms:created MUST be present in format YYYY-MM-DD (100% consensus)"
  ] ;
  
  # Domain (83% consensus on poclets - MIGRATED to M1 level)
  sh:property [
    sh:path m1:domain ;
    sh:or (
      [ sh:datatype xsd:string ]           # Single domain string
      [ sh:nodeKind sh:Literal ]           # Array of domain strings (for multi-domain poclets)
    ) ;
    sh:minCount 1 ;
    sh:message "m1:domain is MANDATORY (M1-level property, not m0:domain). Accepts single string ('Chemistry') or array (['Chemistry', 'Physics']). Domain values are registered in M1_Domains.jsonld (evolving registry). Examples: 'Biology', 'Physics', 'Chemistry', 'Electronics', 'Economics', 'Optics', 'Music Theory', 'Game Theory', 'Computer Science', 'Geology', 'Engineering'. IMPORTANT: If this validation fails but m1:domain is present, check that 'm1:' namespace in @context uses ABSOLUTE URL (https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#) not relative URL (M1_CoreConcepts.jsonld#) - pyshacl cannot resolve relative URLs."
  ] ;
  
  # ===== STRONGLY RECOMMENDED PROPERTIES (Consensus 70-89%) =====
  
  # Imports (75% consensus)
  sh:property [
    sh:path owl:imports ;
    sh:minCount 0 ;
    sh:message "owl:imports is strongly recommended (75% consensus) - should list M3, M2, M1 ontologies"
  ] ;
  
  # Changelog (71% consensus - MUST be array format)
  sh:property [
    sh:path m2:changelog ;
    sh:minCount 0 ;
    sh:message "m2:changelog is strongly recommended (71% consensus - threshold reached!). MUST use array format with version/date/changes objects, NOT object format with version keys. 76% use array format (13/17), 24% use object format (4/17 to convert)."
  ] ;
  
  # ===== OPTIONAL PROPERTIES (Poclets primarily) =====
  
  # ASFID Scores (50% of poclets have scores)
  sh:property [
    sh:path m0:asfidScores ;
    sh:node m3:eagle_eye:AttractorsfidScoresShape ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:asfidScores is recommended for poclets (50% have scores) - detailed ASFID scoring. Also applicable to other instance types."
  ] ;
  
  # REVOI Scores (50% of poclets have scores - NEVER ORIVE)
  sh:property [
    sh:path m0:revoiScores ;
    sh:node m3:eagle_eye:RepresentableevoiScoresShape ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:revoiScores is recommended for poclets (50% have scores) - detailed REVOI scoring. CRITICAL: NEVER use oriveScores, sphinxEye_ORIVE, or ORIVE_Global (obsolete terminology - detected in VSM). Always use REVOI."
  ] ;
  
  # Epistemic Gap
  sh:property [
    sh:path m0:epistemicGap ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:epistemicGap (if present) must be a float in [0.0, 1.0]"
  ] .

# ============================================
# ASFID SCORES SHAPE (unchanged from v0.3)
# ============================================
m3:eagle_eye:AttractorsfidScoresShape
  a sh:NodeShape ;
  sh:name "ASFID Scores Structure" ;
  sh:description "Detailed ASFID scoring with optional justifications. Compact format {A, S, F, I, D, mean} observed in majority (86% when present)." ;
  
  sh:property [
    sh:path m3:eagle_eye:Attractor ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "ASFID A (Attractor) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:eagle_eye:Structure ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "ASFID S (Structure) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:eagle_eye:Flow ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "ASFID F (Flow) score is mandatory (0.0-1.0). F=0 is valid (represents Stase)."
  ] ;
  sh:property [
    sh:path m3:eagle_eye:Information ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "ASFID I (Information) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:eagle_eye:Dynamics ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "ASFID D (Dynamics) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m0:mean ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "ASFID mean (if present) must be in [0.0, 1.0]"
  ] .

# ============================================
# REVOI SCORES SHAPE (NOT ORIVE - CRITICAL)
# ============================================
m3:eagle_eye:RepresentableevoiScoresShape
  a sh:NodeShape ;
  sh:name "REVOI Scores Structure" ;
  sh:description "Detailed REVOI scoring with optional justifications. CRITICAL: ORIVE is OBSOLETE terminology - use REVOI. Order: R, E, V, O, I (NOT ORIVE). R = Representability (NOT Reproducibility)." ;
  
  sh:property [
    sh:path m3:sphinx_eye:Representable ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "REVOI R (Representable) score is mandatory (0.0-1.0). NOT Reproducibility."
  ] ;
  sh:property [
    sh:path m3:sphinx_eye:Evolvable ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "REVOI E (Evolvable) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:sphinx_eye:Verifiable ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "REVOI V (Verifiable) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:sphinx_eye:Observable ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "REVOI O (Observability) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m3:sphinx_eye:Interoperable ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "REVOI I (Interoperability) score is mandatory (0.0-1.0)"
  ] ;
  sh:property [
    sh:path m0:mean ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "REVOI mean (if present) must be in [0.0, 1.0]"
  ] .

# ============================================
# FORBIDDEN PATTERNS (CRITICAL)
# ============================================

# CRITICAL: Forbid owl:NamedIndividual at ontology level
m3:eagle_eye:FloworbidNamedIndividualShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path rdf:type ;
      sh:hasValue owl:NamedIndividual
    ]
  ] ;
  sh:message "CRITICAL ERROR: TSCG instances MUST use @type: owl:Ontology, NOT owl:NamedIndividual. Detected in 38% of poclets (9/24) - must be corrected. All other instances (2/2) are correct." .

# CRITICAL: Forbid @type: m0:Poclet at ontology level
m3:eagle_eye:FloworbidM0PocletTypeShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path rdf:type ;
      sh:hasValue m0:Poclet
    ]
  ] ;
  sh:message "CRITICAL ERROR: Do NOT use @type: m0:Poclet at ontology level. Use @type: owl:Ontology + m3:ontologyType: m3:Poclet instead. Detected in 1 poclet (NakamotoConsensus)." .

# CRITICAL: Forbid obsolete ORIVE terminology (VSM violation)
m3:eagle_eye:FloworbidOriveShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:or (
      [ sh:property [ sh:path m0:oriveScores ; sh:minCount 1 ] ]
      [ sh:property [ sh:path m0:sphinxEye_ORIVE ; sh:minCount 1 ] ]
      [ sh:property [ sh:path m3:sphinx_eye:ObservableRIVE_Global ; sh:minCount 1 ] ]
    )
  ] ;
  sh:message "OBSOLETE TERMINOLOGY: Use m0:revoiScores, m0:sphinxEye_REVOI, m3:eagle_eye:RepresentableEVOI_Global - NOT ORIVE variants (ORIVE is deprecated). Detected in VSM SystemicFramework - must be corrected to REVOI throughout." .

# CRITICAL: Forbid tscg: namespace (92% clean)
m3:eagle_eye:FloworbidTscgNamespaceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "FORBIDDEN NAMESPACE: 'tscg:' namespace is not allowed (8% violation rate - 2/24 poclets). Use standard namespaces (owl, rdf, rdfs, skos, dcterms, xsd) or TSCG namespaces (m3, m2, m1, m1bio, m1chem, etc., m0)" ;
    sh:select """
      PREFIX tscg: <http://undefined.tscg.namespace/>
      SELECT $this ?property ?value
      WHERE {
        $this ?property ?value .
        FILTER(STRSTARTS(STR(?property), "http://undefined.tscg.namespace/") ||
               REGEX(STR(?property), "tscg:", "i"))
      }
      LIMIT 1
    """
  ] .

# CRITICAL: Forbid incorrect @base URL (88% correct)
# NOTE: This constraint is commented out because SPARQL cannot reliably validate @base in JSON-LD @context
