# CRITICAL: Forbid m3:ontologyCategory (VSM violation) and m2:ontologyCategory
m3:eagle_eye:FloworbidObsoleteOntologyCategories
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:or (
      [ sh:property [ sh:path m3:ontologyCategory ; sh:minCount 1 ] ]
      [ sh:property [ sh:path m2:ontologyCategory ; sh:minCount 1 ] ]
    )
  ] ;
  sh:message "FORBIDDEN PROPERTIES: m3:ontologyCategory and m2:ontologyCategory are obsolete. ONLY m3:ontologyType is allowed (defined in M3_GenesisSpace.jsonld). Detected: m3:ontologyCategory in VSM (1), m2:ontologyCategory in 5 poclets." .

# CRITICAL: Forbid dcterms:title at ontology level (71% use rdfs:label)
m3:eagle_eye:FloworbidDctermsTitle
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path dcterms:title ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN at ontology level: Use rdfs:label instead of dcterms:title (38% minority usage detected - 9/24 poclets + 2/2 other instances = 11/26 total)" .

# CRITICAL: Forbid dcterms:description at ontology level (79% use rdfs:comment)
m3:eagle_eye:FloworbidDctermsDescription
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path dcterms:description ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN at ontology level: Use rdfs:comment instead of dcterms:description (29% minority usage detected - 7/24 poclets + 2/2 other instances = 9/26 total)" .

# CRITICAL: Forbid m0:version (83% use owl:versionInfo)
m3:eagle_eye:FloworbidM0Version
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:version ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Use owl:versionInfo instead of m0:version (17% minority usage detected - 4/24 poclets)" .

# CRITICAL: Forbid alternative ontologyType declarations
m3:eagle_eye:FloworbidAlternativeOntologyTypes
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m2:ontologyType ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Only m3:ontologyType is valid. Do NOT use m2:ontologyType (wrong namespace)." .

# CRITICAL: Forbid rdf:type with Poclet variants
m3:eagle_eye:FloworbidRdfTypePoclet
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:or (
      [ sh:property [ sh:path rdf:type ; sh:hasValue m0:Poclet ] ]
      [ sh:property [ sh:path rdf:type ; sh:hasValue m1:core:Poclet ] ]
    )
  ] ;
  sh:message "FORBIDDEN: Do NOT use rdf:type: m0:Poclet or rdf:type: m1:core:Poclet at ontology level. Use m3:ontologyType: {\"@id\": \"m3:Poclet\"} instead." .

# ============================================
# FINAL STATISTICS (26 TSCG instances total)
# ============================================
# 
# INSTANCE TYPE DISTRIBUTION:
# - Poclets (m3:Poclet): 24/26 (92%)
# - SystemicFramework (m3:SystemicFramework): 1/26 (4%)
# - SymbolicSystemGrammar (m3:SymbolicSystemGrammar): 1/26 (4%)
#
# CONSENSUS ACHIEVED (≥90%):
# - dcterms:creator: 26/26 (100%)
# - dcterms:created: 26/26 (100%)
# - No tscg:* namespace: 24/26 (92%)
#
# STRONG CONSENSUS (70-89%):
# - owl:versionInfo: 22/26 (85%)
# - m1:domain: 22/26 (85%) [MIGRATED from m0:domain - M1-level property]
# - rdfs:comment: 21/26 (81%)
# - owl:imports: 20/26 (77%)
# - rdfs:label: 19/26 (73%) ← THRESHOLD REACHED
# - m2:changelog: 18/26 (69%) ← JUST BELOW threshold (71% poclets-only)
#
# CRITICAL NORMALIZATION NEEDED (<70%):
# - @type: owl:Ontology: 16/26 (62%) ← MUST REACH 100% (10 to correct)
# - m3:ontologyType correct: 10/26 (38%) ← CRITICAL PRIORITY (16 to correct)
# - ASFID/REVOI scores: 14/26 (54%) ← RECOMMENDED
#
# FORBIDDEN PATTERNS DETECTED:
# - owl:NamedIndividual: 9/24 poclets (38%) ← MUST ELIMINATE
# - m3:ontologyCategory: 1/2 other (VSM) ← MUST ELIMINATE
# - m2:ontologyCategory: 5/24 poclets (21%) ← MUST ELIMINATE
# - dcterms:title: 11/26 (42%) ← MUST ELIMINATE
# - dcterms:description: 9/26 (35%) ← MUST ELIMINATE
# - m0:version: 4/24 poclets (17%) ← MUST ELIMINATE
# - tscg:* namespace: 2/24 poclets (8%) ← MUST ELIMINATE
# - @base incorrect: 4/26 (15%) ← MUST CORRECT
# - m0:Poclet type: 1/24 poclets (4%) ← MUST ELIMINATE
# - ORIVE terminology: 1/2 other (VSM) ← MUST CORRECT TO REVOI
#
