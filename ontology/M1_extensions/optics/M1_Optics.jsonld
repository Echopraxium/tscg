          "perceptualChange": "Equal brightness steps",
          "sequence": "100, 200, 400, 800, 1600, 3200, 6400, 12800"
        }
      },
      "m1:advantage": "Equal control adjustments Ã¢â€ â€™ equal perceptual changes",
      "m1:transdisciplinary": [
