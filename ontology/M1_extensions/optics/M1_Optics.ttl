ns1:MapTerritory_Optics a owl:Class ;
    rdfs:label "Map-Territory Distinction (Optics)" ;
    rdfs:comment "One Territory (perceived color) Ã¢â€ â€™ Multiple Maps (RGB, HSL, CMY, CMYK). Maps differ in ORIVE quality despite representing same Territory." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Environment,
        m2:Observer,
        m2:Representation ;
    ns1:M0_instance "M0_ColorSynthesis_Federated.jsonld" ;
    ns1:caseStudy_ColorSynthesis [ ] ;
    ns1:epistemicGap "ÃŽâ€ÃŽËœ = Ã¢â‚¬â€“Territory_ASFID - Map_ORIVEÃ¢â‚¬â€“ quantifies model limitation" ;
    ns1:principle "Map Ã¢â€°Â  Territory (Korzybski 1933). Territory is phenomenon, Map is model." ;
    ns1:validatedPoclets 1 .

<m1:optics:AdditiveColorSynthesis> a owl:Class ;
    rdfs:label "Additive Color Synthesis" ;
    rdfs:comment "Pattern where colored lights combine to produce resultant color. Adding all primaries Ã¢â€ â€™ white. Used in displays (RGB)." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Channel,
        m2:Component,
        m2:Fusion ;
    ns1:contrastedWith "m1:SubtractiveColorSynthesis (pigments absorb light)" ;
    ns1:examples [ ] ;
    ns1:formula "C_result = C_R + C_G + C_B (vector addition in color space)" ;
    ns1:perceptualBasis "Trichromatic vision (3 cone types in human retina)" ;
    ns1:physicalBasis "Electromagnetic waves superposition (constructive interference)" ;
    ns1:primaries "Blue (~435nm)",
        "Green (~546nm)",
        "Red (~700nm)" ;
    ns1:principle "Light addition: R + G + B Ã¢â€ â€™ White" ;
    ns1:validatedPoclets 2 .

<m1:optics:ChannelMultiplexing> a owl:Class ;
    rdfs:label "Channel Multiplexing (RGB/CMYK Channels)" ;
    rdfs:comment "Independent channels carry orthogonal information dimensions. Each channel isolates one component, filters content, has finite capacity." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Channel,
        m2:Component,
        m2:Modularity ;
    ns1:M0_instances "M0_CMYK_Subtractive.jsonld",
        "M0_RGB_Additive.jsonld" ;
    ns1:examples [ ] ;
    ns1:principle "Orthogonal decomposition: Signal = Ã¢Ë†â€˜ ChannelÃ¡ÂµÂ¢ (ideally independent)" ;
    ns1:properties [ ] ;
    ns1:transdisciplinary "Audio stereo (Left/Right channels)",
        "Biology (ion channels: NaÃ¢ÂÂº, KÃ¢ÂÂº, CaÃ‚Â²Ã¢ÂÂº)",
        "Economics (distribution channels)",
        "Telecommunications (frequency multiplexing)" ;
    ns1:validatedDomains 6 .

<m1:optics:ColorSpaceTransformation> a owl:Class ;
    rdfs:label "Color Space Transformation" ;
    rdfs:comment "Invertible mapping between different color representations preserving perceived color. Different spaces optimize for different purposes." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Coding,
        m2:Representation,
        m2:Transformation ;
    ns1:M0_instance "M0_ColorSynthesis_Federated.jsonld" ;
    ns1:principle "Same perceptual color Ã¢â€ â€™ multiple mathematical representations" ;
    ns1:purposeDriven "No 'best' color space - depends on application (display, print, editing)" ;
    ns1:transformations [ ] ;
    ns1:validatedPoclets 1 .

<m1:optics:CompensatoryTriplet> a owl:Class ;
    rdfs:label "Compensatory Triplet (Exposure Triangle)" ;
    rdfs:comment "Pattern where three parameters maintain constant output through reciprocal balance. Changing one requires adjusting others. Contrast with Synergistic Triplet (Fire Triangle)." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Balance,
        m2:Component,
        m2:Regulation ;
    ns1:M0_instance "M0_ExposureTriangle_Photography.jsonld" ;
    ns1:ORIVE 8.9e-01 ;
    ns1:contrastedWith [ ] ;
    ns1:example "ISO 100Ã¢â€ â€™200 (+1 stop) + Shutter 1/125Ã¢â€ â€™1/250 (-1 stop) = same exposure" ;
    ns1:formula "E = (L Ãƒâ€” t Ãƒâ€” A) / (NÃ‚Â² Ãƒâ€” S) where E=constant requires compensation" ;
    ns1:interactionMode "COMPENSATORY (not synergistic)" ;
    ns1:parameters [ ] ;
    ns1:principle "Reciprocal balance: Aperture Ãƒâ€” Shutter Ãƒâ€” ISO = Exposure (constant)" ;
    ns1:validatedPoclets 1 .

<m1:optics:LogarithmicScaling> a owl:Class ;
    rdfs:label "Logarithmic Scaling Pattern (Photographic Stops)" ;
    rdfs:comment "Parameters scaled logarithmically (doubling/halving) to match human perception. Each 'stop' represents 2Ãƒâ€” change in physical quantity but equal perceptual step." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Information,
        m2:Representation,
        m2:Signal ;
    ns1:M0_instance "M0_ExposureTriangle_Photography.jsonld" ;
    ns1:advantage "Equal control adjustments Ã¢â€ â€™ equal perceptual changes" ;
    ns1:formula "ÃŽâ€Perception = k Ãƒâ€” log(StimulusÃ¢â€šâ€š / StimulusÃ¢â€šÂ)" ;
    ns1:principle "Weber-Fechner Law: Perceived intensity Ã¢Ë†Â log(stimulus)" ;
    ns1:scales [ ] ;
    ns1:transdisciplinary "Astronomical magnitude (stellar brightness)",
        "Decibels (sound intensity)",
        "Richter scale (earthquake energy)",
        "pH scale (acidity)" ;
    ns1:validatedPoclets 1 .

<m1:optics:Optics_Domain> a owl:Ontology ;
    dcterms:created "2026-01-20" ;
    dcterms:creator "Echopraxium with collaboration of Claude AI Pro" ;
    dcterms:description "Domain-specific patterns for optics, color theory, photography, and visual perception. M1 layer instantiates M2 metaconcepts into concrete optical/photographic patterns." ;
    dcterms:modified "2026-02-24" ;
    dcterms:title "M1 Narratives - Optics Domain" ;
    rdfs:comment "M1 layer bridges abstract M2 metaconcepts to concrete M0 instances. Optics domain demonstrates color synthesis, exposure control, channel multiplexing, and perceptual scaling patterns." ;
    owl:versionInfo "1.0.0.p3" ;
    m2:changelog [ ] ;
    ns1:childInstances [ ] ;
    ns1:domain "Optics / Photography / Color Theory / Visual Perception" ;
    ns1:parentLayers [ ] ;
    ns1:patternCount 8 .

<m1:optics:PerceptualNonlinearity> a owl:Class ;
    rdfs:label "Perceptual Non-linearity (Gamma Correction)" ;
    rdfs:comment "Human perception is non-linear in light intensity. Displays/encodings apply gamma to match perception." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Adaptation,
        m2:Code,
        m2:Transformation ;
    ns1:M0_relevance "RGB, HSL models use gamma-corrected values, not linear light" ;
    ns1:formula [ ] ;
    ns1:gammaValues [ ] ;
    ns1:principle "Perceived brightness Ã¢Ë†Â Intensity^(1/ÃŽÂ³) where ÃŽÂ³ Ã¢â€°Ë† 2.2" ;
    ns1:purpose "More encoding bits for shadows (perceptually sensitive) vs highlights" ;
    ns1:validatedPoclets 0 .

<m1:optics:SideEffectCoupling> a owl:Class ;
    rdfs:label "Side Effect Coupling (Photography)" ;
    rdfs:comment "Primary parameter function coupled with unintended secondary effects. Mastery = using side effects creatively." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Emergence,
        m2:Trade-off ;
    ns1:M0_instance "M0_ExposureTriangle_Photography.jsonld" ;
    ns1:couplings [ ] ;
    ns1:mastery "Expert photographers use side effects as creative tools, not obstacles" ;
    ns1:principle "Control(Primary) Ã¢â€ â€™ Triggers(SideEffect) unavoidably" ;
    ns1:validatedPoclets 1 .

<m1:optics:SubtractiveColorSynthesis> a owl:Class ;
    rdfs:label "Subtractive Color Synthesis" ;
    rdfs:comment "Pattern where pigments/filters absorb wavelengths from white light. Subtracting all primaries Ã¢â€ â€™ black. Used in printing (CMYK)." ;
    rdfs:subClassOf "m2:GenericConcept" ;
    m2:characterizedBy m2:Channel,
        m2:Component,
        m2:Filter ;
    ns1:contrastedWith "m1:AdditiveColorSynthesis (lights add)" ;
    ns1:examples [ ] ;
    ns1:formula "C_result = White - (C_absorbed + M_absorbed + Y_absorbed)" ;
    ns1:physicalBasis "Selective absorption of wavelengths by molecular pigments" ;
    ns1:practicalChallenge "Pigment impurity Ã¢â€ â€™ CMY mix doesn't yield true black" ;
    ns1:primaries "Cyan (absorbs Red)",
        "Magenta (absorbs Green)",
        "Yellow (absorbs Blue)" ;
    ns1:principle "Light absorption: C + M + Y Ã¢â€ â€™ Black (theoretically)" ;
    ns1:validatedPoclets 2 .

<m1:optics:ValidationSummary> a owl:Class ;
    rdfs:label "M1 Optics Patterns - Validation Summary" ;
