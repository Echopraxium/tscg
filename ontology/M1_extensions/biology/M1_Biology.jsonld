    {
      "@id": "m1:biology:GeneExpression",
      "@type": "owl:Class",
      "rdfs:label": "Gene Expression",
      "rdfs:comment": "Process by which genetic information (DNA) is converted to functional product (protein). Central dogma: DNA â†’ RNA â†’ Protein.",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Information"
        },
