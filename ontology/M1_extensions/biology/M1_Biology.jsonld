          "@id": "m2:Signal"
        }
      ]
    },
    {
      "@id": "m1:biology:ImmuneResponse",
      "@type": "owl:Class",
      "rdfs:label": "Immune Response",
      "rdfs:comment": "Coordinated reaction of immune system to foreign antigens. Involves innate (immediate) and adaptive (specific, memory) components.",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Response"
