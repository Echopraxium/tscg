  "@graph": [
    {
      "@id": "m1:biology:M1_Biology",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Biology Extension",
      "rdfs:comment": "Domain-specific biological concepts for TSCG framework. Contains patterns and concepts specific to biological systems (cellular, physiological, developmental).",
      "dcterms:title": "TSCG M1 Biology - Domain-Specific Biological Concepts",
      "dcterms:description": "Extension of TSCG framework with biology-specific concepts including cellular communication, signal transduction, homeostasis, and physiological regulation.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-22",
      "owl:versionInfo": "1.0.0.p3",
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_MetaConcepts.jsonld"
      ],
      "dcterms:modified": "2026-02-24",
      "m2:changelog": {
        "p3_20260224": {
          "date": "2026-02-24",
          "description": "Phase 3 migration: (1) Non-standard @types converted to owl:Class. (2) rdfs:subClassOf m2:GenericConcept added to root concepts. (3) m2Basis fields unified → m2:characterizedBy. (4) Wrong IS-A to M2 classes moved to m2:characterizedBy. Renamed DomainConcept → KnowledgeFieldConcept throughout."
        }
      }
    },
    {
      "@id": "m1:biology:CellularCommunication",
      "@type": "owl:Class",
      "rdfs:label": "Cellular Communication",
      "rdfs:comment": "General pattern for intercellular signaling and information exchange. Foundation for all cell-cell communication modes.",
      "rdfs:subClassOf": "m1:core:CommunicationPattern",
      "m1:biology:tensorFormula": "SâŠ—IâŠ—F",
      "m1:biology:domains": [
        "Endocrinology",
        "Neuroscience",
        "Immunology",
        "Developmental Biology"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Signal"
        },
        {
          "@id": "m2:Channel"
        },
        {
          "@id": "m2:Information"
        }
      ]
    },
    {
      "@id": "m1:biology:AutocrineSignaling",
      "@type": "owl:Class",
      "rdfs:label": "Autocrine Signaling",
      "rdfs:comment": "Self-signaling pattern where a cell responds to signals it secretes itself. Used for feedback regulation and autonomous cell behavior.",
      "rdfs:subClassOf": "m1:biology:CellularCommunication",
      "m1:biology:spatialRange": "Intracellular to immediate cell surface (~1-10 Âµm)",
      "m1:biology:temporalRange": "Milliseconds to seconds",
      "m1:biology:mechanism": "Local concentration gradient around secreting cell",
      "m1:biology:examples": [
        "T-cell IL-2 autocrine loops",
        "Cancer cell growth factor self-stimulation",
        "Neurotransmitter autoreceptors"
      ]
    },
    {
      "@id": "m1:biology:ParacrineSignaling",
      "@type": "owl:Class",
      "rdfs:label": "Paracrine Signaling",
      "rdfs:comment": "Local neighborhood signaling pattern where signals diffuse through extracellular space to affect nearby cells. Coordinates tissue-level activity.",
      "rdfs:subClassOf": "m1:biology:CellularCommunication",
      "m1:biology:spatialRange": "Local tissue microenvironment (~10 Âµm - 1 mm)",
      "m1:biology:temporalRange": "Seconds to minutes",
      "m1:biology:mechanism": "Fick's law diffusion through extracellular matrix",
      "m1:biology:examples": [
        "Prostaglandins in inflammation",
        "Nitric oxide vasodilation",
        "Neurotransmitters at synapses",
        "Morphogen gradients in development"
      ]
    },
    {
      "@id": "m1:biology:NeuroendocrineSignaling",
      "@type": "owl:Class",
      "rdfs:label": "Neuroendocrine Signaling",
      "rdfs:comment": "Hybrid signaling pattern combining neural speed with endocrine range. Neurons secrete hormones into bloodstream for systemic distribution.",
      "rdfs:subClassOf": "m1:biology:CellularCommunication",
      "m1:biology:spatialRange": "Systemic (entire organism via bloodstream)",
      "m1:biology:temporalRange": "Seconds (neural trigger) â†’ Minutes to hours (hormonal effect)",
      "m1:biology:mechanism": "Neural activation triggers hormone secretion into circulation",
      "m1:biology:examples": [
        "Hypothalamic-pituitary axis",
        "Adrenal medulla catecholamine release",
        "Oxytocin release in lactation",
        "ADH/Vasopressin water regulation"
      ]
    },
    {
      "@id": "m1:biology:EndocrineSignaling",
      "@type": "owl:Class",
      "rdfs:label": "Endocrine Signaling",
      "rdfs:comment": "Systemic signaling pattern where specialized glands secrete hormones into bloodstream for organism-wide coordination. Classic long-range hormonal communication.",
      "rdfs:subClassOf": "m1:biology:CellularCommunication",
      "m1:biology:spatialRange": "Systemic (entire organism)",
      "m1:biology:temporalRange": "Minutes to hours (hormone half-life dependent)",
      "m1:biology:mechanism": "Convective transport via cardiovascular system",
      "m1:biology:examples": [
        "Insulin glucose regulation",
        "Thyroid hormone metabolic control",
        "Growth hormone",
        "Sex steroids (estrogen, testosterone)",
        "Cortisol stress response"
      ]
    },
    {
      "@id": "m1:biology:Hormone",
      "@type": "owl:Class",
      "rdfs:label": "Hormone",
      "rdfs:comment": "Signaling molecule secreted by cells that travels through body fluids to target cells expressing specific receptors.",
      "m1:biology:categories": {
        "peptide": "Insulin, Growth hormone, Oxytocin (hydrophilic)",
        "steroid": "Cortisol, Estrogen, Testosterone (lipophilic)",
        "amino-acid-derived": "Thyroxine, Adrenaline, Melatonin"
      },
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Signal"
        },
        {
          "@id": "m2:Agent"
        },
        {
          "@id": "m2:Mediator"
        }
      ]
    },
    {
      "@id": "m1:biology:Receptor",
      "@type": "owl:Class",
      "rdfs:label": "Receptor",
      "rdfs:comment": "Molecular structure that binds specific signaling molecules and transduces signal into cellular response.",
      "m1:biology:types": {
        "membrane": "G-protein coupled receptors (GPCRs), Receptor tyrosine kinases (RTKs), Ion channels",
        "intracellular": "Nuclear receptors (steroid hormones), Cytoplasmic receptors"
      },
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Interface"
        },
        {
          "@id": "m2:Transducer"
        },
        {
          "@id": "m2:Switch"
        }
      ]
    },
    {
      "@id": "m1:biology:SignalTransduction",
      "@type": "owl:Class",
      "rdfs:label": "Signal Transduction",
      "rdfs:comment": "Process by which extracellular signal is converted into intracellular response through cascade of molecular interactions.",
      "m1:biology:components": [
        "Ligand-receptor binding",
        "Second messenger systems (cAMP, CaÂ²âº, IPâ‚ƒ)",
        "Protein kinase cascades",
        "Gene expression modulation"
      ],
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
        },
        {
          "@id": "m2:Cascade"
        },
        {
          "@id": "m2:Amplification"
        }
      ]
    },
    {
      "@id": "m1:biology:Homeostasis",
      "@type": "owl:Class",
      "rdfs:label": "Homeostasis",
      "rdfs:comment": "Maintenance of stable internal conditions despite external fluctuations. Achieved through negative feedback regulation.",
      "m1:biology:parameters": [
        "Blood glucose (~5 mM)",
        "Body temperature (37Â°C)",
        "Blood pH (7.35-7.45)",
        "Calcium concentration (~2.5 mM)",
        "Blood pressure (120/80 mmHg)"
      ],
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Balance"
        },
        {
          "@id": "m2:Regulation"
        },
        {
          "@id": "m2:Feedback"
        },
        {
          "@id": "m2:Attractor"
        }
      ]
    },
    {
      "@id": "m1:biology:FeedbackLoop",
      "@type": "owl:Class",
      "rdfs:label": "Feedback Loop",
      "rdfs:comment": "Regulatory circuit where output influences input. Can be negative (stabilizing) or positive (amplifying).",
      "m1:biology:types": {
        "negative": "Thermostat-like stabilization (insulin-glucose, thyroid hormone)",
        "positive": "Explosive amplification (oxytocin in labor, blood clotting)"
      },
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Feedback"
        },
        {
          "@id": "m2:Loop"
        },
        {
          "@id": "m2:Regulation"
        }
      ]
    },
    {
      "@id": "m1:biology:DiffusionGradient",
      "@type": "owl:Class",
      "rdfs:label": "Diffusion Gradient",
      "rdfs:comment": "Spatial concentration pattern driving molecular movement from high to low concentration. Governed by Fick's laws.",
      "m1:biology:physics": {
        "fickFirstLaw": "J = -Dâˆ‡C (flux proportional to gradient)",
        "fickSecondLaw": "âˆ‚C/âˆ‚t = Dâˆ‡Â²C (concentration evolution)",
        "diffusionCoefficient": "D ~ 10â»Â¹â° mÂ²/s for proteins in extracellular matrix"
      },
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Gradient"
        },
        {
          "@id": "m2:Flow"
        },
        {
          "@id": "m2:Field"
        }
      ]
    },
    {
      "@id": "m1:biology:Morphogen",
      "@type": "owl:Class",
      "rdfs:label": "Morphogen",
      "rdfs:comment": "Signaling molecule that forms concentration gradient and specifies cell fate in developing tissue. Position in gradient determines cell identity.",
      "rdfs:subClassOf": "m1:biology:Hormone",
      "m1:biology:examples": [
        "Hedgehog (vertebrate neural tube patterning)",
        "BMP (bone morphogenetic protein)",
        "Wnt (embryonic axis formation)",
        "Retinoic acid (limb development)"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Gradient"
        },
        {
          "@id": "m2:Information"
        },
        {
          "@id": "m2:Pattern"
        }
      ]
    },
    {
      "@id": "m1:biology:HypothalamusPituitaryAxis",
      "@type": "owl:Class",
      "rdfs:label": "Hypothalamus-Pituitary Axis",
      "rdfs:comment": "Master neuroendocrine structure coordinating hormone secretion. Hypothalamus integrates neural signals and controls pituitary hormone release.",
      "m1:biology:axes": [
        "HPA axis (stress): CRH â†’ ACTH â†’ Cortisol",
        "HPG axis (reproduction): GnRH â†’ LH/FSH â†’ Sex steroids",
        "HPT axis (metabolism): TRH â†’ TSH â†’ Thyroid hormones"
      ],
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Hierarchy"
        },
        {
          "@id": "m2:Hub"
        },
        {
          "@id": "m2:Control"
        }
      ]
    },
    {
      "@id": "m1:biology:Cell",
      "@type": "owl:Class",
      "rdfs:label": "Cell",
      "rdfs:comment": "Fundamental unit of life. Bounded compartment capable of metabolism, growth, and reproduction.",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Component"
        },
        {
          "@id": "m2:Agent"
        },
        {
          "@id": "m2:System"
        }
      ]
    },
    {
      "@id": "m1:biology:Tissue",
      "@type": "owl:Class",
      "rdfs:label": "Tissue",
      "rdfs:comment": "Organized ensemble of cells performing coordinated function. Level between cell and organ in biological hierarchy.",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Composition"
