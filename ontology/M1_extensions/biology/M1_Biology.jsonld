    {
      "@id": "m1:biology:Inflammation",
      "@type": "owl:Class",
      "rdfs:label": "Inflammation",
      "rdfs:comment": "Complex biological response to harmful stimuli (pathogens, damaged cells, irritants). Involves immune cell recruitment and tissue repair.",
      "m1:biology:characteristics": [
        "Rubor (redness)",
        "Calor (heat)",
        "Tumor (swelling)",
        "Dolor (pain)",
        "Functio laesa (loss of function)"
      ],
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Response"
        },
        {
          "@id": "m2:Cascade"
        },
        {
          "@id": "m2:Emergence"
        }
      ]
    },
    {
      "@id": "m1:biology:Synapse",
      "@type": "owl:Class",
      "rdfs:label": "Synapse",
      "rdfs:comment": "Specialized junction between neurons enabling signal transmission. Can be chemical (neurotransmitter) or electrical (gap junction).",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Interface"
        },
        {
          "@id": "m2:Channel"
        },
