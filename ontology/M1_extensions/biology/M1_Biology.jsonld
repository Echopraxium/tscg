          "@id": "m2:Layer"
        }
      ]
    },
    {
      "@id": "m1:biology:Organ",
      "@type": "owl:Class",
      "rdfs:label": "Organ",
      "rdfs:comment": "Structural unit composed of multiple tissue types performing specific physiological function.",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Modularity"
        },
        {
          "@id": "m2:Function"
        },
        {
          "@id": "m2:Hierarchy"
        }
      ]
    },
    {
      "@id": "m1:biology:BloodCirculation",
      "@type": "owl:Class",
      "rdfs:label": "Blood Circulation",
      "rdfs:comment": "Cardiovascular transport system distributing nutrients, gases, hormones, and immune cells throughout organism.",
      "m1:biology:parameters": {
        "cardiacOutput": "~5 L/min at rest",
        "circulationTime": "~60 seconds complete circuit",
        "pressure": "120/80 mmHg (systolic/diastolic)"
      },
      "rdfs:subClassOf": "m2:GenericConcept",
