        }
      ]
    },
    {
      "@id": "m1:biology:Metabolism",
      "@type": "owl:Class",
      "rdfs:label": "Metabolism",
      "rdfs:comment": "Sum of all chemical reactions maintaining life. Includes catabolism (breakdown) and anabolism (synthesis).",
      "rdfs:subClassOf": "m2:GenericConcept",
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
