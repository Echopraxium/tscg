      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_19",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Periodic Action",
      "m1:extension:systemic_modeling:principleNumber": 19,
      "m1:extension:systemic_modeling:code": "PerA#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
