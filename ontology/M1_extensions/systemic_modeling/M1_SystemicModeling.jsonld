  "@graph": [
    {
      "@id": "m1:extension:systemic_modeling:M1_SystemicModeling",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Innovation Extension",
      "rdfs:comment": "Domain-specific concepts for innovation methodologies and systematic problem-solving. Hosts 40 TRIZ inventive principles as concrete instances, plus framework components (contradiction matrices, inventivity levels, technical parameters).",
      "dcterms:title": "TSCG M1 Innovation — TRIZ Principles and Innovation Frameworks",
      "dcterms:description": "Extension of TSCG framework with TRIZ-specific concepts: 40 inventive principles as instances of TrizPrinciple class, plus systematic innovation components. Serves as M1 foundation for innovation-focused SystemicFramework instances.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-04-20",
      "owl:versionInfo": "1.2.0",
      "m3:ontologyType": {
        "@id": "m3:DomainExtension"
      },
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld"
      ],
      "m1:extension:systemic_modeling:conceptCount": 6,
      "m1:extension:systemic_modeling:trizPrincipleCount": 40,
      "m1:extension:systemic_modeling:categories": [
        "Inventive Principles (40 instances)",
        "Contradiction Analysis",
        "Framework Components",
        "Systematic Innovation"
      ],
      "m2:changelog": [
        {
          "version": "1.2.0",
          "date": "2026-07-12",
          "changes": "SC-1 FUNCTIONAL GRAMMAR MODEL. RENAME (hard): m2:KnowledgeFieldConceptCombo → m2:DomainConceptCombo. The class is also RE-DEFINED: a DomainConceptCombo is defined by its Fm1m2 formula — a hybrid of ≥1 Domain and ≥1 GenericConcept (domain qualification), superseding the former 'parents from distinct epistemological domains' criterion. A combo's formula IS the function signature: Fm2 : GenericConcept²⁺ → GenericConceptCombo (≥2 concepts); Fm1m2 : Domain⁺, GenericConcept⁺ → DomainConceptCombo (≥1 domain AND ≥1 concept). No monoidal formula, no monoidal expansion — emergence is non-compositional, so Fm2/Fm1m2 are FUNCTIONS, not functors. Arguments = named concepts from M2_GenericConcepts or M1_CoreConcepts only, comma-juxtaposed, never primitives, never joined by ×/+/|. Fm1 does not exist. ⚠ Formulas in this file are FLAGGED by the new SHACL (v1.1.0) and NOT repaired here — repair belongs to SC-6. See StructuralGrammar/Functional_Grammar_Model.md."
        },
        {
          "version": "1.1.1",
          "date": "2026-05-27",
          "changes": "BASE16 NOTATION: 5 formula(s) updated — S→St in hybrid formulas (containing |). Convention: in hybrid formulas, St (Structure/Territory) to avoid collision with Ss (Symbol/Stereopsic/Gs)."
        },
        {
          "version": "1.0.0",
          "date": "2026-04-20",
          "changes": "Initial extension created for TRIZ SystemicFramework (Option C architecture). Added TrizPrinciple class + 40 instances with 3-5 char codes. Added 5 specialized concepts: SubstitutionPrinciple, GeometricPrinciple, PhysicochemicalPrinciple, ContradictionMatrix, InventivityLevel, TechnicalParameter. Extends M1_CoreConcepts (MethodologicalPrinciple, TransformationalPrinciple, CompositionalPrinciple)."
        }
      ],
      "dcterms:modified": "2026-07-12"
    },
    {
      "@id": "m1:extension:systemic_modeling:TrizPrinciple",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:label": "TRIZ Inventive Principle",
      "rdfs:comment": "Abstract class representing a TRIZ inventive principle. Each of the 40 principles is an instance of this class, classified by family (Methodological, Transformational, Compositional, Physicochemical, Substitution, Geometric) and linked to parent GenericConceptCombo.",
      "rdfs:subClassOf": "m2:DomainConceptCombo",
      "m1:extension:systemic_modeling:properties": [
        "principleNumber (1-40)",
        "threeLetterCode (3-5 chars)",
        "family (principle classification)",
        "genericConceptCombo (parent M1 combo)",
        "example (application examples)",
        "m2:mobilizes (GenericConcepts used)"
      ],
      "dcterms:created": "2026-04-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m1:structuralGrammarFormula": "Fm1m2(SystemicModeling, A × St × It × D | R + V)"
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_01",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Segmentation",
      "m1:extension:systemic_modeling:principleNumber": 1,
      "m1:extension:systemic_modeling:code": "Sgm#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Divide an object into independent parts, make it sectional, or increase degree of fragmentation",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Replace mainframe computer with network of PCs; modular furniture; sectional snake drill",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Modularity"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_02",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Extraction",
      "m1:extension:systemic_modeling:principleNumber": 2,
      "m1:extension:systemic_modeling:code": "Xtrc#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Separate disturbing part or property from object, or extract only necessary part/property",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Place noisy air compressor outside building; extract active ingredient from plant; noise-canceling headphones",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Segmentation"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_03",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Local Quality",
      "m1:extension:systemic_modeling:principleNumber": 3,
      "m1:extension:systemic_modeling:code": "LocQ",
      "rdfs:comment": "Change structure from uniform to non-uniform; make different parts perform different functions",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Pencil with eraser; hammer with claw; multi-zone climate control",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Asymmetry"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_04",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Asymmetry",
      "m1:extension:systemic_modeling:principleNumber": 4,
      "m1:extension:systemic_modeling:code": "AsmY",
      "m1:extension:systemic_modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Replace symmetrical form with asymmetrical; if already asymmetric, increase degree of asymmetry",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Flat side on cylindrical shaft; asymmetric tire tread; ergonomic tool handles",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Symmetry"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_05",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Merging",
      "m1:extension:systemic_modeling:principleNumber": 5,
      "m1:extension:systemic_modeling:code": "Merg%",
      "m1:extension:systemic_modeling:codeConvention": "%=ing",
      "rdfs:comment": "Bring identical or similar objects together; assemble identical or similar parts for parallel operations",
      "m1:extension:systemic_modeling:family": "Compositional",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:CompositionalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Multiple medical tests on single blood sample; parallel processing; multi-blade razor",
      "m2:mobilizes": [
        "m2:Composition",
        "m2:Modularity",
        "m2:Synergy"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_06",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Universality",
      "m1:extension:systemic_modeling:principleNumber": 6,
      "m1:extension:systemic_modeling:code": "UnivY",
      "m1:extension:systemic_modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Make object perform multiple functions; eliminate need for other parts",
      "m1:extension:systemic_modeling:family": "Compositional",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:CompositionalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Swiss Army knife; smartphone (phone+camera+computer); sofa bed",
      "m2:mobilizes": [
        "m2:Composition",
        "m2:Modularity",
        "m2:Integration"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_07",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Nesting",
      "m1:extension:systemic_modeling:principleNumber": 7,
      "m1:extension:systemic_modeling:code": "Nest#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Place object inside another; make one part pass through cavity of another",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Telescopic antenna; Russian dolls; nested shopping carts",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Hierarchy"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_08",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Anti-weight",
      "m1:extension:systemic_modeling:principleNumber": 8,
      "m1:extension:systemic_modeling:code": "AWght",
      "rdfs:comment": "Compensate weight by merging with object providing lift",
      "m1:extension:systemic_modeling:family": "Physicochemical",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:extension:systemic_modeling:PhysicochemicalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Helium balloon supporting sign; hydrofoil boat; airplane wing lift",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Balance",
        "m2:Composition"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_09",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Preliminary Anti-action",
      "m1:extension:systemic_modeling:principleNumber": 9,
      "m1:extension:systemic_modeling:code": "PrAA#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Create pre-stresses to oppose known undesirable working stresses",
      "m1:extension:systemic_modeling:family": "Geometric",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:extension:systemic_modeling:GeometricPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Pre-stressing steel bars before pouring concrete; pre-shrinking fabric",
      "m2:mobilizes": [
        "m2:Pattern",
        "m2:Space",
        "m2:Constraint"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_10",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Preliminary Action",
      "m1:extension:systemic_modeling:principleNumber": 10,
      "m1:extension:systemic_modeling:code": "PrA#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Perform required change in advance; pre-arrange objects",
      "m1:extension:systemic_modeling:family": "Methodological",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:MethodologicalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Pre-glued wallpaper; self-adhesive stamps; instant coffee",
      "m2:mobilizes": [
        "m2:Process",
        "m2:Workflow",
        "m2:Pattern"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_11",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Beforehand Cushioning",
      "m1:extension:systemic_modeling:principleNumber": 11,
      "m1:extension:systemic_modeling:code": "B4Cus",
      "m1:extension:systemic_modeling:codeConvention": "B4=Before",
      "rdfs:comment": "Prepare emergency means beforehand to compensate for low reliability",
      "m1:extension:systemic_modeling:family": "Methodological",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:MethodologicalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Backup parachute; airbag; spare tire; firewall",
      "m2:mobilizes": [
        "m2:Process",
        "m2:Workflow",
        "m2:Resilience"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_12",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Equipotentiality",
      "m1:extension:systemic_modeling:principleNumber": 12,
      "m1:extension:systemic_modeling:code": "EquiP",
      "rdfs:comment": "Change operating conditions to eliminate need to raise/lower object",
      "m1:extension:systemic_modeling:family": "Geometric",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:extension:systemic_modeling:GeometricPrinciple"
