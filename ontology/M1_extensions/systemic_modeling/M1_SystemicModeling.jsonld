      "m1:extension:systemic_modeling:example": "Panama Canal locks; spring-loaded parts delivery",
      "m2:mobilizes": [
        "m2:Pattern",
        "m2:Space",
        "m2:Balance"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_13",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Do it in Reverse",
      "m1:extension:systemic_modeling:principleNumber": 13,
      "m1:extension:systemic_modeling:code": "DIIR",
      "rdfs:comment": "Invert action to solve problem; make moving parts fixed and fixed parts moving",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Cool inner part instead of heating outer; turn mold upside down",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Polarity"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_14",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Spheroidality",
      "m1:extension:systemic_modeling:principleNumber": 14,
      "m1:extension:systemic_modeling:code": "SphrY",
      "m1:extension:systemic_modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Replace linear parts with curved ones; use spherical shapes",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Ball casters; cylindrical brush roller; spherical storage tank",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Topology"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_15",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Dynamics",
      "m1:extension:systemic_modeling:principleNumber": 15,
      "m1:extension:systemic_modeling:code": "Dyn$",
      "m1:extension:systemic_modeling:codeConvention": "$=ics",
      "rdfs:comment": "Allow characteristics to change to be optimal at each stage",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Adjustable car seat; folding smartphone screen; adaptive suspension",
      "m2:mobilizes": [
        "m2:Transformation",
        "m2:Pattern",
        "m2:Adaptation"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_16",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Partial or Excessive Action",
      "m1:extension:systemic_modeling:principleNumber": 16,
      "m1:extension:systemic_modeling:code": "P/ExA",
      "rdfs:comment": "Use slightly less or more; do more than necessary then remove excess",
      "m1:extension:systemic_modeling:family": "Methodological",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:MethodologicalPrinciple"
      },
