    {
      "@id": "m1:extension:systemic_modeling:Principle_22",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Convert Harm into Benefit",
      "m1:extension:systemic_modeling:principleNumber": 22,
      "m1:extension:systemic_modeling:code": "CH2B",
      "m1:extension:systemic_modeling:codeConvention": "2=to",
