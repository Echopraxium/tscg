        "m2:Pattern",
        "m2:Space"
      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_18",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Mechanical Vibration",
      "m1:extension:systemic_modeling:principleNumber": 18,
      "m1:extension:systemic_modeling:code": "MecV#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Cause object to oscillate; use resonant frequency; use ultrasonic vibrations",
      "m1:extension:systemic_modeling:family": "Geometric",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:extension:systemic_modeling:GeometricPrinciple"
      },
      "m1:extension:systemic_modeling:example": "Electric knife; ultrasonic cleaning; vibratory compaction",
      "m2:mobilizes": [
