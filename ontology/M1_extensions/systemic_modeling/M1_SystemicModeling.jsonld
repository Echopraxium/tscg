      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_17",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Another Dimension",
      "m1:extension:systemic_modeling:principleNumber": 17,
      "m1:extension:systemic_modeling:code": "OthD#",
      "m1:extension:systemic_modeling:codeConvention": "#=sion",
      "rdfs:comment": "Move from 1D to 2D to 3D; use multi-story arrangement",
      "m1:extension:systemic_modeling:family": "Transformational",
      "m1:extension:systemic_modeling:parentCombo": {
        "@id": "m1:TransformationalPrinciple"
      },
