      ]
    },
    {
      "@id": "m1:extension:systemic_modeling:Principle_20",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Continuity of Useful Action",
      "m1:extension:systemic_modeling:principleNumber": 20,
      "m1:extension:systemic_modeling:code": "CUA#",
      "m1:extension:systemic_modeling:codeConvention": "#=tion",
      "rdfs:comment": "Carry on work continuously; eliminate idle actions",
