    {
      "@id": "m1:extension:systemic_modeling:Principle_21",
      "@type": "m1:extension:systemic_modeling:TrizPrinciple",
      "rdfs:label": "Rushing Through",
      "m1:extension:systemic_modeling:principleNumber": 21,
      "m1:extension:systemic_modeling:code": "Rus==",
      "m1:extension:systemic_modeling:codeConvention": "==Through",
