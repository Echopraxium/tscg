  "@graph": [
    {
      "@id": "m1.ext:systemic-modeling:M1_SystemicModeling",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Innovation Extension",
      "rdfs:comment": "Domain-specific concepts for innovation methodologies and systematic problem-solving. Hosts 40 TRIZ inventive principles as concrete instances, plus framework components (contradiction matrices, inventivity levels, technical parameters).",
      "dcterms:title": "TSCG M1 Innovation — TRIZ Principles and Innovation Frameworks",
      "dcterms:description": "Extension of TSCG framework with TRIZ-specific concepts: 40 inventive principles as instances of TrizPrinciple class, plus systematic innovation components. Serves as M1 foundation for innovation-focused SystemicFramework instances.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-04-20",
      "owl:versionInfo": "1.0.0",
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld"
      ],
      "m1.ext:systemic-modeling:conceptCount": 6,
      "m1.ext:systemic-modeling:trizPrincipleCount": 40,
      "m1.ext:systemic-modeling:categories": [
        "Inventive Principles (40 instances)",
        "Contradiction Analysis",
        "Framework Components",
        "Systematic Innovation"
      ],
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-04-20",
          "changes": "Initial extension created for TRIZ SystemicFramework (Option C architecture). Added TrizPrinciple class + 40 instances with 3-5 char codes. Added 5 specialized concepts: SubstitutionPrinciple, GeometricPrinciple, PhysicochemicalPrinciple, ContradictionMatrix, InventivityLevel, TechnicalParameter. Extends M1_CoreConcepts (MethodologicalPrinciple, TransformationalPrinciple, CompositionalPrinciple)."
        }
      ]
    },
    {
      "@id": "m1.ext:systemic-modeling:TrizPrinciple",
      "@type": "owl:Class",
      "rdfs:label": "TRIZ Inventive Principle",
      "rdfs:comment": "Abstract class representing a TRIZ inventive principle. Each of the 40 principles is an instance of this class, classified by family (Methodological, Transformational, Compositional, Physicochemical, Substitution, Geometric) and linked to parent GenericConceptCombo.",
      "rdfs:subClassOf": "m2:Pattern",
      "m1.ext:systemic-modeling:properties": [
        "principleNumber (1-40)",
        "threeLetterCode (3-5 chars)",
        "family (principle classification)",
        "genericConceptCombo (parent M1 combo)",
        "example (application examples)",
        "m2:mobilizes (GenericConcepts used)"
      ],
      "dcterms:created": "2026-04-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_01",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Segmentation",
      "m1.ext:systemic-modeling:principleNumber": 1,
      "m1.ext:systemic-modeling:code": "Sgm#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Divide an object into independent parts, make it sectional, or increase degree of fragmentation",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Replace mainframe computer with network of PCs; modular furniture; sectional snake drill",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Modularity"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_02",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Extraction",
      "m1.ext:systemic-modeling:principleNumber": 2,
      "m1.ext:systemic-modeling:code": "Xtrc#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Separate disturbing part or property from object, or extract only necessary part/property",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Place noisy air compressor outside building; extract active ingredient from plant; noise-canceling headphones",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Segmentation"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_03",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Local Quality",
      "m1.ext:systemic-modeling:principleNumber": 3,
      "m1.ext:systemic-modeling:code": "LocQ",
      "rdfs:comment": "Change structure from uniform to non-uniform; make different parts perform different functions",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Pencil with eraser; hammer with claw; multi-zone climate control",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Asymmetry"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_04",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Asymmetry",
      "m1.ext:systemic-modeling:principleNumber": 4,
      "m1.ext:systemic-modeling:code": "AsmY",
      "m1.ext:systemic-modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Replace symmetrical form with asymmetrical; if already asymmetric, increase degree of asymmetry",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Flat side on cylindrical shaft; asymmetric tire tread; ergonomic tool handles",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Symmetry"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_05",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Merging",
      "m1.ext:systemic-modeling:principleNumber": 5,
      "m1.ext:systemic-modeling:code": "Merg%",
      "m1.ext:systemic-modeling:codeConvention": "%=ing",
      "rdfs:comment": "Bring identical or similar objects together; assemble identical or similar parts for parallel operations",
      "m1.ext:systemic-modeling:family": "Compositional",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:CompositionalPrinciple"},
      "m1.ext:systemic-modeling:example": "Multiple medical tests on single blood sample; parallel processing; multi-blade razor",
      "m2:mobilizes": ["m2:Composition", "m2:Modularity", "m2:Synergy"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_06",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Universality",
      "m1.ext:systemic-modeling:principleNumber": 6,
      "m1.ext:systemic-modeling:code": "UnivY",
      "m1.ext:systemic-modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Make object perform multiple functions; eliminate need for other parts",
      "m1.ext:systemic-modeling:family": "Compositional",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:CompositionalPrinciple"},
      "m1.ext:systemic-modeling:example": "Swiss Army knife; smartphone (phone+camera+computer); sofa bed",
      "m2:mobilizes": ["m2:Composition", "m2:Modularity", "m2:Integration"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_07",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Nesting",
      "m1.ext:systemic-modeling:principleNumber": 7,
      "m1.ext:systemic-modeling:code": "Nest#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Place object inside another; make one part pass through cavity of another",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Telescopic antenna; Russian dolls; nested shopping carts",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Hierarchy"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_08",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Anti-weight",
      "m1.ext:systemic-modeling:principleNumber": 8,
      "m1.ext:systemic-modeling:code": "AWght",
      "rdfs:comment": "Compensate weight by merging with object providing lift",
      "m1.ext:systemic-modeling:family": "Physicochemical",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:PhysicochemicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Helium balloon supporting sign; hydrofoil boat; airplane wing lift",
      "m2:mobilizes": ["m2:Transformation", "m2:Balance", "m2:Composition"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_09",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Preliminary Anti-action",
      "m1.ext:systemic-modeling:principleNumber": 9,
      "m1.ext:systemic-modeling:code": "PrAA#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Create pre-stresses to oppose known undesirable working stresses",
      "m1.ext:systemic-modeling:family": "Geometric",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:GeometricPrinciple"},
      "m1.ext:systemic-modeling:example": "Pre-stressing steel bars before pouring concrete; pre-shrinking fabric",
      "m2:mobilizes": ["m2:Pattern", "m2:Space", "m2:Constraint"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_10",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Preliminary Action",
      "m1.ext:systemic-modeling:principleNumber": 10,
      "m1.ext:systemic-modeling:code": "PrA#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Perform required change in advance; pre-arrange objects",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Pre-glued wallpaper; self-adhesive stamps; instant coffee",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Pattern"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_11",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Beforehand Cushioning",
      "m1.ext:systemic-modeling:principleNumber": 11,
      "m1.ext:systemic-modeling:code": "B4Cus",
      "m1.ext:systemic-modeling:codeConvention": "B4=Before",
      "rdfs:comment": "Prepare emergency means beforehand to compensate for low reliability",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Backup parachute; airbag; spare tire; firewall",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Resilience"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_12",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Equipotentiality",
      "m1.ext:systemic-modeling:principleNumber": 12,
      "m1.ext:systemic-modeling:code": "EquiP",
      "rdfs:comment": "Change operating conditions to eliminate need to raise/lower object",
      "m1.ext:systemic-modeling:family": "Geometric",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:GeometricPrinciple"},
      "m1.ext:systemic-modeling:example": "Panama Canal locks; spring-loaded parts delivery",
      "m2:mobilizes": ["m2:Pattern", "m2:Space", "m2:Balance"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_13",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Do it in Reverse",
      "m1.ext:systemic-modeling:principleNumber": 13,
      "m1.ext:systemic-modeling:code": "DIIR",
      "rdfs:comment": "Invert action to solve problem; make moving parts fixed and fixed parts moving",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Cool inner part instead of heating outer; turn mold upside down",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Polarity"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_14",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Spheroidality",
      "m1.ext:systemic-modeling:principleNumber": 14,
      "m1.ext:systemic-modeling:code": "SphrY",
      "m1.ext:systemic-modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Replace linear parts with curved ones; use spherical shapes",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Ball casters; cylindrical brush roller; spherical storage tank",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Topology"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_15",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Dynamics",
      "m1.ext:systemic-modeling:principleNumber": 15,
      "m1.ext:systemic-modeling:code": "Dyn$",
      "m1.ext:systemic-modeling:codeConvention": "$=ics",
      "rdfs:comment": "Allow characteristics to change to be optimal at each stage",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Adjustable car seat; folding smartphone screen; adaptive suspension",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Adaptation"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_16",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Partial or Excessive Action",
      "m1.ext:systemic-modeling:principleNumber": 16,
      "m1.ext:systemic-modeling:code": "P/ExA",
      "rdfs:comment": "Use slightly less or more; do more than necessary then remove excess",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Extra paint then sand; overfill mold then trim; overbook flights",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Trade-off"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_17",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Another Dimension",
      "m1.ext:systemic-modeling:principleNumber": 17,
      "m1.ext:systemic-modeling:code": "OthD#",
      "m1.ext:systemic-modeling:codeConvention": "#=sion",
      "rdfs:comment": "Move from 1D to 2D to 3D; use multi-story arrangement",
      "m1.ext:systemic-modeling:family": "Transformational",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:TransformationalPrinciple"},
      "m1.ext:systemic-modeling:example": "Double-sided circuit boards; stacked chips; vertical farming",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Space"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_18",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Mechanical Vibration",
      "m1.ext:systemic-modeling:principleNumber": 18,
      "m1.ext:systemic-modeling:code": "MecV#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Cause object to oscillate; use resonant frequency; use ultrasonic vibrations",
      "m1.ext:systemic-modeling:family": "Geometric",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:GeometricPrinciple"},
      "m1.ext:systemic-modeling:example": "Electric knife; ultrasonic cleaning; vibratory compaction",
      "m2:mobilizes": ["m2:Pattern", "m2:Space", "m2:Oscillation"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_19",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Periodic Action",
      "m1.ext:systemic-modeling:principleNumber": 19,
      "m1.ext:systemic-modeling:code": "PerA#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Replace continuous action with periodic; change frequency",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Pulsed siren; intermittent wipers; pulse-width modulation",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Oscillation"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_20",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Continuity of Useful Action",
      "m1.ext:systemic-modeling:principleNumber": 20,
      "m1.ext:systemic-modeling:code": "CUA#",
      "m1.ext:systemic-modeling:codeConvention": "#=tion",
      "rdfs:comment": "Carry on work continuously; eliminate idle actions",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Printer prints during carriage return; continuous production line",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Optimization"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_21",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Rushing Through",
      "m1.ext:systemic-modeling:principleNumber": 21,
      "m1.ext:systemic-modeling:code": "Rus==",
      "m1.ext:systemic-modeling:codeConvention": "==Through",
      "rdfs:comment": "Conduct harmful operation at high speed",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Paper cutter; quick freezing; rapid prototyping; fast fail",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Trade-off"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_22",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Convert Harm into Benefit",
      "m1.ext:systemic-modeling:principleNumber": 22,
      "m1.ext:systemic-modeling:code": "CH2B",
      "m1.ext:systemic-modeling:codeConvention": "2=to",
      "rdfs:comment": "Use harmful factors to achieve positive effect",
      "m1.ext:systemic-modeling:family": "Geometric",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:GeometricPrinciple"},
      "m1.ext:systemic-modeling:example": "Waste heat warms offices; composting; carbon capture",
      "m2:mobilizes": ["m2:Pattern", "m2:Transformation", "m2:Polarity"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_23",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Feedback",
      "m1.ext:systemic-modeling:principleNumber": 23,
      "m1.ext:systemic-modeling:code": "FeedB",
      "rdfs:comment": "Introduce feedback; change its magnitude/influence",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Thermostat; cruise control; adaptive learning",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:FeedbackLoop"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_24",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Intermediary",
      "m1.ext:systemic-modeling:principleNumber": 24,
      "m1.ext:systemic-modeling:code": "IntmY",
      "m1.ext:systemic-modeling:codeConvention": "Y=y suffix",
      "rdfs:comment": "Use intermediary object to transfer action",
      "m1.ext:systemic-modeling:family": "Substitution",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1.ext:systemic-modeling:SubstitutionPrinciple"},
      "m1.ext:systemic-modeling:example": "Carrier pigeon; catalyst; middleware; broker; mediator pattern",
      "m2:mobilizes": ["m2:Transformation", "m2:Pattern", "m2:Mediator"]
    },
    {
      "@id": "m1.ext:systemic-modeling:Principle_25",
      "@type": "m1.ext:systemic-modeling:TrizPrinciple",
      "rdfs:label": "Self-service",
      "m1.ext:systemic-modeling:principleNumber": 25,
      "m1.ext:systemic-modeling:code": "SlfS",
      "rdfs:comment": "Make object serve itself; use waste resources",
      "m1.ext:systemic-modeling:family": "Methodological",
      "m1.ext:systemic-modeling:parentCombo": {"@id": "m1:MethodologicalPrinciple"},
      "m1.ext:systemic-modeling:example": "Self-cleaning oven; self-lubricating bearing; garbage collection",
      "m2:mobilizes": ["m2:Process", "m2:Workflow", "m2:Self-Organization"]
    },
