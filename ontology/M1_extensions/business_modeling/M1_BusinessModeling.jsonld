{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "m1": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#",
    "m2": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#",
    "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "M1_extensions/business-modeling/M1_BusinessModeling.jsonld",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Business Modeling Extension",
      "rdfs:comment": "Domain-specific concepts for business strategy and business model design. Contains 9 KnowledgeFieldConceptCombos derived from the Business Model Canvas (Osterwalder & Pigneur, 2010), covering value creation, delivery, and capture mechanisms. Discovery context: M0_Bmc SystemicFramework analysis (2026-06-20).",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-20",
      "dcterms:modified": "2026-06-20",
      "owl:versionInfo": "1.0.0",
      "m3:ontologyType": {
        "@id": "m3:DomainExtension"
      },
      "owl:imports": [
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ],
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-06-20",
          "changes": "Initial version. 9 KFCCs from BMC analysis: ValueProposition, CustomerSegment, RevenueStream, CrossSubsidy, PlatformDuality, BusinessModelPattern, StrategicTension, BusinessModelMutation, VerticalIntegration. 2 KnowledgeFields: BusinessModeling (NOUN), Strategic (ADJECTIVE)."
        }
      ]
    },
    {
      "@id": "m1:extension:business_modeling:BusinessModeling",
      "@type": [
        "owl:NamedIndividual",
        "m2:KnowledgeField"
      ],
      "rdfs:label": "BusinessModeling",
      "rdfs:comment": "Study of how organizations design, implement, and evolve mechanisms for value creation, delivery, and capture. As a KnowledgeField, BusinessModeling is bicephalous: Territory (ASFID) captures the operational dynamics of real business systems; Map (REVOI) captures the strategic frameworks and canvas representations used to model them. Primary anchor for M0_Bmc SystemicFramework.",
      "m2:knowledgeFieldRole": "NOUN",
      "m2:structuralGrammarFormula": "A × St × F | R + Im",
      "m2:dominantASFID": [
        "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Structure",
        "m3:eagle_eye:Flow"
      ],
      "m2:dominantREVOI": [
        "m3:sphinx_eye:Representability",
        "m3:sphinx_eye:Interoperability"
      ],
      "m2:epistemicDepth": "Medium — BMC is a prescriptive map (Sphinx Eye dominant) that shapes the territory it models. Reflexivity: companies that model themselves on BMC alter their own structure.",
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:Strategic",
      "@type": [
        "owl:NamedIndividual",
        "m2:KnowledgeField"
      ],
      "rdfs:label": "Strategic",
      "rdfs:comment": "Disciplinary qualifier (ADJECTIVE form) for use in KnowledgeFieldConceptCombo patterns. Derived from m1:extension:business_modeling:BusinessModeling, specialized to strategic positioning, competitive dynamics, and long-term value architecture.",
      "m2:knowledgeFieldRole": "ADJECTIVE",
      "m2:derivedFrom": {
        "@id": "m1:extension:business_modeling:BusinessModeling"
      },
      "m2:qualifier": "Pertaining to long-term positioning, competitive advantage, and strategic architecture of business models",
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:ValueProposition",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:KnowledgeFieldConceptCombo",
        { "@id": "m1:Attractor" }
      ],
      "rdfs:label": "Value Proposition",
      "rdfs:comment": "The specific bundle of products, services, and experiences that resolves a customer's job-to-be-done, relieves a pain, or creates a gain. The primary attractor of the BMC system: all other 8 blocks are organized around the ValueProposition as their convergence point. A well-defined VP creates a stable basin of attraction in the customer's decision space — alternatives lose competitive pull once the VP is compelling enough. In TSCG terms, it is simultaneously an informational construct (It: what promise is communicated) and an attractor (A: what equilibrium state is targeted).",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, A × It)",
      "m1:extension:business_modeling:bmcBlock": "ValuePropositions",
      "m1:extension:business_modeling:bmcSide": "Value",
      "m1:extension:business_modeling:jobsToBeDone": "Resolve customer pains, create gains, fulfill functional/social/emotional jobs",
      "m1:extension:business_modeling:realWorldInstances": [
        "Netflix: 'Unlimited streaming, no ads, cancel anytime' — friction-free entertainment VP",
        "Amazon AWS: 'Elastic compute at marginal cost' — utility computing VP",
        "Michelin: 'Tire performance + fleet optimization service' — outcome-based VP"
      ],
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:CustomerSegment",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Customer Segment",
      "rdfs:comment": "A distinct group of people or organizations that share common needs, behaviors, or attributes and for which a business creates value. CustomerSegments define the Information boundary of the BMC system: they determine which signals (customer needs, willingness-to-pay, usage patterns) are relevant inputs to the model. In multi-sided platforms, multiple CustomerSegments interact — their coupling creates emergent network effects (m2:Emergence) that are not reducible to individual segment analysis.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, It × St)",
      "m1:extension:business_modeling:bmcBlock": "CustomerSegments",
      "m1:extension:business_modeling:bmcSide": "Customer",
      "m1:extension:business_modeling:segmentTypology": {
        "mass_market": "Undifferentiated large population (consumer electronics, FMCG)",
        "niche_market": "Specialized segment with specific requirements (luxury goods, B2B industrial)",
        "segmented": "Multiple segments with slightly different needs (banks: retail vs private banking)",
        "diversified": "Unrelated segments (Amazon: e-commerce customers + AWS cloud enterprise clients)",
        "multi_sided": "Two or more interdependent segments (Visa: cardholders + merchants)"
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:RevenueStream",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Revenue Stream",
      "rdfs:comment": "The cash a company generates from each Customer Segment in exchange for delivered Value Propositions. RevenueStreams are the Flow manifestation of successful value exchange — they quantify the economic signal that the VP has achieved sufficient attractor pull. The typology of revenue mechanisms (transactional vs recurring) directly maps to the Dynamics dimension: recurring revenues (subscription, licensing) create stable limit cycles; transactional revenues create episodic flow pulses.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, F × A)",
      "m1:extension:business_modeling:bmcBlock": "RevenueStreams",
      "m1:extension:business_modeling:bmcSide": "Value",
      "m1:extension:business_modeling:revenueTypology": {
        "asset_sale": "Transfer of ownership of physical product (car, appliance)",
        "usage_fee": "Pay-per-use (AWS compute hours, hotel room nights, Michelin tire-km)",
        "subscription": "Recurring access fee (Netflix, Spotify, SaaS)",
        "licensing": "Granting rights to IP (software, patents, media)",
        "brokerage": "Intermediation fee (Visa interchange, Airbnb 3%+12%, eBay commission)",
        "advertising": "Attention monetization (Google, Meta, free-tier apps)"
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:CrossSubsidy",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Cross Subsidy",
      "rdfs:comment": "A business instantiation of m2:Amplification with dual polarity: one segment (or service) is deliberately priced below cost (subsidy pole) to attract volume, while another segment (or service) is priced above marginal cost (capture pole) to generate surplus that funds the subsidy. CrossSubsidy creates a structural asymmetry in RevenueStreams: the flow from the capture segment amplifies the volume of the subsidized segment, which in turn increases total network value. The classic form is the multi-sided platform razor/blade or freemium architecture.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, A × F × D)",
      "m1:extension:business_modeling:bmcBlock": "RevenueStreams",
      "m1:extension:business_modeling:bmcSide": "Value",
      "m1:extension:business_modeling:crossSubsidyTypes": {
        "platform": "One side subsidized to build network effects that monetize the other (Google: free search → ad revenue)",
        "freemium": "Basic free, premium paid (Spotify free tier → 30% premium conversion)",
        "razorBlade": "Durable product subsidized, consumable priced above cost (Gillette razors → blades)",
        "bundling": "Unprofitable product bundled with profitable one (free checking → overdraft fees)"
      },
      "m1:extension:business_modeling:tscgNote": "CrossSubsidy is NOT a simple m2:Cascade — it requires explicit dual-polarity amplification and a structural dependency between the two flows. It is the economic instantiation of m2:Amplification where the amplifier is a subsidized attractor.",
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:PlatformDuality",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Platform Duality",
      "rdfs:comment": "The structural property of multi-sided platform business models in which two or more distinct customer segments interact through a common infrastructure, and the value created for each side depends on the presence and activity of the other sides. PlatformDuality is the M1 instantiation of m2:Synergy in the business domain: the combined value of the two-sided network exceeds the sum of each side considered independently. The TSCG Sphinx Eye (Map) dimension is particularly relevant here — the platform IS a map (representational infrastructure) that enables territory-side interactions to occur.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, St × F × D | Im)",
      "m1:extension:business_modeling:bmcBlock": "CustomerSegments",
      "m1:extension:business_modeling:bmcSide": "Customer",
      "m1:extension:business_modeling:platformExamples": {
        "visa": "Cardholders (free to use) ↔ Merchants (interchange fee) — mutual dependency",
        "airbnb": "Guests ↔ Hosts — platform as trust infrastructure",
        "amazon": "Buyers ↔ Third-party sellers — marketplace + logistics platform",
        "google": "Users (free search) ↔ Advertisers (pay-per-click) — attention intermediation"
      },
      "m1:extension:business_modeling:networkEffectTypes": {
        "same_side": "Direct: more users → more value for each user (WhatsApp, Facebook)",
        "cross_side": "Indirect: more sellers → more value for buyers; more buyers → more sellers (Airbnb, Visa)"
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:BusinessModelPattern",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Business Model Pattern",
      "rdfs:comment": "A recurring, transferable configuration of the 9 BMC building blocks that has proven viability across multiple industries and contexts. BusinessModelPatterns are the structural invariants of the business modeling domain — they correspond to m2:Modularity at the meta-level: reusable blueprints that can be combined and adapted. Osterwalder identifies ~55 patterns (freemium, long tail, open business model, subscription, etc.). In TSCG terms, a pattern is a compressed structural grammar formula that encodes the essential attractor-flow-dynamics relationship of a business archetype.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, St × It | R)",
      "m1:extension:business_modeling:bmcBlock": "cross-cutting",
      "m1:extension:business_modeling:patternExamples": {
        "freemium": "Free basic + paid premium — CrossSubsidy + PlatformDuality",
        "subscription": "Recurring revenue replaces transaction — RevenueStream D-stabilization",
        "long_tail": "Aggregating niche demand economically unviable before digital — CustomerSegment expansion",
        "open_innovation": "External R&D reduces KeyActivities cost — KPA + KP restructuring",
        "outcome_based": "Pay for results not assets — VP + Revenue transformation (Michelin Pay-Per-Km)"
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:StrategicTension",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Strategic Tension",
      "rdfs:comment": "A structural antagonism between two or more BMC blocks that generates productive creative pressure when balanced, or system-level instability when unresolved. StrategicTension is the M1 instantiation of m2:Polarity in the business domain. The most fundamental BMC tension is between the Cost Structure block (minimize) and the Value Proposition block (maximize) — any VP enhancement typically increases costs. Secondary tensions: scale vs quality (CustomerRelationships), openness vs control (KeyPartnerships), flexibility vs efficiency (KeyActivities). A healthy business model transforms tension into competitive advantage rather than resolving it by sacrificing one pole.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, D × A | St)",
      "m1:extension:business_modeling:bmcBlock": "cross-cutting",
      "m1:extension:business_modeling:tensionTypology": {
        "cost_value": "Value maximization vs cost minimization — primary BMC tension",
        "scale_quality": "Volume growth vs service quality (CustomerRelationships)",
        "open_control": "Partnership leverage vs IP/channel control (KeyPartnerships vs Channels)",
        "flexibility_efficiency": "Agility vs operational efficiency (KeyActivities vs CostStructure)",
        "short_long": "Short-term revenue vs long-term customer value (RevenueStream vs CustomerLifetimeValue)"
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:BusinessModelMutation",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Business Model Mutation",
      "rdfs:comment": "A significant, non-incremental reconfiguration of multiple BMC blocks that produces a qualitatively different attractor state. BusinessModelMutation is the M1 instantiation of m2:Transformation in the business domain: the system traverses a bifurcation point beyond which the previous equilibrium is no longer accessible. Distinguished from incremental optimization (which stays in the same basin of attraction) and from strategic pivots (which may involve only VP change). True mutation involves structural change to KeyActivities, KeyPartnerships, and/or RevenueStream simultaneously — at least 3 of the 9 blocks are reconfigured.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, D × F × St)",
      "m1:extension:business_modeling:bmcBlock": "cross-cutting",
      "m1:extension:business_modeling:mutationThreshold": "Mutation requires reconfiguration of ≥3 BMC blocks AND a qualitative change in the attractor (VP or RevenueStream logic). Pure cost optimization or channel extension does not constitute mutation.",
      "m1:extension:business_modeling:mutationExamples": {
        "netflix": [
          "State 0 (1997): DVD-by-mail — physical logistics, subscription, no channels",
          "State 1 (2007): Streaming — digital delivery, same subscription model, CDN infrastructure",
          "State 2 (2013): Original content — vertical integration, studio model, content IP ownership"
        ],
        "aws": [
          "State 0 (2000): Internal IT infrastructure — cost center, no external customers",
          "State 1 (2006): External cloud services — utility pricing, API-first, elastic compute"
        ],
        "michelin": [
          "State 0 (1900s-1980s): Tire manufacturer — asset sale, dealer network",
          "State 1 (1999+): Fleet solutions — Pay-Per-Km outcome contract, IoT monitoring, service model"
        ]
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:business_modeling:VerticalIntegration",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Vertical Integration",
      "rdfs:comment": "The strategic acquisition or development of capabilities at adjacent stages of the value chain (upstream toward suppliers or downstream toward customers), reducing dependence on external KeyPartners and converting external flows into internal KeyActivities. VerticalIntegration is the M1 instantiation of m2:Cascade in the business domain: the flow of value through previously external interfaces is internalized, creating a longer and more controlled internal cascade. In the BMC, VerticalIntegration transforms KeyPartnerships into KeyResources + KeyActivities — the structural boundary of the firm extends to encompass the previously external stage.",
      "m1:structuralGrammarFormula": "Fm1m2(BusinessModeling, F × St × A)",
      "m1:extension:business_modeling:bmcBlock": "KeyActivities + KeyResources",
      "m1:extension:business_modeling:bmcSide": "Infrastructure",
      "m1:extension:business_modeling:integrationDirection": {
        "upstream": "Acquiring supplier capabilities — Netflix (content studios), Apple (chip design → TSMC still fab but design internalized)",
        "downstream": "Acquiring distribution/customer capabilities — Apple (retail stores), Tesla (direct sales, service centers)"
      },
      "m1:extension:business_modeling:tradeoffs": {
        "benefits": [
          "Reduced transaction costs and dependency risk",
          "Quality control over critical upstream/downstream stages",
          "Capture of value previously extracted by partners",
          "Proprietary knowledge accumulation"
        ],
        "risks": [
          "Loss of partner ecosystem flexibility",
          "Capital intensity increases fixed cost base",
          "Management complexity of heterogeneous activities",
          "Reduced ability to switch suppliers/channels if technology shifts"
        ]
      },
      "dcterms:created": "2026-06-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    }
  ]
}
