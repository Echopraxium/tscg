  "@graph": [
    {
      "@id": "m1.ext:chemistry:M1_Chemistry_Ontology",
      "@type": "owl:Ontology",
      "dcterms:title": "TSCG M1 Extension: Chemistry",
      "dcterms:description": "Domain-specific instantiation of M2 GenericConcepts for chemistry. Defines chemical processes, reactions, substances, and transformations using TSCG M2 GenericConcepts as foundation.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-17",
      "dcterms:modified": "2026-04-26",
      "owl:versionInfo": "1.1.1",
      "owl:imports": [
        "TSCG_M2_GenericConcepts_Ontology.jsonld"
      ],
      "m1.ext:chemistry:domain": "Chemistry",
      "m1.ext:chemistry:functor": "F_instantiate : M2 â†’ M1_Chemistry",
      "rdfs:comment": "This M1 extension specializes M2 GenericConcepts for chemical systems. Key principles: (1) Inherit M2 tensor formulas, (2) Add chemistry-specific properties, (3) Maintain ASFID foundation.",
      "m1.ext:chemistry:scope": [
        "Chemical reactions and processes",
        "Molecular structure and bonding",
        "Thermochemistry and kinetics",
        "Chemical equilibria and dynamics",
        "Catalysis and reaction mechanisms",
        "Atomic structure and periodic properties"
      ],
      "m1.ext:chemistry:examplePoclets": [
        "Fire Triangle (Combustion)",
        "Ptoe (Periodic Table of Elements)",
        "Water Electrolysis",
        "Photosynthesis",
        "Enzyme Catalysis",
        "Acid-Base Neutralization"
      ],
      "m2:changelog": [
        {
          "version": "1.1.1",
          "date": "2026-05-17",
          "changes": "M3_GenesisSpace → M3_GenesisGrammar (IRI update)"
        },
        {
          "version": "1.1.0",
          "date": "2026-04-26",
          "description": "ENRICHMENT for Ptoe poclet: Added 8 atomic structure concepts (Element, ElectronConfiguration, NobleGas, OrbitalBlock, ChemicalFamily, AtomicProperty, OxidationState, QuantumNumbers). Extends M1_Chemistry scope from chemical reactions to atomic/periodic organization."
        },
        {
          "p3_20260224": {
            "date": "2026-02-24",
            "description": "Phase 3 migration: (1) Non-standard @types converted to owl:Class. (2) rdfs:subClassOf m2:GenericConcept added to root concepts. (3) m2Basis fields unified → m2:characterizedBy. (4) Wrong IS-A to M2 classes moved to m2:characterizedBy. Renamed DomainConcept → KnowledgeFieldConcept throughout."
          }
        }
      ]
    },
    {
      "@id": "m1.ext:chemistry:ChemicalReaction",
      "@type": "owl:Class",
      "rdfs:label": "Chemical Reaction",
      "skos:altLabel": [
        "Reaction",
        "Chemical Transformation"
      ],
      "rdfs:comment": "Process involving transformation of chemical species through bond breaking and formation, with associated energy changes. Instantiates M2:Process with chemistry-specific semantics.",
      "m1.ext:chemistry:asfidSignature": "D×F (high dynamics, high flow)",
      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:reactants": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "1..*",
          "role": "Input substances consumed"
        },
        "m1.ext:chemistry:products": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "1..*",
          "role": "Output substances produced"
        },
        "m1.ext:chemistry:energyBalance": {
          "type": "xsd:string",
          "enum": [
            "Exothermic",
            "Endothermic",
            "Isothermal"
          ],
          "role": "Net energy change"
        },
        "m1.ext:chemistry:catalyst": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "0..1",
          "role": "Optional species enabling reaction without being consumed"
        },
        "m1.ext:chemistry:mechanism": {
          "type": "xsd:string",
          "role": "Step-by-step process description"
        },
        "m1.ext:chemistry:rateConstant": {
          "type": "xsd:float",
          "unit": "varies (mol/LÂ·s, sâ»Â¹, etc.)",
          "role": "Kinetic parameter"
        }
      },
      "m1.ext:chemistry:constraints": [
        "Conservation of mass (atoms)",
        "Conservation of charge",
        "Energy conservation (1st law thermodynamics)"
      ],
      "m1.ext:chemistry:examples": [
        "Hâ‚‚ + Oâ‚‚ â†’ Hâ‚‚O (water formation)",
        "CaCOâ‚ƒ â†’ CaO + COâ‚‚ (thermal decomposition)",
        "CHâ‚„ + 2Oâ‚‚ â†’ COâ‚‚ + 2Hâ‚‚O (methane combustion)"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
        },
        {
          "@id": "m2:Transformation"
        },
        {
          "@id": "m2:Event"
        }
      ],
      "rdfs:subClassOf": "m2:GenericConcept"
    },
    {
      "@id": "m1.ext:chemistry:Combustion",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m1:ChemicalReaction",
      "rdfs:label": "Combustion",
      "skos:altLabel": [
        "Burning",
        "Fire"
      ],
      "rdfs:comment": "Exothermic chemical reaction between a fuel and an oxidizer, producing heat, light, and combustion products. Canonical example: Fire Triangle (Fuel + Oâ‚‚ + Heat â†’ Flame).",
      "m1.ext:chemistry:asfidSignature": "High A, Medium S, High F, Medium I, High D",
      "m1.ext:chemistry:requiredComponents": [
        {
          "name": "Fuel",
          "type": "m1:ChemicalSpecies",
          "role": "Energy source (typically hydrocarbon or organic matter)",
          "examples": [
            "Wood",
            "Gasoline",
            "Methane",
            "Coal"
          ]
        },
        {
          "name": "Oxidizer",
          "type": "m1:ChemicalSpecies",
          "role": "Electron acceptor (typically Oâ‚‚, but can be other oxidizers)",
          "examples": [
            "Oâ‚‚ (atmospheric)",
            "Clâ‚‚",
            "NOâ‚ƒâ»",
            "ClOâ‚„â»"
          ]
        },
        {
          "name": "ActivationEnergy",
          "type": "Energy",
          "role": "Initial heat to reach ignition temperature",
          "examples": [
            "Spark",
            "Flame",
            "Hot surface"
          ]
        }
      ],
      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:energyBalance": "Exothermic (always)",
        "m1.ext:chemistry:products": {
          "typical": [
            "Heat",
            "Light",
            "COâ‚‚",
            "Hâ‚‚O",
            "Smoke"
          ],
          "note": "Products vary by fuel composition"
        },
        "m1.ext:chemistry:ignitionTemperature": {
          "type": "xsd:float",
          "unit": "Kelvin or Celsius",
          "role": "Threshold temperature for self-sustaining combustion",
          "examples": {
            "Wood": "300Â°C",
            "Gasoline": "-43Â°C",
            "Methane": "580Â°C"
          }
        },
        "m1.ext:chemistry:flameStructure": {
          "zones": [
            "Preheat zone",
            "Combustion zone",
            "Post-combustion zone"
          ],
          "note": "Spatial organization of combustion process"
        },
        "m1.ext:chemistry:flameColor": {
          "type": "xsd:string",
          "examples": {
            "Complete combustion": "Blue (high temp)",
            "Incomplete combustion": "Yellow-orange (soot emission)"
          }
        }
      },
      "m1.ext:chemistry:constraints": [
        {
          "parameter": "Fuel concentration",
          "condition": "> LEL (Lower Explosive Limit)",
          "note": "Below LEL, mixture too lean to sustain combustion"
        },
        {
          "parameter": "Oâ‚‚ concentration",
          "condition": "> 16% (typical for air)",
          "note": "Below this, combustion slows or stops"
        },
        {
          "parameter": "Temperature",
          "condition": "> T_ignition (fuel-specific)",
          "note": "Must overcome activation energy barrier"
        },
        {
          "parameter": "Mixing",
          "condition": "Proper fuel-oxidizer ratio (stoichiometry)",
          "note": "Affects completeness and efficiency"
        }
      ],
      "m1.ext:chemistry:subTypes": [
        {
          "name": "Complete Combustion",
          "condition": "Excess Oâ‚‚",
          "products": "COâ‚‚ + Hâ‚‚O only",
          "efficiency": "High (max energy release)"
        },
        {
          "name": "Incomplete Combustion",
          "condition": "Limited Oâ‚‚",
          "products": "CO + C (soot) + Hâ‚‚O",
          "efficiency": "Lower (partial oxidation)"
        },
        {
          "name": "Spontaneous Combustion",
          "trigger": "Self-heating (no external ignition)",
          "examples": [
            "Hay piles",
            "Coal stockpiles",
            "Oily rags"
          ]
        }
      ],
      "m1.ext:chemistry:fireTrianglePrinciple": {
        "description": "Removal of ANY component stops combustion",
        "extinguishmentStrategies": [
          {
            "component": "Fuel",
            "method": "Fuel removal or dilution",
            "examples": [
              "Clear brush",
              "Close gas valve"
            ]
          },
          {
            "component": "Oxidizer",
            "method": "Oâ‚‚ exclusion (smothering)",
            "examples": [
              "Fire blanket",
              "COâ‚‚ extinguisher",
              "Foam"
            ]
          },
          {
            "component": "Heat",
            "method": "Cooling below ignition temperature",
            "examples": [
              "Water spray",
              "Heat-absorbing powder"
            ]
          }
        ]
      },
      "m1.ext:chemistry:feedbackLoop": {
        "type": "Positive feedback (self-sustaining)",
        "mechanism": "Heat produced â†’ Fuel vaporization â†’ More combustion â†’ More heat",
        "consequence": "Self-propagating once ignited (until resource exhaustion)"
      },
      "m1.ext:chemistry:examples": [
        {
          "name": "Wood fire",
          "fuel": "Cellulose (Câ‚†Hâ‚â‚€Oâ‚…)â‚™",
          "products": "COâ‚‚ + Hâ‚‚O + Ash",
          "T_ignition": "~300Â°C"
        },
        {
          "name": "Methane combustion",
          "reaction": "CHâ‚„ + 2Oâ‚‚ â†’ COâ‚‚ + 2Hâ‚‚O",
          "Î”H": "-890 kJ/mol (exothermic)",
          "T_ignition": "580Â°C"
        },
        {
          "name": "Candle flame",
          "fuel": "Paraffin wax (Câ‚™Hâ‚‚â‚™â‚Šâ‚‚)",
          "mechanism": "Wax melts â†’ Wicks â†’ Vaporizes â†’ Burns",
          "selfSustaining": "Yes (heat melts more wax)"
        }
      ],
      "rdfs:seeAlso": [
        "m1:Oxidation",
        "m1:Pyrolysis",
        "m1:Deflagration"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
        },
        {
          "@id": "m2:Dissipation"
        },
        {
          "@id": "m2:Synergy"
        },
        {
          "@id": "m2:Composition"
        },
        {
          "@id": "m2:Trigger"
        },
        {
          "@id": "m2:Threshold"
        },
        {
          "@id": "m2:Feedback"
        }
      ]
    },
    {
      "@id": "m1.ext:chemistry:Oxidation",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m1:ChemicalReaction",
      "rdfs:label": "Oxidation",
      "skos:altLabel": [
        "Electron Loss",
        "Oxygen Gain"
      ],
      "rdfs:comment": "Reaction involving electron loss or oxygen gain. Combustion is a rapid oxidation; corrosion (rust) is slow oxidation.",
      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:electronTransfer": "Loss of electrons",
        "m1.ext:chemistry:oxidationState": "Increase in oxidation number",
        "m1.ext:chemistry:coupledReaction": "Always paired with Reduction (redox)"
      },
      "m1.ext:chemistry:examples": [
        "2Fe + Oâ‚‚ â†’ 2FeO (iron rusting - slow oxidation)",
        "C + Oâ‚‚ â†’ COâ‚‚ (carbon combustion - fast oxidation)",
        "FeÂ²âº â†’ FeÂ³âº + eâ» (electron loss)"
      ],
      "rdfs:seeAlso": [
        "m1:Reduction",
        "m1:Combustion",
        "m1:Corrosion"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
        },
        {
          "@id": "m2:Transformation"
        }
      ]
    },
    {
      "@id": "m1.ext:chemistry:Reduction",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m1:ChemicalReaction",
      "rdfs:label": "Reduction",
      "skos:altLabel": [
        "Electron Gain",
        "Oxygen Loss"
      ],
      "rdfs:comment": "Reaction involving electron gain or oxygen loss. Always coupled with Oxidation in redox reactions.",
      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:electronTransfer": "Gain of electrons",
        "m1.ext:chemistry:oxidationState": "Decrease in oxidation number",
        "m1.ext:chemistry:coupledReaction": "Always paired with Oxidation (redox)"
      },
      "m1.ext:chemistry:examples": [
        "CuÂ²âº + 2eâ» â†’ Cu (copper plating)",
        "Feâ‚‚Oâ‚ƒ + 3CO â†’ 2Fe + 3COâ‚‚ (iron smelting)",
        "Oâ‚‚ + 4eâ» â†’ 2OÂ²â» (oxygen reduction)"
      ],
      "rdfs:seeAlso": "m1:Oxidation",
      "m2:characterizedBy": [
        {
          "@id": "m2:Process"
        },
        {
          "@id": "m2:Transformation"
        }
      ]
    },
