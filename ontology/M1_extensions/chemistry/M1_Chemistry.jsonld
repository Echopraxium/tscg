      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:molecularFormula": "Chemical composition (e.g., Hâ‚‚O, COâ‚‚, Câ‚†Hâ‚â‚‚Oâ‚†)",
        "m1.ext:chemistry:molecularMass": "Mass in g/mol or Da",
        "m1.ext:chemistry:phase": [
          "Solid",
          "Liquid",
          "Gas",
