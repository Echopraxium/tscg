{
  "@context": {
    "m1": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#",
    "m2": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#",
    "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#",
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "m3:eagle_eye": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_EagleEye.jsonld#",
    "m3:sphinx_eye": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_SphinxEye.jsonld#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "m1:extension:chemistry:M1_Chemistry_Ontology",
      "@type": "owl:Ontology",
      "dcterms:title": "TSCG M1 Extension: Chemistry",
      "dcterms:description": "Domain-specific instantiation of M2 GenericConcepts for chemistry. Defines chemical processes, reactions, substances, and transformations using TSCG M2 GenericConcepts as foundation.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-17",
      "dcterms:modified": "2026-05-27",
      "owl:versionInfo": "1.1.1",
      "m3:ontologyType": {
        "@id": "m3:DomainExtension"
      },
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld"
      ],
      "m1:extension:chemistry:domain": "Chemistry",
      "m1:extension:chemistry:functor": "F_instantiate : M2 → M1_Chemistry",
      "rdfs:comment": "This M1 extension specializes M2 GenericConcepts for chemical systems. Key principles: (1) Inherit M2 tensor formulas, (2) Add chemistry-specific properties, (3) Maintain ASFID foundation.",
      "m1:extension:chemistry:scope": [
        "Chemical reactions and processes",
        "Molecular structure and bonding",
        "Thermochemistry and kinetics",
        "Chemical equilibria and dynamics",
        "Catalysis and reaction mechanisms",
        "Atomic structure and periodic properties"
      ],
      "m1:extension:chemistry:exampleInstances": [
        "Fire Triangle (Combustion)",
        "Ptoe (Periodic Table of Elements)",
        "Water Electrolysis",
        "Photosynthesis",
        "Enzyme Catalysis",
        "Acid-Base Neutralization"
      ],
      "m2:changelog": [
        {
          "version": "1.1.1",
          "date": "2026-05-27",
          "changes": "BASE16 NOTATION: 5 formula(s) updated — S→St in hybrid formulas (containing |). Convention: in hybrid formulas, St (Structure/Territory) to avoid collision with Ss (Symbol/Stereopsic/Gs)."
        },
        {
          "version": "1.1.0",
          "date": "2026-04-26",
          "description": "ENRICHMENT for Ptoe poclet: Added 8 atomic structure concepts (Element, ElectronConfiguration, NobleGas, OrbitalBlock, ChemicalFamily, AtomicProperty, OxidationState, QuantumNumbers). Extends M1_Chemistry scope from chemical reactions to atomic/periodic organization."
        },
        {
          "p3_20260224": {
            "date": "2026-02-24",
            "description": "Phase 3 migration: (1) Non-standard @types converted to owl:Class. (2) rdfs:subClassOf m2:GenericConcept added to root concepts. (3) m2Basis fields unified → m2:characterizedBy. (4) Wrong IS-A to M2 classes moved to m2:characterizedBy. Renamed DomainConcept → KnowledgeFieldConcept throughout."
          }
        }
      ]
    },
    {
      "@id": "m1:extension:chemistry:ChemicalReaction",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Chemical Reaction",
      "skos:altLabel": [
        "Reaction",
        "Chemical Transformation"
      ],
      "rdfs:comment": "Process involving transformation of chemical species through bond breaking and formation, with associated energy changes. Instantiates M2:Process with chemistry-specific semantics.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:reactants": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "1..*",
          "role": "Input substances consumed"
        },
        "m1:extension:chemistry:products": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "1..*",
          "role": "Output substances produced"
        },
        "m1:extension:chemistry:energyBalance": {
          "type": "xsd:string",
          "enum": [
            "Exothermic",
            "Endothermic",
            "Isothermal"
          ],
          "role": "Net energy change"
        },
        "m1:extension:chemistry:catalyst": {
          "type": "m1:ChemicalSpecies",
          "cardinality": "0..1",
          "role": "Optional species enabling reaction without being consumed"
        },
        "m1:extension:chemistry:mechanism": {
          "type": "xsd:string",
          "role": "Step-by-step process description"
        },
        "m1:extension:chemistry:rateConstant": {
          "type": "xsd:float",
          "unit": "varies (mol/L·s, s⁻¹, etc.)",
          "role": "Kinetic parameter"
        }
      },
      "m1:extension:chemistry:constraints": [
        "Conservation of mass (atoms)",
        "Conservation of charge",
        "Energy conservation (1st law thermodynamics)"
      ],
      "m1:extension:chemistry:examples": [
        "H1‚ + O1‚ → H2O (water formation)",
        "CaCO1ƒ → CaO + CO2 (thermal decomposition)",
        "CH1„ + 2O1‚ → CO2 + 2H2O (methane combustion)"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × St × F × It × D | V)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:Combustion",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Combustion",
      "skos:altLabel": [
        "Burning",
        "Fire"
      ],
      "rdfs:comment": "Exothermic chemical reaction between a fuel and an oxidizer, producing heat, light, and combustion products. Canonical example: Fire Triangle (Fuel + O1‚ + Heat → Flame).",
      "m1:extension:chemistry:requiredComponents": [
        {
          "name": "Fuel",
          "type": "m1:ChemicalSpecies",
          "role": "Energy source (typically hydrocarbon or organic matter)",
          "examples": [
            "Wood",
            "Gasoline",
            "Methane",
            "Coal"
          ]
        },
        {
          "name": "Oxidizer",
          "type": "m1:ChemicalSpecies",
          "role": "Electron acceptor (typically O1‚, but can be other oxidizers)",
          "examples": [
            "O1‚ (atmospheric)",
            "Cl1‚",
            "NO1ƒâ-",
            "ClO1„â-"
          ]
        },
        {
          "name": "ActivationEnergy",
          "type": "Energy",
          "role": "Initial heat to reach ignition temperature",
          "examples": [
            "Spark",
            "Flame",
            "Hot surface"
          ]
        }
      ],
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:energyBalance": "Exothermic (always)",
        "m1:extension:chemistry:products": {
          "typical": [
            "Heat",
            "Light",
            "CO2",
            "H2O",
            "Smoke"
          ],
          "note": "Products vary by fuel composition"
        },
        "m1:extension:chemistry:ignitionTemperature": {
          "type": "xsd:float",
          "unit": "Kelvin or Celsius",
          "role": "Threshold temperature for self-sustaining combustion",
          "examples": {
            "Wood": "300°C",
            "Gasoline": "-43°C",
            "Methane": "580°C"
          }
        },
        "m1:extension:chemistry:flameStructure": {
          "zones": [
            "Preheat zone",
            "Combustion zone",
            "Post-combustion zone"
          ],
          "note": "Spatial organization of combustion process"
        },
        "m1:extension:chemistry:flameColor": {
          "type": "xsd:string",
          "examples": {
            "Complete combustion": "Blue (high temp)",
            "Incomplete combustion": "Yellow-orange (soot emission)"
          }
        }
      },
      "m1:extension:chemistry:constraints": [
        {
          "parameter": "Fuel concentration",
          "condition": "> LEL (Lower Explosive Limit)",
          "note": "Below LEL, mixture too lean to sustain combustion"
        },
        {
          "parameter": "O1‚ concentration",
          "condition": "> 16% (typical for air)",
          "note": "Below this, combustion slows or stops"
        },
        {
          "parameter": "Temperature",
          "condition": "> T_ignition (fuel-specific)",
          "note": "Must overcome activation energy barrier"
        },
        {
          "parameter": "Mixing",
          "condition": "Proper fuel-oxidizer ratio (stoichiometry)",
          "note": "Affects completeness and efficiency"
        }
      ],
      "m1:extension:chemistry:subTypes": [
        {
          "name": "Complete Combustion",
          "condition": "Excess O1‚",
          "products": "CO2 + H2O only",
          "efficiency": "High (max energy release)"
        },
        {
          "name": "Incomplete Combustion",
          "condition": "Limited O1‚",
          "products": "CO + C (soot) + H2O",
          "efficiency": "Lower (partial oxidation)"
        },
        {
          "name": "Spontaneous Combustion",
          "trigger": "Self-heating (no external ignition)",
          "examples": [
            "Hay piles",
            "Coal stockpiles",
            "Oily rags"
          ]
        }
      ],
      "m1:extension:chemistry:fireTrianglePrinciple": {
        "description": "Removal of ANY component stops combustion",
        "extinguishmentStrategies": [
          {
            "component": "Fuel",
            "method": "Fuel removal or dilution",
            "examples": [
              "Clear brush",
              "Close gas valve"
            ]
          },
          {
            "component": "Oxidizer",
            "method": "O1‚ exclusion (smothering)",
            "examples": [
              "Fire blanket",
              "CO2 extinguisher",
              "Foam"
            ]
          },
          {
            "component": "Heat",
            "method": "Cooling below ignition temperature",
            "examples": [
              "Water spray",
              "Heat-absorbing powder"
            ]
          }
        ]
      },
      "m1:extension:chemistry:feedbackLoop": {
        "type": "Positive feedback (self-sustaining)",
        "mechanism": "Heat produced → Fuel vaporization → More combustion → More heat",
        "consequence": "Self-propagating once ignited (until resource exhaustion)"
      },
      "m1:extension:chemistry:examples": [
        {
          "name": "Wood fire",
          "fuel": "Cellulose (C6H10O5)n",
          "products": "CO2 + H2O + Ash",
          "T_ignition": "~300°C"
        },
        {
          "name": "Methane combustion",
          "reaction": "CH1„ + 2O1‚ → CO2 + 2H2O",
          "Î”H": "-890 kJ/mol (exothermic)",
          "T_ignition": "580°C"
        },
        {
          "name": "Candle flame",
          "fuel": "Paraffin wax (C1™H1‚1™1Š1‚)",
          "mechanism": "Wax melts → Wicks → Vaporizes → Burns",
          "selfSustaining": "Yes (heat melts more wax)"
        }
      ],
      "rdfs:seeAlso": [
        "m1:Oxidation",
        "m1:Pyrolysis",
        "m1:Deflagration"
      ],
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × S × F × It × D)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:Oxidation",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Oxidation",
      "skos:altLabel": [
        "Electron Loss",
        "Oxygen Gain"
      ],
      "rdfs:comment": "Reaction involving electron loss or oxygen gain. Combustion is a rapid oxidation; corrosion (rust) is slow oxidation.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:electronTransfer": "Loss of electrons",
        "m1:extension:chemistry:oxidationState": "Increase in oxidation number",
        "m1:extension:chemistry:coupledReaction": "Always paired with Reduction (redox)"
      },
      "m1:extension:chemistry:examples": [
        "2Fe + O1‚ → 2FeO (iron rusting - slow oxidation)",
        "C + O1‚ → CO2 (carbon combustion - fast oxidation)",
        "Fe²⁺ → Fe³⁺ + eâ- (electron loss)"
      ],
      "rdfs:seeAlso": [
        "m1:Reduction",
        "m1:Combustion",
        "m1:Corrosion"
      ],
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, St × F × It × D | V)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:Reduction",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Reduction",
      "skos:altLabel": [
        "Electron Gain",
        "Oxygen Loss"
      ],
      "rdfs:comment": "Reaction involving electron gain or oxygen loss. Always coupled with Oxidation in redox reactions.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:electronTransfer": "Gain of electrons",
        "m1:extension:chemistry:oxidationState": "Decrease in oxidation number",
        "m1:extension:chemistry:coupledReaction": "Always paired with Oxidation (redox)"
      },
      "m1:extension:chemistry:examples": [
        "Cu²⁺ + 2eâ- → Cu (copper plating)",
        "Fe1‚O1ƒ + 3CO → 2Fe + 3CO2 (iron smelting)",
        "O2 + 4e- → 2O2- (oxygen reduction)"
      ],
      "rdfs:seeAlso": "m1:Oxidation",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, St × F × It × D | V)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:ChemicalSpecies",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Chemical Species",
      "skos:altLabel": [
        "Molecule",
        "Compound",
        "Element",
        "Ion"
      ],
      "rdfs:comment": "Identifiable chemical entity with specific molecular formula and properties. Instantiates M2:Component in chemistry domain.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:molecularFormula": "Chemical composition (e.g., H2O, CO2, C6H12O6)",
        "m1:extension:chemistry:molecularMass": "Mass in g/mol or Da",
        "m1:extension:chemistry:phase": [
          "Solid",
          "Liquid",
          "Gas",
          "Plasma"
        ],
        "m1:extension:chemistry:structure": "3D arrangement of atoms (if applicable)"
      },
      "m1:extension:chemistry:subTypes": [
        "m1:Element",
        "m1:Compound",
        "m1:Ion",
        "m1:Radical"
      ],
      "m1:extension:chemistry:examples": [
        "H2O (water)",
        "O1‚ (dioxygen)",
        "CH1„ (methane)",
        "NaCl (sodium chloride)",
        "H+ (proton)"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, S × It)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:Catalyst",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Catalyst",
      "rdfs:comment": "Chemical species that increases reaction rate without being consumed. Instantiates M2:Catalysis and M2:Mediator.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:mechanism": "Lowers activation energy barrier",
        "m1:extension:chemistry:specificity": "Often selective for particular reactions",
        "m1:extension:chemistry:regeneration": "Recovered unchanged after reaction"
      },
      "m1:extension:chemistry:examples": [
        "Platinum (catalytic converter)",
        "Enzymes (biological catalysts)",
        "H1‚SO1„ (acid catalyst in esterification)"
      ],
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × St × F × It × D | Im)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:ReactionMechanism",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Reaction Mechanism",
      "rdfs:comment": "Step-by-step sequence of elementary reactions constituting overall chemical transformation.",
      "m1:extension:chemistry:properties": {
        "m1:extension:chemistry:elementarySteps": "List of individual reaction steps",
        "m1:extension:chemistry:intermediates": "Transient species formed and consumed",
        "m1:extension:chemistry:rateDeterminingStep": "Slowest step controlling overall rate"
      },
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × F × D)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:Element",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Chemical Element",
      "skos:altLabel": [
        "Atom",
        "Elementary Substance"
      ],
      "rdfs:comment": "Pure chemical substance with atoms of same atomic number Z. Building block of Periodic Table.",
      "m1:extension:chemistry:examples": [
        "H (Z=1)",
        "C (Z=6)",
        "Fe (Z=26)",
        "Au (Z=79)"
      ],
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, S × It)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:ElectronConfiguration",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Electron Configuration",
      "skos:altLabel": [
        "Orbital Occupation"
      ],
      "rdfs:comment": "Distribution of electrons across atomic orbitals. Notation: [core] ns^a np^b nd^c nf^d.",
      "m1:extension:chemistry:examples": [
        "H: 1s¹",
        "Ne: [He] 2s² 2p⁶",
        "Fe: [Ar] 3d⁶ 4s²"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, St × It | V)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:NobleGas",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Noble Gas",
      "skos:altLabel": [
        "Inert Gas",
        "Group 18 Element"
      ],
      "rdfs:comment": "Elements with filled electron shells (ns² np⁶). Chemically inert, high ionization energy.",
      "m1:extension:chemistry:members": [
        "He",
        "Ne",
        "Ar",
        "Kr",
        "Xe",
        "Rn",
        "Og"
      ],
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × S × D)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:OrbitalBlock",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Orbital Block",
      "skos:altLabel": [
        "Electron Block"
      ],
      "rdfs:comment": "Classification by angular momentum quantum number l: s (l=0), p (l=1), d (l=2), f (l=3).",
      "m1:extension:chemistry:blocks": [
        "s-block (2 elem/period)",
        "p-block (6)",
        "d-block (10)",
        "f-block (14)"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × S × It × D)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:ChemicalFamily",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Chemical Family",
      "skos:altLabel": [
        "Element Group",
        "Periodic Group"
      ],
      "rdfs:comment": "Elements with similar valence configuration and chemical properties (vertical columns in table).",
      "m1:extension:chemistry:examples": [
        "Alkali metals (Group 1)",
        "Halogens (Group 17)",
        "Transition metals (Groups 3-12)"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × S × F × It × D)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:AtomicProperty",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Atomic Property",
      "rdfs:comment": "Measurable characteristic of elements: electronegativity, atomic radius, ionization energy, etc.",
      "m1:extension:chemistry:propertyTypes": [
        "Electronegativity (χ)",
        "Atomic radius (r)",
        "Ionization energy (IE)",
        "Electron affinity (EA)"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, F × It × D | V + O)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:OxidationState",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Oxidation State",
      "skos:altLabel": [
        "Valence State"
      ],
      "rdfs:comment": "Charge of atom in compound, representing electron loss/gain. E.g., Fe²⁺, Fe³⁺, Cl⁻.",
      "m1:extension:chemistry:examples": [
        "Na: +1",
        "Fe: +2, +3",
        "Cl: -1",
        "O: -2"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "m1:structuralGrammarFormula": "Fm1m2(Chemistry, A × It)",
      "m2:knowledgeField": {
        "@id": "m1:extension:chemistry:Chemistry"
      }
    },
    {
      "@id": "m1:extension:chemistry:QuantumNumbers",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:label": "Quantum Numbers",
