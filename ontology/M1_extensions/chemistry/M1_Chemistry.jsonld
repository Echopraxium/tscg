    {
      "@id": "m1.ext:chemistry:Catalyst",
      "@type": "owl:Class",
      "rdfs:subClassOf": "m1:ChemicalSpecies",
      "rdfs:label": "Catalyst",
      "rdfs:comment": "Chemical species that increases reaction rate without being consumed. Instantiates M2:Catalysis and M2:Mediator.",
      "m1.ext:chemistry:properties": {
        "m1.ext:chemistry:mechanism": "Lowers activation energy barrier",
        "m1.ext:chemistry:specificity": "Often selective for particular reactions",
        "m1.ext:chemistry:regeneration": "Recovered unchanged after reaction"
      },
      "m1.ext:chemistry:examples": [
        "Platinum (catalytic converter)",
        "Enzymes (biological catalysts)",
        "Hâ‚‚SOâ‚„ (acid catalyst in esterification)"
      ],
      "m2:characterizedBy": [
        {
          "@id": "m2:Catalysis"
        },
        {
          "@id": "m2:Mediator"
        }
      ]
