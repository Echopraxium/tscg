  "@graph": [
    {
      "@id": "m1:extension:electronics:M1_Electronics",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Electronics Extension",
      "rdfs:comment": "Domain-specific electronic concepts for the TSCG framework. Covers analog and digital electronics, signal processing, power systems, and modular synthesis. Provides reusable patterns bridging M2 GenericConcepts and M0 poclets in the Electronics domain.",
      "dcterms:title": "TSCG M1 Electronics — Domain-Specific Electronic Concepts",
      "dcterms:description": "Extension of the TSCG framework with electronics-specific concepts: active components, signal manipulation, oscillator types, modulation, and modular synthesis architecture. Serves as M1 foundation for M0 poclets: VCO, VCF, VCA, LFO, Transistor, etc.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-02-27",
      "owl:versionInfo": "1.1.0",
      "dcterms:modified": "2026-07-12",
      "m3:ontologyType": {
        "@id": "m3:DomainExtension"
      },
      "owl:imports": [
        "M1_CoreConcepts.jsonld",
        "M2_GenericConcepts.jsonld"
      ],
      "m1:extension:electronics:conceptCount": 17,
      "m1:extension:electronics:categories": [
        "Active Components",
        "Signal Processing",
        "Oscillation",
        "Modulation",
        "Modular Synthesis"
      ],
      "m1:extension:electronics:validatedInstances": [
        "M0_Transistor.jsonld",
        "M0_VCO.jsonld"
      ],
      "m1:extension:electronics:changelogLegacy": [
        {
          "version": "1.1.0",
          "date": "2026-07-12",
          "changes": "SC-1 FUNCTIONAL GRAMMAR MODEL. RENAME (hard): m2:KnowledgeFieldConceptCombo → m2:DomainConceptCombo. The class is also RE-DEFINED: a DomainConceptCombo is defined by its Fm1m2 formula — a hybrid of ≥1 Domain and ≥1 GenericConcept (domain qualification), superseding the former 'parents from distinct epistemological domains' criterion. A combo's formula IS the function signature: Fm2 : GenericConcept²⁺ → GenericConceptCombo (≥2 concepts); Fm1m2 : Domain⁺, GenericConcept⁺ → DomainConceptCombo (≥1 domain AND ≥1 concept). No monoidal formula, no monoidal expansion — emergence is non-compositional, so Fm2/Fm1m2 are FUNCTIONS, not functors. Arguments = named concepts from M2_GenericConcepts or M1_CoreConcepts only, comma-juxtaposed, never primitives, never joined by ×/+/|. Fm1 does not exist. ⚠ Formulas in this file are FLAGGED by the new SHACL (v1.1.0) and NOT repaired here — repair belongs to SC-6. See StructuralGrammar/Functional_Grammar_Model.md."
        },
        "v1_0_0"
      ],
      "m2:changelog": [
        {
          "version": "1.0.1",
          "date": "2026-05-17",
          "changes": "tensorFormula* → structuralGrammarFormula* (Structural Grammar migration)"
        }
      ]
    },
    {
      "@id": "m1:extension:electronics:Electronics",
      "@type": [
        "owl:NamedIndividual",
        "m2:KnowledgeField"
      ],
      "rdfs:label": "Electronics",
      "rdfs:comment": "Electronics as a Knowledge Field for TSCG domain modeling.",
      "m2:knowledgeFieldRole": "NOUN",
      "dcterms:created": "2026-05-26",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:ActiveComponent",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Component"
      ],
      "rdfs:label": "Active Component",
      "rdfs:comment": "An electronic component that requires an external power supply and is capable of controlling or amplifying electrical signals. Distinct from passive components (resistors, capacitors, inductors) which only dissipate or store energy. Foundation for all active electronics patterns in M1_Electronics.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × It × D × F)",
      "m1:extension:electronics:subclasses": [
        "m1:extension:electronics:Amplifier",
        "m1:extension:electronics:ElectronicOscillator",
        "m1:extension:electronics:SignalProcessor"
      ],
      "m1:extension:electronics:examples": [
        "Bipolar Junction Transistor (BJT)",
        "Field Effect Transistor (MOSFET, JFET)",
        "Operational Amplifier (op-amp)",
        "Logic gates (NAND, NOR, NOT)"
      ],
      "m1:extension:electronics:domains": [
        "Analog Electronics",
        "Digital Electronics",
        "Power Electronics",
        "RF Electronics"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:Amplifier",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ActiveComponent"
      ],
      "rdfs:label": "Amplifier",
      "rdfs:comment": "An active component that increases the power, voltage, or current of a signal. Implements m2:Amplification with a structural component (m2:Component) and a defined gain factor. Gain G = V_out / V_in (voltage amplifier) or I_out / I_in (current amplifier). The VCA (Voltage Controlled Amplifier) is a specialisation where G is controlled by an external signal.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × (Ft × D × It) × F)",
      "m1:extension:electronics:gainFormula": "G = V_out / V_in (linear) or 20·log₁₀(V_out/V_in) dB",
      "m1:extension:electronics:amplifierClasses": [
        "Class A",
        "Class B",
        "Class AB",
        "Class D"
      ],
      "m1:extension:electronics:examples": [
        "Op-amp inverting amplifier",
        "BJT common-emitter",
        "VCA (Voltage Controlled Amplifier)",
        "Instrumentation amplifier"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:Filter",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:SignalProcessor"
      ],
      "rdfs:label": "Filter",
      "rdfs:comment": "A signal processor that selectively attenuates or passes frequency components of an input signal. Implements m2:Regulation (frequency-domain control) combined with m2:Transformation (spectral shaping). The VCF (Voltage Controlled Filter) is the canonical modular synthesis instantiation.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × A × I × F)",
      "m1:extension:electronics:filterTypes": {
        "LowPass": "Passes frequencies below f_cutoff, attenuates above (-12/-24 dB/oct)",
        "HighPass": "Passes frequencies above f_cutoff, attenuates below",
        "BandPass": "Passes a band around f_cutoff, attenuates outside",
        "Notch": "Attenuates a narrow band (inverse of bandpass)",
        "AllPass": "Passes all frequencies but shifts phase"
      },
      "m1:extension:electronics:keyParameters": {
        "cutoffFrequency": "f_c — frequency at -3dB point",
        "resonance": "Q — sharpness of rolloff / self-oscillation tendency",
        "slope": "Filter rolloff in dB/octave (6, 12, 18, 24...)"
      },
      "m1:extension:electronics:examples": [
        "VCF (Voltage Controlled Filter) — Moog ladder filter",
        "State-variable filter (SVF)",
        "Sallen-Key low-pass"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:SignalProcessor",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ActiveComponent"
      ],
      "rdfs:label": "Signal Processor",
      "rdfs:comment": "An active component or circuit that transforms a signal according to a defined transfer function. Generalises over filters, waveshapers, ring modulators, and effects units. Directly instantiates m2:Processor (S × I × D × F × V × R).",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × It × D × F)",
      "m1:extension:electronics:subclasses": [
        "m1:extension:electronics:Filter"
      ],
      "m1:extension:electronics:examples": [
        "VCF (Voltage Controlled Filter)",
        "Waveshaper / wavefolder",
        "Ring modulator",
        "Sample & Hold"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:ElectronicOscillator",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ActiveComponent",
        "m2:Oscillator"
      ],
      "rdfs:label": "Electronic Oscillator",
      "rdfs:comment": "An active electronic circuit that produces a periodic output signal without an external periodic input. Directly instantiates m2:Oscillator ( × ⇒(Component, Process, Trajectory | Circular)). The oscillation frequency is determined by reactive components (L, C) or RC networks. Subclasses: VoltageControlledOscillator (pitch set by CV), FeedbackOscillator (self-sustaining via positive feedback), LFO (sub-audio rate).",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × A × I × D × F)",
      "m1:extension:electronics:oscillatorTypes": {
        "LC": "Inductor-Capacitor tank — high-Q, radio frequencies",
        "RC": "Resistor-Capacitor — audio to sub-audio frequencies, Wien bridge",
        "Crystal": "Quartz resonator — ultra-stable reference (watches, microcontrollers)",
        "VCO": "Voltage Controlled — pitch set by control voltage (V/Oct)",
        "LFO": "Low Frequency — modulation source (< 20 Hz)"
      },
      "m1:extension:electronics:subclasses": [
        "m1:extension:electronics:VoltageControlledOscillator",
        "m1:extension:electronics:FeedbackOscillator",
        "m1:extension:electronics:LFO"
      ],
      "m1:extension:electronics:examples": [
        "LC tank circuit",
        "Wien bridge oscillator",
        "Quartz crystal oscillator (32.768 kHz)",
        "Ring oscillator (CMOS)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:VoltageControlledOscillator",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ElectronicOscillator"
      ],
      "rdfs:label": "Voltage Controlled Oscillator (VCO)",
      "rdfs:comment": "An electronic oscillator whose frequency is determined by an input control voltage following a defined transfer law. In modular synthesis the standard is V/Oct: f(CV) = f₀ × 2^(CV). The archetypal Territory Oscillator in the Eurorack domain. Instantiated as M0 poclet M0_VCO.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × A × I × D × F)",
      "m1:extension:electronics:frequencyLaw": "f(CV) = f₀ × 2^(CV / 1V)  [V/Oct standard]",
      "m1:extension:electronics:alternativeLaws": {
        "Hz/V": "f = k × CV  (linear — older Korg/Yamaha standard)",
        "1V/Oct": "f = f₀ × 2^CV  (Eurorack/Moog standard)"
      },
      "m1:extension:electronics:waveformOutputs": [
        "Sine",
        "Square",
        "Triangle",
        "Sawtooth",
        "Pulse"
      ],
      "m1:extension:electronics:modulationInputs": [
        "Pitch CV (V/Oct)",
        "FM (linear/exponential)",
        "Hard Sync",
        "PWM"
      ],
      "m1:extension:electronics:instantiatedBy": "M0_VCO.jsonld",
      "m1:extension:electronics:eurorackStandard": {
        "pitchCV": "1V/Oct",
        "signalLevel": "±5V audio",
        "cvLevel": "0–10V or ±5V",
        "power": "+12V / -12V"
      },
      "m1:extension:electronics:examples": [
        "Moog 921 VCO",
        "CEM 3340 / SSI 2130 chip-based VCO",
        "Buchla 258 Complex Oscillator",
        "Doepfer A-110 (Eurorack)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:LFO",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ElectronicOscillator"
      ],
      "rdfs:label": "Low Frequency Oscillator (LFO)",
      "rdfs:comment": "An electronic oscillator operating below the audio threshold (typically 0.01 Hz – 20 Hz). Used as a modulation source to animate parameters of other modules (pitch vibrato, filter wobble, amplitude tremolo). Implements m2:Oscillator at infrasonic frequency. Distinct from VCO: the LFO output is typically used as a CV signal (modulation), not as audio.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × A × I × D × F)",
      "m1:extension:electronics:frequencyRange": "0.01 Hz – 20 Hz (infrasonic)",
      "m1:extension:electronics:typicalApplications": {
        "vibrato": "LFO → VCO Pitch CV (periodic pitch variation)",
        "tremolo": "LFO → VCA CV (periodic amplitude variation)",
        "wah": "LFO → VCF cutoff CV (periodic filter sweep)",
        "pwm": "LFO → VCO PWM input (pulse width animation)"
      },
      "m1:extension:electronics:waveformOutputs": [
        "Sine",
        "Triangle",
        "Square",
        "Sawtooth",
        "Random (S&H)"
      ],
      "m1:extension:electronics:examples": [
        "Doepfer A-145 LFO",
        "Mutable Instruments Tides",
        "Befaco Rampage"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:FeedbackOscillator",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ElectronicOscillator"
      ],
      "rdfs:label": "Feedback Oscillator",
      "rdfs:comment": "An oscillator that sustains itself via positive feedback exceeding unity gain at a specific frequency (Barkhausen criterion: |βA| = 1, ∠βA = 0°). Implements m2:Oscillator with m2:FeedbackLoop as the sustaining mechanism. Examples: Wien bridge, phase-shift oscillator, Colpitts. Contrasts with relaxation oscillators (hysteresis-based) and VCOs (external CV-controlled).",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × A × I × D × F)",
      "m1:extension:electronics:barkhausenCriterion": "|β(ω)·A(ω)| = 1  and  ∠β(ω)·A(ω) = 0° (or 360°)",
      "m1:extension:electronics:examples": [
        "Wien bridge oscillator (op-amp based)",
        "Colpitts LC oscillator",
        "Phase-shift oscillator (RC)",
        "Crystal oscillator (Pierce topology)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:WaveformMode",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Mode"
      ],
      "rdfs:label": "Waveform Mode",
      "rdfs:comment": "An N-ary operational mode of an electronic oscillator selecting the shape of the periodic output signal. Each waveform has a distinct harmonic spectrum (Fourier decomposition) and therefore a distinct timbre. Directly instantiates m2:Mode (N-ary) in the electronics domain.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, I × S)",
      "m1:extension:electronics:nArity": 5,
      "m1:extension:electronics:waveforms": {
        "Sine": {
          "harmonics": "Fundamental only",
          "spectrum": "Pure tone",
          "formula": "x(t) = A·sin(2πft)"
        },
        "Square": {
          "harmonics": "Odd harmonics (1/n)",
          "spectrum": "Rich odd harmonics",
          "formula": "x(t) = sign(sin(2πft))"
        },
        "Triangle": {
          "harmonics": "Odd harmonics (1/n²)",
          "spectrum": "Soft odd harmonics",
          "formula": "x(t) = (2A/π)·arcsin(sin(2πft))"
        },
        "Sawtooth": {
          "harmonics": "All harmonics (1/n)",
          "spectrum": "Bright full spectrum",
          "formula": "x(t) = 2A·{ft} - A  ({} = fractional part)"
        },
        "Pulse": {
          "harmonics": "Duty-cycle dependent",
          "spectrum": "Variable harmonic mix",
          "formula": "x(t) = square with duty cycle δ ∈ [5%,95%]"
        }
      },
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:AudioSignal",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Signal"
      ],
      "rdfs:label": "Audio Signal",
      "rdfs:comment": "A time-varying electrical signal in the audio frequency range (20 Hz – 20 kHz) representing sound information. In Eurorack modular synthesis: ±5V peak, AC coupled. Carries the acoustic information of a synthesized sound between modules. Implements m2:Signal with temporal periodicity (m2:Oscillator output) or aperiodicity (noise, percussion).",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, F × I × D)",
      "m1:extension:electronics:frequencyRange": "20 Hz – 20 kHz",
      "m1:extension:electronics:eurorackLevel": "±5V peak (AC)",
      "m1:extension:electronics:representation": "x(t) = A(t)·sin(2π·f(t)·t + φ(t))  [AM+FM+PM general form]",
      "m1:extension:electronics:examples": [
        "VCO sine output",
        "VCO sawtooth output",
        "White/pink noise generator output",
        "VCF filtered audio"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:ControlVoltage",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Signal"
      ],
      "rdfs:label": "Control Voltage (CV)",
      "rdfs:comment": "A DC or slowly varying electrical signal used to control a parameter of another module (frequency, amplitude, filter cutoff, etc.). In Eurorack: 0–10V for unipolar or ±5V for bipolar CV. Pitch CV follows V/Oct standard. The CV interface is the fundamental interoperability mechanism of modular synthesis — implements m2:Interoperability in the electronics domain.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, F × I)",
      "m1:extension:electronics:cvTypes": {
        "Pitch_CV": "V/Oct — 1V per octave for pitch control",
        "Gate": "0V/+5V binary — note on/off trigger",
        "Trigger": "Short +5V pulse — event trigger (< 10 ms)",
        "Envelope": "Unipolar 0–10V — ADSR envelope shape",
        "Mod_CV": "Bipolar ±5V — modulation from LFO or expression"
      },
      "m1:extension:electronics:standardLevels": {
        "Eurorack": "0–10V unipolar, ±5V bipolar, 1V/Oct pitch",
        "Buchla": "0–10V, 1.2V/Oct pitch"
      },
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:PitchCV",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:ControlVoltage"
      ],
      "rdfs:label": "Pitch CV (V/Oct)",
      "rdfs:comment": "A control voltage following the 1V/Oct standard for pitch control. Maps linearly to a logarithmic frequency scale: each +1V doubles the frequency (one octave). The universally adopted pitch interface in Eurorack modular synthesis. Implements m2:Transformation (voltage domain → frequency domain) via an ExponentialConverter.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, F × I × D)",
      "m1:extension:electronics:transferLaw": "f(V) = f₀ × 2^(V / 1V)  — exponential (V/Oct)",
      "m1:extension:electronics:reference": "f₀ = 440 Hz (A4) at V = 0V  (or C4 = 261.63 Hz depending on tuning)",
      "m1:extension:electronics:semitone": "1 semitone = 1/12 V ≈ 83.3 mV",
      "m1:extension:electronics:examples": [
        "Keyboard CV output",
        "Sequencer step CV",
        "Arpeggiator pitch output",
        "MIDI-to-CV converter output"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:ExponentialConverter",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m1:extension:electronics:SignalProcessor"
      ],
      "rdfs:label": "Exponential Converter",
      "rdfs:comment": "A circuit that converts a linear input voltage into an exponential output current (or voltage), implementing the V/Oct law. Core internal sub-component of every VCO. Uses the exponential I-V characteristic of a bipolar transistor or matched transistor pair (for temperature compensation). Directly instantiates m2:Amplification (exponential gain profile) and m2:Transformation.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, Ft × D × It)",
      "m1:extension:electronics:transferFunction": "I_out = I_s × exp(V_in / V_T)  where V_T = kT/q ≈ 26 mV at 25°C",
      "m1:extension:electronics:temperatureIssue": "V_T is temperature-dependent — matched transistor pairs and tempco resistors used for compensation",
      "m1:extension:electronics:examples": [
        "Matched transistor pair (e.g. THAT 300)",
        "CEM 3340 internal expo converter",
        "Discrete NPN pair (BC546B matched)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:ModulationSource",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Signal"
      ],
      "rdfs:label": "Modulation Source",
      "rdfs:comment": "Any signal used to animate or vary a parameter of another module over time. LFO, envelope generators, and sequencers are the primary modulation sources in a modular synthesizer. Implements m2:Signal as a carrier of temporal variation information (m2:Process + m2:Information).",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, F × I × D)",
      "m1:extension:electronics:modulationSources": {
        "LFO": "Periodic sub-audio oscillation (vibrato, tremolo, filter sweep)",
        "Envelope": "One-shot ADSR shape (Attack, Decay, Sustain, Release)",
        "Sequencer": "Step-quantized CV sequence (melodic patterns)",
        "Random": "Sample & Hold white noise (random stepped CV)"
      },
      "m1:extension:electronics:modulationTargets": [
        "VCO Pitch CV (vibrato)",
        "VCO FM input (FM synthesis)",
        "VCF Cutoff CV (filter animation)",
        "VCA CV (tremolo, envelope shaping)",
        "VCO PWM input (pulse-width animation)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:EurorackModule",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Component"
      ],
      "rdfs:label": "Eurorack Module",
      "rdfs:comment": "A self-contained electronic function unit conforming to the Eurorack modular synthesis standard (Doepfer, 1995). Implements m2:Component: bounded structural identity within a modular synthesizer rack, with standardised inputs/outputs (3.5mm jacks, ±12V power, V/Oct pitch, ±5V audio/CV). The synthesis patch is a composition of Eurorack Modules — implements m2:Composable.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × I × F)",
      "m1:extension:electronics:eurorackSpec": {
        "rackFormat": "3U (133.35 mm) or 1U (44.45 mm) height",
        "widthUnit": "HP (Horizontal Pitch = 5.08 mm)",
        "power": "+12V / -12V / optional +5V",
        "audioLevel": "±5V peak",
        "cvLevel": "0–10V unipolar, ±5V bipolar",
        "pitchStandard": "1V/Oct",
        "connectors": "3.5mm mono TS jacks"
      },
      "m1:extension:electronics:canonicalModules": {
        "VCO": "Pitch generation",
        "VCF": "Timbre shaping (filter)",
        "VCA": "Amplitude control",
        "LFO": "Modulation source",
        "EG": "Envelope Generator (ADSR)",
        "SEQ": "Sequencer (pitch + gate patterns)",
        "MIX": "Signal mixer",
        "OUT": "Audio output / headphone amp"
      },
      "m1:extension:electronics:subclasses": [
        "m1:extension:electronics:VoltageControlledOscillator",
        "m1:extension:electronics:Filter",
        "m1:extension:electronics:Amplifier",
        "m1:extension:electronics:LFO"
      ],
      "m1:extension:electronics:instantiatedBy": [
        "M0_VCO.jsonld",
        "M0_Transistor.jsonld"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:SignalChain",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Cascade"
      ],
      "rdfs:label": "Signal Chain",
      "rdfs:comment": "An ordered sequence of signal processing modules through which an audio signal passes, with each module transforming the signal according to its transfer function. Directly instantiates m2:Cascade ( × ⇒(Process, Step, Trajectory)) in the electronics/modular synthesis domain. The canonical signal chain is: VCO → VCF → VCA → Output.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, S × I × A × D × F)",
      "m1:extension:electronics:canonicalChain": "VCO (pitch) → VCF (timbre) → VCA (amplitude) → Output",
      "m1:extension:electronics:transferFunction": "H_total(f) = H_VCO(f) × H_VCF(f) × H_VCA(f)",
      "m1:extension:electronics:examples": [
        "Classic subtractive synthesis chain: VCO → VCF → VCA",
        "FM synthesis: carrier VCO + modulator VCO → Output",
        "Effects chain: DRY → Delay → Reverb → OUT"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:electronics:FrequencyModulation",
      "@type": [
        "owl:Class",
        "m2:DomainConceptCombo"
      ],
      "rdfs:subClassOf": [
        "m2:DomainConceptCombo",
        "m2:Process"
      ],
      "rdfs:label": "Frequency Modulation (FM)",
      "rdfs:comment": "A modulation technique in which the instantaneous frequency of a carrier oscillator is varied by a modulating signal. At audio-rate modulation frequencies (modulator = VCO), produces complex inharmonic or harmonic spectra (Chowning FM synthesis). At sub-audio rates (modulator = LFO), produces vibrato. Instantiates m2:Process (D × I × F) in the electronics domain.",
      "m1:structuralGrammarFormula": "Fm1m2(Electronics, D × I × F)",
      "m1:extension:electronics:fmEquation": "f_inst(t) = f_c + k_f × m(t)  [linear FM]  or  f_inst(t) = f_c × 2^(m(t) × depth)  [exponential FM]",
      "m1:extension:electronics:modulationIndex": "β = Δf / f_m  (ratio of frequency deviation to modulator frequency)",
      "m1:extension:electronics:sidebands": "f_sidebands = f_c ± n·f_m  for n = 1, 2, 3… (Bessel function amplitudes)",
      "m1:extension:electronics:fmTypes": {
        "Linear": "Δf constant regardless of f_c — preferred for audio-rate FM (symmetric spectrum)",
        "Exponential": "Δf/f_c constant — V/Oct compatible (musical pitch relationships)"
      },
      "m1:extension:electronics:examples": [
        "Chowning FM synthesis (DX7, 4-operator FM)",
        "VCO FM input for audio-rate modulation",
        "LFO → VCO pitch = vibrato (exponential FM)"
      ],
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    }
  ]
}