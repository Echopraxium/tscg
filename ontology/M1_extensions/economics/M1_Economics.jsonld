  },
  "@graph": [
    {
      "@id": "m1:extension:economics:M1_Economics",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG M1 Economics Extension",
      "rdfs:comment": "Domain-specific economic and financial concepts for the TSCG framework. Contains patterns and concepts specific to financial systems, market dynamics, speculative cycles, and macroeconomic regulation. Discovery context: M0_KindlebergerMinsky poclet analysis (2026-02-28).",
      "dcterms:title": "TSCG M1 Economics — Domain-Specific Financial and Economic Concepts",
      "dcterms:description": "Extension of the TSCG framework with economics-specific concepts. Covers the Kindleberger-Minsky speculative cycle (Displacement → Boom → Euphoria → Distress → Revulsion), credit dynamics, leverage, financial contagion, narrative economics, and systemic risk. First TSCG domain extension in the Finance / Economics field.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-02-28",
      "dcterms:modified": "2026-02-28",
      "owl:versionInfo": "1.0.0",
      "m3:ontologyType": {
        "@id": "m3:DomainExtension"
      },
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-02-28",
          "changes": "Initial version. 14 domain concepts from M0_KindlebergerMinsky analysis. 4 families: Cycle (5), Credit (3), Risk (3), Valuation (3). KnowledgeField NOUN + ADJECTIVE instances."
        }
      ],
      "owl:imports": [
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ]
    },
    {
      "@id": "m1:extension:economics:Economics",
      "@type": [
        "owl:NamedIndividual",
        "m2:KnowledgeField"
      ],
      "rdfs:label": "Economics",
      "rdfs:comment": "Study of how agents allocate scarce resources under conditions of uncertainty. Includes financial economics, behavioral finance, macroeconomics, and systemic risk analysis. As a KnowledgeField, Economics is intrinsically bicephalous: Territory (ASFID) captures observable market dynamics; Map (REVOI) captures theoretical frameworks and models.",
      "m2:knowledgeFieldRole": "NOUN",
      "m2:structuralGrammarFormula": "D × F × A | O + R",
      "m2:sigma_mean": 0.72,
      "m2:alignmentAngle": "~35°",
      "m2:maturityLevel": "developing",
      "m2:maturityNote": "Mature in microeconomics and financial metrics (σ_mean~0.85); contested in macroeconomic prediction and systemic risk forecasting (σ_mean~0.45). Overall developing field.",
      "m2:dominantASFID": [
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Attractor"
      ],
      "m2:dominantREVOI": [
        "m3:sphinx_eye:Observability",
        "m3:sphinx_eye:Representability"
      ],
      "m2:epistemicDepth": "Medium-High — Reflexivity (Soros) creates fundamental limit: the observer affects the observed market",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:Financial",
      "@type": [
        "owl:NamedIndividual",
        "m2:KnowledgeField"
      ],
      "rdfs:label": "Financial",
      "rdfs:comment": "Disciplinary qualifier (ADJECTIVE form) for use in KnowledgeFieldMetaCombo patterns. Derived from m1:extension:economics:Economics, specialized to financial markets, instruments, and institutions.",
      "m2:knowledgeFieldRole": "ADJECTIVE",
      "m2:derivedFrom": "m1:extension:economics:Economics",
      "m2:qualifier": "Pertaining to financial markets, instruments, capital flows, and financial institutions",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:ExogenousShock",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Exogenous Shock",
      "rdfs:comment": "An external event that displaces an economic system from its previous equilibrium by creating new information or changing the opportunity structure. The trigger of the Kindleberger-Minsky Displacement phase. Exogenous shocks are not predictable from within the system (they are outside its model boundary). The shock must be significant enough to alter profit expectations for a large class of assets or agents.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, It × D)",
      "m1:extension:economics:minskyPhase": "Displacement",
      "m1:extension:economics:typology": {
        "technological": "New invention creates new investment opportunities (railways, internet, blockchain)",
        "financial": "Regulatory change or financial innovation (deregulation, new instruments: MBS, CDO)",
        "geopolitical": "War end, peace treaty, trade opening (post-WWII boom, post-Cold War expansion)",
        "monetary": "Central bank policy change (Fed easy money 1920s, 2001-2004 low rates)"
      },
      "m1:extension:economics:necessaryConditions": [
        "Novel profit opportunity not yet incorporated in prices",
        "Sufficient scale to attract significant capital flows",
        "Positive initial returns for early movers (validating the narrative)"
      ],
      "m1:extension:economics:historicalInstances": [
        "1630s: Tulip — luxury commodity speculation in Dutch Republic",
        "1711: South Sea Company — colonial trade monopoly grant",
        "1922: Post-WWI industrialization + electrification + Ford mass production",
        "1993: World Wide Web commercialization (Mosaic browser, 1993)",
        "2001: Fed Funds Rate → 1% + financial securitization innovation (MBS/CDO)",
        "2019: DeFi emergence + Bitcoin halving (May 2020) + institutional adoption"
      ],
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:CreditExpansion",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Credit Expansion",
      "rdfs:comment": "Rapid growth in the volume of credit available to economic agents, typically driven by low interest rates, financial innovation, or reduced lending standards. The primary fuel of the Kindleberger-Minsky Boom phase. Credit expansion enables leverage (amplification of both returns and losses). Minsky's key observation: credit expansion is self-validating during the Boom — rising asset prices confirm the wisdom of lending, encouraging further credit creation.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, F × D × A)",
      "m1:extension:economics:minskyPhase": "Boom",
      "m1:extension:economics:mechanism": "Low interest rates → higher borrowing → asset purchase → price rise → higher collateral value → higher borrowing capacity → further asset purchase (pro-cyclical positive feedback)",
      "m1:extension:economics:keyMetrics": [
        "Credit growth rate vs GDP growth rate (excess = credit boom)",
        "Private sector credit / GDP ratio",
        "Bank leverage ratios",
        "Loan-to-value (LTV) ratios in real estate",
        "Commercial paper outstanding"
      ],
      "m1:extension:economics:minskyFinanceTypes": {
        "hedge": "Cash flows cover debt service and principal (sustainable)",
        "speculative": "Cash flows cover interest but not principal (must refinance)",
        "ponzi": "Cash flows cover neither — only asset price appreciation enables repayment (unstable)"
      },
      "m1:extension:economics:historicalInstances": [
        "1920s: Margin accounts at 10% (10:1 leverage); broker call loans",
        "1998-2000: VC funding surge; online broker margin accounts",
        "2003-2007: Subprime mortgage expansion; CDO squared; shadow banking (leverage 30:1)",
        "2020-2021: DeFi yield farming; SPAC boom; crypto leverage platforms"
      ],
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:LeverageCycle",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Leverage Cycle",
      "rdfs:comment": "The pro-cyclical dynamic by which leverage ratios expand during asset price booms and contract violently during busts, amplifying both the upswing and the crash. Formalized by John Geanakoplos (2010). Leverage is the ratio of asset value to equity: a 10:1 leveraged position loses all equity on a 10% price decline. The leverage cycle is the primary mechanism connecting Boom (leverage expansion) to Revulsion (forced deleveraging cascade).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, F × D × A)",
      "m1:extension:economics:minskyPhase": "Boom → Revulsion",
      "m1:extension:economics:leverageDefinition": "Leverage = Asset Value / Equity = 1 / (1 - Debt/Assets)",
      "m1:extension:economics:amplificationMechanism": {
        "upswing": "Asset price ↑ → Collateral value ↑ → Borrowing capacity ↑ → More purchases → Asset price ↑ (accelerator)",
        "downswing": "Asset price ↓ → Margin call → Forced sale → Asset price ↓ → Margin call (cascade)"
      },
      "m1:extension:economics:keyMetrics": [
        "Bank leverage ratio (Assets / Equity)",
        "Repo market size (short-term collateralized borrowing)",
        "Margin debt as % of market cap",
        "VIX (fear index — proxy for deleveraging pressure)"
      ],
      "m1:extension:economics:historicalInstances": [
        "1929: Margin accounts 10:1; NYSE call money market",
        "2007: Investment bank leverage 30:1–40:1 (Bear Stearns, Lehman)",
        "2021: Crypto DeFi platforms offering 100:1 leverage on perpetual futures"
      ],
      "m1:extension:economics:theoreticalBasis": "Geanakoplos (2010) Leverage Cycle; Adrian & Shin (2010) pro-cyclical leverage",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:MarketSentiment",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Market Sentiment",
      "rdfs:comment": "The aggregate psychological disposition of market participants toward an asset class or market, ranging from extreme fear to extreme greed. Market sentiment is the primary carrier of m2:Narration in financial markets: it encodes the collective belief network and is both transmitted (Propagation) and transformed (Narration) across the Kindleberger-Minsky phases. Shiller (2019) demonstrates that sentiment narratives are causal — not merely epiphenomenal — in driving market prices.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, S × It × D × F × A | V + R + Im)",
      "m1:extension:economics:minskyPhase": "Boom → Euphoria → Distress → Revulsion",
      "m1:extension:economics:sentimentSpectrum": {
        "ExtremeFear": "Revulsion phase — 'Never again'; fire-sale prices",
        "Fear": "Distress phase — 'This is serious'; de-risking",
        "Neutral": "Pre-Displacement equilibrium",
        "Greed": "Boom phase — 'Don't miss the opportunity'; FOMO",
        "ExtremeGreed": "Euphoria phase — 'This time is different'; total complacency"
      },
      "m1:extension:economics:measurableIndicators": [
        "CNN Fear & Greed Index (composite)",
        "AAII Investor Sentiment Survey (bull/bear ratio)",
        "Put/Call ratio (options market fear proxy)",
        "Short interest ratio",
        "Google Trends for 'buy [asset]' vs 'sell [asset]' (Shiller methodology)",
        "Social media sentiment analysis (crypto: LunarCrush)",
        "VIX (implied volatility — fear index)"
      ],
      "m1:extension:economics:shillerConnection": "Shiller Narrative Economics: sentiment narratives spread virally (m2:Propagation), mutate (m2:Narration.Transformation), and reach saturation (m2:Propagation.Saturated) then collapse (m2:Narration.attractorType=Collapse)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:SpeculativePremium",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Speculative Premium",
      "rdfs:comment": "The excess of market price over fundamental value, attributable to expectations of future price appreciation rather than underlying cash flows. The speculative premium is zero at equilibrium, grows monotonically during Boom and Euphoria, and collapses to zero (or below) during Revulsion. Formally: SpeculativePremium = MarketPrice - FundamentalValue. Keynes 'beauty contest' dynamic: investors buy what others will buy, independent of fundamentals.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, A × It × D)",
      "m1:extension:economics:minskyPhase": "Boom → Euphoria (peak) → Revulsion (collapse)",
      "m1:extension:economics:formula": "SpeculativePremium = MarketPrice - FundamentalValue",
      "m1:extension:economics:fundamentalValueProxies": [
        "Price/Earnings ratio vs historical mean (Shiller CAPE)",
        "Price/Book ratio",
        "Housing: Price/Rent ratio",
        "Equities: Tobin's Q (Market Value / Replacement Cost)",
        "Crypto: Network Value / Transaction ratio (NVT)"
      ],
      "m1:extension:economics:historicalPeakPremiums": {
        "Tulip 1637": "Semper Augustus at 10× skilled craftsman annual income",
        "DotCom 2000": "Shiller CAPE at 44× (historical mean ~16×); PE of 500× for unprofitable companies",
        "Housing 2006": "US Price/Rent ratio at 3σ above 1975-2000 baseline",
        "Crypto 2021": "Bitcoin at $69K vs cost-of-production ~$10K"
      },
      "m1:extension:economics:keynesBeautyContest": "Investors buy not what they think is fundamentally valuable but what they think others will buy — a self-referential game that inflates the speculative premium beyond any fundamental anchor",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:FundamentalValue",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Fundamental Value",
      "rdfs:comment": "The intrinsic value of an asset derived from its expected future cash flows, discounted at an appropriate risk-adjusted rate. Fundamental value serves as the 'true attractor' of asset prices in the long run — the reference point from which SpeculativePremium is measured. During Euphoria, market price diverges maximally from FundamentalValue. During Revulsion, prices may undershoot FundamentalValue (overshoot to the downside).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, A × It)",
      "m1:extension:economics:minskyPhase": "Reference across all phases",
      "m1:extension:economics:valuationMethods": {
        "DCF": "Discounted Cash Flow: FV = Σ CF_t / (1+r)^t",
        "DDM": "Dividend Discount Model (Gordon growth model): FV = D₁ / (r - g)",
        "ComparableMultiples": "P/E, EV/EBITDA vs sector peers",
        "AssetBased": "Net asset value (liquidation value)"
      },
      "m1:extension:economics:limitationsNote": "Fundamental value is itself uncertain and model-dependent. Different DCF assumptions yield very different values. This epistemic uncertainty is exploited by speculative narratives ('traditional metrics don't apply in a new paradigm').",
      "m1:extension:economics:longRunAttractor": "Empirically, market prices mean-revert toward fundamental value over 7-10 year horizons (Shiller data 1871-present, CAPE reversion)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:AssetBubble",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Asset Bubble",
      "rdfs:comment": "A sustained, self-reinforcing deviation of asset prices above fundamental value, driven by speculative demand and credit expansion, that eventually collapses. An AssetBubble is the macroscopic, system-level manifestation of the Kindleberger-Minsky Boom + Euphoria phases. It is an emergent property irreducible to any single market participant. The bubble is only definitively identified after its collapse — a fundamental observability limitation (V=0.75 in the REVOI analysis).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, A × S × F × D)",
      "m1:extension:economics:minskyPhase": "Euphoria (peak) + retrospective identification in Revulsion",
      "m1:extension:economics:necessaryConditions": [
        "Sustained price appreciation well above fundamental value",
        "Widespread narrative justifying 'new paradigm' valuations",
        "Credit-fueled demand (leverage amplification)",
        "New participants entering attracted by past returns"
      ],
      "m1:extension:economics:historicalDiagnostics": {
        "Shiller_CAPE": "CAPE > 30 = elevated bubble risk (2000: 44, 1929: 32)",
        "Case_Shiller_Housing": "Price/Rent > 2σ above long-run mean",
        "MarginDebt": "NYSE margin debt > 3% of GDP",
        "TobinsQ": "Q > 1.5 (equities worth more than physical replacement cost)"
      },
      "m1:extension:economics:observabilityParadox": "The bubble is clearly visible in retrospect. It cannot be identified with certainty in real time — central bank and regulatory interventions to 'prick the bubble' carry their own crash risk",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:InformationAsymmetry",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Information Asymmetry",
      "rdfs:comment": "A condition in which different market participants have access to different information about asset values, risks, or the state of the system. Information asymmetry is a structural feature of financial markets and is maximal during Displacement (insiders know, majority does not) and Distress (banks know their own exposure, counterparties do not). George Akerlof (1970 Nobel) demonstrated that information asymmetry can cause market failure ('lemons problem').",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, It × S × A)",
      "m1:extension:economics:minskyPhase": "Displacement (maximal) · Distress (counterparty risk opacity)",
      "m1:extension:economics:types": {
        "PreDisplacement": "Insiders aware of shock opportunity; public not yet informed",
        "BoomEuphoria": "Sophisticated investors quietly exiting while retail entering",
        "Distress": "Banks unaware of counterparty exposure (LIBOR freeze 2008: 'who is solvent?')",
        "Revulsion": "Fraud revelations (Ponzi schemes exposed when tide goes out — Buffett)"
      },
      "m1:extension:economics:akelorfLemons": "In used car market: seller knows quality, buyer does not → adverse selection → market collapse. In finance: CDO tranche quality, structured product complexity",
      "m1:extension:economics:regulation": "Securities regulation (SEC, AMF) attempts to reduce information asymmetry via mandatory disclosure (10-K, prospectus, material event filings)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:MinskyCrisis",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Minsky Crisis",
      "rdfs:comment": "The critical phase transition (Minsky Moment) in which the financial system bifurcates from speculative equilibrium to crash dynamics. Characterized by: (1) a triggering default or forced liquidation event, (2) a rapid and self-reinforcing panic propagation through the interbank network, (3) qualitative change in market regime from optimism to fear. The Minsky Moment is the financial equivalent of a phase transition in physics — a system-wide state change at a critical threshold.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, It × D × A)",
      "m1:extension:economics:minskyPhase": "Distress",
      "m1:extension:economics:minskyMomentDefinition": "Term coined by Paul McCulley (PIMCO, 1998): the moment when over-leveraged investors are forced to sell good assets to repay debt, depressing prices and triggering further margin calls in a self-reinforcing cascade",
      "m1:extension:economics:triggerTypology": {
        "internal": "Ponzi unit exposure (investors who need rising prices to service debt)",
        "external": [
          "Major institutional default (Lehman 2008, LTCM 1998)",
          "Regulatory tightening (Bubble Act 1720, margin rule changes)",
          "Geopolitical shock (oil embargo)",
          "Technology failure or fraud revelation"
        ]
      },
      "m1:extension:economics:propagationR0": "At Minsky Moment: panic R₀ crosses 1 (Propagation regime: SubThreshold → Supercritical)",
      "m1:extension:economics:historicalInstances": [
        "Sep 3, 1929 → Oct 24 'Black Thursday': DJIA peak → margin call cascade",
        "Aug 9, 2007: BNP Paribas freezes funds → first interbank freeze (GFC onset)",
        "Sep 15, 2008: Lehman bankruptcy → money market funds 'break the buck'",
        "May 9, 2022: Terra UST depeg → $40B destroyed in 72h → crypto contagion"
      ],
      "m1:extension:economics:physicsAnalogy": "Phase transition: liquid → gas at boiling point. The financial system crosses a critical threshold from stable (speculative) phase to unstable (crash) phase. First-order transition (discontinuous) rather than second-order (continuous)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:SystemicRisk",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Systemic Risk",
      "rdfs:comment": "The risk of collapse of an entire financial system or market, rather than failure of individual components — an emergent property of network interconnectedness and correlated exposures. Systemic risk is irreducible to the sum of individual institution risks. It arises from: (1) network contagion (m2:Propagation), (2) common asset exposures (correlated failures), (3) pro-cyclical leverage (m1:extension:economics:LeverageCycle), (4) liquidity spirals (fire-sales depressing collateral values). Post-2008 regulation attempts to internalize systemic risk (Basel III, Dodd-Frank, G-SIB surcharges).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, S × It × A × D × F | V + Im)",
      "m1:extension:economics:minskyPhase": "Distress → Revulsion",
      "m1:extension:economics:transmissionChannels": {
        "DirectExposure": "Bank A defaults → Bank B holds Bank A bonds → Bank B weakened",
        "CommonAsset": "All banks hold MBS → MBS price falls → all banks weaken simultaneously",
        "FundingContagion": "Bank A run → depositors fear Bank B → Bank B run (pure contagion, V<0.5)",
        "LiquiditySpiral": "Price fall → margin call → fire sale → price fall (Adrian & Shin 2010)"
      },
      "m1:extension:economics:measurableIndicators": [
        "SRISK (NYU Stern systemic risk index)",
        "CoVaR (conditional Value at Risk — Δ in system VaR given institution stress)",
        "TED spread (LIBOR - T-bill rate: interbank trust proxy)",
        "LIBOR-OIS spread (unsecured vs secured interbank rate differential)",
        "Credit Default Swap spreads on major banks"
      ],
      "m1:extension:economics:regulatoryResponse": "G-SIB surcharges (Basel III), stress testing (CCAR/DFAST), resolution planning (living wills), derivatives clearing centralization (CCPs)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:CreditCrunch",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Credit Crunch",
      "rdfs:comment": "A sudden and severe reduction in the availability of credit, typically triggered by lender panic, rising counterparty risk, or regulatory capital constraints. The credit crunch is the financial market manifestation of m2:Propagation in the Revulsion phase: panic about creditworthiness spreads through the interbank network (Im = interbank exposure), causing credit availability to collapse even for creditworthy borrowers (V drops: panic fidelity degrades — legitimate borrowers confused with defaulters).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, F × D | Im)",
      "m1:extension:economics:minskyPhase": "Distress → Revulsion",
      "m1:extension:economics:mechanism": "Counterparty risk rises → lenders cannot distinguish solvent from insolvent borrowers (information asymmetry) → universal credit denial → even solvent firms starved of working capital → real economy contraction",
      "m1:extension:economics:interactionWithLeverageCycle": "Credit crunch triggers forced deleveraging: firms cannot refinance → must sell assets → asset prices fall → collateral values fall → more credit denied (vicious cycle)",
      "m1:extension:economics:indicators": [
        "Senior Loan Officer Survey (Fed): % of banks tightening standards",
        "Commercial paper spreads vs Treasuries",
        "TED spread > 100bps (2008 peak: 460bps)",
        "LIBOR-OIS spread > 50bps",
        "Bank lending growth turning negative"
      ],
      "m1:extension:economics:lolrResponse": "Lender of Last Resort (Central Bank) provides emergency liquidity to solvent banks to break the credit crunch (Bagehot principle: lend freely at penalty rate against good collateral)",
      "m1:extension:economics:historicalInstances": [
        "1929-1933: 9,000 US bank failures; commercial credit frozen",
        "Sep-Dec 2008: LIBOR-OIS spread 360bps; money market funds gated; commercial paper market frozen",
        "Jun-Jul 2022: Crypto credit: Celsius Network freeze ($12B), BlockFi, Voyager suspension"
      ],
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:DebtDeflation",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Debt Deflation",
      "rdfs:comment": "A self-reinforcing economic contraction in which falling asset prices increase the real burden of debt, leading to further defaults, more asset sales, further price falls, and deeper contraction. Formalized by Irving Fisher (1933) as the mechanism explaining the Great Depression's severity. Debt deflation is the Revulsion phase's primary amplification dynamic: it transforms a financial crisis into a prolonged economic depression. Fisher's 'paradox': the more debtors pay, the more they owe in real terms (if prices fall faster than debt is repaid).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, F × D × A)",
      "m1:extension:economics:minskyPhase": "Revulsion",
      "m1:extension:economics:fisherMechanism": {
        "step1": "Over-indebtedness → distress selling",
        "step2": "Contraction of deposit currency (bank credit money destroyed)",
        "step3": "Fall in price level (deflation — each dollar buys more goods)",
        "step4": "Fall in net worth → business failures",
        "step5": "Fall in profits → reduction in output and trade",
        "step6": "Pessimism and loss of confidence",
        "step7": "Hoarding → slower velocity of circulation → further deflation",
        "step8": "Rise in real interest rate → further distress"
      },
      "m1:extension:economics:fisherParadox": "The more debtors repay, the more they owe in real terms if prices fall faster than debt is liquidated — a pathological positive feedback between deflation and debt burden",
      "m1:extension:economics:historicalInstances": [
        "1929-1933: US CPI -25%, DJIA -89%, 25% unemployment — classic debt deflation spiral",
        "Japan 1990-2010: 'Lost Decade' — asset deflation + zombie banks + balance sheet recession",
        "2008-2009: Averted by massive QE and TARP; near-deflation in 2009 (-0.4% CPI)"
      ],
      "m1:extension:economics:policyResponse": "Helicopter money (Fisher's own proposal), QE (Bernanke's 'printing press'), debt restructuring (Brady bonds), fiscal stimulus (Keynesian multiplier)",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:FinancialContagion",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Financial Contagion",
      "rdfs:comment": "The cross-institutional or cross-market spread of financial distress, panic, or default risk through a financial network. FinancialContagion is the M1 Economics instantiation of m2:Propagation: panic spreads from one node (bank, market, country) to others through bilateral exposures (Im), with the panic signal maintaining fidelity (V) as it propagates. Distinguished from Debt Deflation (m1:extension:economics:DebtDeflation): contagion is the network-level spread mechanism; debt deflation is the macroeconomic amplification. Both co-occur during Revulsion.",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, S × It × A × D × F | V + Im)",
      "m1:extension:economics:minskyPhase": "Distress → Revulsion",
      "m1:extension:economics:propagationMapping": {
        "S": "Interbank exposure network topology (bilateral credit, CDS, repo, common assets)",
        "I": "Distress signal (counterparty default risk, liquidity shortage)",
        "A": "Minsky Moment threshold: R₀=1 (below: contained; above: systemic crisis)",
        "D": "Contagion velocity (hours to days in acute phase)",
        "F": "Capital withdrawal, margin calls, repo non-renewal between nodes",
        "V": "Signal fidelity (high: legitimate counterparty risk; low: pure panic without fundamental basis)",
        "Im": "Bilateral exposure compatibility (credit lines, CDS contracts, repo agreements)"
      },
      "m1:extension:economics:contagionChannels": {
        "DirectBalance": "Cross-holdings of equity and debt (Bank A fails → Bank B holds Bank A bonds)",
        "FundingLiquidity": "Short-term funding dependency (repo, commercial paper) → sudden withdrawal",
        "CommonShock": "Simultaneous exposure to same depreciating asset class",
        "Informational": "Uncertainty about counterparty quality → universal credit denial (pure contagion)"
      },
      "m1:extension:economics:historicalInstances": [
        "1997-98: Thai baht crisis → Korean won → Russian default → LTCM (sequential contagion)",
        "Sep 2008: Lehman → money market funds → commercial paper → global credit freeze (24h)",
        "May 2022: Terra/LUNA → Celsius → Three Arrows → Voyager → FTX (crypto domino chain)"
      ],
      "m1:extension:economics:distinctionFromDebtDeflation": "FinancialContagion is network-level (who infects whom via bilateral links). DebtDeflation is macro-level (falling prices increase real debt burden for all simultaneously). Contagion ignites; debt deflation sustains.",
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m1:extension:economics:ProfitOpportunity",
      "@type": [
        "owl:Class",
        "m2:KnowledgeFieldConceptCombo"
      ],
      "rdfs:subClassOf": "m2:KnowledgeFieldConceptCombo",
      "rdfs:label": "Profit Opportunity",
      "rdfs:comment": "A new or underexploited configuration of assets, markets, or technologies that offers expected returns above the risk-adjusted equilibrium rate. The attractor that activates the Displacement phase: the profit opportunity is the information content (I) of the exogenous shock that sets the Kindleberger-Minsky cycle in motion. Early movers capture the genuine economic value; late movers arrive when the speculative premium has already incorporated most of the value (and more).",
      "m1:structuralGrammarFormula": "Fm1m2(Economics, A × It × D)",
      "m1:extension:economics:minskyPhase": "Displacement → Boom",
      "m1:extension:economics:lifecycle": {
        "genuine": "Displacement: real economic value exists (internet does change commerce; housing does have value)",
        "amplified": "Boom: genuine value amplified by narrative beyond any fundamental anchor",
        "fictitious": "Euphoria: 'opportunity' divorced from any value — pure speculative game",
        "exposed": "Revulsion: value reassessed (often below genuine level — overshoot)"
      },
      "m1:extension:economics:examples": [
        "Railways (1840s): genuine opportunity (transport revolution) → overbuilding → rail bubble",
        "Internet (1990s): genuine opportunity (commercial transformation) → dot-com overvaluation",
        "Housing (2000s): genuine demand + securitization innovation → subprime bubble",
        "Blockchain (2019+): genuine innovation potential → crypto speculation spiral"
      ],
      "dcterms:created": "2026-02-28",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    }
  ]
}