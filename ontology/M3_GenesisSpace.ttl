@prefix math: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/math#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<m3:Attractor> a math:BasisVector ;
    rdfs:comment "Basin of attraction, equilibrium state" ;
    math:index 0 ;
    math:latex "A" ;
    math:symbol "A" .

<m3:Dynamics> a math:BasisVector ;
    rdfs:comment "Temporal evolution, change" ;
    math:index 1 ;
    math:latex "D" ;
    math:symbol "D" .

<m3:Flow> a math:BasisVector ;
    rdfs:comment "Material, energy, or information transfer" ;
    math:index 2 ;
    math:latex "F" ;
    math:symbol "F" .

<m3:Information> a math:BasisVector ;
    rdfs:comment "Data, meaning, or representation" ;
    math:index 3 ;
    math:latex "I" ;
    math:symbol "I" .

<m3:Structure> a math:BasisVector ;
    rdfs:comment "Topology, organization, spatial arrangement" ;
    math:index 4 ;
    math:latex "S" ;
    math:symbol "S" .

