{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/",
    "@vocab": "http://www.w3.org/2002/07/owl#",
    "dcterms": "http://purl.org/dc/terms/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "m3gf": "M3_GrammarFoundation.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3gf:GrammarFoundation",
      "@type": "owl:Ontology",
      "owl:versionInfo": "1.4.0",
      "dcterms:created": "2026-05-12",
      "dcterms:modified": "2026-05-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:title": "TSCG M3 Grammar Foundation",
      "dcterms:description": "Apex ontology of the TSCG hierarchy — no imports, no dependencies. Defines the Lambek Calculus mathematical foundation (free commutative monoidal categories), the operators (×, +, |, ×⇒, +⇒, ^op) — Territory product ×, Map sum +, Stereopsic fusion |. Three primitive alphabets: 𝕋₀(×)={A,S,F,I,D}, 𝕋₀(+)={R,E,V,O,Im}, 𝕋₀(|)={T}., abstract classes M3Grammar and M3Dimension, the TSCG type system hierarchy (𝕋₀→𝕄₀), and the intersubjective benchmark properties. Imported by M3_EagleEye, M3_SphinxEye, and M3_GenesisGrammar.",
      "rdfs:label": "M3 Grammar Foundation — TSCG Apex Ontology",
      "rdfs:comment": "Foundational definitions for the TSCG Structural Grammar. Rooted in Lambek Calculus (Lambek 1958) and free commutative monoidal categories (MacLane 1963). Three monoidal operators: × (Territory/ASFID product), + (Map/REVOI sum), | (Stereopsic fusion, bicephalous). No metric, no Hilbert space, no scalar multiplication required or assumed.",
      "metadata": {
        "layer": "M3",
        "name": "Grammar Foundation",
        "version": "1.1.0",
        "architecture": "apex — no owl:imports",
        "date_created": "2026-05-12",
        "date_modified": "2026-05-13",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "imported_by": [
          "M3_EagleEye.jsonld",
          "M3_SphinxEye.jsonld",
          "M3_GenesisGrammar.jsonld",
          "M3_BicephalousPerspective.jsonld"
        ],
        "changelog": {
          "v1.4.0": "CLARIFICATION: Added operator_grammar_types section distinguishing intra-grammar (×, +) from inter-grammar (|) operators. Formulated within Lambek calculus only — no tensor algebra. Corrects earlier mention of 'multi-sorted algebra'.",
          "v1.3.0": "STEREOPSIS GRAMMAR: Added three_alphabets, updated TypeSystem T0 to 11 primitives.",
          "v1.2.0": "OPERATOR REFORM: ⊗ᵗ → ×, ⊗ᵐ → +. Added | operator and 4 special elements."
        }
      },
      "mathematical_foundation": {
        "formalism": "Lambek Calculus / Free Commutative Monoidal Categories",
        "references": [
          "Lambek, J. (1958). The mathematics of sentence structure. American Mathematical Monthly 65(3): 154-170.",
          "MacLane, S. (1963). Natural associativity and commutativity. Rice University Studies.",
          "MacLane, S. (1971). Categories for the Working Mathematician. Springer."
        ],
        "operator_disclaimer": "The former single ⊗ operator (with subscripts ᵗ/ᵐ) has been replaced by three distinct operators: × (intra-ASFID structural product), + (intra-REVOI structural sum), | (inter-space stereopsic fusion). This reform eliminates subscript ambiguity and makes the bicephalous architecture explicit in the notation itself.",
        "see_also": "ontology/StructuralGrammar/TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md"
      },
      "m2:changelog": [
        {
          "version": "3.0.0",
          "date": "2026-05-18",
          "changes": "CLARIFICATION: operator_grammar_types added — intra-grammar (×,+) vs inter-grammar (|). Lambek framework only, no tensor algebra."
        },
        {
          "version": "2.9.0",
          "date": "2026-05-18",
          "changes": "STEREOPSIS GRAMMAR: three_alphabets section, TypeSystem T0 → 11 primitives."
        }
      ],
      "three_alphabets": {
        "description": "TSCG defines three primitive alphabets, one per monoidal operator. Each alphabet contains the irreducible generators of its grammar.",
        "territory": {
          "notation": "𝕋₀(×) = {A, S, F, I, D}",
          "grammar": "Territory Grammar Gt — Eagle Eye",
          "operator": "×",
          "neutral": "m3gf:EmptyTerritory",
          "perspective": "What systems ARE (empirical/ontological)"
        },
        "map": {
          "notation": "𝕋₀(+) = {R, E, V, O, Im}",
          "grammar": "Map Grammar Gm — Sphinx Eye",
          "operator": "+",
          "neutral": "m3gf:EmptyMap",
          "perspective": "How models QUALIFY (epistemic)"
        },
        "stereopsis": {
          "notation": "𝕋₀(|) = {T}",
          "grammar": "Stereopsis Grammar Gs — Reification of stereopsic synergy",
          "operator": "|",
          "neutral": "m3gf:StereopsisEmptySet",
          "perspective": "How Territory and Map CORRESPOND (relational)",
          "note": "T (Temporality) is the first and currently only primitive. Further members emerge from poclet corpus analysis, not systematic search.",
          "see_also": "M3_BicephalousPerspective.jsonld"
        }
      },
      "operator_grammar_types": {
        "description": "× and + are intra-grammar operators (closed within their grammar). | is an inter-grammar operator (open — connects Gt, Gm and Gs). This asymmetry is constitutive of the stereopsic architecture and is explained entirely within the Lambek calculus / free monoidal grammar framework — no tensor algebra or multi-sorted algebra is needed.",
        "intra_grammar": {
          "territory_product": {
            "operator": "×",
            "domain": "Gt × Gt",
            "codomain": "Gt",
            "property": "closed — result always stays in Territory Grammar"
          },
          "map_sum": {
            "operator": "+",
            "domain": "Gm × Gm",
            "codomain": "Gm",
            "property": "closed — result always stays in Map Grammar"
          }
        },
        "inter_grammar": {
          "stereopsic_fusion": {
            "operator": "|",
            "domain": "(Gt ∪ Gm ∪ Gs) × (Gt ∪ Gm ∪ Gs)",
            "codomain": "Gs",
            "property": "open — connects grammars, result ALWAYS in Bicephalous Perspective Grammar",
            "rationale": "| is constitutively inter-grammar: its defining role is to traverse the Gt/Gm boundary. If | could only operate on 𝕋₀(|)={T}, it could not perform this traversal.",
            "coherence_constraint": "| always produces a Gs type — never T nor M. This preserves well-definedness.",
            "no_tensor_algebra": "This asymmetry requires no tensor algebra, no multi-sorted algebra, no structure beyond free monoidal grammars."
          }
        }
      }
    },
    {
      "@id": "m3gf:M3Grammar",
      "@type": "owl:Class",
      "rdfs:label": "M3 Grammar (Abstract)",
      "rdfs:comment": "Abstract base class for M3-level structural grammars. Concrete subclasses: TerritoryGrammar (Gt, ASFID primitives) and MapGrammar (Gm, REVOI primitives).",
      "skos:definition": "A free commutative monoidal grammar over a finite set of primitive types. Characterized by: primitives (generators), monoidal product (⊗ⁱ), emergence operator (⊗ⁱ⇒), and duality operator (^opⁱ)."
    },
    {
      "@id": "m3gf:M3Dimension",
      "@type": "owl:Class",
      "rdfs:label": "M3 Dimension (Abstract)",
      "rdfs:comment": "Abstract base class for M3 primitive types. At M2/M3: generators of structural formulas (qualitative, no metric). At M0: instantiation functors map structural primitives to observable instance values (quantitative scoring belongs to the M0 ValueSpace, not to the M3 structural grammar).",
      "skos:definition": "A primitive type in the TSCG Structural Grammar. Plays two roles: (1) generator of type expressions at M2 level; (2) evaluation functor at M0 level via norm-referenced scoring against intersubjective benchmarks.",
      "skos:note": "The word 'dimension' is used in the analytical sense (independent axis of characterisation), NOT in the metric/Hilbert sense."
    },
    {
      "@id": "m3gf:grammarType",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Grammar Type",
      "rdfs:comment": "Type of grammar — prevents collision between M3 structural grammar and M0 instance grammar (e.g. SHACL validation grammars).",
      "rdfs:domain": {
        "@id": "m3gf:M3Grammar"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:example": "free_commutative_monoidal"
    },
    {
      "@id": "m3gf:monoidalProduct",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Structural Product Operators ×, +",
      "rdfs:comment": "Monoidal product operators following Lambek Calculus. × operates intra-ASFID (Territory), + operates intra-REVOI (Map). Both are free commutative monoidal products.",
      "rdfs:domain": {
        "@id": "m3gf:M3Grammar"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Two structural co-activation operators of the TSCG Grammar: × for Territory type expressions (A, S, F, I, D), + for Map type expressions (R, E, V, O, I). Encode simultaneous presence of multiple primitive types in a concept signature.",
      "m3gf:indexed_forms": {
        "territory": "×  — Territory Grammar Gt structural product (intra-ASFID)",
        "map": "+  — Map Grammar Gm structural sum (intra-REVOI)",
        "former_notation": "⊗ᵗ → ×,  ⊗ᵐ → + (migration v1.2.0)"
      },
      "m3gf:axioms": {
        "associativity_territory": "(A × B) × C = A × (B × C)",
        "commutativity_territory": "A × B = B × A",
        "neutral_element_territory": "A × EmptyTerritory = A",
        "associativity_map": "(R + E) + V = R + (E + V)",
        "commutativity_map": "R + E = E + R",
        "neutral_element_map": "R + EmptyMap = R",
        "no_metric": "no norm, no inner product, no scalar multiplication"
      }
    },
    {
      "@id": "m3gf:emergenceOperator",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Emergence Operators ×⇒, +⇒",
      "rdfs:comment": "Structural emergence operators. Produce a derived concept whose properties are irreducible to the sum of its parts. ×⇒ for Territory emergence, +⇒ for Map emergence.",
      "rdfs:domain": {
        "@id": "m3gf:M3Grammar"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Type function operator: takes two existing concept types and produces an emergent derived type. Corresponds to function type (→) in the Curry-Howard correspondence.",
      "m3gf:indexed_forms": {
        "territory": "×⇒  — Territory emergence (ontological)",
        "map": "+⇒  — Map emergence (epistemic)",
        "former_notation": "⊗ᵗ⇒ → ×⇒,  ⊗ᵐ⇒ → +⇒ (migration v1.2.0)"
      },
      "skos:example": "×⇒(Memory, Entropy) = Inertia  |  +⇒(Representable, Verifiable) = ModelQuality"
    },
    {
      "@id": "m3gf:dualityOperator",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Duality Operator ^opⁱ",
      "rdfs:comment": "Structural duality (opposition) operator. Produces the polar opposite of a concept type within the same dimensional space. Indexed: ^opᵗ (Territory), ^opᵐ (Map).",
      "rdfs:domain": {
        "@id": "m3gf:M3Grammar"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Dual type operator: maps a concept type to its structural opposite. Corresponds to negation in propositional logic via the Curry-Howard correspondence.",
      "m3gf:indexed_forms": {
        "territory": "^opᵗ  — Territory duality",
        "map": "^opᵐ  — Map duality",
        "general": "^opⁱ  — general form, i ∈ {t, m}"
      },
      "skos:example": "Coherence^opᵗ = Incoherence  |  Observable^opᵐ = Unobservable"
    },
    {
      "@id": "m3gf:TypeSystem",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "TSCG Type System",
      "rdfs:comment": "Complete type hierarchy of the TSCG Structural Grammar across all layers.",
      "skos:definition": "Four-level type hierarchy derived from 10 primitive types via 3 operators.",
      "m3gf:levels": {
        "T0": {
          "label": "Primitive Types",
          "notation": "𝕋₀ = 𝕋₀(×) ∪ 𝕋₀(+) ∪ 𝕋₀(|)  =  {A,S,F,I,D} ∪ {R,E,V,O,Im} ∪ {T}  (11 primitives)",
          "cardinality": 11,
          "layer": "M3",
          "role": "generators of the TSCG Structural Grammar",
          "subsets": {
            "territory": "{A, S, F, I, D}  — 𝕋₀(×) Gt primitives (Eagle Eye)",
            "map": "{R, E, V, O, Im}  — 𝕋₀(+) Gm primitives (Sphinx Eye)",
            "stereopsis": "{T}  — 𝕋₀(|) Gs primitives (Reification of Stereopsis)"
          }
        },
        "T1": {
          "label": "Derived Types (Named Product Types)",
          "notation": "𝕋₁ = { τ₁ × τ₂ × ... × τₙ | τᵢ ∈ 𝕋₀(Gt) }  or  { τ₁ + τ₂ + ... + τₙ | τᵢ ∈ 𝕋₀(Gm) }  or bicephalous { Gt_expr | Gm_expr }",
          "layer": "M2",
          "role": "M2 GenericConcepts — named structural formulas",
          "examples": [
            "Process    = D × I × F           (pure Territory)",
            "Coherence  = A × S × I | R + O   (bicephalous: Territory | Map)",
            "Entropy    = D × F^op            (Territory with duality)"
          ]
        },
        "T2": {
          "label": "Compound Types (Emergent Combos)",
          "notation": "𝕋₂ = { τ₁ ×⇒ τ₂ | τᵢ ∈ 𝕋₁ }  or  { τ₁ +⇒ τ₂ | τᵢ ∈ 𝕋₁ }",
          "layer": "M1",
          "role": "M1 GenericConceptCombos — emergent compound concepts",
          "examples": [
            "SelfOrganization = ×⇒(Emergence, Coherence)",
            "ModelQuality     = +⇒(Representable, Verifiable)"
          ]
        },
        "M0": {
          "label": "Terms (Proof Terms)",
          "notation": "𝕄₀ = { poclets inhabiting a type τ ∈ 𝕋₁ ∪ 𝕋₂ }",
          "layer": "M0",
          "role": "Instances that prove a system inhabits a conceptual type",
          "curry_howard": "Poclet = proof term. δ₁ = degree of proof (Curry-Howard correspondence)."
        }
      }
    },
    {
      "@id": "m3gf:intersubjectiveBenchmark",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "Intersubjective Benchmark",
      "rdfs:comment": "Domain-contextualized canonical poclet(s) used as scoring reference for M0 instances. Grounds TSCG measurement in norm-referenced intersubjective consensus. Defeasible by design — valid until superseded by broader consensus.",
      "skos:definition": "A provisional structural attractor of a conceptual domain, identified by multi-cook convergence, domain-contextualized by default, explicitly defeasible, and self-improving through corpus growth.",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "m3gf:structure": {
        "epistemicScore": {
          "property": "m0:epistemicGap",
          "formula": "||ASFID_mean - REVOI_mean|| / sqrt(2)",
          "range": "[0.0, 1.0]"
        },
        "objectivityLevel": {
          "values": [
            "Subjective",
            "MultiExpertConsensus",
            "CanonCalibrated",
            "ContextualizedBenchmark"
          ],
          "default": "ContextualizedBenchmark"
        },
        "benchmarkRefs": {
          "type": "array",
          "items": {
            "uri": "IRI of canonical poclet",
            "domain": "M1 domain  (e.g. m1:Biology, m1:Electronics)",
            "canonType": "DomainSpecific | CrossDomain | Universal",
            "weight": "xsd:float  [0.0, 1.0]"
          }
        },
        "expertConsensus": {
          "numberOfExperts": "xsd:integer",
          "convergenceScore": "xsd:float  (ICC / Cohen kappa)",
          "method": "comparative | absolute | hybrid"
        }
      },
      "m3gf:resolutionOrder": [
        "1. DomainSpecific benchmark  (M1 domain of the poclet)  <- DEFAULT",
        "2. CrossDomain benchmark     (adjacent M1 domain)",
        "3. Universal benchmark       (e.g. M0_AdaptiveImmuneResponse)",
        "4. Free scoring + justification                         <- last resort"
      ],
      "skos:note": "Philosophical grounding: Popper (falsifiability), Kuhn (paradigm shifts), Peirce (limit of inquiry). Mathematical grounding: norm-referenced measurement (Stevens 1946), inter-rater reliability (ICC, Cohen kappa)."
    },
    {
      "@id": "m3gf:defeasibilityStatus",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Defeasibility Status",
      "rdfs:comment": "Explicit declaration that a benchmark or canonical reference is provisional — valid until superseded by broader consensus. Makes revisability a first-class property of TSCG measurements.",
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Defeasible knowledge: held as valid until defeated by stronger evidence or broader consensus. The normal epistemic status of scientific, legal, and practical knowledge.",
      "m3gf:structure": {
        "status": {
          "values": [
            "provisional",
            "established",
            "deprecated"
          ],
          "default": "provisional"
        },
        "validUntil": "superseded_by_better_consensus",
        "revisionTrigger": [
          "new_canonical_poclet_identified",
          "expert_consensus_challenged",
          "domain_expansion",
          "corpus_maturation"
        ]
      },
      "skos:note": "Analogous to stare decisis in law (precedent holds until overruled) and scientific paradigms (Kuhn: valid until anomalies accumulate)."
    },
    {
      "@id": "m3gf:stereopsicFusion",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Stereopsic Fusion Operator |",
      "rdfs:comment": "Bicephalous fusion operator connecting Territory (ASFID) and Map (REVOI) expressions. Interpreted as union: each side contributes its own properties. The mathematical expression of stereopsis — the fusion of Eagle Eye and Sphinx Eye into systemic depth perception.",
      "rdfs:domain": {
        "@id": "m3gf:M3Grammar"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Inter-space operator bridging Territory Grammar Gt and Map Grammar Gm. Left operand: ASFID expression. Right operand: REVOI expression. Asymmetric by construction — Territory | Map (never Map | Territory).",
      "m3gf:signature": "| : Gt_expr × Gm_expr → Bicephalous",
      "m3gf:semantics": "Union — each side contributes its properties without cancellation",
      "m3gf:asymmetry": "Left side is always ASFID (Territory), right side is always REVOI (Map)",
      "m3gf:monoidAxioms": {
        "associativity": "(X | Y) | Z = X | (Y | Z)  [in bicephalous space]",
        "neutral_element": "StereopsisEmptySet | X = X | StereopsisEmptySet = X"
      },
      "m3gf:examples": {
        "simple": "A × S | R  →  Attractor+Structure (Territory) fused with Representable (Map)",
        "compound": "A × S × F | R + E  →  complex bicephalous expression",
        "reading": "Left of | = Territory contribution, Right of | = Map contribution"
      },
      "m3gf:documentation_metaphor": "Stereopsis: fusion of two eye images (Eagle Eye + Sphinx Eye) to create systemic depth perception"
    },
    {
      "@id": "m3gf:EmptyTerritory",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Empty Territory",
      "rdfs:comment": "Neutral element of the structural product operator × (intra-ASFID). Represents the complete absence of empirical properties. Analogous to the empty set ∅ on the Territory side.",
      "skos:definition": "The unique neutral element e_× satisfying: EmptyTerritory × X = X × EmptyTerritory = X for any ASFID type expression X.",
      "m3gf:monoidRole": "neutral element of ×",
      "m3gf:visualEncoding": "Black (absence of color in additive color synthesis)",
      "m3gf:spectralClass": "degenerate — no ASFID scoring possible",
      "m3gf:monoid": "(ASFID, ×, EmptyTerritory)"
    },
    {
      "@id": "m3gf:EmptyMap",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Empty Map",
      "rdfs:comment": "Neutral element of the structural sum operator + (intra-REVOI). Represents the complete absence of epistemic properties. Analogous to the empty set ∅ on the Map side.",
      "skos:definition": "The unique neutral element e_+ satisfying: EmptyMap + X = X + EmptyMap = X for any REVOI type expression X.",
      "m3gf:monoidRole": "neutral element of +",
      "m3gf:visualEncoding": "Empty pentagon (no sectors activated)",
      "m3gf:spectralClass": "degenerate — no REVOI scoring possible",
      "m3gf:monoid": "(REVOI, +, EmptyMap)"
    },
    {
      "@id": "m3gf:StereopsisEmptySet",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Stereopsis Empty Set",
      "rdfs:comment": "Neutral element of the stereopsic fusion operator | (bicephalous). Corresponds to maximal epistemic gap (δ₁ = max) — Map/Territory intersection is empty. No stereopsis is possible.",
      "skos:definition": "The unique neutral element e_| satisfying: StereopsisEmptySet | X = X | StereopsisEmptySet = X for any bicephalous expression X. Represents the complete absence of stereopsic fusion.",
      "m3gf:monoidRole": "neutral element of |",
      "m3gf:epistemicGap": "δ₁ = maximum",
      "m3gf:spectralClass": "Incoherent (limit case, δ₁ = max strictly)",
      "m3gf:documentationMetaphor": "Divergent Strabismus: both eyes look in opposite directions — Territory and Map share no common point. No stereopsis possible.",
      "m3gf:relation": "StereopsisEmptySet = EmptyTerritory | EmptyMap",
      "m3gf:monoid": "(ASFID×REVOI, |, StereopsisEmptySet)"
    },
    {
      "@id": "m3gf:StereopsisUniversalSet",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Stereopsis Universal Set",
      "rdfs:comment": "Represents perfect Map/Territory alignment (δ₁ = 0) — the 1:1 case (Borges paradox). Both eyes converge on exactly the same focal point. A theoretical ideal, never fully instantiated in real systems.",
      "skos:definition": "Semantic limit element corresponding to perfect stereopsic convergence: Territory and Map describe the same reality with zero epistemic gap. Not an algebraic neutral element — a semantic attractor of the TSCG scoring space.",
      "m3gf:epistemicGap": "δ₁ = 0",
      "m3gf:spectralClass": "Coherent (limit case, δ₁ = 0 strictly)",
      "m3gf:documentationMetaphor": "Convergent Strabismus: both eyes converge on exactly the same focal point — Map and Territory in perfect 1:1 correspondence. The Borges map that equals the territory.",
      "m3gf:note": "Semantic concept only — not an algebraic special element (no monoid role). Represents the ideal toward which TSCG modeling aspires. Named by analogy with the Universal Set U in set theory: contains all properties, so intersecting with it changes nothing."
    }
  ]
}