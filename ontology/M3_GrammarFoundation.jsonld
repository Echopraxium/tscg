{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/",  
    "@vocab": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "m3gf": "M3_GrammarFoundation.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3gf:Ontology",
      "@type": "Ontology",
      "versionInfo": "1.0.0",
      "rdfs:label": "M3 Grammar Foundation",
      "rdfs:comment": "Foundational interface ontology for TSCG M3 layer. Defines Lambek Calculus mathematical foundation (free commutative monoidal categories), monoidal product ⊗ with indexed forms (⊗ⁱ where i ∈ {t,m}), and abstract classes for all M3 grammars. Resolves circular dependencies by serving as common foundation for EagleEye, SphinxEye, and GenesisGrammar.",
      "m3gf:created": "2026-05-12"
    },
    {
      "@id": "m3gf:M3Grammar",
      "@type": "Class",
      "rdfs:label": "M3 Grammar (Abstract)",
      "rdfs:comment": "Abstract base class for M3-level structural grammars"
    },
    {
      "@id": "m3gf:M3Dimension",
      "@type": "Class",
      "rdfs:label": "M3 Dimension (Abstract)",
      "rdfs:comment": "Abstract base class for M3 primitive dimensions"
    },
    {
      "@id": "m3gf:grammarType",
      "@type": "DatatypeProperty",
      "rdfs:label": "Grammar Type",
      "rdfs:comment": "Type of grammar to prevent collision between M3 structural grammar and M0 instance grammar (SHACL validation)",
      "rdfs:domain": "m3gf:M3Grammar",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "m3gf:monoidalProduct",
      "@type": "ObjectProperty",
      "rdfs:label": "Monoidal Product ⊗",
      "rdfs:comment": "Free commutative monoidal product following Lambek Calculus. Properties: associative, commutative, has neutral element 1. Indexed forms: ⊗ᵗ (Territory/Eagle), ⊗ᵐ (Map/Sphinx), general form ⊗ⁱ where i ∈ {t, m}"
    }
  ]
}