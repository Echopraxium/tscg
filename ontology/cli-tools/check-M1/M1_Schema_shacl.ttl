# ============================================================================
# M1_Schema.shacl.ttl
# SHACL Grammar for TSCG M1 Layer
# Covers: M1_CoreConcepts.jsonld + all M1 Extension files
# ============================================================================
# Author : Echopraxium with the collaboration of Claude AI
# Version: 1.1.0
# Date   : 2026-07-12
# Status : Active
# ============================================================================

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

@prefix m3: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#> .
@prefix m2: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#> .
@prefix m1: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#> .


# ============================================================================
# SHAPE 1 : M1 Ontology Node (owl:Ontology)
# Applies to ALL M1 files (CoreConcepts + Extensions)
# ============================================================================

m1:M1OntologyShape
    a sh:NodeShape ;
    sh:name "M1OntologyShape" ;
    sh:description "Validates the owl:Ontology header node of any M1 file." ;
    sh:targetClass owl:Ontology ;

    # --- Mandatory metadata ---
    sh:property [
        sh:path dcterms:creator ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:pattern "^Echopraxium with the collaboration of Claude AI$" ;
        sh:message "REQUIRED: dcterms:creator must be 'Echopraxium with the collaboration of Claude AI'."
    ] ;
    sh:property [
        sh:path dcterms:created ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" ;
        sh:message "REQUIRED: dcterms:created must be ISO 8601 date (YYYY-MM-DD)."
    ] ;
    sh:property [
        sh:path owl:versionInfo ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:pattern "^[0-9]+\\.[0-9]+\\.[0-9]+$" ;
        sh:message "REQUIRED: owl:versionInfo must use semver format (X.Y.Z)."
    ] ;
    sh:property [
        sh:path m3:ontologyType ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: m3:ontologyType must be declared exactly once."
    ] ;

    # --- m3:ontologyType must be DomainExtension or CoreConcepts ---
    sh:property [
        sh:path m3:ontologyType ;
        sh:in (
            <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension>
            <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CoreConcepts>
        ) ;
        sh:message "FORBIDDEN: m3:ontologyType value must be m3:DomainExtension or m3:CoreConcepts."
    ] ;

    # --- owl:imports must reference M3_GenesisGrammar (not GenesisSpace) ---
    sh:sparql [
        sh:select """
            PREFIX owl: <http://www.w3.org/2002/07/owl#>
            SELECT $this ?import
            WHERE {
                $this owl:imports ?import .
                FILTER(CONTAINS(STR(?import), "M3_GenesisSpace"))
            }
        """ ;
        sh:message "FORBIDDEN: owl:imports references M3_GenesisSpace.jsonld — use M3_GenesisGrammar.jsonld instead."
    ] ;

    # --- m2:changelog must be present for extensions ---
    sh:property [
        sh:path m2:changelog ;
        sh:minCount 0 ;
        sh:message "RECOMMENDED: m2:changelog should be present and use array of objects format."
    ] ;

    # --- FORBIDDEN: GenesisSpace references ---
    sh:not [
        sh:property [
            sh:path rdfs:comment ;
            sh:pattern "GenesisSpace" ;
            sh:minCount 1
        ]
    ] ;
    sh:message "FORBIDDEN: M3_GenesisSpace reference — use M3_GenesisGrammar." ;
.


# ============================================================================
# SHAPE 2 : GenericConceptCombo (M1_CoreConcepts only)
# Pattern: ["owl:Class", "m2:GenericConceptCombo"]
# Formula: Fm2(...)
# ============================================================================

m1:GenericConceptComboShape
    a sh:NodeShape ;
    sh:name "GenericConceptComboShape" ;
    sh:description "Validates GenericConceptCombo instances in M1_CoreConcepts.jsonld." ;
    sh:targetClass m2:GenericConceptCombo ;

    # --- Must be also typed as owl:Class ---
    sh:property [
        sh:path rdf:type ;
        sh:hasValue owl:Class ;
        sh:minCount 1 ;
        sh:message "REQUIRED: GenericConceptCombo must also be typed as owl:Class."
    ] ;

    # --- Must declare rdfs:subClassOf m2:GenericConceptCombo ---
    sh:property [
        sh:path rdfs:subClassOf ;
        sh:hasValue m2:GenericConceptCombo ;
        sh:minCount 1 ;
        sh:message "REQUIRED: rdfs:subClassOf must point to m2:GenericConceptCombo for OWL hierarchy visibility."
    ] ;

    # --- rdfs:label mandatory ---
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: rdfs:label must be present (PascalCase concept name)."
    ] ;

    # --- rdfs:comment mandatory ---
    sh:property [
        sh:path rdfs:comment ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "REQUIRED: rdfs:comment must define the concept."
    ] ;

    # --- m1:structuralGrammarFormula: must start with Fm2( ---
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:pattern "^Fm2[²]?\\(" ;
        sh:message "REQUIRED: m1:structuralGrammarFormula must use Fm2(...) notation for GenericConceptCombos."
    ] ;

    # --- FORBIDDEN: ⊗ in formulas ---
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [
            sh:pattern "⊗"
        ] ;
        sh:message "FORBIDDEN: ⊗ tensor notation in structuralGrammarFormula — use × / + / |."
    ] ;
.


# ============================================================================
# SHAPE 3 : DomainConceptCombo (M1 Extensions)          [renamed v1.1.0 — SC-1]
# Pattern: ["owl:Class", "m2:DomainConceptCombo"]
# Formula: Fm1m2(<Domain>+, <GenericConcept>+)
# NOTE: the m2:knowledgeField requirement below is a KNOWN PHANTOM (SC-5 fixes it,
#       replacing it with m2:appliesToDomains). Left untouched on purpose: SC-1
#       renames the combo class only and does not resolve the Domain duplicate.
# ============================================================================

m1:DomainConceptComboShape
    a sh:NodeShape ;
    sh:name "DomainConceptComboShape" ;
    sh:description "Validates DomainConceptCombo instances in M1 extension files." ;
    sh:targetClass m2:DomainConceptCombo ;

    # --- Must also be typed as owl:Class ---
    sh:property [
        sh:path rdf:type ;
        sh:hasValue owl:Class ;
        sh:minCount 1 ;
        sh:message "REQUIRED: DomainConceptCombo must also be typed as owl:Class."
    ] ;

    # --- rdfs:subClassOf → m2:KnowledgeFieldConceptCombo (OWL hierarchy) ---
    sh:property [
        sh:path rdfs:subClassOf ;
        sh:hasValue m2:DomainConceptCombo ;
        sh:minCount 1 ;
        sh:message "REQUIRED: rdfs:subClassOf must point to m2:DomainConceptCombo for OWL hierarchy visibility."
    ] ;

    # --- m2:knowledgeField mandatory ---
    sh:property [
        sh:path m2:knowledgeField ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: m2:knowledgeField must reference the domain KnowledgeField instance."
    ] ;

    # --- rdfs:label mandatory ---
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: rdfs:label must be present (PascalCase concept name)."
    ] ;

    # --- m1:structuralGrammarFormula: must start with Fm1m2( ---
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:pattern "^Fm1m2\\(" ;
        sh:message "REQUIRED: m1:structuralGrammarFormula must use Fm1m2(<Domain>, ...) notation for DomainConceptCombos."
    ] ;

    # --- FORBIDDEN: ⊗ in formulas ---
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [
            sh:pattern "⊗"
        ] ;
        sh:message "FORBIDDEN: ⊗ tensor notation in structuralGrammarFormula — use × / + / |."
    ] ;

    # --- FORBIDDEN: old asfidSignature property ---
    sh:not [
        sh:property [
            sh:path <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Poclet#asfidSignature> ;
            sh:minCount 1
        ]
    ] ;
    sh:message "FORBIDDEN: asfidSignature is deprecated — use m1:structuralGrammarFormula." ;
.


# ============================================================================
# SHAPE 4 : KnowledgeField Instance
# Pattern: ["owl:NamedIndividual", "m2:KnowledgeField"]
# ============================================================================

m1:KnowledgeFieldInstanceShape
    a sh:NodeShape ;
    sh:name "KnowledgeFieldInstanceShape" ;
    sh:description "Validates KnowledgeField instances (NOUN/ADJECTIVE forms)." ;
    sh:targetClass m2:KnowledgeField ;

    sh:property [
        sh:path rdf:type ;
        sh:hasValue owl:NamedIndividual ;
        sh:minCount 1 ;
        sh:message "REQUIRED: KnowledgeField must also be typed as owl:NamedIndividual."
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: KnowledgeField must have rdfs:label."
    ] ;
    sh:property [
        sh:path rdfs:comment ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "REQUIRED: KnowledgeField must have rdfs:comment."
    ] ;
.


# ============================================================================
# SHAPE 5 : owl:Class general (plain domain classes in extensions)
# Applies to owl:Class nodes that are NOT GenericConceptCombo or KFCC
# ============================================================================

m1:PlainDomainClassShape
    a sh:NodeShape ;
    sh:name "PlainDomainClassShape" ;
    sh:description "Validates plain owl:Class nodes (non-combo specializations) in M1 extensions." ;

    # Target: owl:Class that is NOT a KnowledgeFieldConceptCombo
    sh:targetSubjectsOf rdfs:subClassOf ;

    # --- rdfs:label mandatory ---
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:message "REQUIRED: All M1 classes must have rdfs:label."
    ] ;

    # --- rdfs:comment mandatory ---
    sh:property [
        sh:path rdfs:comment ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:message "RECOMMENDED: M1 classes should have rdfs:comment."
    ] ;
.


# ============================================================================
# SHAPE 6 : Namespace Purity — FORBIDDEN patterns
# ============================================================================

m1:NamespacePurityShape
    a sh:NodeShape ;
    sh:name "NamespacePurityShape" ;
    sh:description "Enforces M1 namespace conventions and forbids obsolete patterns." ;
    sh:targetSubjectsOf rdf:type ;

    # FORBIDDEN: m2:characterizedBy
    sh:not [
        sh:property [
            sh:path m2:characterizedBy ;
            sh:minCount 1
        ]
    ] ;
    sh:message "FORBIDDEN: m2:characterizedBy is deprecated — remove it (Fm1m2() formula captures the relationship)." ;

    # FORBIDDEN: tensorFormula
    sh:not [
        sh:property [
            sh:path m1:tensorFormula ;
            sh:minCount 1
        ]
    ] ;
    sh:message "FORBIDDEN: m1:tensorFormula is obsolete — use m1:structuralGrammarFormula." ;

    # FORBIDDEN: hasTensorFormula
    sh:not [
        sh:property [
            sh:path m2:hasTensorFormula ;
            sh:minCount 1
        ]
    ] ;
    sh:message "FORBIDDEN: m2:hasTensorFormula is obsolete — use m1:structuralGrammarFormula." ;
.


# ============================================================================
# SHAPE 7 : m1:structuralGrammarFormula property constraints
# ============================================================================

m1:StructuralGrammarFormulaShape
    a sh:NodeShape ;
    sh:name "StructuralGrammarFormulaShape" ;
    sh:description "Validates m1:structuralGrammarFormula values across M1 files." ;
    sh:targetSubjectsOf m1:structuralGrammarFormula ;

    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:pattern "^(Fm1m2|Fm2)\\(" ;
        sh:message "REQUIRED: structuralGrammarFormula must start with Fm1m2( or Fm2(."
    ] ;

    # FORBIDDEN: raw ⊗ tensor product
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [ sh:pattern "⊗" ] ;
        sh:message "FORBIDDEN: ⊗ in structuralGrammarFormula — replace with × (product) / | (bridge) / + (sum)."
    ] ;

    # FORBIDDEN: ORIVE (should be REVOI)
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [ sh:pattern "ORIVE" ] ;
        sh:message "FORBIDDEN: ORIVE terminology — use REVOI (Representability, Evolvability, Verifiability, Observability, Interoperability)."
    ] ;
.


# ============================================================================
# CHANGELOG
# ============================================================================
#
# v1.0.0 (2026-05-26)
#   Initial M1 SHACL grammar. 7 shapes covering:
#   - M1OntologyShape          : owl:Ontology header validation
#   - GenericConceptComboShape  : Fm2() combos in CoreConcepts
#   - KFConceptComboShape       : Fm1m2() combos in Extensions
#   - KnowledgeFieldShape       : NOUN/ADJECTIVE KF instances
#   - PlainDomainClassShape     : specialization classes
#   - NamespacePurityShape      : forbidden deprecated patterns
#   - StructuralGrammarShape    : formula format validation
#
# ============================================================================

# ============================================================================
# SHAPE 8 : m1:CorePattern NamedIndividual
# CorePatterns are NamedIndividuals with raw structural formulas (no Fm2 wrapping)
# ============================================================================

m1:CorePatternShape
    a sh:NodeShape ;
    sh:name "CorePatternShape" ;
    sh:description "Validates m1:CorePattern NamedIndividuals in M1_CoreConcepts." ;
    sh:targetClass m1:CorePattern ;

    sh:property [
        sh:path rdf:type ;
        sh:hasValue owl:NamedIndividual ;
        sh:minCount 1 ;
        sh:message "REQUIRED: CorePattern must be typed as owl:NamedIndividual."
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "REQUIRED: CorePattern must have rdfs:label."
    ] ;
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:message "OPTIONAL: CorePattern may have a raw structural formula (× / + / | notation)."
    ] ;
.

# ============================================================================
# SHAPE 9 : ComboFormulaShape  — A COMBO'S FORMULA *IS* A FUNCTION SIGNATURE
# ----------------------------------------------------------------------------
# SC-1, 2026-07-12. See StructuralGrammar/Functional_Grammar_Model.md.
#
#   Fm2   : GenericConcept²⁺           -> m2:GenericConceptCombo
#   Fm1m2 : Domain⁺, GenericConcept⁺   -> m2:DomainConceptCombo
#
# Fm2/Fm1m2 are FUNCTIONS, not functors: emergence is non-compositional, so a
# combo has NO monoidal expansion. Its formula is the signature — nothing else.
# Arguments are NAMED CONCEPTS, juxtaposed by comma, never joined by an operator.
# ============================================================================

m1:ComboFormulaShape
    a sh:NodeShape ;
    sh:name "ComboFormulaShape" ;
    sh:description "A combo's structuralGrammarFormula is a function signature: no monoidal operator, no primitive as argument, correct arity." ;
    sh:targetClass m2:GenericConceptCombo ;   # inherited by m2:DomainConceptCombo

    # --- FORBIDDEN: monoidal operators inside a signature -------------------
    # x / + / | belong to ATOM formulas only. In a signature they would assert
    # the compositional (functorial) reading that SC-1 retires.
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [ sh:pattern "[×+|⊗]" ] ;
        sh:severity sh:Violation ;
        sh:message "FORBIDDEN (SC-1): monoidal operator (× / + / | / ⊗) inside a combo formula. A combo's formula IS a function signature — arguments are juxtaposed by comma, never joined by a grammar operator. Monoidal formulas belong to ATOMS only."
    ] ;

    # --- FORBIDDEN: a bare primitive type as an argument ---------------------
    # ASFID {A,S,F,I,D} + REVOI {R,E,V,O,Im} + TKSL {T,K,Ss,L} + subscripted
    # {St,It,Ss,Im}. A primitive is a generative DIMENSION of a grammar, not a
    # GenericConcept, hence not a legal argument.
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:not [ sh:pattern "[(,][ ]*(A|S|F|I|D|R|E|V|O|T|K|L|St|Ss|It|Im)[ ]*[,)]" ] ;
        sh:severity sh:Violation ;
        sh:message "FORBIDDEN (SC-1): primitive type used as an argument of Fm2/Fm1m2. Arguments must be NAMED CONCEPTS declared in M2_GenericConcepts.jsonld or M1_CoreConcepts.jsonld."
    ] ;

    # --- REQUIRED: a well-formed signature, correct arity (D5) ---------------
    # Fm2   : >= 2 concept arguments  -> at least one comma
    # Fm1m2 : >= 1 domain AND >= 1 concept -> at least one comma
    # (A domain-less Fm1m2 is an Fm2 that mislabelled itself.)
    sh:property [
        sh:path m1:structuralGrammarFormula ;
        sh:pattern "^(Fm2|Fm1m2)\\([^,()]+,[^()]+\\)$" ;
        sh:severity sh:Violation ;
        sh:message "REQUIRED (SC-1): formula must be a well-formed signature Fm2(a, b, ...) or Fm1m2(Domain, a, ...) with at least two arguments. Fm2 needs >= 2 concepts (an emergence needs two ingredients); Fm1m2 needs >= 1 Domain AND >= 1 GenericConcept."
    ] ;
.


# ============================================================================
# SHAPE 10 : NoMonoidalExpansionShape  — m1:structuralGrammarFormulaExpanded
# ----------------------------------------------------------------------------
# SC-1 / Decision D8, 2026-07-12.
# This property stored the "expansion" of a combo as a monoidal formula, e.g.
# "S × I × A × D × F" — i.e. lattice_join(dims(parents)), the union of the
# parents' dimensions. That is precisely the COMPOSITIONAL thesis SC-1 retires
# (with m2:morphism_emergence, from which it descends). If emergence is
# non-compositional, there is nothing to expand: the property has no referent,
# which is why half its occurrences are empty strings.
# ============================================================================

m1:NoMonoidalExpansionShape
    a sh:NodeShape ;
    sh:name "NoMonoidalExpansionShape" ;
    sh:description "A combo has no monoidal expansion (emergence is non-compositional)." ;
    sh:targetClass m2:GenericConceptCombo ;

    sh:property [
        sh:path m1:structuralGrammarFormulaExpanded ;
        sh:maxCount 0 ;
        sh:severity sh:Violation ;
        sh:message "FORBIDDEN (SC-1/D8): m1:structuralGrammarFormulaExpanded is retired. A combo has NO monoidal expansion — the arguments are combined, not associated. Superseded by the function signature carried by m1:structuralGrammarFormula."
    ] ;
.
