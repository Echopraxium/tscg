@prefix ns1: <m2:> .
@prefix ns2: <rdfs:> .
@prefix ns3: <dcterms:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Oscillator a ns1:GenericConcept,
        ns1:GenericConceptCombo,
        <owl:Class> ;
    ns3:created "2026-02-27" ;
    ns3:creator "Echopraxium with the collaboration of Claude AI" ;
    ns1:couplingExplanation "Ternary combo (N=3). D couples temporal evolution (Process) with periodic progression along the circular path (Trajectory) — contraction yields period T. F couples energy flow (Process) with state-space traversal (Trajectory) — contraction yields energy stored per cycle. I couples functional role (Component) with phase information (Process) — contraction yields phase state φ as the functional signature of the Oscillator within its host system. S from Component adds structural identity (bounded entity). A from Trajectory adds the attractor (equilibrium point or limit cycle). Result: full 5D ASFID coverage." ;
    ns1:discoveryContext [ ] ;
    ns1:distinctionFromRelated [ ] ;
    ns1:eagleView [ ] ;
    ns1:hasAttribute [ ] ;
    ns1:hasDominantM3 "m3:eagle_eye:Attractor",
        "m3:eagle_eye:Dynamics",
        "m3:eagle_eye:Flow",
        "m3:eagle_eye:Information",
        "m3:eagle_eye:Structure" ;
    ns1:hasEpistemicGap 2e-01 ;
    ns1:hasFamily "m2:Combo" ;
    ns1:hasPolarity "neutral" ;
    ns1:hasTensorFormula "⊗⇒(Component, Process, Trajectory) | trajectoryShape=Circular" ;
    ns1:hasTensorFormulaASCII "(x)=>(Component, Process, Trajectory) | trajectoryShape=Circular" ;
    ns1:hasTensorFormulaExpanded "S ⊗ A ⊗ I ⊗ D ⊗ F" ;
    ns1:hasTensorFormulaExpandedASCII "S (x) A (x) I (x) D (x) F" ;
    ns1:hasTensorFormulaExpandedTeX "S \\otimes A \\otimes I \\otimes D \\otimes F" ;
    ns1:hasTensorFormulaTeX "\\otimes\\Rightarrow(\\text{Component}, \\text{Process}, \\text{Trajectory}) \\;|\\; \\text{trajectoryShape}=\\text{Circular}" ;
    ns1:implements ns1:Composable ;
    ns1:parentGenericConcepts ns1:Component,
        ns1:Process,
        ns1:Trajectory ;
    ns1:perspective "territory" ;
    ns1:sharedDimensions [ ] ;
    ns1:significance "Second GenericConceptCombo (with m2:Cascade) to achieve full ASFID coverage (5D). The ternary composition with Component is what unlocks S: Oscillation (behaviour alone) has no structure, but an Oscillator (component) does. Demonstrates that subclassing m2:Component systematically promotes a behavioural combo to a fully structural one." ;
    ns1:transdisciplinaryValidation [ ] ;
    ns2:comment "A system component that sustains periodic return to previous states through a cyclic trajectory around an attractor. Subclass of Component (S ⊗ I): the Oscillator has a structural identity within a larger system and a functional role (producing periodicity). Emergent combination of Component (S ⊗ I), Process (D ⊗ I ⊗ F) and Trajectory constrained to Circular shape (A ⊗ D ⊗ F). Shared dimensions D, F, I couple across parents; the union yields full ASFID coverage (S ⊗ A ⊗ I ⊗ D ⊗ F). Emergent properties irreducible to any single parent: period T, amplitude A, phase φ. Characterised by four ValueSpace attributes: frequency, amplitude, phase, damping_ratio." ;
    ns2:label "Oscillator" ;
    ns2:subClassOf "m2:Component",
        "m2:GenericConcept",
        "m2:GenericConceptCombo" .

