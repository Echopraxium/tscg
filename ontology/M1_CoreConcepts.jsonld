            "status": "Active"
          },
          {
            "ontology": "M1_Optics.jsonld",
            "namespace": "m1:extension:optics:",
            "domain": "Optics / Color Theory / Light Physics",
            "status": "Active"
          },
          {
            "ontology": "M1_Photography.jsonld",
            "namespace": "m1:extension:photography:",
            "domain": "Photography / Camera Technology / Exposure Control",
            "status": "Active"
          },
          {
            "ontology": "M1_Physics.jsonld",
            "namespace": "m1:extension:physics:",
            "domain": "Physics / Mechanics / Thermodynamics",
            "status": "Active"
          },
          {
            "ontology": "M1_SystemicModeling.jsonld",
            "namespace": "m1:extension:systemic_modeling:",
            "domain": "Systemic Modeling / Cybernetics / Systems Theory",
            "status": "Active"
          }
        ],
        "proposed": [
          {
            "ontology": "M1_Philosophy.jsonld",
            "namespace": "m1:extension:philosophy:",
            "domain": "Philosophy / Ethics / Value Systems",
            "patterns": "TBD",
