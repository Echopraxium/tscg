# TSCG Instances - Complete Grammar SHACL Schema v1.5
# Author: Echopraxium with the collaboration of Claude AI
# Date: 2026-06-19
# Status: ACTIVE
#
# ============================================
# CHANGELOG
# ============================================
# v1.5 (2026-06-19): M0_Common.jsonld + ENUMERATION TYPES
#   - BREAKING: m0: prefix updated from M0_Poclet# → M0_Common.jsonld# (canonical source of truth)
#   - BREAKING: m0:spectralClass now owl:ObjectProperty — value MUST be sh:nodeKind sh:IRI
#     Valid IRIs: m0:spectralClass.Coherent | .OnCriticalLine | .Liminal | .Enigmatic
#   - BREAKING: m0:focalClass now owl:ObjectProperty — value MUST be sh:nodeKind sh:IRI
#     Valid IRIs: m0:focalClass.Emmetropic | .SlightlyMyopic | .SlightlyHyperopic | .Myopic | .Hyperopic | .Astigmatic
#   - BREAKING: m0:scoringStatus now owl:ObjectProperty — value MUST be sh:nodeKind sh:IRI
#     Valid IRIs: m0:scoringStatus.Complete | .Partial | .Pending
#   - BREAKING: Score values are now bare numerics (no @type:xsd:float annotation needed)
#     rdfs:range xsd:float declared in M0_Common.jsonld — parsers infer type
#   - NEW: owl:imports M0_Common.jsonld REQUIRED in all M0 instances
#   - UPDATED: Naming convention documented — camelCase.PascalCase for enum values
#   - FORBIDDEN: A_score/S_score/... aliases (replaced by m0:scoreA/m0:scoreS/...)
#   - FORBIDDEN: {"@value":"0.85","@type":"xsd:float"} — use bare 0.85
#
# v1.4 (2026-06-19): NAMESPACE IRI CONVENTION — m0.<instance>: and m1.extension.<domain>: enforcement
#   - NEW: m0:CanonicalNamespaceShape — VIOLATION if any property IRI is not an absolute URL
#   - NEW: m0:CanonicalTscgBaseShape  — WARNING if TSCG IRI uses non-canonical repo base
#   - DOCUMENTED: 23/32 instances have namespace violations (unresolved @context aliases)
#   - Root causes catalogued: m0: declared relative, m1core: undeclared, @base missing
#   - Convention: m0.<instance>: and m1.extension.<domain>: aliases MUST resolve to HTTPS
#
# v1.3 (2026-06-19): SCORE CONVENTION ENFORCEMENT + FOCAL SCORE (Gs stereopsis)
#   - BREAKING: m0:asfidScores{} and m0:revoiScores{} sub-objects → FORBIDDEN
#   - BREAKING: eagle_eye:*/sphinx_eye:* as score properties → FORBIDDEN
#   - NEW: Flat scores A_score..Im_score at owl:Ontology root level → STRONGLY RECOMMENDED
#   - NEW: m0:asfidMean, m0:revoiMean → RECOMMENDED
#   - NEW: m0:epistemicGap constraint tightened (coherence check documented)
#   - NEW: m0:spectralClass enum constraint added
#   - NEW: m0:scoringStatus → OPTIONAL ("complete"|"partial"|"pending")
#   - NEW: Focal Score family (Gs stereopsis) → OPTIONAL, conditional on focalApplicable
#     - m0:focalApplicable (boolean, always)
#     - m0:stereopsicDepth [0,1]
#     - m0:focalBias [-1,1]  — signed: REVOI_mean - ASFID_mean
#     - m0:focalScore [0,1]  — EFS = stereopsicDepth × (1 - |focalBias|)
#     - m0:focalClass enum (Emmetropic|SlightlyMyopic|SlightlyHyperopic|Myopic|Hyperopic|Astigmatic)
#     - m0:stereopsicDepthProfile (object)
#   - Updated corpus stats: 33 instances (26 poclets + 2 SF + 1 SSG + 3 TscgTools + 1 stub)
#   - m3:ontologyType values extended: TscgTool added
#
# v1.2 (2026-04-19): Absolute URL requirements for pyshacl
# v1.1 (2026-04-18): Domain property migration to M1 level (m0:domain → m1:domain)
# v1.0 (2026-04-13): FINAL grammar after complete corpus analysis (26 instances)
# ============================================

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m0:      <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Common.jsonld#> .
@prefix m1:      <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld#> .
@prefix m2:      <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld#> .
@prefix m3:      <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#> .

# ============================================
# NAMESPACE POLICY (CRITICAL)
# ============================================
# ALLOWED NAMESPACES:
#   Standard:  owl, rdf, rdfs, skos, dcterms, xsd
#   TSCG:      m3, m2, m1 (+ extensions m1:extension:<domain>:), m0
#
# FORBIDDEN NAMESPACES:
#   tscg:        → use m0: for instance-specific properties
#   eagle_eye:*  → MonoidalTypes, NOT score properties (v1.3)
#   sphinx_eye:* → MonoidalTypes, NOT score properties (v1.3)
#
# @CONTEXT URL REQUIREMENTS (pyshacl — CRITICAL):
#   ALL namespace URLs MUST be ABSOLUTE:
#   ✅ "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#"
#   ❌ "m3": "M3_GenesisGrammar.jsonld#"
#
# SCORE CONVENTION (v1.5 MANDATORY):
#   Scores MUST be flat at owl:Ontology root level as m0:scoreX bare numerics:
#   m0:scoreA, m0:scoreS, m0:scoreF, m0:scoreIt, m0:scoreD  (ASFID / Gt)
#   m0:scoreR, m0:scoreE, m0:scoreV, m0:scoreO, m0:scoreIm  (REVOI / Gm)
#   Properties defined in M0_Common.jsonld with rdfs:range xsd:float.
#   FORBIDDEN: A_score/S_score/... @context aliases (replaced by m0:scoreX directly)
#   FORBIDDEN: m0:asfidScores{} and m0:revoiScores{} sub-objects.
#   FORBIDDEN: {"@value":"0.85","@type":"xsd:float"} — use bare numeric 0.85
#
# ENUMERATION CONVENTION (v1.5 NEW):
#   m0:spectralClass, m0:focalClass, m0:scoringStatus are owl:ObjectProperty.
#   Values MUST be IRIs using pattern: m0:<propertyName>.<ValuePascalCase>
#   ✅ "m0:spectralClass": {"@id": "m0:spectralClass.Coherent"}
#   ❌ "m0:spectralClass": "Coherent"   (string — FORBIDDEN since v1.5)
#   All enum individuals defined in M0_Common.jsonld.
#
# M0_Common.jsonld (v1.5 NEW — MANDATORY):
#   All M0 instances MUST declare in @context:
#     "m0": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Common.jsonld#"
#   AND in owl:imports: "M0_Common.jsonld"
#   Instance-local properties use: "m0.<instanceName>": "instances/.../M0_<Name>.jsonld#"
#
# FOCAL SCORE (v1.3 NEW — conditional):
#   Only meaningful when stereopsic GenericConcepts (isStereopsic=true) are mobilized.
#   m0:focalApplicable=true triggers the full focal score family.
#   m0:focalApplicable=false → all other focal properties MUST be absent.
# ============================================

# ============================================
# TSCG INSTANCE TYPES (v1.3 — 4 validated types)
# ============================================
# m3:Poclet              — primary M0 instance type (26 instances)
# m3:SystemicFramework   — external methodology (Vsm, Triz, Bmc)
# m3:SymbolicSystemGrammar — formal symbolic grammar (IChing)
# m3:TscgTool            — reflexive TSCG tooling instances
# ============================================

# ============================================
# COMMON TSCG INSTANCE SHAPE
# ============================================
m0:TscgInstanceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:name "TSCG Instance Common Shape v1.3" ;
  sh:description "Common constraints for all TSCG instances. Score Convention Option B enforced. Focal Score (Gs) added as optional conditional block." ;

  # ===== MANDATORY PROPERTIES =====

  sh:property [
    sh:path rdf:type ;
    sh:hasValue owl:Ontology ;
    sh:minCount 1 ;
    sh:message "CRITICAL: All TSCG instances MUST have @type: owl:Ontology (never owl:NamedIndividual)."
  ] ;

  sh:property [
    sh:path m3:ontologyType ;
    sh:nodeKind sh:IRI ;
    sh:in ( m3:Poclet m3:SystemicFramework m3:SymbolicSystemGrammar m3:TscgTool ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "CRITICAL: m3:ontologyType MUST be one of: m3:Poclet, m3:SystemicFramework, m3:SymbolicSystemGrammar, m3:TscgTool. NEVER use m3:ontologyCategory or m2:ontologyCategory."
  ] ;

  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "rdfs:label is MANDATORY. Use rdfs:label, NOT dcterms:title."
  ] ;

  sh:property [
    sh:path rdfs:comment ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "rdfs:comment is MANDATORY. Use rdfs:comment, NOT dcterms:description."
  ] ;

  sh:property [
    sh:path owl:versionInfo ;
    sh:datatype xsd:string ;
    sh:pattern "^[0-9]+\\.[0-9]+\\.[0-9]+$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "owl:versionInfo MUST follow semantic versioning X.Y.Z. Use owl:versionInfo, NOT m0:version."
  ] ;

  sh:property [
    sh:path dcterms:creator ;
    sh:datatype xsd:string ;
    sh:hasValue "Echopraxium with the collaboration of Claude AI" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "dcterms:creator MUST be exactly 'Echopraxium with the collaboration of Claude AI'."
  ] ;

  sh:property [
    sh:path dcterms:created ;
    sh:or (
      [ sh:datatype xsd:date ]
      [ sh:datatype xsd:string ]
    ) ;
    sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "dcterms:created MUST be present in format YYYY-MM-DD."
  ] ;

  sh:property [
    sh:path m1:domain ;
    sh:or (
      [ sh:datatype xsd:string ]
      [ sh:nodeKind sh:Literal ]
    ) ;
    sh:minCount 1 ;
    sh:message "m1:domain is MANDATORY (use m1:domain, NOT m0:domain). Accepts single string or array. Values registered in M1_Domains.jsonld."
  ] ;

  # ===== STRONGLY RECOMMENDED =====

  sh:property [
    sh:path owl:imports ;
    sh:minCount 0 ;
    sh:message "owl:imports is strongly recommended — should list M3, M2, M1 ontologies."
  ] ;

  sh:property [
    sh:path m2:changelog ;
    sh:minCount 0 ;
    sh:message "m2:changelog is strongly recommended. MUST be array of {version, date, changes} objects. Max 3 entries (rolling). NOT a bare string array."
  ] ;

  # ===== SCORES — FLAT AT ROOT LEVEL (Option B — v1.3) =====
  # ASFID scores: A_score, S_score, F_score, It_score, D_score

  sh:property [
    sh:path m0:scoreA ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreA (Attractor score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld. NO @type annotation needed. NOT inside m0:asfidScores{}."
  ] ;

  sh:property [
    sh:path m0:scoreS ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreS (Structure score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld."
  ] ;

  sh:property [
    sh:path m0:scoreF ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreF (Flow score). Bare numeric float in [0.0, 1.0]. F=0.0 valid (Stase — no flow is legitimate). Defined in M0_Common.jsonld."
  ] ;

  sh:property [
    sh:path m0:scoreIt ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreIt (Information/Territory score). NOT m0:scoreIm (Interoperability/Map). Bare numeric float [0.0, 1.0]."
  ] ;

  sh:property [
    sh:path m0:scoreD ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreD (Dynamics score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld."
  ] ;

  # REVOI scores: R_score, E_score, V_score, O_score, Im_score

  sh:property [
    sh:path m0:scoreR ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreR (Representability score). R = Representability, NEVER Reproducibility. Bare numeric float [0.0, 1.0]."
  ] ;

  sh:property [
    sh:path m0:scoreE ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreE (Evolvability score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld."
  ] ;

  sh:property [
    sh:path m0:scoreV ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreV (Verifiability score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld."
  ] ;

  sh:property [
    sh:path m0:scoreO ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreO (Observability score). Bare numeric float in [0.0, 1.0]. Defined in M0_Common.jsonld."
  ] ;

  sh:property [
    sh:path m0:scoreIm ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoreIm (Interoperability/Map score). NOT m0:scoreIt (Information/Territory). Bare numeric float [0.0, 1.0]."
  ] ;

  # Aggregate scores

  sh:property [
    sh:path m0:asfidMean ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:asfidMean = (A_score + S_score + F_score + It_score + D_score) / 5. Recommended when scores present."
  ] ;

  sh:property [
    sh:path m0:revoiMean ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:revoiMean = (R_score + E_score + V_score + O_score + Im_score) / 5. Recommended when scores present."
  ] ;

  # Epistemic gap δ₁

  sh:property [
    sh:path m0:epistemicGap ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:epistemicGap = |asfidMean - revoiMean| / √2. Must be float in [0.0, 1.0]. Recommended when asfidMean and revoiMean are present."
  ] ;

  sh:property [
    sh:path m0:spectralClass ;
    sh:nodeKind sh:IRI ;
    sh:in (
      m0:spectralClass.Coherent
      m0:spectralClass.OnCriticalLine
      m0:spectralClass.Liminal
      m0:spectralClass.Enigmatic
    ) ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:spectralClass MUST be an IRI from m0:SpectralClass enumeration. Use: m0:spectralClass.Coherent (δ₁<0.05), m0:spectralClass.OnCriticalLine (0.05≤δ₁<0.15), m0:spectralClass.Liminal (0.15≤δ₁<0.30), m0:spectralClass.Enigmatic (δ₁≥0.30). FORBIDDEN: bare string 'Coherent' — use IRI with @id."
  ] ;

  # Scoring status (for stubs / incomplete instances)

  sh:property [
    sh:path m0:scoringStatus ;
    sh:nodeKind sh:IRI ;
    sh:in (
      m0:scoringStatus.Complete
      m0:scoringStatus.Partial
      m0:scoringStatus.Pending
    ) ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:scoringStatus MUST be an IRI from m0:ScoringStatus enumeration. Use: m0:scoringStatus.Complete (all 10 scores), m0:scoringStatus.Partial (some scores), m0:scoringStatus.Pending (no scores — stub). FORBIDDEN: bare string 'complete' — use IRI with @id."
  ] ;

  # ===== FOCAL SCORE — Gs Stereopsis (v1.3 NEW — OPTIONAL, CONDITIONAL) =====

  sh:property [
    sh:path m0:focalApplicable ;
    sh:datatype xsd:boolean ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:focalApplicable: true if instance mobilizes at least one stereopsic GenericConcept (isStereopsic=true in M2). false otherwise. When false, all other m0:focal* properties MUST be absent."
  ] ;

  sh:property [
    sh:path m0:stereopsicDepth ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:stereopsicDepth: Gs depth score [0,1]. Computed from TKSL primitives active in mobilized stereopsic GenericConcepts: (T×0.25 + K×0.25 + Ss×0.25 + L×0.25). Only present when m0:focalApplicable=true."
  ] ;

  sh:property [
    sh:path m0:focalBias ;
    sh:datatype xsd:float ;
    sh:minInclusive -1.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:focalBias = REVOI_mean - ASFID_mean. Signed float in [-1.0, 1.0]. Positive = Map dominant (Hyperopic). Negative = Territory dominant (Myopic). Only present when m0:focalApplicable=true."
  ] ;

  sh:property [
    sh:path m0:focalScore ;
    sh:datatype xsd:float ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 1.0 ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:focalScore: Epistemic Focal Score (EFS) [0,1]. Formula: stereopsicDepth × (1 - |focalBias|). 1=Emmetropic (sharp combined image), 0=Astigmatic (no stereopsic depth) or strongly biased. Only present when m0:focalApplicable=true."
  ] ;

  sh:property [
    sh:path m0:focalClass ;
    sh:nodeKind sh:IRI ;
    sh:in (
      m0:focalClass.Emmetropic
      m0:focalClass.SlightlyMyopic
      m0:focalClass.SlightlyHyperopic
      m0:focalClass.Myopic
      m0:focalClass.Hyperopic
      m0:focalClass.Astigmatic
    ) ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:message "m0:focalClass MUST be an IRI from m0:FocalClass enumeration. Use: m0:focalClass.Emmetropic (EFS≥0.70), m0:focalClass.SlightlyMyopic/.SlightlyHyperopic (0.50≤EFS<0.70), m0:focalClass.Myopic/.Hyperopic (0.30≤EFS<0.50), m0:focalClass.Astigmatic (EFS<0.30). Only present when m0:focalApplicable=true. FORBIDDEN: bare string — use IRI with @id."
  ] .

# ============================================
# FORBIDDEN PATTERNS (v1.3 — extended)
# ============================================

# FORBIDDEN: owl:NamedIndividual at ontology level
m0:ForbidNamedIndividualShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path rdf:type ;
      sh:hasValue owl:NamedIndividual
    ]
  ] ;
  sh:message "FORBIDDEN: TSCG instances MUST use @type: owl:Ontology, NOT owl:NamedIndividual." .

# FORBIDDEN: m0:asfidScores{} sub-object (Pattern A — obsolete since v1.3)
m0:ForbidAsfidScoresSubObjectShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:asfidScores ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN (v1.3): m0:asfidScores{} sub-object is obsolete (Pattern A). Use flat scores A_score, S_score, F_score, It_score, D_score at owl:Ontology root level (Option B convention)." .

# FORBIDDEN: m0:revoiScores{} sub-object (Pattern A — obsolete since v1.3)
m0:ForbidRevoiScoresSubObjectShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:revoiScores ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN (v1.3): m0:revoiScores{} sub-object is obsolete (Pattern A). Use flat scores R_score, E_score, V_score, O_score, Im_score at owl:Ontology root level (Option B convention)." .

# FORBIDDEN: m3:ontologyCategory and m2:ontologyCategory
m0:ForbidObsoleteOntologyCategoriesShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:or (
      [ sh:property [ sh:path m3:ontologyCategory ; sh:minCount 1 ] ]
      [ sh:property [ sh:path m2:ontologyCategory ; sh:minCount 1 ] ]
    )
  ] ;
  sh:message "FORBIDDEN: m3:ontologyCategory and m2:ontologyCategory are obsolete. Use m3:ontologyType exclusively." .

# FORBIDDEN: dcterms:title at ontology level
m0:ForbidDctermsTitleShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path dcterms:title ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Use rdfs:label instead of dcterms:title at ontology level." .

# FORBIDDEN: dcterms:description at ontology level
m0:ForbidDctermsDescriptionShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path dcterms:description ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Use rdfs:comment instead of dcterms:description at ontology level." .

# FORBIDDEN: m0:version (use owl:versionInfo)
m0:ForbidM0VersionShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:version ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Use owl:versionInfo instead of m0:version." .

# FORBIDDEN: m2:ontologyType (wrong namespace)
m0:ForbidM2OntologyTypeShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m2:ontologyType ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN: Only m3:ontologyType is valid. Do NOT use m2:ontologyType (wrong namespace)." .

# FORBIDDEN: obsolete ORIVE terminology
m0:ForbidOriveShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:or (
      [ sh:property [ sh:path m0:oriveScores ; sh:minCount 1 ] ]
      [ sh:property [ sh:path m0:sphinxEye_ORIVE ; sh:minCount 1 ] ]
    )
  ] ;
  sh:message "FORBIDDEN: ORIVE is obsolete terminology. Use m0:revoiMean, R_score..Im_score, REVOI throughout. R = Representability (NEVER Reproducibility)." .

# FORBIDDEN: tscg: namespace
m0:ForbidTscgNamespaceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "FORBIDDEN NAMESPACE: 'tscg:' namespace is not allowed. Use standard (owl/rdf/rdfs/skos/dcterms/xsd) or TSCG (m3/m2/m1/m0) namespaces." ;
    sh:select """
      SELECT $this ?property ?value
      WHERE {
        $this ?property ?value .
        FILTER(STRSTARTS(STR(?property), "http://undefined.tscg.namespace/") ||
               REGEX(STR(?property), "tscg:", "i"))
      }
      LIMIT 1
    """
  ] .

# ============================================
# FOCAL SCORE COHERENCE RULES (v1.3)
# ============================================
# When focalApplicable=false, other focal props must be absent.
# Expressed as SPARQL constraint for cross-property coherence.

m0:FocalScoreCoherenceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "FOCAL SCORE COHERENCE: When m0:focalApplicable=false, properties m0:focalScore, m0:focalClass, m0:stereopsicDepth, m0:focalBias MUST be absent." ;
    sh:select """
      PREFIX m0: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Poclet#>
      SELECT $this
      WHERE {
        $this m0:focalApplicable false .
        {
          { $this m0:focalScore ?s }
          UNION
          { $this m0:focalClass ?c }
          UNION
          { $this m0:stereopsicDepth ?d }
          UNION
          { $this m0:focalBias ?b }
        }
      }
    """
  ] .


# ============================================
# M0_Common.jsonld IMPORT CONSTRAINT (v1.5)
# ============================================
m0:RequireM0CommonImportShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:severity sh:Warning ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "M0_Common.jsonld IMPORT RECOMMENDED (v1.5): All M0 instances should declare owl:imports M0_Common.jsonld to inherit shared property definitions (m0:scoreA..m0:scoreIm, m0:epistemicGap, m0:focalScore, enumeration classes). Without this import, m0: properties may not resolve correctly in OWL reasoners." ;
    sh:select """
      PREFIX owl: <http://www.w3.org/2002/07/owl#>
      PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      SELECT $this
      WHERE {
        $this rdf:type owl:Ontology .
        FILTER NOT EXISTS {
          $this owl:imports ?imp .
          FILTER(
            CONTAINS(STR(?imp), "M0_Common") ||
            CONTAINS(STR(?imp), "m0_common")
          )
        }
      }
    """
  ] .

# ============================================
# FORBIDDEN: String values for enum properties (v1.5)
# ============================================
m0:ForbidStringSpectralClassShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:spectralClass ;
      sh:datatype xsd:string ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN (v1.5): m0:spectralClass must be an IRI (e.g. {'@id': 'm0:spectralClass.Coherent'}), NOT a string literal ('Coherent'). Use @id notation." .

m0:ForbidStringScoringStatusShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:scoringStatus ;
      sh:datatype xsd:string ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN (v1.5): m0:scoringStatus must be an IRI (e.g. {'@id': 'm0:scoringStatus.Complete'}), NOT a string literal. Use @id notation." .

m0:ForbidStringFocalClassShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:not [
    sh:property [
      sh:path m0:focalClass ;
      sh:datatype xsd:string ;
      sh:minCount 1
    ]
  ] ;
  sh:message "FORBIDDEN (v1.5): m0:focalClass must be an IRI (e.g. {'@id': 'm0:focalClass.Emmetropic'}), NOT a string literal. Use @id notation." .

# ============================================
# FORBIDDEN: A_score/S_score/... aliases (v1.5)
# ============================================
# These were @context aliases resolving to M0_Poclet# (now replaced by m0:scoreX → M0_Common.jsonld#).
# If still present as unresolved aliases, they appear as non-canonical IRIs
# and are already caught by m0:CanonicalNamespaceShape.
# Documented here for clarity.
#
# FORBIDDEN aliases (must NOT appear in @context):
#   "A_score", "S_score", "F_score", "It_score", "D_score"
#   "R_score", "E_score", "V_score", "O_score", "Im_score"
# CORRECT: use m0:scoreA, m0:scoreS, m0:scoreF, m0:scoreIt, m0:scoreD
#          and m0:scoreR, m0:scoreE, m0:scoreV, m0:scoreO, m0:scoreIm directly

