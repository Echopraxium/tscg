# ============================================
# NAMESPACE IRI CONVENTION (v1.4 — 2026-06-19)
# ============================================
#
# RULE: Every property IRI used in a TSCG M0 instance MUST begin with
# one of the canonical HTTPS prefixes. An IRI that does NOT start with
# "https://" signals a broken/unresolved @context alias or a relative
# URL — both are forbidden.
#
# ALLOWED IRI prefixes (exhaustive):
#   Standard W3C / Dublin Core:
#     http://www.w3.org/1999/02/22-rdf-syntax-ns#   (rdf:)
#     http://www.w3.org/2002/07/owl#                 (owl:)
#     http://www.w3.org/2000/01/rdf-schema#          (rdfs:)
#     http://www.w3.org/2004/02/skos/core#           (skos:)
#     http://www.w3.org/ns/shacl#                    (sh:)
#     http://www.w3.org/2001/XMLSchema#              (xsd:)
#     http://purl.org/dc/terms/                      (dcterms:)
#   TSCG canonical base (all m0/m1/m2/m3 namespaces resolve here):
#     https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/
#   TSCG instances (m0.<instance>: namespace):
#     https://raw.githubusercontent.com/Echopraxium/tscg/main/instances/
#
# FORBIDDEN patterns (what this constraint detects):
#   ❌ "m1core:simulationTitle"     → @context alias unresolved
#   ❌ "M0_Poclet#epistemicGap"     → relative URL (missing base)
#   ❌ "M0_Vco.jsonld#A"            → relative filename (missing base)
#   ❌ "m0bmc:Block_VP"             → short alias (deprecated, use m0.bmc:)
#   ❌ "m1.ext:chemistry:Foo"       → dot-separated but non-canonical
#   ❌ Anything not starting with http:// or https://
#
# NOTE on dot separator convention for local namespaces:
#   Instance-local properties MUST use the pattern:
#     m0.<instanceName>:   →  resolves to instances/.../M0_<Name>.jsonld#
#   M1 extension properties MUST use:
#     m1.extension.<domain>:  →  resolves to ontology/M1_extensions/.../M1_<D>.jsonld#
#   These are @context ALIASES — the IRI they resolve to must be canonical HTTPS.
#   The alias name convention (dot separator) is enforced by documentation
#   and linting; SHACL enforces that the RESOLVED IRI is always canonical HTTPS.
# ============================================

m0:CanonicalNamespaceShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:severity sh:Violation ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "NAMESPACE VIOLATION (v1.4): Property IRI is not an absolute URL. This means an @context alias is unresolved (e.g. 'm1core:', 'm0bmc:') or a relative URL was used (e.g. 'M0_Poclet#foo', 'M0_Vco.jsonld#A'). Root causes: (1) m0: declared as relative 'M0_Poclet#' instead of absolute URL in @context; (2) alias not declared in @context at all; (3) @base missing or incorrect. Fix: declare ALL aliases with absolute HTTPS URLs in @context. Canonical prefixes: m0='.../M0_Poclet#', m1='.../M1_CoreConcepts.jsonld#', m1core='.../M1_CoreConcepts.jsonld#', m2='.../M2_GenericConcepts.jsonld#', m3='.../M3_GenesisGrammar.jsonld#'." ;
    sh:select """
      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      PREFIX owl:  <http://www.w3.org/2002/07/owl#>

      SELECT DISTINCT $this ?unresolved_property
      WHERE {
        $this rdf:type owl:Ontology .
        $this ?unresolved_property ?value .

        FILTER (
          # Reject any IRI that is not an absolute URL (no http:// or https://)
          !STRSTARTS(STR(?unresolved_property), "http://") &&
          !STRSTARTS(STR(?unresolved_property), "https://")
        )
      }
      LIMIT 5
    """
  ] .

# ── ADDITIONAL: detect m0: resolved to non-canonical base ──────────────
# When @context declares m0 with relative URL "M0_Poclet#" instead of
# the canonical absolute URL, rdflib emits the alias name literally.
# The constraint above catches this as a non-http IRI.
# BUT: some rdflib versions DO partially resolve relative @context URLs,
# producing IRIs like "M0_Poclet#epistemicGap" (still not absolute).
# The filter !STRSTARTS(..., "http") catches both cases.
#
# CANONICAL m0: MUST resolve to:
#   https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M0_Poclet#
# NOT: "M0_Poclet#" (relative) nor bare "m0:" (unresolved prefix)
#
# CANONICAL m0.<instance>: pattern (ALLOWED — these ARE absolute HTTPS IRIs):
#   https://raw.githubusercontent.com/Echopraxium/tscg/main/instances/...
#   resolved from @context alias: "m0.bmc": "instances/systemic-frameworks/Bmc/M0_Bmc.jsonld#"
#   with @base: "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/"
#   NOTE: The @base must be set so that relative instance paths resolve correctly.

# ============================================
# ADDITIONALLY: Detect relative-style IRIs that start with http://
# but reference non-canonical TSCG namespaces (e.g. obsolete repos)
# ============================================

m0:CanonicalTscgBaseShape
  a sh:NodeShape ;
  sh:targetClass owl:Ontology ;
  sh:severity sh:Warning ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "NAMESPACE WARNING (v1.4): TSCG property IRI references a non-canonical repository base. All TSCG-specific IRIs MUST use 'https://raw.githubusercontent.com/Echopraxium/tscg/main/' as base. Detected IRI uses an alternate path (old repo, local path, or incorrect branch). Fix: update @context to use canonical base URL." ;
    sh:select """
      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      PREFIX owl:  <http://www.w3.org/2002/07/owl#>

      SELECT DISTINCT $this ?non_canonical_property
      WHERE {
        $this rdf:type owl:Ontology .
        $this ?non_canonical_property ?value .

        # Detect TSCG-looking IRIs that don't use the canonical base
        FILTER (
          STRSTARTS(STR(?non_canonical_property), "https://") &&

          # Contains "echopraxium" or "tscg" but NOT the canonical path
          (
            CONTAINS(LCASE(STR(?non_canonical_property)), "echopraxium") ||
            CONTAINS(LCASE(STR(?non_canonical_property)), "tscg")
          ) &&

          # NOT the canonical base
          !STRSTARTS(
            STR(?non_canonical_property),
            "https://raw.githubusercontent.com/Echopraxium/tscg/main/"
          )
        )
      }
      LIMIT 5
    """
  ] .

# ============================================
# SUMMARY OF NAMESPACE VIOLATIONS DETECTED IN CORPUS (v1.4 audit)
# ============================================
# Files with unresolved @context aliases (m1core:, m0:, relative URLs):
#   FireTriangle       : m1core:simulationTitle, M0_Poclet#epistemicGap
#   ColorSynthesis     : m1core:simulationTitle + m0: unresolved props
#   Counterpoint       : M1_CoreConcepts.jsonld#simulationTitle (relative)
#   FourStrokeEngine   : M1_CoreConcepts.jsonld#simulationTitle (relative)
#   ExposureTriangle   : m1core:simulationTitle + m0: unresolved props
#   KindlebergerMinsky : M0_KindlebergerMinsky.jsonld#xxx (relative)
#   MtgColorWheel      : m1core:simulationTitle
#   NakamotoConsensus  : M0_Poclets.jsonld#xxx (wrong filename, relative)
#   Ptoe               : m1core:simulationTitle
#   Transistor         : m1core:simulationTitle
#   TrophicPyramid     : M1_CoreConcepts.jsonld#xxx (relative)
#   Vco                : M0_Vco.jsonld#A/S/F... (relative scores!)
#
# Root causes:
#   1. m1core: → not declared in @context with absolute URL
#      Fix: add "m1core": "https://.../M1_CoreConcepts.jsonld#" to @context
#      OR use m1:simulationTitle (m1: already declared with absolute URL)
#
#   2. M0_Xxx.jsonld#prop → @base not set, or @base set incorrectly
#      Fix: ensure "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/"
#      Then instance-local prefix becomes: "m0.<instance>": "instances/.../M0_X.jsonld#"
#
#   3. M0_Poclets.jsonld (NakamotoConsensus) → wrong source file referenced
#      Fix: update @context to reference M0_NakamotoConsensus.jsonld#
# ============================================
