@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m3: <M3_GenesisGrammar.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:SphinxEye> a owl:Ontology ;
    rdfs:label "Sphinx Eye - Map Grammar Gm" ;
    m3:ontologyCategory <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenesisExtension> ;
    dcterms:created "2026-01-21" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:description "Map Grammar Gm: free commutative monoidal grammar over primitive types {R, E, V, O, I}. Provides the epistemic/representational perspective on systems-as-map. Each primitive type instantiates at M0 as an evaluation functor F_x : System → [0,1]." ;
    dcterms:modified "2026-05-13" ;
    rdfs:comment "Map Grammar Gm: free commutative monoidal grammar over primitive types {R,E,V,O,I}. Provides the epistemic/representational perspective on systems-as-map. At M0, each primitive type instantiates as an evaluation functor F_x : System → [0,1]. Part of the TSCG bicephalous architecture (Gt + Gm). See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md." ;
    owl:imports "M3_GrammarFoundation.jsonld" ;
    owl:versionInfo "3.3.0" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:formerName> a owl:DatatypeProperty ;
    rdfs:label "Former Name (REVOI)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Previous name of the REVOI dimension before v3.0.0 simplification" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Historical dimension name using -ability suffix (e.g., Representability, Verifiability)" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:note> a owl:DatatypeProperty ;
    rdfs:label "Dimension Note (REVOI)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Additional clarifications or refinements to REVOI dimension interpretation" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Supplementary information about semantic evolution or interpretation details for REVOI dimensions" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:philosophicalInterpretation> a owl:DatatypeProperty ;
    rdfs:label "Philosophical Interpretation (REVOI)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Epistemological and philosophical meaning of the REVOI dimension in Map construction" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Description of how the REVOI dimension relates to knowledge construction, representation, and the Map-Territory distinction" ;
    skos:example "Representable → Expressibility, encodability, representational capacity" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:rangeProposed> a owl:DatatypeProperty ;
    rdfs:label "Range Proposed (REVOI)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Proposed measurement range and interpretation scale for REVOI Map quality dimension" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Normalized scale [0,1] with semantic anchors describing extreme and typical values for Map quality assessment" ;
    skos:example "Verifiable: [0,1] where 0=unfalsifiable, 1=completely testable" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#sphinx_eye:renameRationale> a owl:DatatypeProperty ;
    rdfs:label "Rename Rationale (REVOI)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Explanation for REVOI dimension name change in v3.0.0" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Justification for simplifying from abstract noun to adjective form" .

