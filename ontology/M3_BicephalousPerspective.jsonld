{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "@vocab": "http://www.w3.org/2002/07/owl#",
    "dcterms": "http://purl.org/dc/terms/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "m3": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:bicephalous:BicephalousPerspective",
      "@type": "owl:Ontology",
      "owl:versionInfo": "1.4.0",
      "dcterms:created": "2026-05-18",
      "dcterms:modified": "2026-07-22",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:title": "TSCG M3 Stereopsis Grammar — Bicephalous Perspective",
      "dcterms:description": "Reification of the stereopsic synergy between Territory Grammar (Gt / Eagle Eye) and Map Grammar (Gm / Sphinx Eye). Defines the Stereopsis Grammar Gs with operator | and the Base16 Gs alphabet: 6 primitives — T (Temporality), _^ (PositivePole), _$ (NegativePole), K (Knowledge), Ss (Symbol/Stereopsic), L (Localizability). TKSL acronym for the 4 nominal Gs primitives. Each Gs primitive is an irreducible inter-grammar mediator — not derivable from ASFID (Gt) or REVOI (Gm). v1.3.0: EquilibriumPole (_0 = _^ | _$) added as named derived Gs element (m3:DerivedGsElement) — not a primitive, Base16 preserved.",
      "rdfs:label": "M3 Bicephalous Perspective — Stereopsis Grammar Gs",
      "rdfs:comment": "Third grammar of the TSCG tricephalous architecture. Gs formalizes what the Eagle Eye and Sphinx Eye produce together — the stereopsic depth born from their binocular fusion. 𝕋₀(|) = {T, _^, _$, K, Ss, L} — 6 primitives. Operator: | (stereopsic fusion, inter-grammar).",
      "grammar_properties": {
        "grammar_name": "Stereopsis Grammar Gs",
        "grammar_type": "free_monoidal",
        "acronym": "TKSL",
        "acronym_note": "TKSL = T (Temporality), K (Knowledge), Ss (Symbol/Stereopsic), L (Localizability). Poles _^/_$ are polarity modifiers, not nominal primitives.",
        "primitives": [
          "Temporality",
          "PositivePole",
          "NegativePole",
          "Knowledge",
          "Symbol",
          "Localizability"
        ],
        "primitives_count": 6,
        "primitives_symbols_note": "Symbolic notation: T (Temporality), _^ (PositivePole), _$ (NegativePole), K (Knowledge), Ss (Symbol/Stereopsic — subscript s to distinguish from St/Structure/Territory), L (Localizability). _^ and _$ are string notations only — not URIs.",
        "product": "|",
        "neutral": "m3:bicephalous:StereopsisEmptySet",
        "primitive_role": "Gs type generators — inter-grammar relational types between Territory and Map",
        "perspective": "bicephalous / relational",
        "independence": "verified — T, _^, _$ pre-existing; K, Ss, L independently validated (≥6 unrelated domains each). None of the 6 primitives is derivable from ASFID or REVOI.",
        "mathematical_foundation": "Lambek Calculus / free monoidal category — third grammar Gs — free extension over {T, _^, _$, K, Ss, L}",
        "operator": "| (Stereopsic fusion — inter-grammar)",
        "neutral_element": "m3:bicephalous:StereopsisEmptySet",
        "neutral_element_label": "Stereopsis Empty Set (neutral of |)",
        "neutral_element_semantic": "Divergent Strabismus — EmptyTerritory | EmptyMap",
        "transcendental_questions": {
          "T": "When?",
          "K": "What?",
          "Ss": "Sign?",
          "L": "Converging?"
        },
        "transcendental_questions_note": "4 of the 6 Gs primitives answer transcendental questions about the Territory/Map correspondence. The poles _^/_$ encode polarity (onset/terminus) rather than answering a transcendental question.",
        "asymmetry_justification": "5-5-6 asymmetry: Gs carries 6 primitives vs 5 for Gt and Gm. This is semantically justified — Gs is the inter-grammar axis by nature; the 6th primitive L (Localizability) encodes convergence discrimination that requires both Gt (Attractor A) and Gm (Map representation) to make sense.",
        "derived_elements": {
          "description": "Named derived elements of Gs — not primitives, Base16 preserved",
          "elements": [
            {
              "symbol": "_0",
              "name": "EquilibriumPole",
              "definition": "_^ | _$",
              "semantics": "The optimal central state — fusion of PositivePole and NegativePole. Encodes the equilibrium optimum in a triadic balance.",
              "analogy": "As StereopsisEmptySet = EmptyTerritory | EmptyMap is the neutral element, _0 = _^ | _$ is the equilibrium element",
              "usage": "TriadicBalance | _0 (optimal state), Balance | _0 (equilibrium point)"
            }
          ]
        }
      },
      "associativity": {
        "property": "| is associative: (a | b) | c = a | (b | c)",
        "consequence": "Parentheses optional for chained |. Left-associative by convention.",
        "pole_pattern_positive": "expr | _^   e.g. A × St × It | R + O | _^  = Coherence",
        "pole_pattern_negative": "expr | _$   e.g. A × St × It | R + O | _$  = Incoherence"
      },
      "notation_convention": {
        "rule": "In hybrid formulas (formulas containing |), Territory and Map types carry their monoid index to prevent ambiguity with new Gs type Ss.",
        "territory_index": "It = Information (Territory), St = Structure (Territory)",
        "map_index": "O = Observability (Map)",
        "scope": "Only in hybrid formulas. Pure intra-monoid formulas (e.g. A × S × F) and ASFID/REVOI scoring terminology are unaffected.",
        "rationale": "Ss (Symbol/Gs) could be confused with S (Structure/Territory) in mixed formulas. Indexing eliminates the ambiguity without changing the semantics of pure-monoid formulas."
      },
      "parent_ontology": {
        "@id": "m3:genesis_space:GenesisGrammar",
        "relationship": "component_of"
      },
      "complementary_grammars": {
        "territory": "M3_EagleEye.jsonld — Gt, ASFID, ×",
        "map": "M3_SphinxEye.jsonld — Gm, REVOI, +",
        "architecture": "TSCG Bicephalous = Gt + Gm — Gs is reification of stereopsic synergy"
      },
      "m3:changelog": [
        {
          "version": "1.4.0",
          "date": "2026-07-22",
          "changes": "VOC/B1: declared 19 previously-undeclared m3:* documentation properties used in this file (role, semantics, symbol, grammar, visual, usage, derivation, formula_role, independence, analogyInGt, analogyInGs, pairWith, triadicPattern, theoretical_basis, transcendentalQuestion, openQuestion, rejected_names, notation_note, notation_disambiguation) as owl:AnnotationProperty. Declaration only — no usage or data changed. HELD for separate decisions: definition/examples (Family-A standard candidates skos:definition/skos:example), epistemicGap (δ₁ measurement, SC-6 sensitivity). EXCLUDED: typeSymbol/typeIndex (already defined in M3_GenesisGrammar). FLAGGED: pairWith carries a string where an @id is expected (latent reference defect)."
        },
        {
          "version": "1.3.2",
          "date": "2026-07-22",
          "changes": "LAYERING FIX: m2:changelog → m3:changelog. An M3 file must not reference an M2 property (dependency inversion: M3 is the foundational layer, M2 imports it). Compounding this, the 'm2' prefix was NOT declared in this @context (CTX-1), so the key resolved to an opaque 'm2:' URI scheme instead of the M2 namespace — invisible to any reasoner. m3:changelog is defined in M3_GrammarFoundation v2.5.0."
        },
        {
          "version": "1.3.1",
          "date": "2026-07-18",
          "changes": "@context hygiene fix (CTX): 'm3' prefix made ABSOLUTE (https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#). It was relative and, combined with @vocab=owl#, resolved m3:* terms (incl. MonoidalType) against owl# instead of the M3 namespace — desynchronising this file's IRIs from EagleEye/SphinxEye. Data graph unchanged."
        },
        {
          "version": "1.3.0",
          "date": "2026-06-23",
          "changes": "DERIVED ELEMENT: EquilibriumPole (_0 = _^ | _$) added as m3:DerivedGsElement. Named constant of Gs monoide — not a primitive. Base16 preserved (6 primitives unchanged). Introduced to support m2:TriadicBalance and m2:Balance revision. DerivedGsElement class added."
        },
        {
          "version": "1.2.0",
          "date": "2026-05-27",
          "changes": "BASE16 EXTENSION: Three new Gs primitives added — K (Knowledge, idx 3), Ss (Symbol/Stereopsic, idx 4), L (Localizability, idx 5). TKSL acronym introduced for 4 nominal Gs primitives. Transcendental questions map updated: {T: When?, K: What?, Ss: Sign?, L: Converging?}. 5-5-6 asymmetry documented. Notation convention added: St/It/O indexation in hybrid formulas."
        },
        {
          "version": "1.1.0",
          "date": "2026-05-20",
          "changes": "Added PositivePole (_^) and NegativePole (_$) as Gs type primitives. typeSymbol and typeIndex (not dimensionSymbol/dimensionIndex). Symbols _^ and _$ are string notations only — not URIs."
        }
      ]
    },
    {
      "@id": "m3:bicephalous:typeT",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Temporality (T)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "T",
      "m3:typeIndex": 0,
      "m3:grammar": "Gs",
      "m3:transcendentalQuestion": "When?",
      "skos:definition": "Pure Temporality — the temporal interface that emerges from the fusion of Territory time (as flow/evolution: F, D) and Map time (as synchronisation/interoperability: Im). T captures what is relational in time — not what a system does in time (F, D) nor how a model qualifies time (Im) but how Territory and Map correspond temporally.",
      "rdfs:comment": "First primitive of 𝕋₀(|). T is irreducible — not derivable from F, D, or Im. Manifests as: F|Im (flux temporality seen through interoperability), D|Im (dynamic temporality seen through interoperability). These are manifestations of T, not its definition.",
      "m3:independence": "T cannot be derived from ASFID or REVOI — genuinely new ontological category.",
      "m3:examples": [
        "Musical rhythm (time as relational: tempo, meter, syncopation)",
        "Biological circadian cycles (time as Territory/Map alignment)",
        "Network synchronisation protocols (time as inter-grammar coordination)",
        "Historical periodization (time as Territory/Map correspondence)",
        "Phase transitions in physics (time as critical point correspondence)",
        "Developmental timing in embryology (time as positional-genetic correspondence)"
      ],
      "dcterms:created": "2026-05-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:PositivePole",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Positive Pole (_^)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "_^",
      "m3:typeIndex": 1,
      "m3:grammar": "Gs",
      "m3:role": "polarity_modifier",
      "skos:definition": "Positive pole primitive of 𝕋₀(|). Applied as suffix: formula | _^. Marks the onset/amplifying/constructive pole of a GenericConcept pair. Replaces former ^op notation.",
      "rdfs:comment": "String notation _^ only — not a URI. OWL identifier: m3:bicephalous:PositivePole. Used in: A × St × It | R + O | _^ = Coherence (positive pole).",
      "m3:pairWith": "m3:bicephalous:NegativePole",
      "m3:notation_note": "_^ is a STRING NOTATION used in formula values only — never an OWL/RDF URI.",
      "dcterms:created": "2026-05-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:NegativePole",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Negative Pole (_$)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "_$",
      "m3:typeIndex": 2,
      "m3:grammar": "Gs",
      "m3:role": "polarity_modifier",
      "skos:definition": "Negative pole primitive of 𝕋₀(|). Applied as suffix: formula | _$. Marks the terminus/attenuating/destructive pole of a GenericConcept pair. Replaces former ^op notation.",
      "rdfs:comment": "String notation _$ only — not a URI. OWL identifier: m3:bicephalous:NegativePole. Used in: A × St × It | R + O | _$ = Incoherence (negative pole).",
      "m3:pairWith": "m3:bicephalous:PositivePole",
      "m3:notation_note": "_$ is a STRING NOTATION used in formula values only — never an OWL/RDF URI.",
      "dcterms:created": "2026-05-20",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:typeK",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Knowledge (K)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "K",
      "m3:typeIndex": 3,
      "m3:grammar": "Gs",
      "m3:transcendentalQuestion": "What?",
      "skos:definition": "Cognitive interface — contextualisation of raw Information (It, Territory) into meaning. K is the Gs primitive that mediates between Territory observations and Map interpretations by anchoring them in a cognitive/contextual frame. Not the information itself (It) nor its representation (R/E), but the cognitive act of making It meaningful within a Map context.",
      "rdfs:comment": "Fourth primitive of 𝕋₀(|). K is irreducible — not derivable from It (Territory) nor from R/E (Map). It answers 'What does this mean?' — the contextualisation question. Theoretical basis: cognitive science (Maturana/Varela — cognition as enaction), phenomenology (Husserl — intentionality), semiotics (Peirce — interpretant).",
      "m3:independence": "K cannot be derived from ASFID or REVOI. It (Territory) is raw data; R (Representability/Map) is model quality; K is neither — it is the cognitive bridge that transforms It into meaning.",
      "m3:theoretical_basis": [
        "Maturana & Varela (1987) — cognition as enaction: knowing = doing in a domain",
        "Husserl — intentionality: every act of knowledge is directed at an object (meaning)",
        "Peirce — interpretant: the sign produces a meaning in a mind",
        "Bateson (1972) — 'a difference that makes a difference' — K as discriminative contextualisation"
      ],
      "m3:examples": [
        "Immune system (antigen recognition = contextualisation of molecular It into 'self/non-self')",
        "Natural language processing (tokenisation = raw signal It → semantic unit K)",
        "Scientific paradigm (Kuhn: raw observations It → theory-laden K within a paradigm)",
        "Musical perception (sound waves It → melodic pattern K within tonal context)",
        "Legal interpretation (statute text It → legal meaning K within jurisdictional context)",
        "Medical diagnosis (symptom It → clinical meaning K within nosological framework)"
      ],
      "m3:formula_role": "K appears in hybrid formulas as inter-grammar contextualisation: It | K = contextualised information. Role | K = role within knowledge context. Agent = St × It × D | K (agent = structured + informed + dynamic + knowing context).",
      "dcterms:created": "2026-05-27",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:typeSs",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Symbol — Stereopsic (Ss)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "Ss",
      "m3:typeIndex": 4,
      "m3:grammar": "Gs",
      "m3:transcendentalQuestion": "Sign?",
      "m3:notation_disambiguation": "Ss (subscript s = Stereopsic) distinguishes from St (Structure/Territory, subscript t = Territory). In pure intra-Territory formulas, S remains unindexed (ASFID convention). In hybrid formulas containing |, use St for Structure and Ss for Symbol.",
      "skos:definition": "Semiotic interface — the sign-relation between signifier (Territory/Gt) and signified (Map/Gm). Ss is the Gs primitive that formalises the Peircean sign: a Territory entity (signifier) stands for a Map meaning (signified) for an interpreter. Not the structure itself (St) nor the representation (R), but the semiotic bridge that links them.",
      "rdfs:comment": "Fifth primitive of 𝕋₀(|). Ss is irreducible — not derivable from St (Territory structure) nor from R (Map representability). It answers 'What is the sign for?' — the semiotic question. Theoretical basis: Peirce (sign = signifier + signified + interpretant), Saussure (signifier/signified), Eco (semiotics of culture).",
      "m3:independence": "Ss cannot be derived from St or R. St (Territory) is physical/structural organisation; R (Map) is representational quality; Ss is neither — it is the semiotic bridge that makes St carry Gm meaning.",
      "m3:theoretical_basis": [
        "Peirce — sign: 'something that stands for something else in some respect or capacity'",
        "Saussure — signifier (acoustic image) ↔ signified (concept): arbitrary but systematic",
        "Eco (1976) — A Theory of Semiotics: sign as social/cultural convention",
        "Morris (1938) — semiotics: syntactics (signs ↔ signs), semantics (signs ↔ objects), pragmatics (signs ↔ interpreters)"
      ],
      "m3:examples": [
        "Natural language (words St = signifiers ↔ concepts Gm = signified)",
        "Musical notation (note symbols St ↔ sonic events Gm — semiotic convention)",
        "Mathematical notation (symbol St ↔ mathematical object Gm)",
        "DNA genetic code (codon St ↔ amino acid Gm — biochemical semiosis)",
        "Traffic signs (sign St ↔ traffic rule Gm — social convention)",
        "Computer code (token St ↔ computational operation Gm)"
      ],
      "m3:formula_role": "Ss appears in hybrid formulas as semiotic mediation: St × Ss = relation (structural pair with semiotic link). Language = Ss × F | K (symbol-flow with knowledge context). Code = It × Ss (information encoded as symbol).",
      "dcterms:created": "2026-05-27",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:typeL",
      "@type": [
        "owl:Class",
        "m3:MonoidalType"
      ],
      "rdfs:label": "Localizability (L)",
      "rdfs:subClassOf": {
        "@id": "m3:MonoidalType"
      },
      "m3:typeSymbol": "L",
      "m3:typeIndex": 5,
      "m3:grammar": "Gs",
      "m3:transcendentalQuestion": "Converging?",
      "skos:definition": "Cybernetic interface — ordinal discrimination of convergence direction toward an Attractor (A) by successive state comparison. L answers whether the current trajectory is converging or diverging relative to the Attractor, without requiring a metric. Pure ordinal: closer/farther, not 'how much closer'. Based on Wiener (1948) negative feedback and Ashby (1956) regulation principle.",
      "rdfs:comment": "Sixth primitive of 𝕋₀(|). L is irreducible — not derivable from A (Territory Attractor) nor from V (Map Verifiability). It answers 'Is the system converging toward its Attractor?' — the cybernetic question. Key distinction: L is ordinal (no metric), purely discriminative (converging vs diverging).",
      "m3:independence": "L cannot be derived from A (Territory) or V (Map). A defines the goal state; V verifies the model; L is neither — it is the cybernetic bridge that compares successive Territory states against the Map-defined Attractor to discriminate direction.",
      "m3:rejected_names": {
        "Groundedness": "Rejected — risks Hilbert-space trap (ground state = lowest energy level in QM)",
        "Origin": "Rejected — suggests metric/spatial notion (distance from origin), contradicts ordinal-only constraint"
      },
      "m3:theoretical_basis": [
        "Wiener, N. (1948). Cybernetics: Or Control and Communication in the Animal and the Machine. MIT Press.",
        "Ashby, W.R. (1956). An Introduction to Cybernetics. Chapman & Hall.",
        "Conant & Ashby (1970) — Every Good Regulator of a System Must be a Model of that System: regulation requires Territory/Map comparison",
        "Powers, W.T. (1973) — Behavior: The Control of Perception: control = comparison of perceived state vs reference"
      ],
      "m3:examples": [
        "Thermostat (temperature state compared to setpoint — converging/diverging, no metric needed)",
        "Immune response (inflammation converging toward homeostasis A — ordinal, not quantified)",
        "Economic regulation (Wicksell rate — convergence toward equilibrium, no exact measure)",
        "Evolutionary fitness landscape (population trajectory — converging toward fitness peak A)",
        "Neural reinforcement learning (reward signal — converging toward policy optimum A)",
        "Navigation (bearing correction — converging toward destination A without knowing exact distance)"
      ],
      "m3:formula_role": "L appears in hybrid formulas as convergence discrimination: St | L = topology (structure with convergence context). Homeostasis = A × St × F | L (attractor + structure + flow, discriminated by convergence). Bifurcation = D × F | L (dynamics + flow at convergence boundary). Node/Component = St × It | L.",
      "dcterms:created": "2026-05-27",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:StereopsisEmptySet",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Stereopsis Empty Set",
      "rdfs:comment": "Neutral element of |. Defined as EmptyTerritory | EmptyMap. x | StereopsisEmptySet = x for all x. Divergent Strabismus — Territory and Map share nothing. δ₁ = max.",
      "m3:grammar": "Gs",
      "m3:role": "neutral_element",
      "m3:definition": "EmptyTerritory | EmptyMap",
      "m3:visual": "Black + Empty pentagon — absence of all Territory and Map types",
      "m3:epistemicGap": "δ₁ = max",
      "m3:semantics": "Divergent Strabismus — Territory and Map share nothing. Opposite of StereopsisUniversalSet.",
      "dcterms:created": "2026-05-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:DerivedGsElement",
      "@type": "owl:Class",
      "rdfs:label": "Derived Gs Element",
      "rdfs:subClassOf": {
        "@id": "owl:Thing"
      },
      "rdfs:comment": "A named element of the Gs monoide that is derivable from primitives of 𝕋₀(|) via the | operator. DerivedGsElements are NOT primitives — they do not extend Base16. They are named constants or expressions that appear frequently enough to deserve a canonical symbol. Analogous to named expressions in Gt (e.g. F × D = m2:Process) but at the M3 level.",
      "skos:note": "Base16 is preserved when adding DerivedGsElements. Only additions to 𝕋₀(|) would extend the Base count.",
      "dcterms:created": "2026-06-23",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
    {
      "@id": "m3:bicephalous:EquilibriumPole",
      "@type": [
        "owl:NamedIndividual",
        "m3:bicephalous:DerivedGsElement"
      ],
      "rdfs:label": "Equilibrium Pole (_0)",
      "rdfs:comment": "Named derived element of Gs — the equilibrium pole, fusion of PositivePole and NegativePole. Encodes the optimal central state in a triadic balance: neither excess (_^) nor deficit (_$) but their stereopsic fusion. Not a primitive of 𝕋₀(|) — Base16 is preserved.",
      "m3:symbol": "_0",
      "m3:grammar": "Gs",
      "m3:role": "derived_equilibrium_constant",
      "m3:definition": "_^ | _$",
      "m3:derivation": {
        "operator": "|",
        "operands": [
          "_^  (PositivePole)",
          "_$  (NegativePole)"
        ],
        "result": "_0  (EquilibriumPole)",
        "algebraic_note": "Associativity of | ensures (_^ | _$) is well-defined in the free monoide Gs"
      },
      "m3:semantics": "The stereopsic fusion of the two poles produces their synthesis — not their average (quantitative) but their qualitative resolution (optimal calibration). Territory excess (_^) and Territory deficit (_$) fuse into Map-Territory correspondence (_0).",
      "m3:analogyInGs": "As StereopsisEmptySet = EmptyTerritory | EmptyMap is the neutral element of |, _0 = _^ | _$ is the equilibrium element — the point of optimal Territory/Map calibration.",
      "m3:analogyInGt": "As F × D names m2:Process (a frequently used derived expression in Gt), _^ | _$ names _0 (a frequently used derived expression in Gs).",
      "m3:usage": [
        "m2:Balance = A × S × F | _0  (static equilibrium state)",
        "m2:TriadicBalance | _0  (optimal central state of a triadic system)",
        "m1:ConstraintBalance | _0  (BalancedConstraint — neither over nor under)"
      ],
      "m3:triadicPattern": {
        "underPole": "_^  — excess of openness / under-constraint",
        "equilibriumPole": "_0  — optimal calibration (_^ | _$)",
        "overPole": "_$  — excess of closure / over-constraint"
      },
      "m3:openQuestion": {
        "question": "Does _0 require a new Gs primitive (C=Calibration, As=Adjustment, N=Normativity) to fully encode the degree of Territory/Map fit?",
        "status": "Deferred — _0 as derived element is sufficient for current corpus. Base16→Base17 transition requires broader validation.",
        "resolution": "Best current answer — revisit when ≥3 M0 poclets demonstrate insufficiency of _0 as derived element."
      },
      "dcterms:created": "2026-06-23",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI"
    },
      {
        "@id": "m3:role",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "role",
        "rdfs:comment": "Documentary label for the functional role a primitive plays in a formula (e.g. 'polarity_modifier'). TSCG-native: distinct from prov:hadRole (role of an agent in an activity), verified 2026-07-22 — foreign ontology, not reused.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:semantics",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "semantics",
        "rdfs:comment": "Prose gloss of the semantic reading of a type or degenerate configuration (e.g. 'Divergent Strabismus — Territory and Map share nothing').",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:symbol",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "symbol",
        "rdfs:comment": "The string notation of a primitive or derived element as it appears in formula values (e.g. '_0'). Notation only — never an OWL/RDF URI (see notation_note).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:grammar",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "grammar",
        "rdfs:comment": "Names which of the three monoidal grammars a type belongs to (Gt, Gm, Gs).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:visual",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "visual",
        "rdfs:comment": "Documentary description of the visual/glyph rendering of a type (e.g. 'Black + Empty pentagon').",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:usage",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "usage",
        "rdfs:comment": "List of attested formula-level usages of an element across the corpus (e.g. 'm2:Balance = A × S × F | _0').",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:derivation",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "derivation",
        "rdfs:comment": "Structured record of how a derived Gs element is obtained from primitives via a monoidal operator (operator / operands / result).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:formula_role",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "formula_role",
        "rdfs:comment": "Explains how a primitive behaves inside hybrid inter-grammar formulas (e.g. K as inter-grammar contextualisation).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:independence",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "independence",
        "rdfs:comment": "Justification that a primitive is genuinely irreducible — not derivable from the other grammars' primitives.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:analogyInGt",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "analogyInGt",
        "rdfs:comment": "Cross-grammar analogy expressed in the Territory grammar Gt, used to motivate a Gs construction by parallel with a known Gt expression.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:analogyInGs",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "analogyInGs",
        "rdfs:comment": "Cross-grammar analogy expressed in the Stereopsis grammar Gs, parallel to analogyInGt.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:pairWith",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "pairWith",
        "rdfs:comment": "Links a pole to its complementary pole. NOTE: currently carries a string ('m3:bicephalous:NegativePole') where an @id reference is expected — flagged as a latent reference defect (VOC/STR), declared here as AnnotationProperty pending a decision to promote it to owl:ObjectProperty.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:triadicPattern",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "triadicPattern",
        "rdfs:comment": "Structured description of an under-pole / equilibrium-pole / over-pole triad for a Gs polarity axis.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:theoretical_basis",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "theoretical_basis",
        "rdfs:comment": "List of external scholarly references grounding a construction (e.g. Maturana & Varela, Husserl).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:transcendentalQuestion",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "transcendentalQuestion",
        "rdfs:comment": "The Kantian-style category question a primitive answers (e.g. 'When?' for T).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:openQuestion",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "openQuestion",
        "rdfs:comment": "Structured record of an unresolved design question, with its status and provisional resolution.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:rejected_names",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "rejected_names",
        "rdfs:comment": "Structured record of candidate names that were considered and rejected for a concept, with the rejection rationale.",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:notation_note",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "notation_note",
        "rdfs:comment": "Clarification about notation conventions (e.g. that a pole string is used in formula values only, never as a URI).",
        "dcterms:created": "2026-07-22"
      },
      {
        "@id": "m3:notation_disambiguation",
        "@type": "owl:AnnotationProperty",
        "rdfs:label": "notation_disambiguation",
        "rdfs:comment": "Disambiguation rule for potentially colliding primitive notations (e.g. Ss vs St). NOTE: the value of this property is the target of SC-2, which revises the S/I subscription rule; SC-2 changes the VALUE, not this declaration.",
        "dcterms:created": "2026-07-22"
      }
  ]
}
