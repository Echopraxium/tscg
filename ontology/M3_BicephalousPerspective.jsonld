    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:bicephalous:BicephalousPerspective",
      "@type": "owl:Ontology",
      "owl:versionInfo": "1.0.0",
      "dcterms:created": "2026-05-18",
      "dcterms:modified": "2026-05-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:title": "TSCG M3 Bicephalous Perspective Grammar Gs",
      "dcterms:description": "Reification of stereopsic synergy (Bicephalous Perspective) — the synergy that emerges from the fusion of Eagle Eye (Territory/ASFID) and Sphinx Eye (Map/REVOI). The bicephalous architecture remains the foundational metaphor (two eyes, two perspectives). Stereopsis is the depth perception that arises from their fusion. This grammar formalizes that synergy as a first-class algebraic structure: the bicephalous monoid (Gs, |, EmptyStereopsis) with its own primitive alphabet {T}. T (Temporality) is the first primitive type to emerge from this reification. Further primitives will emerge from poclet corpus analysis.",
      "owl:imports": [
        "M3_GrammarFoundation.jsonld",
        "M3_EagleEye.jsonld",
        "M3_SphinxEye.jsonld"
      ],
      "rdfs:label": "Bicephalous Perspective - Stereopsis Grammar Gs",
      "rdfs:comment": "Reification of the stereopsic synergy between Eagle Eye (Territory Grammar Gt / ASFID) and Sphinx Eye (Map Grammar Gm / REVOI). The TSCG architecture remains bicephalous — two eyes, two perspectives. Stereopsis is the emergent synergy of their fusion. This ontology gives that synergy a formal algebraic existence: an operator (|), a neutral element (EmptyStereopsis), and a primitive alphabet ({T}). T (Temporality) is its first primitive. Part of the TSCG bicephalous architecture: Gt (Territory) + Gm (Map), with Gs as the reification of their stereopsic fusion.",
      "metadata": {
        "layer": "M3",
        "name": "Bicephalous Perspective Grammar Gs",
        "version": "1.0.0",
        "architecture": "bicephalous — third grammar of the TSCG system",
        "date_created": "2026-05-18",
        "date_modified": "2026-05-18",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "description": "Reification of stereopsis — the synergy produced by the bicephalous fusion of Territory (Eagle Eye / ASFID) and Map (Sphinx Eye / REVOI)",
        "changelog": {
          "v1.0.0": "Initial creation. Declares Stereopsis Grammar Gs with T (Temporality) as first bicephalous primitive. Closes the structural gap of the bicephalous monoid (|) having no proper alphabet. See StructuralGrammar_MonoidalOperators_README.md and PotentialRefinements_MonoidalOperators.md."
        }
      },
      "grammar_properties": {
        "grammar_name": "Stereopsis Grammar Gs",
        "grammar_type": "free_monoidal",
        "primitives": [
          "T"
        ],
        "product": "|  (stereopsic fusion — bicephalous structural operator)",
        "primitive_role": "generators of bicephalous type expressions — types that emerge from the Territory↔Map enrichment loop (Φ/Ψ)",
        "perspective": "bicephalous / relational",
        "independence": "verified — T is not derivable from ASFID or REVOI primitives alone",
        "mathematical_foundation": "Lambek Calculus / free monoidal categories — third grammar alongside Gt and Gm"
      },
      "architectural_position": {
        "description": "Gs is the reification of stereopsis — the formal algebraic structure that emerges from the mutual enrichment loop (Φ/Ψ) between Territory Grammar Gt and Map Grammar Gm. The TSCG architecture remains bicephalous (Eagle Eye + Sphinx Eye). Gs does not add a third head — it formalizes what the two heads produce together.",
        "enrichment_loop": {
          "Phi": "Φ : Gt → Gm  (observation: Territory measurements inform Map construction)",
          "Psi": "Ψ : Gm → Gt  (interpretation: Map predictions guide Territory measurement)",
          "Gs": "Gs emerges from the Φ/Ψ loop — types that exist in the correspondence between Territory and Map, not in either alone"
        },
        "metaphor": {
          "eagle_eye": "Eagle Eye sees the Territory (ASFID — colors)",
          "sphinx_eye": "Sphinx Eye sees the Map (REVOI — shapes)",
          "stereopsis": "Stereopsis fuses both eyes into depth perception — Gs captures what this fusion creates"
        },
        "dichotomy_reinforced": "The Territory/Map dichotomy with mutual enrichment loop (Φ/Ψ) now has three proper ontological levels: what systems ARE (Gt), how models QUALIFY (Gm), and how Territory and Map CORRESPOND (Gs)."
      },
      "parent_ontology": {
        "@id": "m3:genesis_space:GenesisGrammar",
        "relationship": "component_of",
        "description": "Stereopsis Grammar is the bicephalous component of M3 Genesis Space, providing the relational perspective on systems"
      },
      "complementary_grammars": {
        "territory": {
          "@id": "m3:eagle_eye:EagleEye",
          "description": "Territory Grammar Gt over {A, S, F, I, D}",
          "product": "×"
        },
        "map": {
          "@id": "m3:sphinx_eye:SphinxEye",
          "description": "Map Grammar Gm over {R, E, V, O, Im}",
          "product": "+"
        },
        "complete_architecture": "TSCG Bicephalous Architecture = Gt (Territory) + Gm (Map) — Gs is the reification of their stereopsic synergy, not a third head"
      },
      "independence_note": {
        "description": "Gs primitive types are analytically independent from both Gt and Gm primitives. A bicephalous primitive T is not derivable from any combination of ASFID or REVOI types — it is a new ontological category.",
        "key_insight": "T (Temporality) does NOT need to be 'extracted' from F or D via F|Im or D|Im. T is primitive — F|Im and D|Im are manifestations of T in their respective contexts, not its definition. This mirrors how A (Attractor) is primitive in Gt — A is not defined by other ASFID types; it manifests in thermostats, basins of attraction, homeostatic setpoints."
      },
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-05-18",
          "changes": "Initial release. Stereopsis Grammar Gs declared with T (Temporality) as first bicephalous primitive type. Closes structural gap in the monoidal operator system."
        }
      ]
    },
    {
      "@id": "m3:stereopsis:Temporality",
      "@type": [
        "owl:NamedIndividual",
        "m3:M3Dimension"
      ],
      "rdfs:label": "Temporality",
      "m3:dimensionSymbol": "T",
      "m3:dimensionIndex": 1,
      "rdfs:comment": "First primitive type of the Stereopsis Grammar Gs. Represents pure temporality — the temporal interface that emerges from the fusion of Territory (time as flow/evolution) and Map (time as synchronisation/interoperability). T is irreducible: it cannot be decomposed into ASFID or REVOI types. F|Im and D|Im are manifestations of T in their respective contexts, not its definition.",
      "skos:definition": "A primitive bicephalous type representing the temporal correspondence between Territory and Map. T captures what is common to Flow-time (F) and Dynamics-time (D) as seen from the Map perspective — pure synchronisation, temporal interface, the relational aspect of time that binds Territory observations to Map representations.",
      "m3:stereopsis:physicalInterpretation": "The temporal interface between a system's observable flux/evolution (Territory) and its representational synchronisation (Map). Examples: rhythm as the T-dimension of music, clocking as the T-dimension of digital circuits, circadian cycle as the T-dimension of biological systems.",
      "m3:stereopsis:rangeAnalog": "qualitative spectrum: minimal=atemporal (static, frozen correspondence), maximal=fully synchronised (Territory and Map evolve in perfect temporal lockstep)",
      "m3:stereopsis:manifestations": {
        "as_territory_expression": "F | Im  (flux temporality seen through interoperability lens)",
        "as_map_expression": "D | Im  (dynamic temporality seen through interoperability lens)",
        "note": "These are manifestations of T, not definitions. T is primitive and irreducible."
      },
      "m3:stereopsis:consequence_for_gradient": {
        "preferred_formula": "F × T   or   I × T",
        "current_approximation": "F × D   or   I × D",
        "rationale": "F × T isolates temporal gradient precisely; F × D includes full Dynamics dimension which is broader than pure temporality"
      },
      "m3:dimensionExamples": [
        "Music — rhythm (T): the temporal interface between sound flux (F) and listener synchronisation (Im)",
        "Digital circuits — clock signal (T): temporal coordination between data flow (F) and system interoperability (Im)",
        "Biology — circadian rhythm (T): temporal binding between metabolic dynamics (D) and inter-cellular synchronisation (Im)",
        "Distributed systems — consensus timing (T): temporal alignment between state evolution (D) and node interoperability (Im)",
        "Physics — period of oscillation (T): the temporal interface between energy flux (F) and measurement synchronisation (Im)"
      ]
    },
    {
      "@id": "m3:stereopsis:physicalInterpretation",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Physical Interpretation (Bicephalous)",
      "rdfs:comment": "Concrete manifestations or analogues of a Stereopsis Grammar primitive type — examples showing how the type appears as a relational phenomenon between Territory and Map.",
      "rdfs:domain": {
        "@id": "m3:M3Dimension"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "dcterms:created": "2026-05-18"
    },
    {
      "@id": "m3:stereopsis:rangeAnalog",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Qualitative Range (Bicephalous)",
      "rdfs:comment": "Qualitative structural domain of a Stereopsis Grammar primitive — expressed as a relational spectrum between minimal and maximal correspondence.",
      "rdfs:domain": {
        "@id": "m3:M3Dimension"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "dcterms:created": "2026-05-18"
    },
    {
      "@id": "m3:stereopsis:manifestations",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "Manifestations (Bicephalous)",
      "rdfs:comment": "Documents how a bicephalous primitive type manifests as expressions in Territory and Map contexts. Manifestations are not definitions — the primitive is irreducible.",
      "rdfs:domain": {
        "@id": "m3:M3Dimension"
      },
      "dcterms:created": "2026-05-18"
    }
  ]
}