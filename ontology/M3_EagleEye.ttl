@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m3: <M3_GenesisGrammar.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#eagle_eye:EagleEye> a owl:Ontology ;
    rdfs:label "Eagle Eye - Territory Grammar Gt" ;
    m3:ontologyCategory <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenesisExtension> ;
    dcterms:created "2026-01-21" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:description "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A, S, F, I, D}. Provides the ontological/empirical perspective on systems-as-territory. Each primitive type instantiates at M0 as an evaluation functor F_x : System → [0,1]." ;
    dcterms:modified "2026-05-13" ;
    rdfs:comment "Territory Grammar Gt: free commutative monoidal grammar over primitive types {A,S,F,I,D}. Provides the ontological/empirical perspective on systems-as-territory. At M0, each primitive type instantiates as an evaluation functor F_x : System → [0,1]. Part of the TSCG bicephalous architecture (Gt + Gm). See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md." ;
    owl:imports "M3_GrammarFoundation.jsonld" ;
    owl:versionInfo "2.5.0" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#eagle_eye:criticalAxiom> a owl:DatatypeProperty ;
    rdfs:label "Critical Axiom (ASFID)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Fundamental constraint or axiom that applies to this ASFID dimension" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Theoretical or empirical constraint that must be satisfied in Territory measurements (e.g., Flow ≥ 0.1 Universal Openness axiom)" ;
    skos:example "F ≥ 0.1 (no perfectly isolated system exists)" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#eagle_eye:physicalInterpretation> a owl:DatatypeProperty ;
    rdfs:label "Physical Interpretation (ASFID)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Concrete physical manifestations or analogues of the ASFID dimension in Territory" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Description of how the ASFID dimension manifests in physical, biological, or social systems as observable Territory phenomena" ;
    skos:example "Attractor → Stability basin, homeostatic set-point" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#eagle_eye:rangeAnalog> a owl:DatatypeProperty ;
    rdfs:label "Range Analog (ASFID)" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Typical measurement range and interpretation scale for ASFID dimension in Territory" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Normalized scale [0,1] with semantic anchors describing extreme and typical values for Territory measurements" ;
    skos:example "Structure: [0,1] where 0=gas (no structure), 1=crystal (perfect lattice)" .

