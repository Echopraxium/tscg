@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m3: <M3_GenesisGrammar.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Adjunction> a owl:Class ;
    rdfs:label "Adjunction" ;
    m3:components [ ] ;
    m3:formalDefinition "F ⊣ G iff Mor_D(F(A),B) ≈ Mor_C(A,G(B)) naturally in A,B" ;
    m3:tscgAdjunctions [ ] ;
    rdfs:comment "A relationship between two functors F: C → D and G: D → C where F is left adjoint to G (F ⊣ G). Adjunctions capture the idea of 'best approximation'. In TSCG: observation-interpretation duality (Φ ⊣ Ψ), free-forgetful pairs." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#AlignmentLoop> a owl:Class ;
    rdfs:label "Territory \" Map Alignment Loop" ;
    m3:iteration "iterative refinement via Φ/Ψ until δ₁ converges toward epistemic equilibrium" ;
    m3:operators [ ] ;
    rdfs:comment "Bidirectional iterative process aligning Territory observations with Map construction: Eagle Eye measures phenomena (ASFID), Sphinx Eye constructs representations (REVOI), and the Φ/Ψ operators drive progressive convergence between the two. Distinct from systemic feedback loops (biological, mechanical) \" this is an epistemological alignment mechanism intrinsic to TSCG architecture." ;
    skos:definition "Epistemological alignment loop between empirical observations (Territory/ASFID) and conceptual representations (Map/REVOI), driven by Φ and Ψ operators until Map-Territory coherence is achieved." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Cat_M3_ASFID> a owl:NamedIndividual,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> ;
    rdfs:label "Category of ASFID Dimensions" ;
    m3:categoryName "Cat_M3_ASFID" ;
    m3:dimensionAsymmetryNote [ ] ;
    m3:objects "Attractor",
        "Dynamics",
        "Flow",
        "Information",
        "Structure" ;
    rdfs:comment "Category whose objects are ASFID dimensions and morphisms are tensor products." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Cat_M3_REVOI> a owl:NamedIndividual,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> ;
    rdfs:label "Category of REVOI Dimensions" ;
    m3:categoryName "Cat_M3_REVOI" ;
    m3:objects "Evolvable",
        "Interoperable",
        "Observable",
        "Representable",
        "Verifiable" ;
    rdfs:comment "Category whose objects are REVOI dimensions and morphisms are tensor products." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Cat_TSCG> a owl:NamedIndividual,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> ;
    rdfs:label "Category of TSCG Layers" ;
    m3:categoryName "Cat_TSCG" ;
    m3:morphisms "F_concretize: M1→M0",
        "F_inst: M2→M1",
        "F_⊗: M3→M2" ;
    m3:objects "M0",
        "M1",
        "M2",
        "M3" ;
    rdfs:comment "The category whose objects are TSCG layers {M3, M2, M1, M0} and morphisms are functors between them." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CouplingStructure> a owl:Class ;
    rdfs:label "Bicephalous Coupling (Natural Transformations)" ;
    m3:mathematicalForm "Φ : Gt → Gm, Ψ : Gm → Gt (natural transformations), δ₁ = ||ASFID_mean − REVOI_mean|| / √2" ;
    m3:role "Encodes Map/Territory bidirectional epistemological connection" ;
    rdfs:comment "Natural transformations Φ and Ψ encoding bidirectional connection between Territory Grammar Gt and Map Grammar Gm." ;
    skos:definition "Æ’ᵢⱼ represents coupling strength between ASFID dimension i and REVOI dimension j" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#F_ArchitecturalAmendments> a owl:NamedIndividual ;
    rdfs:label "Flow Dimension Architectural Amendments v3.9.0" ;
    m3:amendmentType "additive" ;
    m3:amendment_1 [ ] ;
    m3:amendment_2 [ ] ;
    m3:amendment_3 [ ] ;
    m3:targetDimension "F (Flow) — Eagle Eye / ASFID" ;
    dcterms:date "2026-03-23" ;
    dcterms:source "DOI: 10.5281/zenodo.19160047" ;
    rdfs:comment "Three additive amendments to the Flow (F) dimension of ASFID, emerging from the Ranaora & Yii poclet session (2026-03-23). All amendments are non-destructive — existing M2 tensorizations remain valid." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#F_CategoryTheoryNote> a owl:Annotation ;
    rdfs:label "M3 Categorical Structure — Theoretical Note on F Asymmetry" ;
    m3:currentModel "M3 as Structural Grammar G_T (Territory) + G_M (Map) — free commutative monoidal (post-reform)" ;
    m3:fiberBundleInterpretation [ ] ;
    m3:futureWork "Formal proof of M3 as fibered category. Expert review of F ∈ Mor(Cat_M3) ∩ Ob(Cat_M3) axiom. Investigation of higher-order morphisms in M3." ;
    m3:implicationForTensorization "F-containing M2 tensors naturally encode morphic capacity. M2 = ⊗-products of object-dimensions (static) ⊕ F (dynamic relational component). This is consistent with existing tensorization — it adds interpretive depth, not contradiction." ;
    m3:proposedModel "M3 as enriched category Cat_M3 with Ob={A,S,I,D}-described states and Mor={F}-described transitions" ;
    m3:riskAssessment "Low — the amendment is interpretive and additive. All existing M2 tensor formulas remain valid. No refactoring of M3_EagleEye.jsonld required." ;
    m3:status "HYPOTHESIS — requires expert mathematical review" ;
    rdfs:comment "The F_morphic amendment (v3.9.0) reveals that M3 has richer categorical structure than a pure homogeneous metric space. ASFID dimensions are not equivalent: {A,S,I,D} describe objects, {F} describes morphisms. This suggests M3 is closer to an enriched category or fibered space than to a simple tensor product of homogeneous dimensions." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#F_instantiation> a owl:NamedIndividual,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:label "Instantiation Functor" ;
    m3:examples "F_inst(Component) = MechanicalComponent (in Mechanics)",
        "F_inst(Link) = ChemicalLink (in Chemistry)",
        "F_inst(Processor) = BiologicalProcessor (in Biology)" ;
    m3:functorType "covariant" ;
    m3:signature "F_inst: Cat_M2 → Cat_M1" ;
    rdfs:comment "Functor mapping M2 metaconcepts to M1 domain-specific concepts." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#F_structuralFormula> a owl:NamedIndividual,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:label "Tensorization Functor" ;
    m3:examples "F_⊗(A ⊗ S ⊗ F) = Reservoir",
        "F_⊗(A ⊗ S ⊗ I ⊗ R ⊗ O) = Coherence (v3.9.0)",
        "F_⊗(F ⊗ I ⊗ D) = Entropy (v3.9.0)",
        "F_⊗(F ⊗ S ⊗ I) = Transducer (v3.9.0)",
        "F_⊗(S ⊗ A) = Stase — F=0 ground state (v3.9.0)",
        "F_⊗(S ⊗ F) = Link",
        "F_⊗(S ⊗ I ⊗ D ⊗ F) = Processor (v3.9.0)" ;
    m3:functorSourceCategory "m3:Cat_M3_ASFID" ;
    m3:functorType "covariant" ;
    m3:signature "F_⊗: Cat_M3 → Cat_M2" ;
    rdfs:comment "Functor mapping M3 dimensions to M2 metaconcepts via tensor products." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenesisGrammar> a owl:Ontology ;
    rdfs:label "Genesis Grammar - Bicephalous Structural Grammar" ;
    m3:ontologyType <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis> ;
    dcterms:created "2026-01-21" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:description "Complete orthogonal basis for the TSCG framework, consisting of two complementary perspectives: Eagle Eye (ASFID) for Territory measurement and Sphinx Eye (REVOI) for Map construction. Integrates Category Theory formalization as mathematical foundation (definitions included in this file) for functors, morphisms, and categorical structure of TSCG layers." ;
    dcterms:modified "2026-05-13" ;
    dcterms:title "TSCG M3 Genesis Grammar - Bicephalous Structural Grammar" ;
    rdfs:comment "M3 Genesis Grammar provides the bicephalous structural grammar for TSCG: Territory Grammar Gt (Eagle Eye / ASFID) and Map Grammar Gm (Sphinx Eye / REVOI), connected via natural transformations Φ and Ψ" ;
    owl:imports "M3_EagleEye.jsonld",
        "M3_GrammarFoundation.jsonld",
        "M3_SphinxEye.jsonld" ;
    owl:versionInfo "4.0.0" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#KorzybskiPrinciple> a owl:Class ;
    rdfs:label "Korzybski Principle Formalization" ;
    m3:classicStatement "The map is not the territory (Alfred Korzybski, 1933)" ;
    m3:formalization "Φ : Gt → Gm is never a perfect isomorphism — δ₁ > 0 for all real systems" ;
    m3:tscgExtension "The map influences how we observe the territory, and observations refine the map" ;
    rdfs:comment "Mathematical formalization of 'The map is not the territory' extended to 'The map influences how we observe the territory'" ;
    skos:definition "Epistemological principle recognizing Map and Territory as distinct yet mutually influential through bidirectional coupling Σ" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#NaturalTransformation> a owl:Class ;
    rdfs:label "Natural Transformation" ;
    m3:formalDefinition "η: F ⇒ G is a family η_A: F(A) → G(A) for each A ∈ Ob(C)" ;
    m3:naturality [ ] ;
    m3:tscgApplications "Knowledge transfer: translation between disciplines",
        "Observer transformations: different perspectives on same territory",
        "Representation changes: different encodings of same concept" ;
    rdfs:comment "A morphism between functors. Natural transformations relate two functors F,G: C → D via a family of morphisms. In TSCG: transformations between different observer perspectives (human vs AI), translations between knowledge representations." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#belongsToCategory> a owl:ObjectProperty ;
    rdfs:label "belongs to category" ;
    rdfs:comment "Relates an object to the category it belongs to. Example: Chemistry belongsToCategory Cat_KnowledgeField." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CategoryObject> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#categoryName> a owl:DatatypeProperty ;
    rdfs:label "category name" ;
    rdfs:comment "Name of the category (e.g., 'Cat_M2', 'Cat_KnowledgeField')." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> ;
    rdfs:range xsd:string .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#composedWith> a owl:ObjectProperty ;
    rdfs:label "composed with" ;
    rdfs:comment "Morphism composition: if f: A→B and g: B→C, then f composedWith g yields g∘f: A→C." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#dimensionExamples> a owl:DatatypeProperty ;
    rdfs:label "Dimension Examples" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Concrete system instances illustrating the dimension with typical measurement or quality values" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Real-world examples showing how the dimension applies across different domains and scales (for ASFID) or different types of Maps and representations (for REVOI)" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#dimensionIndex> a owl:DatatypeProperty ;
    rdfs:label "Dimension Index" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Numerical index of the dimension within its basis (1-5 for ASFID, 1-5 for REVOI)" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:integer ;
    skos:definition "Position index within the grammar primitive set (1-5 within Gt or Gm). Used for ordered enumeration and reference." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#dimensionSymbol> a owl:DatatypeProperty ;
    rdfs:label "Dimension Symbol" ;
    dcterms:created "2026-02-16" ;
    rdfs:comment "Symbol identifying a M3 primitive type in TSCG structural formulas" ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> ;
    rdfs:range xsd:string ;
    skos:definition "Symbolic identifier for a M3 primitive type (e.g., A, S, R, V). Used in structural formulas and evaluation functor notation." ;
    skos:example "|A⟩ for Attractor (ASFID)",
        "|R⟩ for Representable (REVOI)",
        "|S⟩ for Structure (ASFID)",
        "|V⟩ for Verifiable (REVOI)" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#functorSourceCategory> a owl:ObjectProperty ;
    rdfs:label "functor source category" ;
    rdfs:comment "The source category of a functor." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#functorTargetCategory> a owl:ObjectProperty ;
    rdfs:label "functor target category" ;
    rdfs:comment "The target category of a functor." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#functorType> a owl:DatatypeProperty ;
    rdfs:label "functor type" ;
    rdfs:comment "Type classification of functor (covariant, contravariant, endofunctor, etc.)." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:range xsd:string .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#hasMorphism> a owl:ObjectProperty ;
    rdfs:label "has morphism" ;
    rdfs:comment "Relates a category to one of its morphisms." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#mapsMorphismTo> a owl:ObjectProperty ;
    rdfs:label "maps morphism to" ;
    rdfs:comment "How a functor maps morphisms. F mapsMorphismTo F(f) for morphism f." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#mapsObjectTo> a owl:ObjectProperty ;
    rdfs:label "maps object to" ;
    rdfs:comment "How a functor maps objects. F mapsObjectTo F(A) for object A." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CategoryObject> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#morphismSource> a owl:ObjectProperty ;
    rdfs:label "morphism source" ;
    rdfs:comment "The source (domain) object of a morphism." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CategoryObject> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#morphismTarget> a owl:ObjectProperty ;
    rdfs:label "morphism target" ;
    rdfs:comment "The target (codomain) object of a morphism." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CategoryObject> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#morphismType> a owl:DatatypeProperty ;
    rdfs:label "morphism type" ;
    rdfs:comment "Type classification of morphism (identity, isomorphism, inclusion, etc.)." ;
    rdfs:domain <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> ;
    rdfs:range xsd:string .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#ontologyType> a owl:ObjectProperty ;
    rdfs:label "Ontology Type" ;
    dcterms:created "2026-01-27" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:modified "2026-01-27" ;
    rdfs:comment "Specifies the architectural type of a TSCG ontology. Value must be an instance of m3:TscgOntologyType (e.g. m3:Poclet, m3:Genesis, m3:DomainExtension). Enables both OWL reasoning (subClassOf hierarchy) and SKOS navigation (ConceptScheme). Renamed from m3:ontologyCategory in v3.3.0." ;
    rdfs:domain owl:Ontology ;
    rdfs:range <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:changeNote "v3.3.0: Renamed from m3:ontologyCategory to m3:ontologyType for clarity. Range changed from m3:OntologyCategoryScheme (incorrect â€” was the ConceptScheme, not a concept) to m3:TscgOntologyType (correct â€” the abstract class)." ;
    skos:definition "A framework-level architectural property that specifies the position and role of an ontology within the TSCG metamodel hierarchy through reference to a controlled vocabulary defined as a skos:ConceptScheme." ;
    skos:editorialNote "Defined in M3 (Genesis Space) because it is a foundational metamodel property needed by all layers. M3 has no dependencies, ensuring m3:ontologyCategory is always available without creating circular dependencies." ;
    skos:example "M0_Yggdrasil.jsonld uses m3:Poclet",
        "M1_Biology.jsonld uses m3:DomainExtension",
        "M2_MetaConcepts.jsonld uses m3:TransdisciplinaryPattern",
        "M3_GenesisSpace.jsonld uses m3:Genesis" .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#semanticSignature> a owl:DatatypeProperty ;
    rdfs:label "Semantic Signature" ;
    dcterms:created "2026-02-20" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Minimal sufficient characterization of an entity's identity within the TSCG framework. Constitutive (positive) rather than differential (negative). Applicable at all layers: M3 (ontology types), M2 (metaconcepts), M1 (domain concepts), M0 (system instances)." ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    skos:definition "A compact, positive, minimal-yet-sufficient description of what an entity IS, expressed as a conjunction of necessary components. Distinct from m3:distinguishingFeatures which is differential (what an entity is NOT). Structure: component_1 + component_2 + ... where all components are necessary and together sufficient." ;
    skos:editorialNote "Supersedes m3:distinguishingFeatures (differential, informal) with a constitutive, formally defined alternative. Existing distinguishingFeatures blocks may be progressively replaced or complemented." ;
    skos:example "M0 poclet: 'Renin→Angiotensin→Aldosterone + pressure_regulation + negative_loop' (RAAS)",
        "M1 concept: 'setpoint + sensor + effector + correction' (Homeostasis)",
        "M2 metaconcept: 'output → input + regulation + attractor_convergence' (FeedbackLoop)",
        "M3 type: 'primitives(finite) + combination_rules + multiple_legitimate_interpretations' (SymbolicSystemGrammar)" ;
    skos:scopeNote "Layer-agnostic property defined at M3 level for universal applicability. At M2 level, semanticSignature is the human-readable counterpart of tensorFormula — both express the same identity at different levels of formalization." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenesisExtension> a owl:Class,
        skos:Concept ;
    m3:expectedCount 2 ;
    m3:layerOrder 1 ;
    m3:semanticSignature "5D_perspective + part_of_bicephalous_architecture + single_basis(ASFID|REVOI)" ;
    rdfs:comment "M3 layer ontologies that are parts of the complete bicephalous architecture. While m3:Genesis represents the unified 10D space, m3:GenesisExtension represents its constituent 5D perspectives (ASFID and REVOI)." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Basis Component",
        "Bicephalous Head",
        "M3 Component" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis> ;
    skos:definition "Component ontologies of the Genesis Space that define the bicephalous perspectives: Eagle Eye (ASFID - Territory) and Sphinx Eye (REVOI - Map). These extend the foundational Genesis Space with specific dimensional bases." ;
    skos:example "M3_EagleEye.jsonld (ASFID - Territory measurement)",
        "M3_SphinxEye.jsonld (REVOI - Map construction)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M3_Ext" ;
    skos:prefLabel "Genesis Extension" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis> ;
    skos:scopeNote "Exactly 2 ontologies in this category: EagleEye and SphinxEye. Closed set forming the bicephalous architecture." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#SymbolicSystemGrammar> a owl:Class,
        skos:Concept ;
    m3:distinguishingFeatures [ ] ;
    m3:expectedCount "5-15" ;
    m3:layerOrder 3 ;
    m3:semanticSignature "finite_primitives + combination_rules + multiple_legitimate_interpretations(symbolic_arbitration)" ;
    rdfs:comment "Symbolic System Grammars are complete symbolic languages with combinatorial structure. Unlike SystemicFrameworks (which converge toward solutions) or Poclets (which validate observable systems), SymbolicSystemGrammars are productive engines of legitimate interpretive diversity. Examples span divination systems, generative alphabets, and musical notation." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Combinatoric Symbolic System",
        "Formal Symbolic Language",
        "Interpretive Grammar" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenericConcepts> ;
    skos:definition "Ontologies representing formal symbolic systems defined by a finite set of primitives and combination rules, whose value lies in the multiplicity of legitimate interpretations they generate. Neither prescriptive nor empirically arbitrated — interpretation is symbolic, cultural, or contextual." ;
    skos:example "M0_AlchemyGame.jsonld (4 elements → 173 compounds by binary combination)",
        "M0_ChineseGlyphs.jsonld (~200 radicals → ~50,000 sinograms)",
        "M0_IChing.jsonld (64 hexagrams from Yin/Yang binary grammar)",
        "M0_MusicalNotation.jsonld (notes + rhythm rules → infinite interpretations)",
        "M0_Tarot.jsonld (78 arcanes, positional combination rules)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M3_SystemSymbolicGrammar" ;
    skos:prefLabel "Symbolic System Grammar" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#SystemicFramework> ;
    skos:scopeNote "Open-ended set. Any formal symbolic system with finite primitives, explicit combination rules, and multiple legitimate interpretations qualifies. Arbitration is symbolic/cultural/contextual, never purely physical or empirical." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TransDisclet> a owl:Class,
        skos:Concept ;
    m3:distinguishingFeatures [ ] ;
    m3:expectedCount "5-20" ;
    m3:layerOrder 4 ;
    m3:semanticSignature "multi_domain_native + same_system_concept + independent_disciplinary_instantiation + M0_level" ;
    m3:storageConvention [ ] ;
    m3:validationCriteria [ ] ;
    rdfs:comment "A TransDisclet (from 'Transdisciplinary' + diminutive suffix '-let', analogous to 'Poclet') is a minimal yet complete cross-domain system model. The defining criterion is that the system is not merely analogous across domains — it is the SAME system concept natively instantiated in each discipline. Example: Transducer exists natively in Electronics (sensor/actuator), Biology (sensory receptor), Acoustics (microphone/speaker), and Physics (piezoelectric effect)." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Cross-Domain System",
        "Multi-Domain Native System",
        "Transdisciplinary System Instance" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:definition "M0-level ontologies modeling systems that exist natively and autonomously across multiple disciplines simultaneously. Unlike Poclets (which validate a single system in one domain), a TransDisclet captures a system concept whose existence is inherently multi-disciplinary — the same system arises independently in each discipline, not by analogy but by native instantiation." ;
    skos:example "M0_Filter.jsonld (Electronics: RC/LC filter; Biology: kidney glomerulus; Acoustics: resonator; Signal Processing: digital filter)",
        "M0_Oscillator.jsonld (Electronics: LC circuit; Biology: circadian rhythm; Physics: pendulum; Neuroscience: neural oscillation)",
        "M0_Transducer.jsonld (Electronics: sensor/actuator; Biology: sensory receptor; Acoustics: microphone/speaker; Physics: piezoelectric effect)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M0_TransDisclet" ;
    skos:prefLabel "TransDisclet" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:scopeNote "Open-ended set. A system qualifies as a TransDisclet when: (1) it exists natively in at least 2 distinct disciplines, (2) the same GenericConcept structure (ASFID) is identifiable in each disciplinary instance, and (3) the cross-domain homology is structural, not merely metaphorical. Stored in instances/transdisclet/ folder." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgTool> a owl:Class,
        skos:Concept ;
    m3:distinguishingFeatures [ ] ;
    m3:expectedCount "3-10" ;
    m3:layerOrder 4 ;
    m3:semanticSignature "operates_on_tscg_artifacts + reflexive_meta_level + software_tool + framework_self_analysis" ;
    rdfs:comment "TscgTools are meta-level applications: visualizers, explorers, validators, converters, simulators that take TSCG ontologies as input and produce analysis, navigation, or transformation as output. They can themselves be characterized by ASFID/REVOI (as any system), but their primary purpose is operating on the TSCG knowledge graph." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Framework Tool",
        "Meta-Level Application",
        "Ontology Tool",
        "Reflexive Tool" ;
    skos:definition "Software tools that operate reflexively ON the TSCG framework itself. Unlike Poclets (which model external systems), TscgTools model and operate on TSCG artifacts: ontologies, GenericConcepts, poclets, formulas. They are M0-level concrete instantiations whose subject matter is the framework." ;
    skos:example "M0_TscgExplorer.jsonld (interactive GenericConcept net visualizer, 3 projection modes)",
        "M0_TscgRagSearch.jsonld (RAG-based semantic search over TSCG — planned)",
        "M0_TscgValidator.jsonld (ontology consistency checker — planned)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M0_TscgTool" ;
    skos:prefLabel "TSCG Tool" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:scopeNote "Open-ended set. Any software tool whose primary input/subject is TSCG ontological artifacts qualifies. Instantiated at M0 level but typed as TscgTool rather than Poclet." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#RealWorldSystem> a owl:Class,
        skos:Concept ;
    m3:expectedCount "0 (future)" ;
    m3:layerOrder 4 ;
    m3:semanticSignature "deployed_system + complex(non_minimal) + stakeholder_validated" ;
    rdfs:comment "Real-World Systems demonstrate TSCG applied to production environments. May be complex (non-minimal) and evolving. Used to validate TSCG scalability beyond simple examples." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "M0 Layer",
        "Operational Ontology",
        "Production Application" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension> ;
    skos:definition "M0 ontologies representing actual deployed systems analyzed using TSCG framework. These are not pedagogical examples but real applications with stakeholders." ;
    skos:example "M0_HospitalERWorkflow.jsonld (hypothetical)",
        "M0_ManufacturingSupplyChain.jsonld (hypothetical)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M0_Real" ;
    skos:prefLabel "Real-World System" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CaseStudy>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:scopeNote "Future category. Not yet populated. Requires TSCG maturity and adoption." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#SystemicFramework> a owl:Class,
        skos:Concept ;
    m3:distinguishingFeatures [ ] ;
    m3:expectedCount "5-20" ;
    m3:integrationGuidelines [ ] ;
    m3:layerOrder 3 ;
    m3:semanticSignature "established_methodology + prescriptive + convergent_toward_solution + formalizable_in_TSCG" ;
    rdfs:comment "Systemic Frameworks are existing theories, methodologies, or analytical frameworks that have been formalized within TSCG's ontological structure. They serve as validation of TSCG's expressiveness and enable practitioners to leverage familiar frameworks within TSCG's rigorous formalism." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "External Framework Mapping",
        "Framework Integration",
        "Theoretical Framework Bridge" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenericConcepts> ;
    skos:definition "Ontologies that map established systemic/theoretical frameworks (TRIZ, VSD, TPACK, etc.) into TSCG formalism. These provide bridges between TSCG and existing methodologies, enabling cross-framework analysis and integration." ;
    skos:example "M0_DesignThinking.jsonld (Design Thinking methodology)",
        "M0_SystemsThinking.jsonld (General Systems Theory)",
        "M0_TPACK.jsonld (Technological Pedagogical Content Knowledge)",
        "M0_TRIZ.jsonld (Theory of Inventive Problem Solving)",
        "M0_VSD.jsonld (Value-Sensitive Design)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M1_Framework" ;
    skos:prefLabel "Systemic Framework" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:scopeNote "Open-ended set. Any established framework with systemic structure can be mapped. Typically 10-20 major frameworks. Distinct from DomainExtension (which are disciplinary) and from Poclet (which are minimal instances)." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CaseStudy> a owl:Class,
        skos:Concept ;
    m3:expectedCount "variable" ;
    m3:layerOrder 4 ;
    m3:semanticSignature "pedagogical + may_be_incomplete + evolves_toward_Poclet" ;
    rdfs:comment "Case Studies demonstrate TSCG application without the rigor required of Poclets. They serve pedagogical or experimental roles and may evolve into full Poclets after validation." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Application Demonstration",
        "Educational Example",
        "M0 Layer" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension> ;
    skos:definition "M0 ontologies created primarily for educational, illustrative, or exploratory purposes. Unlike Poclets, Case Studies may be incomplete (missing ASFID dimensions) or over-specified (non-minimal)." ;
    skos:example "M0_SocialMediaEcosystem.jsonld (hypothetical)",
        "M0_UrbanTrafficFlow.jsonld (hypothetical)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M0_Case" ;
    skos:prefLabel "Case Study" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> ;
    skos:scopeNote "Optional category. Not required for framework validation. May grow based on educational needs." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#M3Dimension> a owl:Class ;
    rdfs:label "M3 Dimension" ;
    dcterms:created "2026-02-16" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "A primitive type in the TSCG Structural Grammar. At M2/M3: generator of type expressions (qualitative, no metric). At M0: evaluation functor F_x : System → [0,1] (quantitative). Belongs to either Territory Grammar Gt (ASFID) or Map Grammar Gm (REVOI)." ;
    rdfs:subClassOf owl:Thing ;
    skos:definition "A primitive type generator of the TSCG Structural Grammar. Independence verified (analytical, not metric). Two roles: (1) type generator at M2 level; (2) evaluation functor at M0 level via norm-referenced intersubjective benchmark scoring." ;
    skos:example "m3:eagle_eye:Attractor (ASFID/Territory)",
        "m3:eagle_eye:Structure (ASFID/Territory)",
        "m3:sphinx_eye:Representable (REVOI/Map)",
        "m3:sphinx_eye:Verifiable (REVOI/Map)" ;
    skos:scopeNote "This class has exactly 10 instances: 5 ASFID dimensions (Attractor, Structure, Flow, Information, Dynamics) defined in M3_EagleEye.jsonld, and 5 REVOI dimensions (Representable, Evolvable, Verifiable, Observable, Interoperable) defined in M3_SphinxEye.jsonld." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CategoryObject> a owl:Class ;
    rdfs:label "Category Object" ;
    m3:formalDefinition "An element A ∈ Ob(C) for some category C" ;
    m3:properties "Every object has an identity morphism id_A: A → A",
        "Objects are sources and targets of morphisms",
        "Objects themselves have no internal structure in category theory",
        "Structure comes from morphisms TO and FROM the object" ;
    m3:tscgReification [ ] ;
    rdfs:comment "An object within a mathematical category. Objects are the 'things' in a category; morphisms are the 'relationships' between them. In TSCG: Chemistry is an object in Cat_KnowledgeField, Link is an object in Cat_M2, ASFID is an object in Cat_M3." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenericConcepts> a owl:Class,
        skos:Concept ;
    m3:expectedCount 1 ;
    m3:layerOrder 2 ;
    m3:semanticSignature "named_product_type(𝕋₁) + domain_agnostic + validated_across_disciplines" ;
    rdfs:comment "M2 layer ontologies containing GenericConcepts — named product types in the TSCG type system. Each concept is expressible as a structural formula combining M3 primitive types (e.g., Homeostasis = A⊗ᵗS⊗ᵗF)." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "M2 Layer",
        "Metaconcept",
        "Structural Formula",
        "Universal Pattern" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis> ;
    skos:definition "Universal patterns derived as named product types (𝕋₁) from M3 primitive types via structural grammar operators, validated across multiple scientific disciplines." ;
    skos:example "M2_MetaConcepts.jsonld (currently 62 metaconcepts including Step, Node, Homeostasis, etc.)" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M2" ;
    skos:prefLabel "GenericConcepts" ;
    skos:scopeNote "Typically 1 ontology containing 72+ metaconcepts. May grow as new transdisciplinary patterns are discovered." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension> a owl:Class,
        skos:Concept ;
    m3:expectedCount "6+" ;
    m3:layerOrder 3 ;
    m3:semanticSignature "domain_specific + specializes_M2_metaconcepts + bridges_M2_to_M0" ;
    rdfs:comment "M1 layer ontologies that bridge transdisciplinary metaconcepts (M2) with concrete systems (M0). Examples include Biology, Chemistry, Optics, Photography, Mythology. Each domain has characteristic ASFID⊗REVOI coupling." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Domain Instance",
        "M1 Layer",
        "Specialized Ontology" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenericConcepts> ;
    skos:definition "Domain-specific ontologies that specialize M2 metaconcepts for particular scientific or professional fields. Each is an instance of the m2:Domain metaconcept with specific 5D tensor structure." ;
    skos:example "M1_Biology.jsonld",
        "M1_Chemistry.jsonld",
        "M1_CoreConcepts.jsonld (transdisciplinary foundation)",
        "M1_Mythology.jsonld",
        "M1_Optics.jsonld",
        "M1_Photography.jsonld" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M1" ;
    skos:prefLabel "Domain Extension" ;
    skos:scopeNote "Open-ended set. New domains can be added as framework expands. Currently ~6 active domain extensions." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis> a owl:Class,
        skos:Concept ;
    m3:expectedCount 3 ;
    m3:layerOrder 1 ;
    m3:semanticSignature "structural_grammar_apex + bicephalous(Gt+Gm) + Lambek_calculus_foundation" ;
    rdfs:comment "M3 layer ontologies that define the bicephalous architecture: Eagle Eye (ASFID - Territory measurement) and Sphinx Eye (REVOI - Map construction). These ontologies have zero dependencies." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "Foundational Basis",
        "M3 Layer",
        "Structural Grammar Basis" ;
    skos:definition "Foundational structural grammar providing the bicephalous type system (Gt + Gm) upon which all other TSCG layers are built. Rooted in Lambek Calculus and free commutative monoidal categories." ;
    skos:example "M3_EagleEye.jsonld",
        "M3_GenesisGrammar.jsonld",
        "M3_GrammarFoundation.jsonld",
        "M3_SphinxEye.jsonld" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M3" ;
    skos:prefLabel "Genesis" ;
    skos:scopeNote "Exactly 3 ontologies in this category. Closed set." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Functor> a owl:Class ;
    rdfs:label "Functor" ;
    m3:formalDefinition "F: C → D mapping Ob(C) → Ob(D) and Mor(C) → Mor(D)" ;
    m3:functorLaws "Composition preservation: F(g∘f) = F(g)∘F(f)",
        "Identity preservation: F(id_A) = id_F(A)",
        "Morphism mapping: F: Mor_C(A,B) → Mor_D(F(A),F(B))",
        "Object mapping: F: Ob(C) → Ob(D)" ;
    m3:functorTypes [ ] ;
    m3:tscgFunctors [ ] ;
    rdfs:comment "A structure-preserving map between categories. Functors map objects to objects and morphisms to morphisms, preserving identity and composition. In TSCG: F_⊗ (tensorization M3→M2), F_inst (instantiation M2→M1), domain projection functors." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Morphism> a owl:Class ;
    rdfs:label "Category Morphism" ;
    m3:formalDefinition "An element f ∈ Mor(A,B) for objects A,B ∈ Ob(C)" ;
    m3:morphismTypes [ ] ;
    m3:notation [ ] ;
    m3:tscgMorphisms [ ] ;
    rdfs:comment "An arrow (morphism) between category objects. Morphisms represent structure-preserving transformations. In TSCG: tensorization (M3→M2), instantiation (M2→M1), concept application (M1→M0), knowledge transfer between domains." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#MathematicalCategory> a owl:Class ;
    rdfs:label "Mathematical Category" ;
    m3:categoryAxioms "Associativity: (h∘g)∘f = h∘(g∘f)",
        "Composition: ∀f ∈ Mor(A,B), g ∈ Mor(B,C), ∃ g∘f ∈ Mor(A,C)",
        "Identity: ∀A ∈ Ob(C), ∃ id_A ∈ Mor(A,A)",
        "Unit law: f∘id_A = f, id_B∘f = f" ;
    m3:structure [ ] ;
    m3:tscgExamples "Cat_KnowledgeField: Ob = {Chemistry, Biology, Optics...}, Mor = knowledge transfers",
        "Cat_M2: Ob = {Link, Processor, Component...}, Mor = metaconcept inclusions",
        "Cat_M3_ASFID: Ob = {A, S, F, I, D} (Gt primitives), Mor = ⊗ᵗ structural products",
        "Cat_TSCG: Ob = {M3, M2, M1, M0}, Mor = functors F_⊗, F_inst" ;
    rdfs:comment "A category in the mathematical sense: a collection of objects (Ob(C)) and morphisms (Mor(C)) between them, satisfying identity and associativity axioms. In TSCG: Cat_M3 (ASFID dimensions), Cat_M2 (metaconcepts), Cat_M1 (concepts), Cat_KnowledgeField (Chemistry, Biology, Optics...)." .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet> a owl:Class,
        skos:Concept ;
    m3:expectedCount "16+" ;
    m3:layerOrder 4 ;
    m3:semanticSignature "minimal + complete(all_ASFID_dimensions) + triple_role(validation+M2_discovery+M1_population)" ;
    rdfs:comment "M0 layer ontologies representing concrete, well-understood systems used to validate TSCG framework. Must be minimal (no unnecessary components) yet complete (all ASFID dimensions present). Examples: Fire Triangle, Butterfly Metamorphosis, Four-Stroke Engine." ;
    rdfs:subClassOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> ;
    skos:altLabel "M0 Layer",
        "Minimal Complete System",
        "Proof of Concept",
        "Validation Instance" ;
    skos:broader <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension> ;
    skos:definition "Minimal yet complete system instances that serve the triple role of (1) framework proof-of-concept, (2) M2 metaconcept identification, and (3) M1 core concept population." ;
    skos:example "M0_ButterflyMetamorphosis.jsonld",
        "M0_ExposureTriangle.jsonld",
        "M0_FireTriangle.jsonld",
        "M0_FourStrokeEngine.jsonld",
        "M0_Yggdrasil.jsonld" ;
    skos:inScheme <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> ;
    skos:notation "M0_Poclet" ;
    skos:prefLabel "Poclet" ;
    skos:related <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CaseStudy>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#RealWorldSystem> ;
    skos:scopeNote "Open-ended set. Goal is 20+ poclets spanning 10+ domains. Currently ~16 validated poclets." ;
    skos:topConceptOf <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyType> a owl:Class ;
    rdfs:label "TSCG Ontology Type" ;
    dcterms:created "2026-02-19" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "Abstract OWL class representing the architectural types of ontologies in the TSCG framework. Each TSCG ontology belongs to exactly one type. Instances (subclasses) are: Genesis, GenesisExtension, GenericConcepts, DomainExtension, SystemicFramework, Poclet, CaseStudy, RealWorldSystem, SymbolicSystemGrammar, TscgTool, TransDisclet. Each type is simultaneously an owl:Class (for OWL reasoning and Protégé class hierarchy) and a skos:Concept (for SKOS vocabulary navigation). Replaces the former m3:OntologyCategoryScheme/m3:OntologyCategoryScheme pattern (v3.3.0)." ;
    rdfs:isDefinedBy "m3:TscgOntologyTypeScheme" ;
    owl:isAbstract true .

<https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgOntologyTypeScheme> a skos:ConceptScheme ;
    rdfs:label "TSCG Ontology Type Scheme" ;
    dcterms:created "2026-01-27" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    rdfs:comment "SKOS controlled vocabulary listing all TSCG ontology types. Each concept in this scheme is simultaneously an owl:Class subClassOf m3:TscgOntologyType (OWL) and a skos:Concept (SKOS). Use m3:ontologyType property (range: m3:TscgOntologyType) to annotate ontologies with their type." ;
    skos:definition "A controlled vocabulary defining the eleven architectural types of TSCG ontologies, organized from foundational mathematical basis (Genesis) to concrete real-world instantiations (RealWorldSystem, TransDisclet). Each type serves as both an OWL class (enabling reasoning) and a SKOS concept (enabling vocabulary navigation)." ;
    skos:hasTopConcept <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#CaseStudy>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#DomainExtension>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenericConcepts>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Genesis>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#GenesisExtension>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#Poclet>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#RealWorldSystem>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#SymbolicSystemGrammar>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#SystemicFramework>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TransDisclet>,
        <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisGrammar.jsonld#TscgTool> ;
    skos:scopeNote "This scheme is extensible upon framework revision. Each category represents a fundamental architectural distinction in the TSCG metamodel." .

