{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "m3": "M3_GenesisGrammar.jsonld#"
  },
  "@graph": [
    {
      "@id": "m3:sphinx_eye:SphinxEye",
      "@type": "owl:Ontology",
      "owl:versionInfo": "3.5.0",
      "dcterms:created": "2026-01-21",
      "dcterms:modified": "2026-05-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:description": "Map Grammar Gm: free commutative monoidal grammar over primitive types {R, E, V, O, I}. Provides the epistemic/representational perspective on systems-as-map. Each primitive type instantiates at M0 as an evaluation functor F_x : System → [0,1].",
      "m3:ontologyCategory": {
        "@id": "m3:GenesisExtension"
      },
      "owl:imports": [
        "M3_GrammarFoundation.jsonld"
      ],
      "rdfs:label": "Sphinx Eye - Map Grammar Gm",
      "rdfs:comment": "Map Grammar Gm: free commutative monoidal grammar over primitive types {R,E,V,O,I}. Provides the epistemic/representational perspective on systems-as-map. At M0, each primitive type instantiates as an evaluation functor F_x : System → (M0 ValueSpace). Part of the TSCG bicephalous architecture (Gt + Gm). See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
      "metadata": {
        "layer": "M3",
        "name": "Sphinx Eye - REVOI Basis",
        "version": "3.5.0",
        "date_created": "2026-01-21",
        "date_modified": "2026-05-18",
        "authors": [
          "Echopraxium with the collaboration of Claude AI"
        ],
        "description": "REVOI basis for Map construction through synthetic composition",
        "changelog": {
          "v3.3.0": "IMPORT UPDATE: owl:imports changed from M3_GenesisSpace.jsonld to M3_GrammarFoundation.jsonld (apex ontology). m3: namespace updated to M3_GenesisGrammar.jsonld. Aligns with new M3 architecture: GrammarFoundation (apex) → EagleEye/SphinxEye → GenesisGrammar.",
          "v3.2.0": "FORMALISM REFORM: Replaced Hilbert space / orthonormal basis framing with Structural Grammar (Lambek calculus). basis_properties → grammar_properties (Map Grammar Gm). Removed hilbert_space, orthonormality, Sigma matrix. coupling_with_ASFID reframed: Phi/Psi recast as natural transformations. orthogonality_matrix → independence_matrix. See TSCG_StructuralGrammar_as_Mathematical_Foundation_README.md.",
          "v3.1.0": "REFACTORING: Removed m3:sphinx_eye:M3Dimension class (now m3:MonoidalType in GenesisSpace). Removed common properties (symbol, index, examples - now m3:dimensionSymbol, m3:dimensionIndex, m3:dimensionExamples in GenesisSpace). Kept REVOI-specific properties (philosophicalInterpretation, rangeProposed, formerName, renameRationale, note)."
        }
      },
      "parent_ontology": {
        "@id": "m3:genesis_space:GenesisGrammar",
        "relationship": "component_of",
        "description": "Sphinx Eye is the REVOI component of M3 Genesis Grammar, providing the synthetic perspective on systems"
      },
      "grammar_properties": {
        "grammar_name": "Map Grammar Gm",
        "grammar_type": "free_commutative_monoidal",
        "primitives": [
          "R",
          "E",
          "V",
          "O",
          "I"
        ],
        "product": "+",
        "primitive_role": "generators of Map type expressions (epistemic quality signatures)",
        "functor_role": "F_R, F_E, F_V, F_O, F_I : System → (M0 numeric ValueSpace)  (evaluation morphisms at M0)",
        "perspective": "epistemic / representational",
        "independence": "verified  (no primitive derivable from others)",
        "mathematical_foundation": "Lambek Calculus / free commutative monoidal categories (Lambek 1958, MacLane 1963)",
        "operator": "+ (Map structural sum — intra-REVOI)",
        "neutral_element": "m3:grammar_foundation:EmptyMap",
        "neutral_element_label": "Empty Map (neutral of +)",
        "neutral_element_semantic": "Empty pentagon — absence of all REVOI types"
      },
      "grammatical_note": {
        "form": "Adjective (qualificatif)",
        "rationale": "Simplified from abstract nouns (-ability) to adjectives (-able) for consistency and brevity. Mirrors ASFID which uses concrete nouns (Attractor, Structure, Flow, Information, Dynamics).",
        "comparison": {
          "ASFID": "Nouns (substantifs concrets)",
          "REVOI_v2": "Abstract nouns ending in -ity (substantifs abstraits)",
          "REVOI_v3": "Adjectives ending in -able (adjectifs qualificatifs)"
        },
        "advantages": [
          "Shorter (5-7 characters saved per type)",
          "More natural in French (représentable, vérifiable, observable, interopérable)",
          "Grammatically parallel (all adjectives)",
          "Easier to use in sentences (e.g., 'is representable' vs 'has representability')"
        ]
      },
      "metaphor": {
        "image": "Sphinx posing riddles at the crossroads",
        "wisdom": "Enigmatic knowledge that constructs understanding",
        "action": "Constructs, synthesizes, composes",
        "domain": "Map (Model)",
        "perspective": "From within, participatory view",
        "symbolic_nature": "Half-human (reason) half-lion (instinct)"
      },
      "dual_axes_position": {
        "model_reality_axis": "Model",
        "analysis_synthesis_axis": "Synthesis",
        "quadrant": "Synthesis of Model (Map)"
      },
      "independence_matrix": {
        "description": "The 5 primitive types {R,E,V,O,I} are analytically independent — no primitive type is derivable from the others",
        "verified": "true",
        "note": "Independence here means conceptual non-redundancy, not metric orthogonality. No inner product is defined or required."
      },
      "coupling_with_TerritoryGrammar": {
        "description": "Map Grammar Gm and Territory Grammar Gt are connected via natural transformations (category theory). Gm and Gt are structurally separate grammars — their separation is fundamental, not a consequence of orthogonality.",
        "natural_transformations": {
          "Phi": {
            "symbol": "Φ",
            "signature": "Φ : Gt → Gm",
            "role": "Observation — Territory measurements inform Map construction"
          },
          "Psi": {
            "symbol": "Ψ",
            "signature": "Ψ : Gm → Gt",
            "role": "Interpretation — Map predictions guide Territory measurement strategies"
          }
        },
        "epistemic_gap": {
          "symbol": "δ₁",
          "formula": "||ASFID_mean − REVOI_mean|| / √2",
          "meaning": "Measure of non-isomorphism of Φ — Korzybski principle: Φ is never a perfect isomorphism"
        },
        "korzybski": "The map is not the territory — Gm ≠ Gt structurally, δ₁ > 0 in all real systems",
        "see_also": "M3_GenesisGrammar.jsonld for complete bicephalous architecture"
      },
      "complementary_grammar": {
        "@id": "m3:eagle_eye:EagleEye",
        "description": "Eagle Eye provides Territory Grammar Gt over primitive types {A,S,F,I,D}, complementing Sphinx's Map Grammar Gm",
        "relationship": "structurally_complementary",
        "complete_architecture": "TSCG Bicephalous Architecture = Gt (Territory) + Gm (Map) — Gs (Stereopsis) is the reification of their stereopsic synergy"
      },
      "m2:changelog": [
        {
          "version": "3.5.0",
          "date": "2026-05-18",
          "changes": "STEREOPSIS: complete_architecture updated to reference Gs as reification of stereopsic synergy."
        },
        {
          "version": "3.4.0",
          "date": "2026-05-18",
          "changes": "OPERATOR REFORM: product notation ⊗ᵐ → + (structural sum, Map)."
        }
      ]
    },
    {
      "@id": "m3:sphinx_eye:philosophicalInterpretation",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Philosophical Interpretation (REVOI)",
      "rdfs:comment": "Epistemological and philosophical meaning of the REVOI types in Map construction",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Description of how the REVOI types relates to knowledge construction, representation, and the Map-Territory distinction",
      "skos:example": "Representable → Expressibility, encodability, representational capacity",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:sphinx_eye:rangeProposed",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Range Proposed (REVOI)",
      "rdfs:comment": "Proposed measurement range and interpretation scale for REVOI Map quality type",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Qualitative structural domain of the REVOI dimension expressed as a spectrum from minimal/absent structural expression to maximal/dominant. Replaces the numeric scale of the former Hilbert-space formalism with qualitative anchors compatible with the Structural Grammar formalism.",
      "skos:example": "Verifiable (V): minimal — unfalsifiable claims, no testable predictions ↔ maximal — completely falsifiable, fully empirically constrained",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:sphinx_eye:formerName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Former Name (REVOI)",
      "rdfs:comment": "Previous name of the REVOI types before v3.0.0 simplification",
      "rdfs:domain": {
        "@id": "m3:MonoidalType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:definition": "Historical type name using -ability suffix (e.g., Representability, Verifiability)",
      "dcterms:created": "2026-02-16"
    },
    {
      "@id": "m3:sphinx_eye:renameRationale",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "Rename Rationale (REVOI)",
      "rdfs:comment": "Explanation for REVOI types name change in v3.0.0",
      "rdfs:domain": {
