      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    },
    {
      "@id": "m0:scoringStatus.Complete",
      "@type": [
        "owl:NamedIndividual",
        "m0:ScoringStatus"
      ],
      "rdfs:label": "Complete",
      "rdfs:comment": "All 10 ASFID+REVOI scores present. m0:asfidMean, m0:revoiMean, m0:epistemicGap, m0:spectralClass computed.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    },
    {
      "@id": "m0:scoringStatus.Partial",
      "@type": [
        "owl:NamedIndividual",
        "m0:ScoringStatus"
      ],
      "rdfs:label": "Partial",
      "rdfs:comment": "Some scores present (typically 5 ASFID without REVOI, or vice versa). Means and gap not yet computable.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    },
    {
      "@id": "m0:scoringStatus.Pending",
      "@type": [
        "owl:NamedIndividual",
        "m0:ScoringStatus"
      ],
      "rdfs:label": "Pending",
      "rdfs:comment": "No scores present. Stub instance awaiting full ASFID/REVOI analysis session.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    },
    {
      "@id": "m0:scoringStatus",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "scoring Status",
      "rdfs:comment": "Completion state of ASFID/REVOI scoring for this M0 instance. Use enumeration values: m0:scoringStatus.Complete, m0:scoringStatus.Partial, m0:scoringStatus.Pending.",
      "rdfs:domain": {
        "@id": "owl:Ontology"
      },
      "rdfs:range": {
        "@id": "m0:ScoringStatus"
