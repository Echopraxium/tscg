      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    },
    {
      "@id": "m0:focalApplicable",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "focal Applicable",
      "rdfs:comment": "Boolean flag: true if instance mobilizes at least one stereopsic GenericConcept (m2:isStereopsic=true) AND all 10 scores are present. When false, all other m0:focal* and m0:stereopsic* properties MUST be absent.",
      "rdfs:domain": {
        "@id": "owl:Ontology"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-19"
    }
