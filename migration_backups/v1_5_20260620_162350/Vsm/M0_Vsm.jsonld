  "@graph": [
    {
      "@id": "instances/systemic-frameworks/Vsm/M0_Vsm.jsonld",
      "@type": "owl:Ontology",
      "owl:imports": [
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:SystemicFramework"
      },
      "rdfs:label": "Viable System Model (VSM) — Stafford Beer",
      "rdfs:comment": "Stafford Beer's VSM formalized in TSCG. Defines organizational viability through 5 recursive subsystems (S1-S5). Foundation: Ashby's Law of Requisite Variety.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-28",
      "owl:versionInfo": "1.2.0",
      "m1:domain": "Cybernetics",
      "dcterms:modified": "2026-04-20",
      "m0:asfidMean": {
        "@value": "0.93",
        "@type": "xsd:float"
      },
      "m0:revoiMean": {
        "@value": "0.85",
        "@type": "xsd:float"
      },
      "m0:epistemicGap": {
        "@value": "0.08",
        "@type": "xsd:float"
      },
      "m0:spectralClass": "Coherent",
      "m2:changelog": [
        {
          "version": "1.2.0",
          "date": "2026-04-20",
          "changes": "VarietyAmplification/Attenuation GenericConceptCombos formalized. ⊗⇒ notation used internally. ORIVE → REVOI. GenesisSpace → GenesisGrammar migration."
        },
        {
          "version": "1.1.0",
          "date": "2026-02-15",
          "changes": "Algedonic signal, ResourceBargain, RequisiteVariety classes added. Full S1-S5 hierarchy formalized."
        },
        {
          "version": "1.0.0",
          "date": "2026-01-28",
          "changes": "Initial VSM SystemicFramework. Beer's 5-subsystem model mapped to TSCG ASFID/REVOI."
        }
      ],
      "m0:scoreJustification": {
        "A_score": "VSM defines clear viable equilibrium states: operational stability (S1), coordination harmony (S2), resource optimization (S3), strategic adaptation (S4), identity coherence (S5)",
        "S_score": "Exceptionally formal 5-system architecture with explicit structural relations. Recursive viable system definition.",
        "F_score": "Well-defined information/variety flows: vertical (S5→S1), horizontal (S1↔Environment), variety attenuation/amplification",
        "It_score": "Variety as core informational concept. Ashby's Law quantifies information flows. Communication channels explicitly modeled.",
        "D_score": "Cybernetic feedback loops throughout. Dynamic equilibrium via S2 (anti-oscillation), S3 (optimization), S4 (adaptation).",
        "R_score": "50+ years of documented applications. Standardized VSM diagrams. Reproducible across industries.",
        "E_score": "Highly extensible: Team Syntegrity, VSM software, recursive application to new domains.",
        "V_score": "Structural diagnosis clear but functional verification qualitative. No quantitative validation metrics.",
        "O_score": "VSM Diagnostic Grid provides observation methodology but requires expertise to apply.",
        "Im_score": "Compatible with cybernetics, systems theory, complexity science. Integrates with QFD, TRIZ, VSD."
      },
      "m0:vsmPrinciples": {
        "viability": "Capacity to maintain separate existence through adaptation",
        "recursion": "Every viable system contains viable subsystems with complete S1-S5 structure",
        "requisiteVariety": "V(Regulator) ≥ V(Disturbance) (Ashby)",
        "autonomy": "Maximum S1 freedom compatible with systemic cohesion"
      },
      "m0:architecture": {
        "S1": "Operations — primary activities, autonomous units, direct environment interface",
        "S2": "Coordination — anti-oscillatory, prevents inter-S1 conflicts",
        "S3": "Optimization (inside/now) — resource allocation, performance monitoring, S3* audit",
        "S4": "Intelligence (outside/then) — strategic scanning, future adaptation",
        "S5": "Policy (identity/ethos) — ultimate authority, arbitrates S3-S4 conflicts"
      },
      "dcterms:source": {
        "primary": "Stafford Beer, Brain of the Firm (1972)",
        "secondary": [
          "Beer, Heart of Enterprise (1979)",
          "Beer, Diagnosing the System (1985)"
        ]
      },
      "rdfs:seeAlso": [
        "https://en.wikipedia.org/wiki/Viable_system_model",
        "instances/systemic-frameworks/Vsm/M0_Vsm_README.md"
      ],
