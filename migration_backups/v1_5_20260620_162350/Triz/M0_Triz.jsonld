      "m3:ontologyType": {
        "@id": "m3:SystemicFramework"
      },
      "rdfs:label": "TRIZ — Theory of Inventive Problem Solving",
      "rdfs:comment": "Systematic innovation methodology by Genrich Altshuller (200,000+ patents). 40 universal inventive principles + contradiction matrix (39×39). Prescriptive Map operating on technical system Territories.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-04-20",
      "owl:versionInfo": "1.1.0",
      "m1:domain": [
        "Systems Theory",
        "Systems Thinking"
      ],
      "dcterms:modified": "2026-04-24",
      "m1:simulationTitle": "TRIZ — Theory of Inventive Problem Solving",
      "m0:asfidMean": {
        "@value": "0.88",
        "@type": "xsd:float"
      },
      "m0:revoiMean": {
        "@value": "0.96",
        "@type": "xsd:float"
      },
      "m0:epistemicGap": {
        "@value": "0.057",
        "@type": "xsd:float"
      },
      "m0:spectralClass": "OnCriticalLine",
      "m0:normalizationNote": "Original Altshuller 0-5 scale normalized to 0-1 (÷5). A=5/5, S=5/5, F=4/5, It=5/5, D=3/5 | R=5/5, E=4/5, V=5/5, O=5/5, Im=5/5.",
      "m2:changelog": [
        {
          "version": "1.1.0",
          "date": "2026-04-24",
          "changes": "Added 20 TRIZ case studies demonstrating principle combinations across domains (automotive, materials, thermal, safety, cooking, etc.). GenesisSpace → GenesisGrammar migration."
        },
        {
          "version": "1.0.0",
          "date": "2026-04-20",
          "changes": "Initial TRIZ SystemicFramework (Option C architecture). 40 inventive principles as M1 instances in M1_SystemicModeling.jsonld. ASFID/REVOI scoring complete."
        }
      ],
      "m0:frameFrameworkInfo": {
        "author": "Genrich Altshuller",
        "origin": "Soviet Union, 1946-1998",
        "empiricalBasis": "Analysis of 200,000+ patents",
        "coreComponents": {
          "inventive_principles": 40,
          "technical_parameters": 39,
          "contradiction_matrix": "39×39 = 1521 cells",
          "inventivity_levels": 5,
          "evolution_trends": 8
        }
      },
      "m0:bicephalousNature": {
        "map": "TRIZ methodology itself (prescriptive framework, Sphinx Eye dominant)",
        "territory": "Technical systems being analyzed and improved (Eagle Eye targets)"
