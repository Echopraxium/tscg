      "m0:spectralClass": "Coherent",
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-03-06",
          "changes": "Initial TscgTool ontology for tscg_poclet_generator.py — dogfooding instance. ASFID/REVOI analysis, 8-component architecture, 8 GenericConcepts mobilized. GenesisSpace → GenesisGrammar migration."
        }
      ],
      "m0:scoreJustification": {
        "A_score": "Converges toward a well-defined attractor: validated poclet deliverable set (jsonld + README + sim.py). RAG augmentation reinforces this attractor.",
        "S_score": "8-component modular architecture with clear separation of concerns. Layered: UI / Generation Logic / LLM Backend / RAG Pipeline.",
        "F_score": "Well-defined unidirectional pipeline: Request → RAG augment → Prompt assembly → LLM call → Parse → Display.",
        "It_score": "High information density: natural language → structured JSON-LD + scored ASFID/REVOI + structural formulas + Pygame code.",
        "D_score": "Non-blocking QThread execution, lazy RAG initialization, settings persistence, history accumulation.",
        "R_score": "System representable as a pipeline FSM. TSCG framework provides representational vocabulary for its own tool.",
        "E_score": "Highly evolvable: new backends, templates, RAG sources all addable with minimal coupling.",
        "V_score": "Outputs are parseable JSON-LD. No automated test suite yet.",
        "O_score": "Multiple observability surfaces: status bar, progress bar, RAG chunk display, history panel.",
        "Im_score": "4 standard LLM protocols + PySide6 cross-platform + standard JSON-LD + Markdown output."
      },
      "m0:implementation": {
        "language": "Python 3.11+",
        "guiToolkit": "PySide6 (Qt 6)",
        "mainFile": "tscg_poclet_generator.py",
        "moduleFile": "tscg_rag_augmentor.py"
      },
      "m0:llmBackends": [
        {
          "name": "Anthropic Claude API",
          "models": [
            "claude-opus-4-5",
            "claude-sonnet-4-5",
            "claude-haiku-4-5"
          ]
        },
        {
          "name": "Google Gemini",
          "models": [
            "gemini-2.0-flash",
            "gemini-1.5-pro"
          ],
          "note": "Free tier"
        },
        {
          "name": "Ollama",
          "models": [
            "llama3.2",
            "mistral",
            "qwen2.5",
            "deepseek-r1"
          ],
          "note": "Local"
        },
        {
          "name": "OpenAI-compatible",
          "models": [
            "local-model"
          ],
          "note": "LM Studio, Jan, vLLM"
        }
      ],
      "m0:synergyPrinciple": {
        "formula": "Fm2(SmartPrompt, RAGContext, LLMEngine) → PocletDeliverableSet",
        "emergentProperty": "Ontological translation — natural language system descriptions faithfully converted into TSCG-compliant formal representations.",
        "reflexivityNote": "The tool applies TSCG grammar to generate TSCG artifacts, and is itself described by a TSCG ontology — complete framework reflexivity (dogfooding)."
      },
      "m0:genericConceptsMobilized": {
        "total": 8,
        "concepts": [
          {
            "name": "Processor",
            "structuralFormula": "S × It × D × F | V",
            "role": "The app as a whole: transforms natural language input into poclet deliverable set"
          },
          {
            "name": "Pipeline",
            "structuralFormula": "S × F × It",
            "role": "Sequential generation flow: Request → RAG → Prompt → LLM → Parse → Display"
          },
          {
            "name": "Interface",
            "structuralFormula": "S × It",
            "role": "PySide6 UI boundary between human intent and LLM processing engine"
          },
          {
            "name": "FeedbackLoop",
            "structuralFormula": "A × S × F × It × D",
            "role": "RAG augmentation: TSCG knowledge base feeds back into prompt driving new generation"
          },
          {
            "name": "Adapter",
            "structuralFormula": "S × It",
            "role": "Multi-backend abstraction normalizing heterogeneous LLM protocols"
          },
          {
            "name": "Context",
            "structuralFormula": "It × S × A",
            "role": "Active context window (SmartPrompt + RAG chunks + request) shaping LLM output"
          },
          {
            "name": "Narration",
            "structuralFormula": "S × It × D × F × A | R + O",
            "role": "Transforms informal description into formal ontological narrative (the poclet)"
          },
          {
            "name": "Propagation",
            "structuralFormula": "F × It × D | Im",
            "role": "User request propagates through system stages, transformed at each step"
          }
        ]
      },
      "m0:reflexivityAnalysis": {
        "dogfoodingType": "Complete",
        "description": "TSCG analyzes its own tool (m3:TscgTool). The tool uses TSCG grammar to generate TSCG artifacts — TSCG(TscgPocletGenerator) is both operator and object (fixed point).",
        "korzybskiReading": "The map (M0_TscgPocletGenerator.jsonld) describes a tool that draws maps. The tool that draws maps is itself on the map."
      },
      "rdfs:seeAlso": "instances/tscg-tools/TscgPocletGenerator/M0_TscgPocletGenerator_README.md"
    }
