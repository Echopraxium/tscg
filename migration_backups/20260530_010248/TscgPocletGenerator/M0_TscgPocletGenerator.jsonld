  "@graph": [
    {
      "@id": "instances/tscg-tools/TscgPocletGenerator/M0_TscgPocletGenerator.jsonld",
      "@type": "owl:Ontology",
      "rdfs:label": "TSCG Poclet Generator",
      "rdfs:comment": "Dogfooding TscgTool: PySide6 desktop application that takes natural language system descriptions and produces complete poclet deliverable sets (M0 JSON-LD + README + Pygame simulation) via 4 LLM backends, augmented by a ChromaDB RAG pipeline over the TSCG knowledge base. Exemplifies framework reflexivity: TSCG analyzes its own generation tool.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-03-06",
      "dcterms:modified": "2026-03-06",
      "owl:versionInfo": "1.0.0",
      "m3:ontologyType": {
        "@id": "m3:TscgTool"
      },
      "m1:domain": "TSCG",
      "owl:imports": [
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ],
