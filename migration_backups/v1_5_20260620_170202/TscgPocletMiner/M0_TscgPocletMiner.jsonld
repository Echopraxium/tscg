  "@graph": [
    {
      "@id": "instances/tscg-tools/TscgPocletMiner/M0_TscgPocletMiner.jsonld",
      "@type": "owl:Ontology",
      "owl:imports": [
        "M0_Common.jsonld",
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:TscgTool"
      },
      "rdfs:label": "TscgPocletMiner",
      "rdfs:comment": "TSCG Poclet Miner — Multi-backend LLM tool with on-the-fly RAG for TSCG ontology exploration and poclet generation assistance.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-03-16",
      "owl:versionInfo": "1.1.0",
      "m1:domain": "TSCG",
      "dcterms:modified": "2026-03-16",
      "m0:asfidMean": 0.826,
      "m0:revoiMean": 0.884,
      "m0:epistemicGap": 0.06,
      "m0:spectralClass": {
        "@id": "m0:spectralClass.Coherent"
      },
      "m2:changelog": [
        {
          "version": "1.1.0",
          "date": "2026-03-16",
          "changes": "RAG integration: JS-native @xenova/transformers (all-MiniLM-L6-v2, 384-dim, WASM). Round 2 queries poclet corpus for duplicate detection. Round 5 queries M2 GenericConcepts for concept suggestions."
        },
        {
          "version": "1.0.0",
          "date": "2026-03-16",
          "changes": "Initial TscgPocletMiner instance. Electron/vanilla JS wizard with 5-round Q&A, ASFID pre-scoring, corpus gap analysis, web search and deterministic verdict engine."
        }
      ],
      "m0:scoreJustification": {
        "A_score": "Attractor: convergence toward scored verdict (accept/reject) via iterative Q&A + RAG enrichment",
        "S_score": "Structure: 5-round wizard, corpus JSON, invariant grid, RAG bridge, scoring engine",
        "F_score": "Flow: user input → Q&A → RAG queries → scoring → web search → verdict → export",
        "It_score": "Information: ASFID pre-scores, RAG semantic results, gap flags, verdict",
        "D_score": "Dynamics: RAG results adapt to each query; corpus grows as new poclets are validated",
        "R_score": "Representability: all RAG results displayed with score, label, definition",
        "E_score": "Evolvability: corpus JSONs external and growable; RAG model swappable",
        "V_score": "Verifiability: scoring is deterministic; RAG results traceable to specific ontology entries",
        "O_score": "Observability: every RAG result, score, and wizard step displayed transparently",
        "Im_score": "Interoperability: JSON export reusable; rag_bridge.py reusable by other tools"
      },
      "m0:workflow": {
        "description": "5-round guided wizard producing scored verdict enriched by TSCG RAG context",
        "rounds": [
          {
            "round": 1,
            "label": "Domain identification",
            "output": "domain, gap_flag"
          },
          {
            "round": 2,
            "label": "Web verification + RAG similar poclets",
            "rag_query": "similar_poclets",
            "output": "doc_quality, rag_similar_results"
          },
          {
            "round": 3,
            "label": "ASFID pre-screening",
            "output": "asfid_prescores [A,S,F,I,D]"
          },
          {
            "round": 4,
            "label": "Type discriminant",
            "output": "candidate_type (Poclet/TransDisclet/SystemicFramework)"
          },
          {
            "round": 5,
            "label": "Invariants + RAG GenericConcepts + Verdict",
            "rag_query": "suggest_concepts",
            "output": "verdict, final_score, rag_concept_results"
          }
        ]
      },
      "m0:techStack": [
        "Electron",
        "Node.js",
        "Vanilla JS",
        "Python (rag_bridge.py)",
        "@xenova/transformers WASM"
      ],
      "m0:ragBackend": "all-MiniLM-L6-v2 (384-dim, WASM, in-process via @xenova/transformers)",
      "rdfs:seeAlso": "instances/tscg-tools/TscgPocletMiner/M0_TscgPocletMiner_README.md"
    }
  ]
