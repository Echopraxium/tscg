      "m0:waterTriplePoint": "273.16 K / 611.73 Pa (defined standard of Kelvin scale until 2019 BIPM redefinition)",
      "m3:asfid_dimension": "Attractor (unique thermodynamic fixed point — equal depth of all three basins)",
