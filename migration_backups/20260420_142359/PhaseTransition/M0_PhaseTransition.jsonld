      "@id": "m0:Phase_Solid",
      "@type": "m0:SystemState",
      "rdfs:label": "Solid Phase",
      "rdfs:comment": "Matter with fixed shape and volume; particles in ordered lattice with only vibrational motion; lowest entropy state",
      "m0:index": 0,
      "m0:orderParameter": "High crystalline order (low entropy)",
      "m0:molecularMotion": "Vibrational only (around fixed lattice positions)",
      "m0:entropy": "Lowest among condensed phases",
      "m0:compressibility": "Very low (incompressible in practice)",
      "m0:typicalDensity": "Highest of the 3 phases (exception: water ice less dense than liquid water)",
      "m3:asfid_dimension": "Attractor (stable energy minimum at low T / high P)",
      "m0:idealGasLaw": "Not directly applicable; requires Einstein/Debye solid models for thermal properties",
      "m0:colorCode": "#3A5F8A",
      "m0:displayLabel": "SOLID"
    },
    {
      "@id": "m0:Phase_Liquid",
      "@type": "m0:SystemState",
      "rdfs:label": "Liquid Phase",
      "rdfs:comment": "Matter with fixed volume but no fixed shape; particles mobile but densely packed; viscosity finite and temperature-dependent",
      "m0:index": 1,
      "m0:orderParameter": "Short-range order, long-range disorder",
      "m0:molecularMotion": "Translational + rotational + vibrational",
      "m0:entropy": "Intermediate (higher than solid, lower than gas)",
      "m0:compressibility": "Very low (quasi-incompressible)",
      "m0:viscosity": "Finite, temperature-dependent: eta proportional exp(Ea/RT) (Arrhenius law)",
      "m3:asfid_dimension": "Flow (dominant: liquid defined by capacity to flow)",
      "m0:idealGasLaw": "Vapor pressure above liquid follows Clausius-Clapeyron: ln(P) = -L_vap/(R*T) + const",
      "m0:colorCode": "#2E86C1",
      "m0:displayLabel": "LIQUID"
    },
    {
      "@id": "m0:Phase_Gas",
      "@type": "m0:SystemState",
      "rdfs:label": "Gas Phase",
      "rdfs:comment": "Matter with no fixed shape or volume; particles far apart with negligible intermolecular forces; obeys ideal gas law pV=nRT",
      "m0:index": 2,
      "m0:orderParameter": "No order (maximum entropy for given T and P)",
      "m0:molecularMotion": "Rapid translational, fully free",
      "m0:entropy": "High (scales with ln(V/n))",
      "m0:compressibility": "High (very compressible)",
      "m0:idealGasLaw": "pV = nRT — primary governing equation",
      "m0:idealGasLawVariables": {
        "p": "Pressure (Pa)",
        "V": "Volume (m^3)",
        "n": "Amount of substance (mol)",
        "R": "Universal gas constant = 8.314 J*mol^-1*K^-1",
