      },
      "m0:deviations": "Real gases deviate via van der Waals: (p + a*n^2/V^2)(V - nb) = nRT",
      "m3:asfid_dimension": "Dynamics (dominant: kinetic energy governs gas behavior)",
      "m0:colorCode": "#85C1E9",
      "m0:displayLabel": "GAS"
    },
    {
