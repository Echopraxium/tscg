      "m0:m2Candidates": [
        {
          "@id": "m0:M2Candidate_SymmetryBreaking",
          "m0:name": "SymmetryBreaking",
          "m0:status": "M2_CANDIDATE",
          "m0:tensorFormula": "Structure x Threshold x Switch",
          "m0:tensorFormulaTeX": "Structure \\otimes Threshold \\otimes Switch",
          "m0:definition": "Spontaneous transition from a high-symmetry state to a lower-symmetry state at a critical threshold, where the resulting structure no longer exhibits the original symmetry group.",
          "m0:primaryInstance": "Solidification: liquid (continuous translational symmetry) -> crystal (discrete lattice symmetry). The OrderParameter transitions from 0 to >0.",
          "m0:transdisciplinaryValidation": {
            "validatedDomains": 10,
            "domainsSample": [
              "Physics: crystallization, ferromagnetism (T < T_Curie), electroweak symmetry breaking",
              "Mathematics: pitchfork bifurcation (symmetric solution becomes unstable, asymmetric branches emerge)",
              "Biology: cell differentiation (totipotent -> specialized), morphogenesis (radial -> bilateral body axis)",
              "Chemistry: chirality (abiotic racemic synthesis -> homochiral biochemistry)",
              "Ecology: speciation (homogeneous population -> isolated species)",
              "Social Sciences: norm formation (balanced opinions -> dominant convention)",
              "Economics: technology lock-in (symmetric competition -> market monopoly)",
              "Computer Science: leader election in symmetric distributed graph"
            ],
            "includesBiology": true,
            "includesMathematics": true,
            "includesSocialSciences": true,
            "includesEconomics": true
          },
          "m0:distinctionFromCriticalityRegime": "CriticalityRegime (already M2): concerns dynamic behavior thresholds (subcritical/critical/supercritical process amplification). SymmetryBreaking: concerns structural outcome — the post-transition configuration has a strictly lower symmetry group. Orthogonal: boiling (Liquid->Gas) is a Switch without SymmetryBreaking (both phases share continuous translational symmetry); solidification is both a Switch AND SymmetryBreaking.",
          "m0:noteForM2Integration": "Proposed category: Structural. Proposed family: Dynamic-Structural boundary. Requires formal entry in M2_GenericConcepts.jsonld."
        }
      ],
      "m0:bicephalousSynthesis": {
        "territory_ASFID_mean": 0.86,
        "map_REVOI_mean": 0.88,
        "epistemicGap": 0.12,
        "balance": "Near-symmetric bicephalous balance. Sphinx Eye (REVOI=0.88) slightly stronger than Eagle Eye (ASFID=0.86), reflecting the exceptional representability and verifiability of thermodynamic phase diagrams.",
        "keyCouplings": [
          "A x R: 0.91 (Phase diagram as canonical Map of Attractor landscape)",
          "S x V: 0.92 (Crystal structure verified by X-ray diffraction at precision < 0.01 Angstrom)",
          "D x O: 0.89 (Nucleation kinetics and latent heat plateau directly observable)",
          "I x R: 0.87 (Order parameter and Boltzmann entropy as precise informational encodings)",
          "F x I: 0.86 (Latent heat flow as measurable interoperability signal between phases)"
        ],
        "epistemicGapAnalysis": {
          "lowGap": [
            "Equilibrium phase boundaries (T_fus, T_boil, T_c, P_triple) known to high precision",
            "Ideal gas law pV=nRT accurate to < 1% for noble gases at moderate conditions",
            "Latent heats measurable by DSC calorimetry"
          ],
          "moderateGap": [
            "Nucleation kinetics (stochastic, impurity-sensitive, path-dependent)",
            "Non-equilibrium phenomena (supercooling, superheating, metastable glasses)",
            "Critical exponents and universality classes (requires renormalization group theory)",
            "Real gas deviations at high P or near critical point (van der Waals corrections)"
          ]
        }
      },
      "m0:keyInsights": [
        "The phase diagram is a structural analogy to TSCG itself: a Map (REVOI / Sphinx Eye) of Territory attractors (ASFID / Eagle Eye) separated by threshold boundaries.",
        "The triple point uniquely validates Polarity(N=3): the only T,P where the three Gibbs energy basins are simultaneously equal — F=0 degrees of freedom (Gibbs phase rule).",
        "The critical point validates CriticalityRegime (M2): above T_c the liquid/gas Switch ceases to exist — a first-order transition becomes second-order (continuous).",
        "Solidification is the primary physical instance of the SymmetryBreaking M2 candidate: the liquid's continuous translational symmetry is spontaneously broken into discrete crystalline lattice symmetry.",
        "Latent heat is the thermodynamic signature of Switch: energy absorbed/released at constant temperature, entirely consumed in structural reorganization rather than kinetic energy change.",
        "Nucleation reveals the kinetic dimension of Switch: the thermodynamic Threshold can be crossed while the actual transition is delayed by the nucleation barrier (supercooling, superheating).",
        "This poclet bootstraps the M1_Physics extension with 6 seed concepts (LatentHeat, TriplePoint, CriticalPoint, OrderParameter, PhaseDiagram, Nucleation).",
        "First TSCG poclet covering the Physics / Thermodynamics domain."
      ],
