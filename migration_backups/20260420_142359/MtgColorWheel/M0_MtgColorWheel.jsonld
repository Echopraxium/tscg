      "m3:ontologyType": {
        "@id": "m3:Poclet"
      },
      "rdfs:label": "Magic Color Wheel - Pentagonal Philosophical System",
      "rdfs:comment": "Minimal yet complete philosophical system from Magic: The Gathering. Models 5 primary color identities, 10 bicolor guilds (5 allied + 5 enemy), and the Artifact pseudo-color. Demonstrates N-ary polarity (N=5), allied/enemy dynamics, and emergent guild identities through color combinations.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-22",
      "owl:versionInfo": "1.2.0",
      "m1:domain": "Cultural Artifact (Gaming/Philosophy)",
      "dcterms:modified": "2026-03-28",
      "m2:changelog": [
        {
          "version": "1.2.0",
          "date": "2026-03-28",
          "changes": [
            "Added m0:guilds section: 10 bicolor guilds (5 allied + 5 enemy) with canonical Ravnica names (Azorius, Dimir, Rakdos, Gruul, Selesnya, Orzhov, Izzet, Golgari, Boros, Simic)",
            "Added m0:artifact section: Artifact pseudo-color as colorless technology (dodecahedron geometry, ivory/pearl visual identity)",
            "Migrated @context to @base pattern (https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/) for shorter IRIs — aligns with M3_GenesisSpace.jsonld convention"
          ]
        },
        {
          "version": "1.1.0",
          "date": "2026-02-26",
          "changes": [
            "BREAKING: Migrated from deprecated ORIVE to canonical REVOI notation (R=Representability, E=Evolvability, V=Verifiability, O=Observability, I=Interoperability)",
            "Updated R dimension: Reproducibility → Representability (semantic decodability/encodability of color identities)",
            "Recalculated REVOI vector: (0.90, 0.85, 0.70, 0.75, 0.90) → mean=0.82"
          ]
        },
        {
          "version": "1.0.1",
          "date": "2026-01-25",
          "changes": [
            "Added GenericConceptMobilization section with 28 M2 instantiations",
            "Added newGenericConceptCandidates: Polarity-N, Alliance, Antagonism",
            "Validated N-ary polarity (N=5) as TSCG paradigm shift"
          ]
        }
      ],
      "dcterms:subject": [
        "Game Theory",
        "Philosophy",
        "Value Systems",
        "Conceptual Modeling",
        "Color Theory"
      ],
      "m0:pocletType": "Conceptual/Philosophical System",
