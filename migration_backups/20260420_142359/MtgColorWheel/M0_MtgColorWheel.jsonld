            "m0:Green"
          ],
          "m0:enemies": [
            "m0:Black",
            "m0:Red"
          ],
          "m0:philosophy": "The many are stronger than the one. Order brings peace, law brings justice. Individual desires must yield to common good.",
          "m0:mechanicalIdentity": "Small creatures, life gain, protection, removal, mass effects",
          "m0:symbolism": "Sun, plains, angels, soldiers, clerics"
        },
