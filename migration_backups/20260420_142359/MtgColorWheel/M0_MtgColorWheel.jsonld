      "rdf:type": "m0:Poclet",
      "rdfs:label": "Magic Color Wheel System",
      "rdfs:comment": "Pentagonal system of five philosophical colors, ten bicolor guilds, and the Artifact pseudo-color. Demonstrates N-ary polarity (N=5) and emergent guild identities from color synergies.",
      "m0:systemGeometry": {
        "topology": "Pentagon (regular 5-gon) + guild network",
        "vertices": 5,
        "edgesAllied": 5,
        "edgesEnemy": 5,
        "totalRelationships": 10,
        "guilds": 10,
        "pseudoColors": 1,
        "symmetry": "C5 rotational symmetry"
      },
      "m0:colors": [
        {
          "@id": "m0:White",
          "@type": "m0:Color",
          "rdfs:label": "White (W) — Order & Collective",
          "m0:manaSymbol": "{W}",
          "m0:pentagramPosition": 0,
          "m0:pentagramAngleDeg": 90,
          "m0:hexColor": "#F9FAF4",
          "m0:hexColor3D": "#C8A87A",
          "m0:coreValues": [
            "Structure",
            "Peace",
            "Community",
            "Absolute Morality"
          ],
          "m0:methods": [
            "Laws",
            "Institutions",
            "Collective Work",
