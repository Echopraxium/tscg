            { "concept": "m2:Process",   "formula": "D⊗I⊗F",       "component": "Task execution pipeline" },
            { "concept": "m2:Emergence", "formula": "S⊗I⊗D⊗V",     "component": "Trustworthy AI as emergent property; Governance Collapse as emergent failure" }
          ],
