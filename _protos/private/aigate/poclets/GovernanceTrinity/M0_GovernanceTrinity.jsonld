  "@graph": [

    {
      "@id": "m0:GovernanceTrinity",
      "@type": "owl:Ontology",
      "dcterms:title": "TSCG M0 Governance Trinity Poclet",
      "dcterms:description": "The AIGATE Governance Trinity (ASTP ⊗ Guardian Ensemble ⊗ Immutable Ledger). A minimal complete sociotechnical system demonstrating that trustworthy autonomous AI action requires three structurally necessary and sufficient components: intent verification (ASTP), risk adjudication (Guardian), and accountability tracing (Ledger). Removing any one component causes governance collapse. Validates m2:Regulation, m2:Constraint, m2:Threshold, m2:Memory, m2:Signature, m2:Resilience. Introduces M1_AIGovernance domain extension. Source: AIGATE whitepaper (SEERAVERSE Research Group, v2.2, November 2025).",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-03-25",
      "dcterms:modified": "2026-03-25",
      "owl:versionInfo": "1.0.0",
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld",
        "M1_extensions/ai_governance/M1_AIGovernance.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:Poclet"
      },
      "m2:changelog": {
        "v1.0.0": {
          "date": "2026-03-25",
          "description": "Initial version. 3-component Governance Trinity (ASTP, Guardian Ensemble, Immutable Ledger). ASFID mean=0.87, REVOI mean=0.84, δ₁=0.066 (OnCriticalLine). 13 M2 GenericConcepts mobilized. Founding poclet of M1_AIGovernance extension. Validates m3:Enigma ternary pattern as 5th documented instance."
        }
      }
    },

    {
      "@id": "m0:GovernanceTrinitySystem",
      "@type": ["owl:NamedIndividual", "owl:Class"],
      "rdfs:label": "Governance Trinity System",
      "rdfs:comment": "The Governance Trinity is a minimal complete sociotechnical architecture ensuring trustworthy autonomous AI action. Three structurally necessary and sufficient components — ASTP (intent verification), Guardian Ensemble (risk adjudication), Immutable Ledger (accountability memory) — form a ternary mediation structure where each component addresses one of the three fundamental 'scale problems' of AI governance: Intent Drift, Governance Collapse, and Liability Diffusion. The emergent property is 'Trustworthy Autonomous Action': a verifiable state where AI agents act within declared purpose, adjudicated risk, and traceable accountability. Removing any single component collapses the governance guarantee — exactly as removing any side of the Fire Triangle extinguishes combustion.",
      "m0:domain": "AI Governance / Sociotechnical Systems",
      "m0:subdomains": [
        "Multi-Agent Systems",
        "AI Safety",
        "Distributed Accountability",
        "Protocol Design",
        "Normative Architecture"
      ],
      "m0:pocletType": "Ternary Governance System",
      "m0:observer": "AI Governance Architect / CIPO / Regulatory Compliance Officer",
      "m0:componentCount": 3,
      "m0:source": "AIGATE whitepaper, SEERAVERSE Research Group, v2.2, November 2025",
      "m0:completeness": "VALIDATED — all 5 ASFID dimensions strongly active across all three components",
      "m0:minimality": "VALIDATED — each component is structurally necessary; none is derivable from the others",
      "m0:pedagogy": "Isomorphic to the Fire Triangle: 3 conditions necessary and sufficient for emergent trustworthy behavior",

      "m0:territorySpace": {
        "m0:asfidState": {
          "A": 0.85,
          "S": 0.90,
          "F": 0.85,
          "I": 0.90,
          "D": 0.85,
          "mean": 0.87,
          "norm": 1.95,
          "commentary": {
            "A": "The governance equilibrium ('Trustworthy AI') is a strong multi-dimensional attractor. Removing any component destabilizes the attractor basin — the system collapses to one of three known failure modes (Intent Drift, Governance Collapse, Liability Diffusion). Fractal self-similarity: same attractor operates at micro/meso/macro scale.",
            "S": "Strict three-layer pipeline topology: ASTP (protocol layer) → Guardian Ensemble (adjudication layer) → Immutable Ledger (memory layer). Clear authority hierarchy: Hard-Block (non-appealable) > Soft-Block (pending review) > Auto-Pass. Risk-Profile triage table (GV-001..GV-007) is the structural routing matrix.",
            "F": "Task requests flow unidirectionally through the pipeline. Bidirectional feedback loop: Ledger → MMS → MMAS → agent selection → Ledger. The Autonomy Cycle (Learn → Decide → Execute → Verify → Record) is a closed dissipative flow with structural persistence (every cycle leaves an immutable Ledger entry).",
            "I": "Exceptionally information-dense: ASTP header encodes Intent-ID (URN), Risk-Profile (Enum), Liability-Owner (URN), Cultural-Context (ISO 3166-1), trace_signature (HMAC-SHA256). Guardian veto ruleset (GV-001..GV-007) encodes risk-action decision logic. Ledger Decision Blocks carry full ASTP snapshot + Guardian signatures + event payload.",
            "D": "State transitions: Task_Pending → Soft-Block → {Approved | Hard-Block}. Risk-Profile escalation dynamics. Cryptographic chaining grows monotonically (append-only). Self-learning loop feeds Ledger outcomes back to MMS Score Matrix, modifying future MMAS selections."
          }
        }
      },

      "m0:mapSpace": {
        "m0:reviState": {
          "R": 0.85,
          "E": 0.80,
          "V": 0.90,
          "O": 0.80,
          "I": 0.85,
          "mean": 0.84,
          "norm": 1.88,
          "commentary": {
            "R": "ASTP header schema (Appendix A), Ledger Decision Block schema (Appendix D), and Veto Ruleset (Appendix E) provide formal, structured, JSON-based representations of all three components. Standardizable domain (CIPO notice): published as proposed RFC / ISO standard candidate.",
            "E": "Explicitly designed for evolution: MMAS auto-integrates new LLMs without human re-engineering. Self-Learning module (Ch. 13) enables autonomous ruleset refinement. Four-phase roadmap (Observation → Resonance → Empathy → Symbiosis) formalizes evolvability trajectory. Residual gap: Trade Secret components (MMAS scoring weights) resist external evolvability assessment.",
            "V": "Strongest REVOI dimension. Cryptographic chaining makes all decisions 100% auditable. HMAC-SHA256 trace_signature on ASTP headers. Guardian digital signatures on every adjudication. Ledger provides technical, indisputable proof of liability chain — directly satisfies EU AI Act Art. 13 (Accountability & Transparency).",
            "O": "Hard-Block and Soft-Block events are logged and observable. Guardian deliberations produce signed, auditable votes. Residual opacity: MMAS internal scoring matrix is a classified Trade Secret (intentional, explicitly declared). ERA biometric inputs (Bear Hermit project) are ephemeral by default. Observability gap is epistemically honest, not accidental.",
            "I": "ASTP designed as open standard ('Ethical HTTP'). Fractal governance: same primitives apply at personal/enterprise/municipal scale. Standardized vocabularies (Intent-ID URN, Risk-Profile Enum) enable cross-system interoperability. Goal: establish ASTP as lingua franca for all AI agent communication."
          }
        }
      },

      "m0:epistemicGap": {
        "formula": "δ₁ = ||v_ASFID - v_REVOI|| / √dim",
        "asfidVector": [0.85, 0.90, 0.85, 0.90, 0.85],
        "reviVector":  [0.85, 0.80, 0.90, 0.80, 0.85],
        "deltaVector": [0.00, 0.10, -0.05, 0.10, 0.00],
        "delta": 0.066,
        "spectralClass": "OnCriticalLine",
        "spectralRange": "[0.05, 0.15)",
        "commentary": "Low epistemic gap reflecting the whitepaper's strong formal specification (schemas, veto tables, protocol fields). The residual gap (δ₁=0.066) is concentrated in E (Evolvability, +0.10) and O (Observability, +0.10): both are intentional — MMAS scoring algorithms are classified Trade Secrets, and ERA biometric data is ephemeral by design. This is not a framework gap but an epistemically honest boundary between the public standardizable architecture and the proprietary competitive advantage.",
        "balanceType": "Eagle Eye slightly dominant (strong empirical formal specification) — Sphinx Eye high (rich schema coverage)"
      },

      "m0:synergyPrinciple": {
        "formula": "GovernanceTrinity = AIGovernance ⊙ (m2:Constraint ⊗ m2:Regulation ⊗ m2:Memory)",
        "formulaASCII": "GovernanceTrinity = AIGovernance [o] (Constraint (x) Regulation (x) Memory)",
        "emergentProperty": "Trustworthy Autonomous Action — the verifiable state where autonomous AI agents act within declared purpose (Intent), adjudicated risk (Judgment), and traceable accountability (Record). Not achievable by any subset of the three components.",
        "coupledDimensions": "S,I,F,V,R (from m2:Constraint/ASTP) + A,S,F,V,R (from m2:Regulation/Guardian) + D,F,S,I,A,O (from m2:Memory+Signature/Ledger) → full ASFID coverage",
        "triadNecessity": {
          "withoutASTP": "Intent Drift — agents optimize metrics while violating unstated purposes (Sorcerer's Apprentice)",
          "withoutGuardian": "Governance Collapse — locally-rational agent decisions cascade into systemic harm (Flash Crash)",
          "withoutLedger": "Liability Diffusion — emergent negligence with no assignable responsibility (Black Box AI)"
        },
        "fireTriangleAnalogy": {
          "Fuel":    { "AIGATE": "Intent (ASTP)",        "collapseWithout": "Intent Drift" },
          "Oxygen":  { "AIGATE": "Judgment (Guardian)",  "collapseWithout": "Governance Collapse" },
          "Heat":    { "AIGATE": "Accountability (Ledger)", "collapseWithout": "Liability Diffusion" },
          "Fire":    { "AIGATE": "Trustworthy Autonomous Action" }
        }
      },

      "m0:components": [
        {
          "@id": "m0:ASTP",
          "rdfs:label": "ASTP — Agent Safety Trust Protocol",
          "rdfs:comment": "Mandatory communication wrapper that transforms bare imperative commands into verifiable context-rich requests by explicitly encoding Civilizational Variables (Intent, Risk, Liability, Cultural-Context) before execution. Kernel-level enforcement: non-compliant requests are technically unroutable, not merely discouraged. Analogy: 'Ethical HTTP' (Ch. 6).",
          "m0:layer": "Protocol (Input Layer)",
          "m0:solvedProblem": "Intent Drift",
          "m0:mechanism": "URN-vocabulary Intent-ID + Enum Risk-Profile + URN Liability-Owner + HMAC trace_signature",
          "m1gov:type": { "@id": "m1gov:TrustProtocol" },
          "m0:asfidContribution": {
            "A": { "score": 0.80, "role": "Convergence toward declared intent; Intent-ID propagates unchanged through task decomposition" },
            "S": { "score": 0.95, "role": "Rigid mandatory protocol structure; defined field schema; no optional bypass path" },
            "F": { "score": 0.85, "role": "Wraps every inter-agent communication flow; transforms trustless commands into trust-based requests" },
            "I": { "score": 0.95, "role": "Maximum information density: Intent-ID, Risk-Profile, Authority-Request, Liability-Owner, Cultural-Context, data_sovereignty, trace_signature" },
            "D": { "score": 0.80, "role": "State transition: Untrusted command → ASTP-wrapped request → Kernel-verified → Routed/Rejected" }
          },
          "m0:genericConceptsActivated": ["m2:Constraint", "m2:Alignment", "m2:IntentDeclaration", "m2:Scope"]
        },
        {
          "@id": "m0:GuardianEnsemble",
          "rdfs:label": "Guardian Ensemble — Collective Risk Adjudication",
          "rdfs:comment": "Dynamic multi-agent judiciary that halts high-risk tasks and adjudicates them via collective deliberation of specialized personas. Anti-fragile by design: no single AI bias dominates. Two veto levels — Soft-Block (temporary injunction) and Hard-Block (constitutional veto, non-appealable). Dynamically assembled per task context from MMAS persona pool (Ch. 7).",
          "m0:layer": "Adjudication (Processing Layer)",
          "m0:solvedProblem": "Governance Collapse",
          "m0:mechanism": "Risk-Profile triage (GV-001..GV-007) → dynamic persona assembly → multi-model consensus → Approve / Soft-Block / Hard-Block",
          "m1gov:type": { "@id": "m1gov:DeliberativeVeto" },
          "m0:asfidContribution": {
            "A": { "score": 0.90, "role": "Governance equilibrium attractor: convergence toward approved-safe states; Hard-Block prevents unsafe attractors from forming" },
            "S": { "score": 0.85, "role": "Multi-persona judiciary topology: CRO + Legal + Domain-Expert per risk type; authority hierarchy (Hard-Block > Soft-Block > Auto-Pass)" },
            "F": { "score": 0.85, "role": "Task routing flow through adjudication pipeline; persona convocation; deliberation outputs routed to Ledger" },
            "I": { "score": 0.85, "role": "Veto ruleset (GV-001..GV-007) encodes risk-action decision matrix; Guardian signatures encode adjudication rationale" },
            "D": { "score": 0.90, "role": "Dynamic Ensemble assembly (persona selection via MMAS); deliberation state machine; temporal evolution of governance rules via Self-Learning" }
          },
          "m0:genericConceptsActivated": ["m2:Regulation", "m2:Threshold", "m2:Trigger", "m2:Agent", "m2:Resilience", "m2:Emergence"]
        },
        {
          "@id": "m0:ImmutableLedger",
          "rdfs:label": "Immutable Ledger — Accountability Memory",
          "rdfs:comment": "Cryptographically secured, append-only chain of Decision Blocks recording the complete custody chain for every autonomous decision: requesting agent, declared intent (ASTP snapshot), adjudication result (Guardian signatures), execution outcome. Transforms 'emergent negligence' (distributed, untraceable liability) into assignable, auditable, insurable accountability. Serves as the system's learning memory: Ledger outcomes feed back to MMS Score Matrix (Ch. 8, 13).",
          "m0:layer": "Memory (Output/Feedback Layer)",
          "m0:solvedProblem": "Liability Diffusion",
          "m0:mechanism": "Cryptographic chaining (SHA-256) → Decision Blocks → ASTP snapshot + Guardian signatures + event payload → Three-Stage Anonymization → MMS feedback",
          "m1gov:type": { "@id": "m1gov:LiabilityChain" },
          "m0:asfidContribution": {
            "A": { "score": 0.85, "role": "Accountability attractor: persistent record ensures no decision escapes traceability; liability assignment converges to deterministic answer" },
            "S": { "score": 0.90, "role": "Cryptographic chain structure: each block hashes predecessor (previous_block_hash field); tamper detection is architectural, not procedural" },
            "F": { "score": 0.85, "role": "Data flow: task result → Decision Block → Ledger → Three-Stage Anonymization → MMS Score Matrix update → future MMAS decisions" },
            "I": { "score": 0.90, "role": "Maximum accountability encoding: block_id, previous_block_hash, task_id, event_type, astp_header_snapshot, guardian_signatures, block_hash" },
            "D": { "score": 0.80, "role": "Monotonic append-only growth; Self-Learning feedback modifies future governance behavior; Privacy-by-Architecture anonymization pipeline" }
          },
          "m0:genericConceptsActivated": ["m2:Memory", "m2:Signature", "m2:Process"]
        }
      ],

      "m0:primaryGenericConcepts": [
        {
          "@id": "m2:Constraint",
          "formula": "S⊗I⊗F⊗V⊗R",
          "role": "PROTOCOL BACKBONE — ASTP as non-bypassable architectural constraint. Transforms ethics from policy (optional) to architecture (mandatory). The system cannot process non-ASTP-compliant requests.",
          "instantiation": "ASTP mandatory header fields; kernel-level rejection of non-compliant requests; HTTP-451-style technical enforcement"
        },
        {
          "@id": "m2:Regulation",
          "formula": "A⊗S⊗F⊗V⊗R",
          "role": "ADJUDICATION CORE — Guardian Ensemble's function: dynamic risk-calibrated regulation of autonomous agent behavior. Not post-hoc correction but in-line prevention.",
          "instantiation": "Veto Ruleset GV-001..GV-007; Soft-Block / Hard-Block authority levels; dynamic persona assembly per risk context"
        },
        {
          "@id": "m2:Memory",
          "formula": "D⊗F⊗D",
          "role": "ACCOUNTABILITY BACKBONE — Immutable Ledger as the persistent, append-only, cryptographically chained memory of all governance events. Prerequisite for both legal liability and self-learning.",
          "instantiation": "Decision Blocks with SHA-256 chaining; ASTP header snapshots; Guardian signature arrays; self-learning feedback loop"
        }
      ],

