# .gitignore pour TSCG

**/.lnk

# Node modules
node_modules/
**/node_modules/
**/node_modules/**

# Fichiers volumineux
*.exe
*.sqlite3
*.db
*.zip
*.tar.gz

**/.backup_
**/.backup_

# TSCG Backups
ontology/backup_*/
ontology/*.backup_*.jsonld
cli-tools/owl_reasoning_test/*.backup_*.jsonld

# Temporary files
*.tmp
*.temp
*~

# Claude Code internal config
.claude/*
!.claude/CLAUDE.md
!.claude/skills/

**/private/
*.tar.gz

api_keys/
*.api_key
*.apik

**/bin/
**/obj/
**/cache/

*.user
*.suo
*.so
*.swp
*.swo
*.log

# Python cache
**/__pycache__/
*.py[cod]
*$py.class
.Python

# Virtual environments
**/venv/
**/env/
**/ENV/
**/.venv/

# IDE files
.vs/
.vscode/
.idea/
*~

# OS files
.DS_Store
Thumbs.db

# Test outputs (if you run tests)
**/test_output/
*.ttl.test

# RAG database - uncompressed runtime directory (commit the .tar.gz instead)
**/db_tscg_rag/
*.sqlite3

# RAG runtime artifacts
**/create_rag_errors.txt
**/*_rag_test_*.txt

# Legacy RAG vector database (moved to src/tscg/rag/_archives/RAG-prev/)
src/tscg/rag/_archives/RAG-prev/db_vector/