# .gitignore pour TSCG

**/private/

# Frozen copies of live files — the /mnt/project/ trap, installed in the repo.
# A duplicate that LOOKS like a source is how M2 got overwritten by two versions.
# Handover docs stay; the .jsonld/.ttl/.py copies they ship with do NOT.
ontology/docs/_01_Worksite/**/*.jsonld
ontology/docs/_01_Worksite/**/*.ttl
ontology/docs/_01_Worksite/**/*.py
**/deliveries/

**/.lnk

# Ignore .git dans TOUS les sous-dossiers (n'importe quelle profondeur)
**/.git/
**/.gitmodules

# Node modules
node_modules/
**/node_modules/
**/node_modules/**

# ---------------------------------------------------------------------------
# Rust build artifacts (TriskeleToolchain)
#
# ⚠ THIS WAS MISSING (found 2026-07-13). Without `target/`, a `git add -A` stages
# THOUSANDS of build products: .rlib, .rmeta, .o, .d, query-cache.bin,
# dep-graph.bin, incremental/**, deps/**, fingerprints… The existing *.exe and
# *.pdb rules caught only a fraction of them.
#
# A committed target/ is IRREVERSIBLE: git keeps history forever, so the hundreds
# of MB stay in every clone even after a later deletion — only a history rewrite
# (git filter-repo) removes them. Cargo regenerates all of it in seconds.
# ---------------------------------------------------------------------------
target/
**/target/
*.rlib
*.rmeta
*.rcgu.o
Cargo.lock.orig

# ---------------------------------------------------------------------------
# TriskeleToolchain build artifacts — regenerated by tsk-cc / tsk-asm / tsk-link
# Same rule as Rust target/: a build product has no business in history.
# ---------------------------------------------------------------------------
*.tobj
# *.tvmx
*.tvmo

# Fichiers Triskele Toolchain
*.pdb

# Fichiers volumineux
*.exe
*.dll
*.lib
*.exp
*.sqlite3
*.db
*.zip
*.tar.gz

# ---------------------------------------------------------------------------
# Generated reports — regenerated by every run; committing them means a stale
# report can be mistaken for a fresh one.
# ---------------------------------------------------------------------------
check_M1_report.txt
check_M0_report.txt
pipeline_report.txt

# TSCG Backups
**/.backup_
ontology/backup_*/
ontology/*.backup_*.jsonld
cli-tools/owl_reasoning_test/*.backup_*.jsonld

# Temporary files
*.tmp
*.temp
*~

# Claude Code internal config
.claude/*
!.claude/CLAUDE.md
!.claude/skills/

api_keys/
*.api_key
*.apik

**/bin/
**/obj/
**/cache/

*.user
*.suo
*.so
*.swp
*.swo
*.log

# Python cache
**/__pycache__/
*.py[cod]
*$py.class
.Python

# Virtual environments
**/venv/
**/env/
**/ENV/
**/.venv/

# IDE files
.vs/
.vscode/
.idea/
*~

# OS files
.DS_Store
Thumbs.db

# Test outputs (if you run tests)
**/test_output/
*.ttl.test

# RAG database - uncompressed runtime directory (commit the .tar.gz instead)
**/db_tscg_rag/
*.sqlite3

# RAG runtime artifacts
**/create_rag_errors.txt
**/*_rag_test_*.txt

# Legacy RAG vector database (moved to src/tscg/rag/_archives/RAG-prev/)
# NOTE: this line was CORRUPTED — it had a quoted path glued onto the end, so it
# matched nothing. Split into two rules.
src/tscg/rag/_archives/RAG-prev/db_vector/
instances/symbolic-system-grammars/TriskeleToolchain/projects/references/wolf3D_4DSL/

# ---------------------------------------------------------------------------
# Line endings: cmd.exe REQUIRES CRLF in .bat files. A .bat checked out with LF
# gets chopped mid-command ('@echo off' is read as '@echo' + 'on') — it prints
# garbage AND silently skips logic. Enforced in .gitattributes:
#     *.bat text eol=crlf
# ---------------------------------------------------------------------------
**/_archives/
ontology/_archives/ 
