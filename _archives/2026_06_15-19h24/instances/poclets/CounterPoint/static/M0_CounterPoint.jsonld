          "style": "Baroque organ fugue",
          "voiceCount": 4,
          "complexity": "Medium — canonical 4-voice fugue, pedagogically clear structure",
          "simulationPrimary": true,
          "keySignature": "G minor"
        },
        {
          "id": "bwv565",
          "label": "Toccata and Fugue in D minor BWV 565 (J.S. Bach)",
          "style": "Baroque organ toccata + fugue",
          "voiceCount": 4,
          "complexity": "High — dramatic subject, extensive development, pedal virtuosity",
          "keySignature": "D minor"
        },
        {
          "id": "jazz_modal",
          "label": "Jazz Modal — Miles Davis / Herbie Hancock Quintet (1964-68)",
          "style": "Jazz modal improvisation",
          "voiceCount": "Variable (2-5)",
          "complexity": "High — rules internalized, real-time collective negotiation",
          "keyDifference": "Rules internalized (not written). Subject emergent (not pre-composed). Mediator: shared stylistic vocabulary."
        }
      ],
