  "@graph": [
    {
      "@id": "m0:CounterpointPoclet",
      "@type": "owl:Ontology",
      "rdf:type": {
        "@id": "m3:Poclet"
      },
      "rdfs:label": "Counterpoint (Music)",
      "rdfs:comment": "Polyphonic compositional system in which N independent melodic voices coexist under shared normative constraints (Counterpoint Rules), producing harmonic coherence as an emergent property. First TSCG poclet in the aesthetic domain. Candidate m3:Enigma: Voice Autonomy ⊗ CounterpointRule → Harmonic Coherence.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-03-20",
      "dcterms:modified": "2026-03-20",
      "m3:ontologyCategory": {
        "@id": "m3:Poclet"
      },
      "m0:pocletType": "Polyphonic",
      "m0:completeness": "All ASFID dimensions present",
      "m0:minimality": "4 poles necessary and sufficient: Exposition, Development, Stretto, Resolution",
      "m0:pedagogy": "First aesthetic domain poclet — demonstrates TSCG applicability beyond natural sciences",
      "m0:observer": "Human (musicological/systemic perspective)",
      "m0:epistemicGap": "0.016",
      "m0:spectralClass": "Coherent [0, 0.05)",
      "m0:enigmaCandidate": true,
      "m0:asfidScores": {
        "A": 0.87,
        "S": 0.9,
        "F": 0.85,
        "I": 0.93,
        "D": 0.88
      },
      "m0:revoiScores": {
        "R": 0.95,
        "E": 0.88,
        "V": 0.92,
        "O": 0.78,
        "I": 0.82
      },
      "m0:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-03-20",
          "changes": [
            "Initial release. 4-pole model (Exposition, Development, Stretto, Resolution). Full ASFID/REVOI bicephalous analysis. Enigma candidate pattern documented. Cross-stylistic validation: Canon (Frère Jacques), Baroque Fugue (BWV 578, BWV 565), Jazz modal (Miles Davis)."
          ]
        }
      ],
      "m0:m1Extensions": [
        "M1_extensions/music/M1_Music.jsonld"
      ],
      "m0:poleCount": 4,
      "m0:poles": [
        {
          "@id": "m0:Pole_Exposition",
          "rdfs:label": "Pole 1 — Exposition",
          "m0:poleNumber": 1,
          "rdfs:comment": "System initialization. All N voices enter successively with Subject or Answer. Polyphonic texture builds progressively from silence to full N-voice density.",
          "m0:asfid": {
            "A": 0.85,
            "S": 0.95,
            "F": 0.82,
            "I": 0.95,
            "D": 0.7
          }
        },
        {
          "@id": "m0:Pole_Development",
          "rdfs:label": "Pole 2 — Development",
          "m0:poleNumber": 2,
          "rdfs:comment": "System exploration. Episodes modulate through related keys using motivic fragments. Middle Subject entries in foreign keys. System navigates harmonic space.",
          "m0:asfid": {
            "A": 0.72,
            "S": 0.85,
            "F": 0.9,
            "I": 0.92,
            "D": 0.82
          }
        },
        {
          "@id": "m0:Pole_Stretto",
          "rdfs:label": "Pole 3 — Stretto",
          "m0:poleNumber": 3,
          "rdfs:comment": "Structural climax. Subject entries overlap — new voice enters before previous voice completes. Maximum polyphonic density. Climactic tension before final resolution.",
          "m0:asfid": {
            "A": 0.8,
            "S": 0.9,
            "F": 0.88,
            "I": 0.95,
            "D": 0.95
          }
        },
        {
          "@id": "m0:Pole_Resolution",
          "rdfs:label": "Pole 4 — Resolution (Coda)",
          "m0:poleNumber": 4,
          "rdfs:comment": "System closure. Tonic key decisively reestablished. Final Subject entry over pedal point. Authentic cadence V7->I releases all accumulated harmonic tension.",
          "m0:asfid": {
            "A": 0.98,
            "S": 0.88,
            "F": 0.75,
            "I": 0.85,
            "D": 0.6
          }
        }
      ],
      "m0:asfidAnalysis": {
        "m0:attractor": {
          "A": 0.87,
          "description": "Tonic key = global attractor. All harmonic motion departs from and returns to tonic. Consonant intervals = local attractors within voice pairs.",
          "instances": [
            "Global: tonic key (G minor BWV 578, D minor BWV 565)",
            "Local: consonant intervals on strong beats",
            "Micro: leading tone -> tonic (half-step pull)"
          ]
        },
        "m0:structure": {
          "S": 0.9,
          "description": "Multi-layered: N simultaneous voices (vertical) x 4-pole formal lifecycle (horizontal) x Subject/Answer/Countersubject motivic hierarchy.",
          "layers": [
            "Vertical (synchronic): N simultaneous voices",
            "Horizontal (diachronic): 4-pole formal lifecycle",
            "Motivic: Subject / Answer / Countersubject hierarchy"
          ]
        },
        "m0:flow": {
          "F": 0.85,
          "description": "Each voice maintains its own melodic flow trajectory. Stretto phase accelerates to maximum density. Sequential episode patterns create directed momentum.",
          "types": [
            "Melodic: stepwise motion (conjunct) vs leaps (disjunct)",
            "Harmonic: tonal journey across keys",
            "Rhythmic: metric regularity punctuated by syncopations/suspensions"
          ]
        },
        "m0:information": {
          "I": 0.93,
          "description": "The Fugue Subject is the primary information unit — announced once, propagated and transformed throughout. The entire fugue is a single information token unfolding in time.",
          "uniqueness": "The Subject is both system DNA and message — it defines AND constitutes the system content simultaneously"
        },
        "m0:dynamics": {
          "D": 0.88,
          "description": "Tension/resolution cycle is the fundamental dynamic engine. Dissonance = energy injection. Resolution = energy release.",
          "energyCurve": "Exposition(0.4) -> Development(0.6) -> Stretto(0.95) -> Resolution(0.1)"
        }
      },
      "m0:revoiAnalysis": {
        "m0:representability": {
          "R": 0.95,
          "description": "Musical notation = one of humanity's oldest and most precise symbolic systems. A fugue score is a complete, lossless representation. Piano Roll adds temporal visual clarity.",
          "forms": [
            "Staff notation (standard, lossless)",
            "Piano Roll (temporal visualization, simulation-friendly)",
            "MIDI (machine-readable, lossless)",
            "Analytical reduction (Schenkerian, harmonic symbols)"
          ]
        },
        "m0:evolvability": {
          "E": 0.88,
          "description": "600+ years of continuous evolution: strict species counterpoint (Fux) -> Baroque tonal fugue (Bach) -> Romantic chromatic (Wagner, Brahms) -> atonal (Schoenberg) -> jazz modal improvisation (Davis, Hancock). ASFID tensor invariant across all evolutions."
        },
        "m0:verifiability": {
          "V": 0.92,
          "description": "Species counterpoint rules fully explicit and mechanically verifiable. Parallel fifths, parallel octaves, unresolved dissonances algorithmically detectable. Structural poles analytically determinable from score."
        },
        "m0:observability": {
          "O": 0.78,
          "description": "Directly audible + score-transparent + visually observable in Piano Roll simulation. Main limit: untrained listeners cannot consciously isolate individual voices (perceptual fusion). Simulation compensates this limit.",
          "limit": "Auditory stream segregation — untrained listeners fuse voices into single texture (cocktail party effect)"
        },
        "m0:interoperability": {
          "I": 0.82,
          "description": "Bridges harmony theory, formal analysis, orchestration, jazz improvisation, algorithmic composition, cognitive science (auditory scene analysis)."
        }
      },
      "m0:enigmaPattern": {
        "description": "Apparent impossibility: Voice Autonomy and Harmonic Coherence appear mutually exclusive yet coexist through a mandatory ternary mediator structure.",
        "formula": "Voice Autonomy (X) Counterpoint Rule -> Harmonic Coherence",
        "mediator": "CounterpointRule — not a restriction of Autonomy but its enabling condition of co-existence",
        "crossDomainInstances": [
          "Ecology: Species Autonomy (x) Niche Differentiation -> Ecosystem Coherence",
          "Distributed Systems: Process Autonomy (x) Consensus Protocol -> System Consistency",
          "Urban Planning: Individual Freedom (x) Zoning Law -> Functional City",
          "Jazz Ensemble: Improviser Autonomy (x) Shared Harmonic Grid -> Collective Music"
        ],
        "status": "CANDIDATE for m3:Enigma — pending formal TransDisclet validation across 2+ disciplines"
      },
      "m0:crossStyleValidation": [
        {
          "id": "canon_frere_jacques",
