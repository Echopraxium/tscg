{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "m2": "M2_GenericConcepts.jsonld#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "m2gc": "http://www.w3.org/2002/07/owl#"
  },
  "@graph": [
    {
      "@id": "m2:Process",
      "@type": "owl:Class",
      "rdfs:label": "Process",
      "m2:hasStructuralGrammarFormula": "D × I × F"
    },
    {
      "@id": "m2:Memory",
      "@type": "owl:Class",
      "rdfs:label": "Memory",
      "m2:hasStructuralGrammarFormula": "S × I × A"
    },
    {
      "@id": "m2:Coherence",
      "@type": "owl:Class",
      "rdfs:label": "Coherence",
      "m2:hasStructuralGrammarFormula": "A × S × It | R + O | _^",
      "m2:isStereopsic": true
    }
  ]
}