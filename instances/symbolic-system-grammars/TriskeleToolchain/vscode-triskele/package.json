{
  "name": "triskele-debug",
  "displayName": "TriskeleVM Debugger",
  "description": "DAP debug adapter for TriskeleVM .tvmx binaries (tsk-dbg)",
  "version": "0.1.0",
  "publisher": "Echopraxium",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "triskele",
        "label": "TriskeleVM Debug",
        "languages": [
          "tasm"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to .tvmx binary to debug",
                "default": "${workspaceFolder}/src/${fileBasenameNoExtension}.tvmx"
              },
              "symbols": {
                "type": "string",
                "description": "Path to .sym symbol table (generated by tsk-asm --emit-symbols)",
                "default": "${workspaceFolder}/src/${fileBasenameNoExtension}.sym"
              },
              "port": {
                "type": "number",
                "description": "TCP port where tsk-dbg is listening",
                "default": 4711
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at first instruction before running",
                "default": true
              },
              "autoLaunchDebugger": {
                "type": "boolean",
                "description": "Automatically run tsk-dbg before connecting",
                "default": false
              },
              "tskDbgPath": {
                "type": "string",
                "description": "Path to tsk-dbg executable (required if autoLaunchDebugger=true)",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "triskele",
            "request": "launch",
            "name": "Debug .tvmx",
            "program": "${workspaceFolder}/src/${fileBasenameNoExtension}.tvmx",
            "symbols": "${workspaceFolder}/src/${fileBasenameNoExtension}.sym",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "TriskeleVM: Launch",
            "description": "Debug a .tvmx binary with tsk-dbg",
            "body": {
              "type": "triskele",
              "request": "launch",
              "name": "Debug ${1:program}",
              "program": "^\"\\${workspaceFolder}/src/${1:wolf3d_v2_clean}.tvmx\"",
              "symbols": "^\"\\${workspaceFolder}/src/${1:wolf3d_v2_clean}.sym\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "tasm",
        "aliases": [
          "TriskeleASM",
          "tasm"
        ],
        "extensions": [
          ".tasm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tasm",
        "scopeName": "source.tasm",
        "path": "./syntaxes/tasm.tmLanguage.json"
      }
    ]
  }
}