{
  "name": "TriskeleASM",
  "scopeName": "source.tasm",
  "fileTypes": ["tasm"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#directive" },
    { "include": "#label" },
    { "include": "#opcode" },
    { "include": "#register" },
    { "include": "#number" },
    { "include": "#string" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.tasm",
      "match": ";.*$"
    },
    "directive": {
      "name": "keyword.control.directive.tasm",
      "match": "\\.(module|type|section|entry|string|byte|word|dword|qword|align|define)\\b"
    },
    "label": {
      "name": "entity.name.function.label.tasm",
      "match": "^[A-Za-z_][A-Za-z0-9_]*:"
    },
    "opcode": {
      "name": "keyword.other.opcode.tasm",
      "match": "\\b(A_|St_|F_|It_|D_|R_|E_|V_|O_|Im_|T_|Pos_|Neg_|K_|Ss_|L_)[A-Z0-9_]+\\b"
    },
    "register": {
      "name": "variable.other.register.tasm",
      "match": "\\b(R[0-9]+|FP|SP|LR|PC)\\b"
    },
    "number": {
      "patterns": [
        { "name": "constant.numeric.hex.tasm",     "match": "0[xX][0-9A-Fa-f]+" },
        { "name": "constant.numeric.decimal.tasm", "match": "\\b[0-9]+\\b" },
        { "name": "constant.character.tasm",       "match": "'[^'\\\\]'" }
      ]
    },
    "string": {
      "name": "string.quoted.double.tasm",
      "begin": "\"", "end": "\"",
      "patterns": [{ "name": "constant.character.escape.tasm", "match": "\\\\." }]
    }
  }
}
