{
    // VS Code launch configuration for TriskeleVM DAP debugger
    // Place in: .vscode/launch.json at the root of TriskeleToolchain/
    //
    // Usage:
    //   1. cargo build -p tsk-dbg
    //   2. tsk-asm src\wolf3d_v2_clean.tasm --emit-symbols -o src\wolf3d_v2_clean.tvmx
    //   3. F5 → "TriskeleVM: Debug wolf3d"
    "version": "0.2.0",
    "configurations": [
        {
            // ── Wolf3D raycaster debug ────────────────────────────────────────
            "name": "TriskeleVM: Debug wolf3d",
            "type": "triskele",
            "request": "launch",
            "program": "${workspaceFolder}/src/wolf3d_v2_clean.tvmx",
            "symbols": "${workspaceFolder}/src/wolf3d_v2_clean.sym",
            "stopOnEntry": true,
            "debugServer": 4711
        },
        {
            // ── Generic .tvmx debug ───────────────────────────────────────────
            "name": "TriskeleVM: Debug ${fileBasenameNoExtension}",
            "type": "triskele",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}.tvmx",
            "symbols": "${fileDirname}/${fileBasenameNoExtension}.sym",
            "stopOnEntry": true,
            "debugServer": 4711
        }
    ]
}
