; wolf3d_raycaster.tasm
; Author: Echopraxium with the collaboration of Claude AI
; Version: 0.1.0
; Wolf3D-style raycaster — DDA algorithm, fixed-point 16.16

#define SCREEN_W   320
#define SCREEN_H   200
#define FB_SIZE    256000
#define MAP_SIZE   8
#define FOV_HALF   30
#define MAX_STEPS  80

.module  wolf3d
.type    executable

.section .rodata

