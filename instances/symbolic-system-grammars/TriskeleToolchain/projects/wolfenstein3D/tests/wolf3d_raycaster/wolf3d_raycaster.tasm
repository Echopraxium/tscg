.section .code
.entry main

main:
    D_MOV_I  R1, FB_SIZE
    A_ALLOC  R19, R1
    L_LEA    R16, sin_table
    L_LEA    R17, cos_table
    L_LEA    R18, tilemap
    D_MOV_I  R6, 163840
    D_MOV_I  R7, 163840
    D_MOV_I  R5, 0

frame_loop:
    ; Sky: fill top half blue
    D_MOV_I  R1, 57
    D_MOV_I  R2, 128000
    D_MEMSET R19, R1, R2
    ; Floor: fill bottom half dark
    D_MOV_I  R1, 128000
    D_ADD    R1, R19, R1
    D_MOV_I  R2, 40
    D_MOV_I  R3, 128000
    D_MEMSET R1, R2, R3

    D_MOV_I  R4, 0

cast_loop:
    ; ray_angle = player_angle - 30 + col*3/16
    D_MOV    R8, R4
    D_ADD    R8, R8, R4
    D_ADD    R8, R8, R4
    D_SHR    R8, R8, 4
    D_MOV    R9, R5
    D_MOV_I  R3, FOV_HALF
    D_SUB    R9, R9, R3
    D_ADD    R9, R9, R8

    ; Normalize angle
angle_norm:
    V_CMP_I  R9, 0
    F_JGE    angle_pos
    D_MOV_I  R3, 360
    D_ADD    R9, R9, R3
    F_JMP    angle_norm
angle_pos:
    V_CMP_I  R9, 360
    F_JL     angle_ok
    D_MOV_I  R3, 360
    D_SUB    R9, R9, R3
    F_JMP    angle_pos
angle_ok:

    ; Fetch cos/sin: offset = angle*4
    D_MOV    R0, R9
    D_ADD    R0, R0, R0
    D_ADD    R0, R0, R0
    D_ADD    R1, R17, R0
    D_LOAD32 R1, R1, 0
    D_ADD    R2, R16, R0
    D_LOAD32 R2, R2, 0

    ; ray pos = player pos
    D_MOV    R12, R6
    D_MOV    R13, R7
    D_MOV_I  R15, 0

    ; step = cos/8, sin/8
    D_SHR    R10, R1, 3
    D_SHR    R11, R2, 3

dda_loop:
    D_ADD    R12, R12, R10
    D_ADD    R13, R13, R11

    D_SHR    R0, R12, 16
    D_SHR    R3, R13, 16

    V_CMP_I  R0, 0
    F_JL     dda_wall
    V_CMP_I  R0, MAP_SIZE
    F_JGE    dda_wall
    V_CMP_I  R3, 0
    F_JL     dda_wall
    V_CMP_I  R3, MAP_SIZE
    F_JGE    dda_wall

    ; tile = tilemap[y*8+x]
    D_MOV    R14, R3
    D_ADD    R14, R14, R14
    D_ADD    R14, R14, R14
    D_ADD    R14, R14, R14
    D_ADD    R14, R14, R0
    D_ADD    R14, R18, R14
    D_LOAD8  R14, R14, 0

    V_CMP_I  R14, 0
    F_JNZ    dda_wall

    D_ADD_I  R15, 1
    V_CMP_I  R15, MAX_STEPS
    F_JL     dda_loop

dda_wall:
    D_ADD_I  R15, 1
	D_MOV_I  R0, 1600
    D_DIV    R10, R0, R15     ; (1600<<16) / steps — résultat est fixed 16.16
    D_SHR    R10, R10, 16     ; integer part

    V_CMP_I  R10, 200
    F_JLE    clamp_hi_ok
    D_MOV_I  R10, 200
	
clamp_hi_ok:
    V_CMP_I  R10, 1
    F_JGE    clamp_lo_ok
    D_MOV_I  R10, 1
clamp_lo_ok:

    D_MOV_I  R0, 200
    D_SUB    R0, R0, R10
    D_SHR    R0, R0, 1
    D_ADD    R3, R0, R10
    D_MOV    R11, R0

draw_col:
    V_CMP    R11, R3
    F_JGE    draw_col_done

    ; ptr = fb + (y*320+col)*4 = fb + (y*256+y*64+col)*4
    D_MOV    R14, R11
    D_SHL    R0, R14, 8
    D_SHL    R14, R14, 6
    D_ADD    R14, R14, R0
    D_ADD    R14, R14, R4
    D_SHL    R14, R14, 2
    D_ADD    R14, R19, R14

    D_MOV_I  R0, 200
    D_STORE8 R14, R0, 0
    D_MOV_I  R0, 60
    D_STORE8 R14, R0, 1
    D_MOV_I  R0, 60
    D_STORE8 R14, R0, 2
    D_MOV_I  R0, 255
    D_STORE8 R14, R0, 3

    D_ADD_I  R11, 1
    F_JMP    draw_col

draw_col_done:
    D_ADD_I  R4, 1
    V_CMP_I  R4, SCREEN_W
    F_JL     cast_loop

    Im_FB_BLIT  R19
    D_MOV_I     R1, 35
    T_FRAME_SYN R1
    Im_INPUT_RD R11
    V_CMP_I     R11, 0
    F_JNZ       quit
    F_JMP       frame_loop

quit:
    D_MOV_I  R0, 0
    F_HALT