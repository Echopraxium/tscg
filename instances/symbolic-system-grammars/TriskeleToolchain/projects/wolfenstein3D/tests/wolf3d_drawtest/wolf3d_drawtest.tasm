; wolf3d_drawtest.tasm — draw red rectangle test
; Author: Echopraxium with the collaboration of Claude AI

#define SCREEN_W  320
#define SCREEN_H  200
#define FB_SIZE   256000

.module  drawtest
.type    executable
.section .code
.entry   main

main:
    D_MOV_I  R1, FB_SIZE
    A_ALLOC  R19, R1

    ; Fill entire FB grey
    D_MOV_I  R1, 80
    D_MOV_I  R2, FB_SIZE
    D_MEMSET R19, R1, R2

frame_loop:
    ; Draw columns 100..220, rows 50..150 in red
    D_MOV_I  R4, 100       ; col = 100

col_loop:
    V_CMP_I  R4, 220
    F_JGE    col_done

    D_MOV_I  R11, 50       ; y = 50

row_loop:
    V_CMP_I  R11, 150
    F_JGE    row_done

    ; ptr = fb + (y*320 + col) * 4
    ; y*320 = (y<<8) + (y<<6)
    D_MOV    R14, R11
    D_SHL    R0, R14, 8
    D_SHL    R14, R14, 6
    D_ADD    R14, R14, R0
    D_ADD    R14, R14, R4
    D_SHL    R14, R14, 2
    D_ADD    R14, R19, R14

    D_MOV_I  R0, 220
    D_STORE8 R14, R0, 0
    D_MOV_I  R0, 50
    D_STORE8 R14, R0, 1
    D_MOV_I  R0, 50
    D_STORE8 R14, R0, 2
    D_MOV_I  R0, 255
    D_STORE8 R14, R0, 3

    D_ADD_I  R11, 1
    F_JMP    row_loop

row_done:
    D_ADD_I  R4, 1
    F_JMP    col_loop

col_done:
    Im_FB_BLIT  R19
    D_MOV_I     R1, 35
    T_FRAME_SYN R1
    Im_INPUT_RD R11
    V_CMP_I     R11, 0
    F_JNZ       quit
    F_JMP       frame_loop

quit:
    D_MOV_I  R0, 0
    F_HALT