.section .code
.entry main

; Register layout (persistent across frame):
;   R16 = sin_table
;   R17 = cos_table
;   R18 = tilemap
;   R19 = framebuffer
;   R20 = player_x (fixed 16.16)
;   R21 = player_y (fixed 16.16)
;   R22 = player_angle (0..359)
; Per-column (can be clobbered):
;   R4  = col (0..319)
;   R5  = wall_height
;   R6  = top row
;   R7  = bottom row
;   R8  = ray_angle
;   R9,R10,R11,R12,R13,R14,R15 = scratch

main:
    D_MOV_I  R1, FB_SIZE
    A_ALLOC  R19, R1
    L_LEA    R16, sin_table
    L_LEA    R17, cos_table
    L_LEA    R18, tilemap
    D_MOV_I  R20, 229376
    D_MOV_I  R21, 229376
    D_MOV_I  R22, 0

frame_loop:
    ; Clear: sky=grey, floor=dark
    D_MOV_I  R1, 60
    D_MOV_I  R2, 128000
    D_MEMSET R19, R1, R2
    D_MOV_I  R1, 128000
    D_ADD    R1, R19, R1
    D_MOV_I  R2, 35
    D_MOV_I  R3, 128000
    D_MEMSET R1, R2, R3

    D_MOV_I  R4, 0

cast_col:
    ; --- compute ray angle ---
    ; delta = col*3 >> 4
    D_MOV    R8, R4
    D_ADD    R8, R8, R4
    D_ADD    R8, R8, R4
    D_SHR    R8, R8, 4
    D_MOV    R9, R22
    D_MOV_I  R1, FOV_HALF
    D_SUB    R9, R9, R1
    D_ADD    R8, R9, R8

    ; normalize [0..359]
norm_loop:
    V_CMP_I  R8, 0
    F_JGE    norm_pos
    D_MOV_I  R1, 360
    D_ADD    R8, R8, R1
    F_JMP    norm_loop
norm_pos:
    V_CMP_I  R8, 360
    F_JL     norm_ok
    D_MOV_I  R1, 360
    D_SUB    R8, R8, R1
    F_JMP    norm_pos
norm_ok:

    ; --- fetch cos/sin ---
    D_MOV    R9, R8
    D_ADD    R9, R9, R9
    D_ADD    R9, R9, R9
    D_ADD    R10, R17, R9
    D_LOAD32 R10, R10, 0
    D_ADD    R11, R16, R9
    D_LOAD32 R11, R11, 0

    ; step = 1/16 tile = 4096
    D_SHR    R10, R10, 4
    D_SHR    R11, R11, 4

    ; --- DDA ---
    D_MOV    R12, R20
    D_MOV    R13, R21
    D_MOV_I  R15, 0

dda:
    D_ADD    R12, R12, R10
    D_ADD    R13, R13, R11

    ; tile coords — use unsigned shift
    D_SHR    R14, R12, 16
    D_SHR    R9,  R13, 16

    ; bounds [0..7]
    V_CMP_I  R14, 0
    F_JL     hit
    V_CMP_I  R14, MAP_SIZE
    F_JGE    hit
    V_CMP_I  R9, 0
    F_JL     hit
    V_CMP_I  R9, MAP_SIZE
    F_JGE    hit

    ; check tile
    D_MOV    R1, R9
    D_ADD    R1, R1, R1
    D_ADD    R1, R1, R1
    D_ADD    R1, R1, R1
    D_ADD    R1, R1, R14
    D_ADD    R1, R18, R1
    D_LOAD8  R1, R1, 0
    V_CMP_I  R1, 0
    F_JNZ    hit

    D_ADD_I  R15, 1
    V_CMP_I  R15, MAX_STEPS
    F_JL     dda

hit:
    ; wall_height = 1600 / (steps+1)
    D_ADD_I  R15, 1
    D_MOV_I  R1, 1600
    D_DIV    R5, R1, R15
    D_SHR    R5, R5, 16

    ; clamp
    V_CMP_I  R5, 200
    F_JLE    ch_ok
    D_MOV_I  R5, 200
ch_ok:
    V_CMP_I  R5, 1
    F_JGE    cl_ok
    D_MOV_I  R5, 1
cl_ok:

    ; top = (200-height)/2
    D_MOV_I  R1, 200
    D_SUB    R6, R1, R5
    D_SHR    R6, R6, 1
    D_ADD    R7, R6, R5

    ; --- draw column R4, rows R6..R7 ---
    D_MOV    R15, R6

draw_row:
    V_CMP    R15, R7
    F_JGE    next_col

    ; ptr = fb + (y*320+col)*4
    D_MOV    R1, R15
    D_SHL    R2, R1, 8
    D_SHL    R1, R1, 6
    D_ADD    R1, R1, R2
    D_ADD    R1, R1, R4
    D_SHL    R1, R1, 2
    D_ADD    R1, R19, R1

    D_MOV_I  R2, 180
    D_STORE8 R1, R2, 0
    D_MOV_I  R2, 60
    D_STORE8 R1, R2, 1
    D_MOV_I  R2, 40
    D_STORE8 R1, R2, 2
    D_MOV_I  R2, 255
    D_STORE8 R1, R2, 3

    D_ADD_I  R15, 1
    F_JMP    draw_row

next_col:
    D_ADD_I  R4, 1
    V_CMP_I  R4, SCREEN_W
    F_JL     cast_col

    Im_FB_BLIT  R19
    D_MOV_I     R1, 35
    T_FRAME_SYN R1
    Im_INPUT_RD R1
    V_CMP_I     R1, 0
    F_JNZ       done
    F_JMP       frame_loop

done:
    D_MOV_I  R0, 0
    F_HALT