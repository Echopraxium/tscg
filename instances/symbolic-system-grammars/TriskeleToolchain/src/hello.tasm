.module  hello
.type    executable

.section .rodata
msg:  .string "Hello !\n"

.section .code
.entry   main

main:
    L_LEA    R1, msg     ; adresse de la string
	D_MOV_I  R2, 8       ; longueur de "Hello !\n"
loop:
    D_LOAD8  R0, R1, 0   ; char courant
    O_LOG    R0          ; affiche
    D_ADD_I  R1, 1       ; avance
    D_SUB_I  R2, 1       ; décrémente
    V_CMP_I  R2, 0
    F_JNZ    loop
    D_MOV_I  R0, 0
    F_HALT