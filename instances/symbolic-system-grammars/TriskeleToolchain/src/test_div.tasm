; test_div.tasm — test D_DIV (R_FixDiv)
; D_DIV Rdst, Ra, Rb = (Ra << 16) / Rb, then >> 16 for integer
.module  test_div
.type    executable
.section .code
.entry main

main:
    ; Test: 1600 / 5 should = 320
    ; D_DIV gives (1600<<16)/5 = 20971520
    ; then >>16 = 320
    D_MOV_I  R1, 1600
    D_MOV_I  R2, 5
    D_DIV    R3, R1, R2    ; R3 = (1600<<16)/5
    D_SHR    R4, R3, 16    ; R4 = 320
    ; Print hundreds digit: 320/100 = 3
    D_MOV_I  R5, 100
    D_DIV    R6, R4, R5    ; (320<<16)/100
    D_SHR    R6, R6, 16    ; 3
    D_MOV_I  R7, 48
    D_ADD    R7, R7, R6
    O_LOG    R7             ; '3'
    D_MOV_I  R7, 10
    O_LOG    R7
    D_MOV_I  R0, 0
    F_HALT
