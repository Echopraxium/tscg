    "m0.triskeleToolchain": "https://raw.githubusercontent.com/Echopraxium/tscg/main/instances/symbolic-system-grammars/TriskeleToolchain/M0_TriskeleToolchain.jsonld#"
  },
  "@graph": [
    {
      "@id": "instances/symbolic-system-grammars/TriskeleToolchain/M0_TriskeleToolchain.jsonld",
      "@type": "owl:Ontology",
      "owl:imports": [
        "M0_Common.jsonld",
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:SymbolicSystemGrammar"
      },
      "rdfs:label": "TriskeleToolchain — Symbolic System Grammar",
      "rdfs:comment": "A computation-oriented Symbolic System Grammar grounded in the TSCG M3 Structural Grammar. The 16 monoidal primitives of the three TSCG grammars (Gt/ASFID × 5, Gm/REVOI × 5, Gs/TKSL × 6) form a Base16 encoding alphabet that defines: (1) TriskeleVM — a register-based virtual machine whose ISA encodes 256 opcodes via 16 primitive categories × 16 instructions; (2) TriskeleL — a high-level language grounded in M2 GenericConcept semantics compiled to TriskeleVM bytecode. Proof-of-concept target: running Wolfenstein 3D (and subsequently Doom) via a C compiler targeting TriskeleVM bytecode.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-05-30",
      "owl:versionInfo": "0.3.0",
      "m1:domain": "Virtual machine design, compiler theory, symbolic computation, formal grammars, game engine",
      "dcterms:modified": "2026-05-30",
      "m0:asfidMean": 0.9,
      "m0:revoiMean": 0.864,
      "m0:epistemicGap": 0.0255,
      "m0:spectralClass": {
        "@id": "m0:spectralClass.Coherent"
      },
      "m0:spectralClassNote": "δ₁ = |0.90 − 0.864| / √2 = 0.0255. High S_score (0.95) reflects the rigorous structural specification of ISA, format .tvm and register file. High It_score (0.92) reflects the information-theoretic grounding (Base16 = log₂(16) = 4 bits per symbol). V_score (0.82) is lower than R/E/O because formal verification of the full toolchain is pending (Wolf3D PoC not yet executed). Im_score (0.87) reflects the SDL2/FFI interoperability design — high but not maximal since native bindings are not yet validated.",
      "m2:changelog": [
        {
          "version": "0.3.0",
          "date": "2026-06-26",
          "changes": "ACTION3: Added m0:focalApplicable=true."
        },
        {
          "version": "0.2.0",
          "date": "2026-05-31",
          "changes": "ISA mapping revised v0.2.0: A_=Pile+Tas, St_=Types/NOP, F_=FluxExec+coroutines, It_=EtatInfo+events+IRQ, D_=Modification(MOV/LOAD/ADD/AND), E_=AutoTransform+GCadaptatif, L_FAR_CALL=L_(not F_). Mandatory indexed notation St_/It_/Ss_/Im_ throughout. Ss_ = identifiants+constantes predefinies (signe pas valeur). Pole symmetry _^_/_ formalized."
        },
        {
          "version": "0.1.0",
          "date": "2026-05-30",
          "changes": "Initial release. Full TriskeleToolchain specification: Base16 alphabet, ISA (256 opcodes / 16 categories), .tvm/.tvx binary format, register file (32x64-bit), calling convention, tsk-asm/tsk-dis/tsk-link specs, TSCG annotation sections, ASFID/REVOI analysis, 18 M2 GenericConcepts. PoC target: Wolfenstein 3D -> Doom."
        }
      ],
      "m0:grammarSpec": {
        "m0:primitiveCount": 16,
        "m0:categoryCount": 3,
        "m0:opcodeCount": 256,
        "m0:grammarLevel": 2,
        "m0:base": "Base16 — 16 M3 monoidal primitives as encoding alphabet",
        "m0:status": "SPECIFICATION — implementation pending",
        "m0:base16Isomorphism": "TriskeleBase16 ≅ {Gt(5) ∪ Gm(5) ∪ Gs(6)} = 16 — bijection with 4-bit nibble space",
        "m0:semanticSignature": "finite_primitives(16_M3_types) + combination_rules(ISA_opcodes + .tvm_format) + multiple_legitimate_interpretations(VM_bytecode + high_level_language)"
      },
      "m0:ssgValidation": {
        "m0:criterion_finite_primitives": "VALIDATED — 16 primitives: A S F It D (Gt) + R E V O Im (Gm) + T _^ _$ K Ss L (Gs)",
        "m0:criterion_combination_rules": "VALIDATED — 3 explicit rule sets: (1) ISA encoding [category nibble | instruction nibble]; (2) .tvm binary format (header + sections + relocation); (3) calling convention (R0-R7 args, R28 FP, R30 LR)",
        "m0:criterion_multiple_interpretations": "VALIDATED — same Base16 alphabet generates: TriskeleVM bytecode (M3 layer), TriskeleL source semantics (M2 layer), .tvm metadata annotations (M0 layer)",
        "m0:criterion_symbolic_arbitration": "VALIDATED — opcode semantics arbitrated by M3 primitive identity (e.g. 0x2_ = F/Flow → all arithmetic; 0x9_ = Im/Interop → all FFI/syscalls)",
        "m0:distinctionFromPoclet": "Models a symbolic computation universe (formal grammar + VM), not a directly observable real-world physical system",
        "m0:distinctionFromSystemicFramework": "Generates a productive combinatorial space (256 opcodes, infinite programs) rather than converging toward a unique solution",
        "m0:distinctionFromIChing": "TriskeleToolchain is an executable grammar — its combinations (programs) produce deterministic computational results, unlike I Ching whose combinations produce symbolic interpretations"
      },
      "m0:architectureSpec": {
        "m0:vmParadigm": "Register-based (inspired by LuaVM simplicity + CLR C-interop)",
        "m0:instructionFormat": "32-bit fixed-width (3 types: R/I/J)",
        "m0:registerCount": 32,
        "m0:registerWidth": "64-bit",
        "m0:addressSpace": "64-bit linear",
        "m0:endianness": "little-endian",
        "m0:callingConvention": "C-compatible cdecl / System V AMD64 ABI",
        "m0:gcStrategy_phase1": "Manual (P_ALLOC / N_FREE) — Wolf3D PoC",
        "m0:gcStrategy_phase2": "Reference counting + cycle detector — TriskeleL",
        "m0:concurrencyModel": "Cooperative coroutines (D_SAVE_CTX / D_REST_CTX)"
      },
      "m0:isaSpec": {
        "m0:totalOpcodes": 256,
        "m0:categories": 16,
        "m0:instructionsPerCategory": 16,
        "m0:encodingScheme": "[4-bit M3 category | 4-bit instruction index]",
        "m0:categoryMapping": {
          "0x0_ A_": "A_  (Attractor/Gt)  — Pile+Tas: PUSH,POP,ALLOC,FREE,STACK_F,ENTER,LEAVE",
          "0x1_ St_": "St_ (Structure/Gt)  — Types/layout/NOP: DEF_STRUCT,SIZEOF,FIELD_OFF,PACK",
          "0x2_ F_": "F_  (Flow/Gt)       — Flux exec+coroutines: JMP,CALL,RET,JZ,LOOP,SWITCH,HALT,YIELD",
          "0x3_ It_": "It_ (Information/Gt)— Etat info+events+IRQ: DEF_FLAG,SET_FLAG,EMIT,SUBSCRIBE,IRQ_ON",
          "0x4_ D_": "D_  (Dynamics/Gt)   — Modification: MOV,LOAD,STORE,MEMCPY,ADD,SUB,MUL,AND,OR,XOR",
          "0x5_ R_": "R_  (Represent./Gm) — Conversions: I2F,F2I,SIGN,ZERO,FIX2F,PACK",
          "0x6_ E_": "E_  (Evolvability/Gm)— Auto-transform+GC adaptatif: LOAD_MOD,HOOK,PATCH,GC_CFG,MEM_POOL",
          "0x7_ V_": "V_  (Verifiab./Gm)  — Verification: CMP,EQ,LT,GT,ASSERT,RANGE,NULL",
          "0x8_ O_": "O_  (Observ./Gm)    — Debug/introspection: DUMP,TRACE,BREAK,WATCH,PERF,LOG",
          "0x9_ Im_": "Im_ (Interop./Gm)   — FFI/syscalls: SYSCALL,FFI_CALL,FB_BLIT,REGISTER_CB,EXIT",
          "0xA_ T_": "T_  (Temporality/Gs)— Timing: TICK,WAIT,FRAME_SYN,TIMER,ATOMIC,BARRIER",
          "0xB_ _^_": "_^_ (PosPole/Gs)    — Creation/onset: NEW_OBJ,SPAWN,OPEN_CH,LOCK,ARENA_B",
          "0xC_ _": "_ (NegPole/Gs)    — Destruction/terminus: DEL_OBJ,KILL,CLOSE_CH,UNLOCK,ARENA_E",
          "0xD_ K_": "K_  (Knowledge/Gs)  — Reflexion: TYPEOF,SIZEOF,IS_A,ANN_GET,SCHEMA,VALIDATE",
          "0xE_ Ss_": "Ss_ (Symbol/Gs)     — Signes/identifiants: INTERN,LOOKUP,HASH,PI,NULL_T,ADDR_CODE",
          "0xF_ L_": "L_  (Localiz./Gs)   — Adressage: LEA,ADDR,IDX,DEREF,BOUND_CHK,FAR_CALL,FAR_JMP"
        },
        "m0:wolfenstein3dCriticalOpcodes": [
          "Im_FB_BLIT (0x92)    — blit framebuffer to SDL2 screen",
          "T_FRAME_SYN (0xA6)   — synchronize to 35fps target",
          "D_FIXMUL (D_*)        — fixed-point 16.16 multiply (raycaster)",
          "D_MEMCPY (0x4C)       — fast framebuffer copy",
          "D_MEMSET (0x4D)       — screen clear",
          "F_LOOP (0x2B)         — raycaster column loop",
          "Im_REGISTER_CB (0x99) — SDL2 event callbacks",
          "L_FAR_CALL (0xFE)     — SDL2 calls beyond ±8MB",
          "_^_ARENA_B (0xBE)     — Z_Malloc arena (Doom Phase 2)",
          "_ (0xCC)     — arena bulk release"
        ],
        "m0:notationConvention": {
          "m0:rule": "Always use indexed form — St_ It_ Ss_ Im_ — never S_ I_",
          "m0:pairs": {
            "St_": "Structure (Territory/Gt) — never S_",
            "It_": "Information (Territory/Gt) — never I_ or It",
            "Ss_": "Symbol (Stereopsis/Gs) — never S_",
            "Im_": "Interoperability (Map/Gm) — never I_ or Im"
          },
          "m0:rationale": "Mirrors M3 hybrid formula notation — St/It/O indexed to prevent ambiguity with Ss (Symbol/Gs)"
        }
      },
      "m0:tvmFormatSpec": {
        "m0:magic": "TSKV",
        "m0:encoding": "Base16 Triskele (all sections except .raw)",
        "m0:sectionTypes": [
          ".code   — executable bytecode (M3 tag: F/Flow)",
          ".rodata — constants, lookup tables (M3 tag: It/Information)",
          ".data   — initialized globals (M3 tag: S/Structure)",
          ".bss    — uninitialized globals (size only)",
          ".symtab — symbol table with TSCG M2 tags (M3 tag: Ss/Symbol)",
          ".strtab — string table",
          ".reltab — relocations (M3 tag: L/Localizability)",
          ".tscg   — TSCG semantic annotations (M3 tag: K/Knowledge)",
          ".import — FFI declarations (M3 tag: Im/Interoperability)",
          ".debug  — debug information (M3 tag: O/Observability)",
          ".raw    — raw binary assets (no M3 tag — raw binary)"
        ],
        "m0:uniqueFeature": "TSCG annotation section (.tscg) maps code ranges to M2 GenericConcept IRIs — enables semantic hover in VS Code plugin and TscgPocletMiner analysis of bytecode"
      },
      "m0:toolchainComponents": {
        "m0:tsk_asm": {
          "role": "Assembler — Triskele assembly → .tvm",
          "produces": [
            ".code",
            ".symtab",
            ".strtab",
            ".reltab"
          ],
          "phase": 1
        },
        "m0:tsk_dis": {
          "role": "Disassembler — .tvm → human-readable assembly with Base16 Triskele semantics",
          "phase": 1
        },
        "m0:tsk_link": {
          "role": "Linker — merge .tvm modules, resolve relocations, generate .import for FFI",
          "phase": 1
        },
        "m0:tsk_cc": {
          "role": "C compiler — C subset → .tvm (Wolf3D / Doom target)",
          "phase": 2
        },
        "m0:tsk_dbg": {
          "role": "Debugger — DAP server for VS Code, reads .tscg annotations, displays Base16 Triskele register values with M3 semantics",
          "phase": 2
        },
        "m0:tsk_lsp": {
          "role": "Language Server — LSP server for TriskeleL and Triskele assembly in VS Code",
          "phase": 3
        },
        "m0:triskele_vm": {
          "role": "Virtual Machine — register-based interpreter (Rust), loads .tvm, executes bytecode, manages FFI to SDL2",
          "language": "Rust",
          "phase": 1
        },
        "m0:triskele_l": {
          "role": "High-level language grounded in M2 GenericConcept semantics — compiled to TriskeleVM bytecode",
          "layer": "M2 GenericConcepts",
          "phase": 4
        },
        "m0:vscode_plugin": {
          "role": "VS Code extension — syntax highlighting, DAP client (tsk-dbg), LSP client (tsk-lsp), M3 hex grid webview, TSCG semantic hover",
          "technology": "TypeScript + VS Code Extension API",
          "phase": 2
        }
      },
      "m0:tscgGrounding": {
        "m0:m3Layer": "ISA Base16 encoding — 16 monoidal primitives as opcode categories",
        "m0:m2Layer": "TriskeleL semantics — GenericConcepts as language constructs (future Phase 4)",
        "m0:base16Validation": "The 3 new Gs primitives (K, Ss, L) that resolve 17 formula collisions in M2 are the same 3 primitives that complete the Base16 ISA — retroactive structural validation of the Gs extension",
        "m0:brainfuckDistinction": "Unlike arbitrary instruction sets, each TriskeleVM opcode category is semantically motivated by its M3 primitive identity — the ISA is deduced from the Structural Grammar, not invented ad hoc",
        "m0:pocTarget": "Wolfenstein 3D (Phase 1) → Doom (Phase 2) — empirical proof that the 16 M3 primitives suffice to encode a complete, performant, game-capable ISA"
      },
      "m0:GenericConceptsMobilized": {
        "m0:total": 18,
        "m0:conceptList": [
          {
            "@id": "m2:Process",
            "role": "bytecode execution — sequential instruction processing (F category opcodes)"
          },
          {
            "@id": "m2:Structure",
            "role": ".tvm format — hierarchical section organization"
          },
          {
            "@id": "m2:Layer",
            "role": "toolchain layers — asm/link/compile/VM/language stacked abstraction"
          },
          {
            "@id": "m2:Component",
            "role": "toolchain components — tsk-asm, tsk-dis, tsk-link, tsk-cc, tsk-dbg"
          },
          {
            "@id": "m2:Channel",
            "role": "FFI channel — Im_FFI_CALL / Im_REGISTER_CB between VM and SDL2"
          },
          {
            "@id": "m2:Code",
            "role": "Base16 Triskele encoding — symbolic representation of binary data"
          },
          {
            "@id": "m2:Signature",
            "role": "calling convention — function ABI (args R0-R7, return R0)"
          },
          {
            "@id": "m2:Symbol",
            "role": ".symtab entries — name → address mappings with TSCG M2 tags"
          },
          {
            "@id": "m2:Language",
            "role": "TriskeleL — high-level language grounded in M2 GenericConcepts"
          },
          {
            "@id": "m2:Agent",
            "role": "TriskeleVM runtime — autonomous execution agent"
          },
          {
            "@id": "m2:Pattern",
            "role": "ISA encoding pattern — [category nibble | instruction nibble]"
          },
          {
            "@id": "m2:Node",
            "role": "register file nodes — 32 register slots in execution graph"
          },
          {
            "@id": "m2:Topology",
            "role": ".tvm section topology — linear ordered section layout"
          },
          {
            "@id": "m2:Constraint",
            "role": "calling convention constraints — register save rules, stack alignment"
          },
          {
            "@id": "m2:Homeostasis",
            "role": "T_FRAME_SYN — maintains stable 35fps render rate (Wolf3D)"
          },
          {
            "@id": "m2:Interoperability",
            "role": "Im_ opcode category — FFI, syscalls, SDL2 bindings"
          },
          {
            "@id": "m2:ValueSpace",
            "role": "Base16 Triskele — defines the encoding space for all constants"
          },
          {
            "@id": "m2:Coherence",
            "role": "δ₁ epistemic gap — measures alignment between ISA design (map) and execution behavior (territory)"
          }
        ]
      },
      "m0:focalApplicable": true
    },
    {
      "@id": "m0:Base16Alphabet",
      "@type": "owl:Class",
      "rdfs:label": "Base16 Triskele Alphabet",
      "rdfs:comment": "The 16 M3 monoidal primitives used as encoding symbols. Each symbol is simultaneously a 4-bit nibble (computational role) and an M3 primitive (semantic role). Three sub-alphabets corresponding to the three TSCG monoidal grammars.",
      "m0:totalSymbols": 16,
      "m0:subAlphabets": {
        "Gt_ASFID": {
          "symbols": [
            "A",
            "S",
            "F",
            "It",
            "D"
          ],
          "count": 5,
          "operator": "×",
          "hex": [
            "0x0",
            "0x1",
            "0x2",
            "0x3",
            "0x4"
          ]
        },
        "Gm_REVOI": {
          "symbols": [
            "R",
            "E",
            "V",
            "O",
            "Im"
          ],
          "count": 5,
          "operator": "+",
          "hex": [
            "0x5",
            "0x6",
            "0x7",
            "0x8",
            "0x9"
          ]
        },
        "Gs_TKSL": {
          "symbols": [
            "T",
            "_^",
            "_$",
            "K",
            "Ss",
            "L"
          ],
          "count": 6,
          "operator": "|",
          "hex": [
            "0xA",
            "0xB",
            "0xC",
            "0xD",
            "0xE",
            "0xF"
          ]
        }
      },
      "m0:informationContent": "log₂(16) = 4 bits per symbol — one nibble",
      "m0:asymmetryNote": "5-5-6 distribution reflects the natural extension of Gs required to resolve 17 formula collisions in M2 GenericConcepts — the Base16 completeness is a consequence of the M2 expressivity requirement, not an arbitrary design choice"
    },
    {
