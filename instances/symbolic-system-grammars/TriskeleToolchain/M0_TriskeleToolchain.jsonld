      "rdfs:comment": "Register-based virtual machine grounded in M3 Structural Grammar. ISA uses Base16 Triskele as opcode encoding: high nibble = M3 primitive category, low nibble = instruction index within category. Inspired by LuaVM (simplicity, register-based) and CLR (C interoperability, multi-language).",
      "m0:paradigm": "register-based",
      "m0:registers": 32,
      "m0:registerWidth": "64-bit",
      "m0:opcodeSpace": 256,
      "m0:instructionWidth": "32-bit fixed",
      "m0:implementationLanguage": "Rust",
      "m0:grounding": "M3 Structural Grammar — Gt × Gm × Gs"
    },
    {
      "@id": "m0:TriskeleL",
      "@type": "owl:Class",
      "rdfs:label": "TriskeleL (high-level language)",
      "rdfs:comment": "High-level programming language whose constructs are grounded in M2 GenericConcept semantics. Compiled to TriskeleVM bytecode. Analogous to Java targeting JVM. Phase 4 — after Wolf3D PoC validated.",
      "m0:grounding": "M2 GenericConcepts",
      "m0:compilesTo": "TriskeleVM bytecode (.tvm)",
      "m0:phase": 4,
      "m0:status": "PLANNED"
    },
    {
      "@id": "m0:TVMFormat",
      "@type": "owl:Class",
      "rdfs:label": ".tvm Binary Format",
      "rdfs:comment": "Binary container format for TriskeleVM executables and libraries. All structural metadata encoded in Base16 Triskele. Raw binary assets (textures, sounds, native libraries) stored in .raw section. Magic: TSKV.",
      "m0:magic": "TSKV",
      "m0:encoding": "Base16 Triskele (structural) + raw binary (assets)",
      "m0:uniqueSection": ".tscg — TSCG semantic annotation section mapping code ranges to M2 GenericConcept IRIs",
