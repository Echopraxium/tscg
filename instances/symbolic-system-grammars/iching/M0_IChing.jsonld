      "m3:ontologyType": {
        "@id": "m3:SymbolicSystemGrammar"
      },
      "rdfs:label": "I Ching (易經) — Symbolic System Grammar",
      "rdfs:comment": "3000-year-old Chinese divination and philosophical system. Minimal binary grammar (2 primitives: Yin/Yang) generates 8 trigram archetypes and 64 hexagrams via systematic stacking. Each hexagram is a unique symbolic signature of a situation with multiple legitimate interpretations. Changing-line mechanism encodes temporal dynamics.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-02-20",
      "owl:versionInfo": "1.1.1",
      "m1:domain": "Symbolic divination, Chinese cosmology, comparative mythology, decision theory",
      "dcterms:modified": "2026-02-20",
      "A_score": {
        "@value": "0.85",
        "@type": "xsd:float"
      },
      "S_score": {
        "@value": "0.97",
        "@type": "xsd:float"
      },
      "F_score": {
        "@value": "0.72",
        "@type": "xsd:float"
      },
      "It_score": {
        "@value": "0.91",
        "@type": "xsd:float"
      },
      "D_score": {
        "@value": "0.8",
        "@type": "xsd:float"
      },
      "R_score": {
        "@value": "0.95",
        "@type": "xsd:float"
      },
      "E_score": {
        "@value": "0.88",
        "@type": "xsd:float"
      },
      "V_score": {
        "@value": "0.5",
        "@type": "xsd:float"
      },
      "O_score": {
        "@value": "0.78",
        "@type": "xsd:float"
      },
      "Im_score": {
        "@value": "0.9",
        "@type": "xsd:float"
      },
      "m0:asfidMean": {
        "@value": "0.85",
        "@type": "xsd:float"
      },
      "m0:revoiMean": {
        "@value": "0.802",
        "@type": "xsd:float"
      },
      "m0:epistemicGap": {
        "@value": "0.0339",
        "@type": "xsd:float"
      },
      "m0:spectralClass": "Coherent",
      "m0:spectralClassNote": "δ₁ = |0.85−0.802| / √2 = 0.0339. The intentional V_score=0.50 (symbolic non-falsifiability) is the SSG's defining feature — this is by design, not a modeling error. Despite low V, the overall gap is small because R, Im, and S compensate.",
      "m2:changelog": [
        {
          "version": "1.1.1",
          "date": "2026-06-26",
          "changes": "ACTION3: Added m0:focalApplicable=true."
        },
        {
          "version": "1.1.0",
          "date": "2026-02-20",
          "changes": "SymbolicArbitration reclassified as m2:Observer.validationMode attribute. GenerativeExhaustion reclassified as m2:Representation.spaceCoverage=1.0. GenesisSpace → GenesisGrammar migration. Scores moved to root level."
        },
        {
          "version": "1.0.0",
          "date": "2026-02-20",
          "changes": "Initial release. Full grammar specification: 2 primitives, 8 trigram archetypes, 64 hexagram combinatorial space. ASFID/REVOI analyses. M2 GenericConcept activation."
        }
      ],
      "m0:grammarSpec": {
        "m0:primitiveCount": 2,
        "m0:archetypeCount": 8,
        "m0:combinationCount": 64,
        "m0:grammarLevel": 3,
        "m0:dynamicMechanism": "changing lines (动爻) → hexagram transformation",
        "m0:status": "VALIDATED",
        "m0:binaryIsomorphism": "I Ching ≅ {Yin,Yang}⁶ = 2⁶ = 64 — bijection with 6-bit binary space",
        "m0:semanticSignature": "finite_primitives(Yin,Yang) + combination_rules(trigram_stacking) + multiple_legitimate_interpretations(symbolic_arbitration)"
      },
      "m0:ssgValidation": {
        "m0:criterion_finite_primitives": "VALIDATED — 2 primitives (Yin, Yang)",
        "m0:criterion_combination_rules": "VALIDATED — 2 explicit rules: trigram (3×line), hexagram (2×trigram)",
        "m0:criterion_multiple_interpretations": "VALIDATED — 4 semantic layers generating distinct yet valid readings",
        "m0:criterion_symbolic_arbitration": "VALIDATED — validity determined by symbolic coherence, not empirical prediction",
        "m0:distinctionFromPoclet": "Models a symbolic universe, not an observable real-world system",
        "m0:distinctionFromSystemicFramework": "Generates interpretive multiplicity rather than converging toward a solution"
      },
      "m0:focalApplicable": true
    },
    {
      "@id": "m0:Primitive",
      "@type": "owl:Class",
      "rdfs:label": "Primitive (Elementary Line)",
      "rdfs:comment": "Two indivisible atomic elements: Yang (undivided ⚊) and Yin (divided ⚋)."
    },
    {
      "@id": "m0:primitive_yang",
      "@type": [
        "m0:Primitive"
      ],
      "rdfs:label": "Yang — Undivided Line (⚊)",
      "m0:grammarLevel": 0,
      "m0:symbol": "⚊",
      "m0:chineseName": "陽",
      "m0:binaryValue": "1",
      "m0:nature": "solid, undivided, active, creative, light",
      "m0:youngForm": "Young Yang (少陽) — stable",
      "m0:oldForm": "Old Yang (老陽) — changes to Yin"
    },
    {
      "@id": "m0:primitive_yin",
      "@type": [
        "m0:Primitive"
      ],
      "rdfs:label": "Yin — Divided Line (⚋)",
      "m0:grammarLevel": 0,
      "m0:symbol": "⚋",
      "m0:chineseName": "陰",
      "m0:binaryValue": "0",
      "m0:nature": "broken, divided, receptive, yielding, dark",
      "m0:youngForm": "Young Yin (少陰) — stable",
      "m0:oldForm": "Old Yin (老陰) — changes to Yang"
    },
    {
      "@id": "m0:rule_trigram_formation",
      "@type": [
        "owl:Class"
      ],
      "rdfs:label": "Trigram Formation Rule",
      "m0:rule": "Stack 3 primitives (bottom→middle→top) → trigram",
      "m0:formula": "{Yin,Yang}³ → 2³ = 8 distinct trigrams",
      "m0:resultCount": 8
    },
    {
      "@id": "m0:rule_hexagram_formation",
      "@type": [
        "owl:Class"
      ],
      "rdfs:label": "Hexagram Formation Rule",
      "m0:rule": "Stack 2 trigrams (lower inner + upper outer) → hexagram",
      "m0:formula": "H(lower, upper) = T_lower × T_upper",
      "m0:formalExpression": "H(i,j) = T_i ⊗ T_j, i,j ∈ {1..8} → 8×8 = 64 unique hexagrams",
      "m0:resultCount": 64,
      "m0:coverageProperty": "exhaustive — 64 hexagrams partition {0,1}⁶"
    },
    {
      "@id": "m0:rule_changing_lines",
      "@type": [
        "owl:Class"
      ],
      "rdfs:label": "Changing Lines Rule (Dynamic Transformation)",
      "m0:rule": "Old Yang (×) → Young Yin; Old Yin (×) → Young Yang",
      "m0:formula": "H_primary → (changing lines) → H_derived",
      "m0:semantics": "Primary hexagram = present; derived hexagram = emerging future",
      "m0:transitions": "64 × 64 = 4096 possible situational transitions"
    },
