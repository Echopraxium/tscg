      "m0:systemDescription": {
        "name": "Nakamoto Consensus Network",
        "type": "Non-Equilibrium Dissipative Structure",
        "domain": "Distributed Systems / Statistical Physics / Information Theory",
        "abstract": "The Bitcoin blockchain as a 1D growing network L of length N(t) evolving under dissipative forcing. Consensus emerges as a continuous phase transition between a high-entropy disordered phase (mempool) and a low-entropy ordered phase (blockchain), analogous to liquid-crystallization. The ledger is a dissipative structure whose low entropy is preserved far from equilibrium only through continuous consumption of work.",
        "scope": "Proof-of-Work systems with Nakamoto-style longest-chain selection. Phenomenological — not microscopic derivation.",
        "keyInsight": "Blockchain immutability is not absolute but thermodynamically robust — rewriting history requires overcoming a ΔF barrier that grows exponentially with depth and diverges beyond physically realizable bounds."
      },
      "m0:isomorphismDictionary": {
