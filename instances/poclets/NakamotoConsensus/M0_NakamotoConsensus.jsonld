      "m0:masterEquations": {
        "description": "4 master equations of the poclet",
        "effectiveTemperature": {
          "formula": "kBTeff(t) = Pnet(t) · τL",
          "meaning": "Thermal noise = blind energy dissipated during geographic latency window τL",
          "variables": {
            "kB": "Boltzmann constant",
            "Teff": "effective information temperature [K]",
            "Pnet": "total network power [W]",
            "τL": "network propagation latency [s]"
          }
        },
        "criticalBlockSize": {
          "formula": "VB,crit ≈ Ceff · (τB/Γc − τ0)",
          "meaning": "Protocol-dependent upper bound on block volume — exceeding it pushes network beyond thermal percolation limit",
          "variables": {
            "Ceff": "effective global channel capacity [B/s]",
            "τB": "target block interval [s] ≈ 600s",
            "Γc": "critical latency ratio ≈ 10",
            "τ0": "geometric delay floor [s]",
            "γ": "validation-time coefficient [s/B] — irreducible even at infinite bandwidth"
          }
        },
        "probabilisticFinality": {
          "formula": "Preorg(z) = (q/p)^z = e^{−z/ξ}",
          "massGap": "ξ⁻¹ = ln(p/q)",
          "meaning": "Reorganization probability decays exponentially with depth z. 6-block rule = 13ξ for standard attacker (q=0.1)",
          "variables": {
            "z": "confirmation depth [blocks]",
            "p": "honest network hashrate share",
            "q": "attacker hashrate share",
            "xi": "correlation length [blocks]"
          }
        },
        "nakaomotoAction": {
          "formula": "SPoW(t1,t2) = τB · ∫[t1→t2] Pnet(t) dt",
          "meaning": "Accumulated consensus action — ledger inertia scale. The heaviest chain maximizes SPoW.",
          "variables": {
            "tau_B": "target block interval [s]",
            "Pnet": "total network power [W]",
            "SPoW": "Nakamoto consensus action [J·s]"
          },
          "phenomenologicalMass": "M_eff^(phen) = SPoW / (e_mfg · τB) [kg]"
        }
      },
