      "m0:analogyToFireTriangle": {
        "structuralSimilarity": {
          "both": "3-component synergistic systems",
          "FireTriangle": "Fuel  ⊗  O₂  ⊗  Heat → Fire",
          "ExposureTriangle": "ISO  ⊗  Aperture  ⊗  Shutter → Correct Exposure"
        },
        "removalTest": {
          "FireTriangle": "Remove ANY component → Fire stops (all necessary)",
          "ExposureTriangle": "Set ANY parameter to extreme → No usable image (ISO=0, f/∞, T=0)"
        },
        "balanceVsSynergy": {
          "FireTriangle": "Synergy dominant (emergent fire from chemical reaction)",
          "ExposureTriangle": "Balance dominant (equilibrium of light capture parameters)"
        },
        "pedagogy": {
          "both": "Universal teaching tools in their domains",
          "FireTriangle": "Fire safety training worldwide",
          "ExposureTriangle": "Photography education worldwide"
        },
        "mapTerritory": {
          "both": "Simple Maps of complex Territory",
          "FireTriangle": "Omits chain reaction → Fire Tetrahedron (evolved)",
          "ExposureTriangle": "Omits scene luminance, metering → Could extend to Square/Pentagon"
        }
      },
      "m0:validation": {
        "asfidCompleteness": "All 5 dimensions present ✅",
        "GenericConceptCoverage": "22 GenericConcepts (31% of M2) ✅",
        "minimality": "Exactly 3 components (irreducible for exposure control) ✅",
        "emergence": "Correct exposure emerges from parameter balance ✅",
        "balanceTradeoffValidated": "Balance and Trade-off fully validated in M2 (v15.1.0) ✅",
        "newGenericConceptsV1_1": "Amplification (ISO gain), FeedbackLoop (metering), Polarity (stops scale), Behavior (photographer routine) ✅",
        "transdisciplinaryPotential": "Balance and Trade-off validated across 8 domains each ✅"
      },
      "m0:sampleImage": {
        "filename": "photo_sample.jpg",
        "description": "Autumn maple leaves on wet cobblestones (Antwerp, Belgium). Used as reference image in exposure-triangle_sim.py to illustrate live photo effects driven by the three exposure parameters.",
        "simulationEffects": {
          "ISO": "Grain/noise overlay — intensity proportional to ISO stops above 100. Max amplitude ~55 pixels at ISO 6400.",
          "Aperture": "Vignette darkening at edges — active for f-number below f/4. Represents shallow depth-of-field (DoF) effect. Strength reaches 70% at f/1.4.",
          "ShutterSpeed": "Horizontal motion blur (camera-shake simulation) — onset at 1/50s, grows with exposure time. Represents hand-held camera shake. Up to 40-pixel kernel at 2s."
        },
        "baseline": {
          "ISO": 400,
          "aperture": "f/5.6",
          "shutterSpeed": "1/250s",
          "description": "Settings at which the image appears correctly exposed (EV offset = 0). Any deviation introduces the corresponding visual effect."
        },
        "asfidLink": "I (Information) — the photograph encodes scene luminance, color, spatial structure. Each slider parameter modulates a different ASFID dimension.",
        "revoiLink": "V (Verifiability) — immediate visual feedback verifies the Triangle model predictions: change any parameter → instant visible consequence on the image."
      },
      "m0:changelog": {
        "v1.2.0": {
          "date": "2026-02-24",
          "description": "Added m0:sampleImage property (photo_sample.jpg — autumn leaves on cobblestones). Documents baseline exposure settings (ISO 400 / f5.6 / 1/250s) and simulation effects: ISO→noise, Aperture→vignette (DoF), Shutter→motion blur. Added exposure-triangle_sim.py Pygame simulation with live photo effects driven by poclet data (ASFID/REVOI from JSON-LD) and interactive sliders."
        },
        "v1.1.0": {
          "date": "2026-02-21",
          "description": "Synchronized with M2 v15.4.0 and M3 v3.5.0. (1) Author field corrected. (2) ORIVE → REVOI terminology update throughout (oriveAnalysis → revoiAnalysis, state vector reordered R/E/V/O/I). (3) Tensor formula spacing normalized (A⊗S⊗F → A ⊗ S ⊗ F). (4) Balance and Trade-off no longer labeled '(NEW)' — now established M2 GenericConcepts. (5) Added 4 new GenericConcepts: Amplification (ISO sensor gain), FeedbackLoop (metering negative loop), Polarity (stops bipolar scale), Behavior (photographer routine). (6) Added spaceCoverage ValueSpace (RSC≈0.65) to Representation instantiation. (7) Added m3:semanticSignature. Total GenericConcepts: 18 → 22."
        },
        "v1.0.0": {
          "date": "2026-01-20",
          "description": "Initial creation. 18 GenericConcepts (34%). First identification of Balance and Trade-off as new M2 GenericConcepts from photography domain analysis."
        }
      },
