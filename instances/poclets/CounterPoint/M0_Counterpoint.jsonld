{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "m0": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/instances/poclets/Music/M0_Counterpoint.jsonld#",
