        "D": 0.70
      },
      "m0:layerSemantics": {
        "m2:Layer_S": "Spatial dominance of ecosystem floor / water column base",
        "m2:Layer_I": "Encodes photosynthetic capacity, chlorophyll content, GPP/NPP ratio",
        "m2:Layer_A": "Rank = 1 (absolute base — no autotroph can be outranked in trophic order)",
        "m2:Layer_R": "Universally named and encoded: 'primary producer' is cross-disciplinary shorthand"
      },
