      "m0:energySource": "Solar radiation (photosynthesis) or chemical energy (chemosynthesis)",
      "m0:biomassPercentage": "~99% of total ecosystem biomass (terrestrial)",
      "m0:energyCapture": "~1-2% of incident solar radiation converted to chemical energy (gross primary production)",
      "m0:representativeOrganisms": [
        "Vascular plants (terrestrial)",
