{
  "@context": {
    "@base": "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/",
    "m0": "instances/poclets/TrophicPyramid/M0_TrophicPyramid.jsonld#",
    "m1bio": "M1_extensions/biology/M1_Biology.jsonld#",
    "m1core": "M1_CoreConcepts.jsonld#",
    "m2": "M2_GenericConcepts.jsonld#",
    "m3eagle": "M3_EagleEye.jsonld#",
    "m3sphinx": "M3_SphinxEye.jsonld#",
    "m3": "M3_GenesisSpace.jsonld#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
