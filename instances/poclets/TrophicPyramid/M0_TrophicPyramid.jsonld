  "@graph": [

    {
      "@id": "m0:TrophicPyramid",
      "@type": "owl:Ontology",
      "dcterms:title": "TSCG M0 Trophic Pyramid Poclet",
      "dcterms:description": "Ecological trophic pyramid (Lindeman 1942) extended with humanity as supra-trophic super-predator. 6-pole layered model demonstrating StratifiedDissipation: ~90% energy loss at each trophic boundary creates a universal pyramidal biomass structure. Humanity (Level 6) bypasses Lindeman's rule via fossil fuel energy, consuming at all trophic levels simultaneously and exerting meta-regulatory control over the entire pyramid. Introduces two KnowledgeFieldConceptCombos: 'StratifiedDissipation' (Biology ⊙ (Layer ⊗ Dissipation)) and 'AnthropogenicDomination' (Biology ⊙ (Transducer ⊗ Regulation ⊗ Entropy)).",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-03-13",
      "dcterms:modified": "2026-04-02",
      "owl:versionInfo": "2.0.0",
      "owl:imports": [
        "M3_GenesisSpace.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld",
        "M1_extensions/biology/M1_Biology.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:Poclet"
      },
      "m2:changelog": {
        "v2.1.0": {
          "date": "2026-04-02",
          "description": "Added Anthropic Pressure (AP ∈ [0,1]) model: per-level biomass impact formulas B_n(AP), critical threshold AP_crit=0.7 (irreversible cascade), decomposers repositioned as base-level transversal split (vertical bisection of pyramid base). Visualization convention: pyramid base split vertically into Producers (left) + Decomposers (right)."
        },
        "v2.0.0": {
          "date": "2026-04-02",
          "description": "Added Level 6 — Humanity as supra-trophic super-predator. New pole m0:level_6_humanity with fossil-fuel energy bypass formula. New KnowledgeFieldConceptCombo AnthropogenicDomination (Biology ⊙ (Transducer ⊗ Regulation ⊗ Entropy)). Updated ASFID=0.94, REVOI=0.87, δ=0.07 (OnCriticalLine). Added m2:Transducer, m2:Entropy, m2:Processor as secondary GenericConcepts. poleCount updated to 6."
        },
        "v1.0.0": {
          "date": "2026-03-13",
          "description": "Initial version. 5-pole trophic pyramid (Producers → Herbivores → Carnivores → Apex Predators + Decomposers). ASFID=0.89, REVOI=0.84, δ=0.05. Introduces StratifiedDissipation KnowledgeFieldConceptCombo. Validates m2:Layer and m2:Context."
        }
      }
    },

    {
      "@id": "m0:TrophicPyramidSystem",
      "@type": ["owl:NamedIndividual", "owl:Class"],
      "rdfs:label": "Trophic Pyramid System",
      "rdfs:comment": "A trophic pyramid is a layered, hierarchical ecological structure in which each trophic level consumes biomass from the level below and dissipates ~90% of received energy as heat (Lindeman's 10% efficiency rule). The pyramidal shape is a thermodynamic attractor: energy flow (F) structured by stable positional strata (S⊗I⊗A) produces irreversible dissipation (F⊗D) at each boundary, universally driving biomass volume downward from base to apex. Humanity (Level 6) is a supra-trophic super-predator that escapes Lindeman's rule through fossil-fuel energy, consuming simultaneously at all levels and exerting global meta-regulatory control — amplifying entropy across the entire biosphere.",
      "m0:domain": "Ecology / Biology",
      "m0:subdomains": [
        "Community Ecology",
        "Trophodynamics",
        "Thermodynamics of Ecosystems",
        "Conservation Biology",
        "Anthropocene Ecology"
      ],
      "m0:pocletType": "Stratified Energy System (with Supra-Trophic Override)",
      "m0:observer": "Ecologist / Systems Biologist / Earth System Scientist",
      "m0:poleCount": 6,
      "m0:discoveryReference": "Lindeman R.L. (1942) — The Trophic-Dynamic Aspect of Ecology, Ecology 23(4):399-417",

      "m0:territorySpace": {
        "m0:asfidState": {
          "A": 0.97,
          "S": 0.92,
          "F": 0.97,
          "I": 0.90,
          "D": 0.95,
          "mean": 0.94,
          "commentary": {
            "A": "Pyramid shape is a universal thermodynamic attractor; humanity adds a supra-trophic meta-attractor (global dominance of all ecosystems). Dual attractor: thermodynamic basin (Lindeman) + anthropogenic basin (Anthropocene).",
            "S": "Discrete, ordered strata: each trophic level is a bounded positional partition (m2:Layer). Structure stable across biomes. Humanity adds a structured meta-layer (agriculture, cities, fishing fleets) overlying all natural levels.",
            "F": "Energy/biomass flow is the fundamental mechanism. Unidirectional (bottom-up) primary flow + top-down trophic cascades + fossil-fuel bypass (humanity extracts ~20000 kJ/m²/yr from geological reserves, exceeding total natural primary production).",
            "I": "Trophic position encodes ecological role, metabolic budget, and niche information. Biomagnification: persistent toxins concentrate upward. Humanity adds unprecedented information processing (technology, symbolic culture, global monitoring).",
            "D": "Lotka-Volterra population oscillations, trophic cascades (predator removal → herbivore irruption), seasonal succession — plus: 6th mass extinction, climate change, habitat destruction, domestication of 80% of mammal biomass. Anthropocene dynamics dominate."
          }
        }
      },

      "m0:mapSpace": {
        "m0:reviState": {
          "R": 0.85,
          "E": 0.80,
          "V": 0.85,
          "O": 0.90,
          "I": 0.95,
          "mean": 0.87,
          "commentary": {
            "R": "Classic pyramid diagram remains iconic, but adding humanity as a meta-level challenges standard representational conventions — the pyramid metaphor strains when a single species commands all levels simultaneously.",
            "E": "Core thermodynamic structure is constrained (Lindeman). Model gains evolvability: Anthropocene scenarios, climate-driven trophic shifts, rewilding, de-extinction, managed ecosystems.",
            "V": "Lindeman's 10% law validated across hundreds of ecosystems. Human impact harder to quantify: HANPP (Human Appropriation of Net Primary Production) estimated at 30-40% globally, but with high uncertainty.",
            "O": "Species identifiable, populations countable. Human activities are highly observable via satellite, fishery data, agricultural statistics, biodiversity indices (IUCN Red List, Living Planet Index).",
            "I": "Excellent interoperability: bridges thermodynamics, evolutionary biology, biogeochemistry, conservation biology, economics (ecosystem services), political science (environmental governance), Earth System Science."
          }
        }
      },

      "m0:epistemicGap": {
        "delta": 0.07,
        "spectralClass": "OnCriticalLine [0.05, 0.15)",
        "deltaVector": "(+0.12, +0.12, +0.12, 0.0, 0.0)",
        "commentary": "Gap increased from 0.05 to 0.07 (Coherent → OnCriticalLine) with the addition of humanity. Main residual gaps: A/R (+0.12) — the meta-trophic attractor (humanity's global dominance) is empirically undeniable but harder to diagram; S/E (+0.12) — while the pyramid structure is observed, its evolvability under combined Anthropocene + climate pressures is hard to model; F/V (+0.12) — quantifying fossil-fuel energy bypass vs natural trophic flows requires Earth System Science methods. ASFID I and D match their REVOI counterparts (O and I) well.",
        "balanceType": "Eagle Eye dominant (thermodynamic + anthropogenic empirical grounding)"
      },

      "m0:synergyPrinciple": [
        {
          "combo": "StratifiedDissipation",
          "formula": "StratifiedDissipation = Biology ⊙ (m2:Layer ⊗ m2:Dissipation)",
          "formulaASCII": "StratifiedDissipation = Biology [o] (Layer (x) Dissipation)",
          "emergentProperty": "Pyramidal biomass structure — the universal conical shape of ecosystems. No designer required: thermodynamic loss (F⊗D) operating through stable positional strata (S⊗I⊗A) inevitably produces the pyramid.",
          "coupledDimensions": "S, I, A (from m2:Layer) + F, D (from m2:Dissipation) → full S⊗I⊗A⊗F⊗D signature"
        },
        {
          "combo": "AnthropogenicDomination",
          "formula": "AnthropogenicDomination = Biology ⊙ (m2:Transducer ⊗ m2:Regulation ⊗ m2:Entropy)",
          "formulaASCII": "AnthropogenicDomination = Biology [o] (Transducer (x) Regulation (x) Entropy)",
          "emergentProperty": "Supra-trophic meta-control — a single species that converts geological energy (fossil fuels) into ecosystem regulation, simultaneously consuming at all trophic levels and amplifying global entropy (mass extinction, climate change, habitat destruction).",
          "coupledDimensions": "F⊗I (Transducer) + A⊗S⊗F (Regulation) + D⊗F (Entropy) → full A⊗S⊗F⊗I⊗D signature"
        }
      ],

      "m0:primaryGenericConcepts": [
        {
          "@id": "m2:Layer",
          "role": "STRUCTURAL BACKBONE — each trophic level IS a Layer (S⊗I⊗A⊗R)",
          "instantiation": "6 layers: Producers, Herbivores, Carnivores, Apex Predators, Decomposers, Humanity"
        },
        {
          "@id": "m2:Dissipation",
          "role": "CORE MECHANISM — ~90% energy lost as heat at each trophic boundary (F⊗D)",
          "instantiation": "Lindeman's 10% efficiency rule — universal across all ecosystems"
        },
        {
          "@id": "m2:Context",
          "role": "EPISTEMIC FRAME — the ecological context (biome, season, latitude) determines which species occupy each level (O⊗R⊗Im⊗E)",
          "instantiation": "Tropical rainforest vs Arctic tundra: same trophic structure, different species filling each layer"
        }
      ],

      "m0:secondaryGenericConcepts": [
        { "@id": "m2:Hierarchy", "role": "Positional ordering base→apex (A⊗S)" },
        { "@id": "m2:Flow", "role": "Energy/biomass transfer between levels (F)" },
        { "@id": "m2:Gradient", "role": "Energy density gradient from base to apex (F at two distinct points)" },
        { "@id": "m2:Homeostasis", "role": "Ecosystem equilibrium under perturbation (A⊗S⊗F⊗I⊗D)" },
        { "@id": "m2:Regulation", "role": "Predator-prey feedback loops + anthropogenic top-down meta-regulation (A⊗S⊗F)" },
        { "@id": "m2:Cascade", "role": "Trophic cascade: apex predator removal → top-down destabilisation; anthropogenic super-cascade: habitat loss + climate change → biosphere collapse (⊗⇒(Process,Step,Trajectory))" },
        { "@id": "m2:Threshold", "role": "Minimum viable population thresholds; trophic collapse triggers; planetary boundaries (A⊗I⊗F)" },
        { "@id": "m2:Network", "role": "Food web underlying the pyramid (S⊗F⊗I)" },
        { "@id": "m2:Emergence", "role": "Ecosystem services (pollination, carbon sequestration) emerging from level interactions" },
        { "@id": "m2:Transducer", "role": "Humanity converts non-biological energy (fossil fuels, nuclear, renewable) into trophic control — the key mechanism enabling the supra-trophic bypass of Lindeman's rule (F⊗I)" },
        { "@id": "m2:Entropy", "role": "Accelerated irreversibility at the planetary scale: mass extinction is an absorbing state for biodiversity; fossil-fuel combustion irreversibly shifts the climate attractor (D⊗F)" },
        { "@id": "m2:Processor", "role": "Humanity's technological information processing enables supra-trophic strategy: agriculture, fishing fleets, conservation management, genomics (I)" }
      ],

      "m0:knowledgeFieldConceptCombos": [
        {
          "@id": "m0:StratifiedDissipation",
          "@type": ["owl:NamedIndividual", "m1core:KnowledgeFieldConceptCombo"],
          "rdfs:label": "StratifiedDissipation",
          "rdfs:comment": "Biology-specific instantiation of the Layer⊗Dissipation pattern. Energy dissipation that is structured by stable positional strata: at each trophic boundary ~90% of received energy is irreversibly converted to heat, producing the universal pyramidal biomass distribution. The Layer dimension (S⊗I⊗A⊗R) provides the spatial scaffolding; the Dissipation dimension (F⊗D) drives the thermodynamic gradient.",
          "m1core:knowledgeField": "Biology",
          "m1core:operator": "⊙ (disciplinary qualification)",
          "m1core:compiledFormula": "Biology ⊙ (S⊗I⊗A⊗R⊗F⊗D)",
          "m1core:dominantDimensions": ["S", "I", "A", "F", "D"],
          "m1core:empiricalLaw": "Lindeman's 10% rule — η ≈ 0.1 at each trophic boundary",
          "m1core:validationDomains": ["Terrestrial ecology", "Marine ecology", "Freshwater ecology", "Aquatic microbial ecology", "Agro-ecology"]
        },
        {
          "@id": "m0:AnthropogenicDomination",
          "@type": ["owl:NamedIndividual", "m1core:KnowledgeFieldConceptCombo"],
          "rdfs:label": "AnthropogenicDomination",
          "rdfs:comment": "Biology-specific instantiation of the Transducer⊗Regulation⊗Entropy pattern. Humanity acts as a meta-transducer converting geological energy (fossil fuels) into ecosystem regulation, consuming at all trophic levels simultaneously and amplifying global entropy through mass extinction, climate forcing, and habitat destruction. Unlike StratifiedDissipation (thermodynamic law), AnthropogenicDomination is a contingent but dominant meta-pattern of the Anthropocene.",
          "m1core:knowledgeField": "Biology",
          "m1core:operator": "⊙ (disciplinary qualification)",
          "m1core:compiledFormula": "Biology ⊙ (F⊗I⊗A⊗S⊗D)",
          "m1core:dominantDimensions": ["F", "I", "A", "D"],
          "m1core:keyMechanism": "Fossil-fuel energy bypass: E_humanity = Σ(f_n × E_n) + E_fossil — humanity's effective energy capture exceeds total natural primary production",
          "m1core:empiricalData": "HANPP (Human Appropriation of Net Primary Production) ≈ 30-40% of terrestrial NPP; >80% of mammal biomass is livestock or humans",
          "m1core:validationDomains": ["Anthropocene ecology", "Earth System Science", "Conservation biology", "Global change biology", "Sustainability science"]
        }
      ],

      "m0:constraints": [
        {
          "m0:constraintId": "c1_energy_efficiency",
          "m0:name": "Lindeman Efficiency",
          "m0:formula": "η = E_n+1 / E_n ≈ 0.10",
          "m0:type": "Thermodynamic (strict)",
          "m0:condition": "Energy transfer efficiency between consecutive trophic levels ≤ 15%",
          "m0:violationConsequence": "Ecosystem collapse — insufficient energy budget to sustain higher levels"
        },
        {
          "m0:constraintId": "c2_level_ordering",
          "m0:name": "Positional Ordering",
          "m0:formula": "rank(L_i) < rank(L_{i+1}) — strict total order",
          "m0:type": "Structural (Layer attractor)",
          "m0:condition": "No cyclic predation at same trophic level (cannibalism is a special case, not the norm)"
        },
        {
          "m0:constraintId": "c3_minimum_base",
          "m0:name": "Autotrophic Base Constraint",
          "m0:formula": "Biomass(Producers) ≥ Σ Biomass(all other levels)",
          "m0:type": "Energetic",
          "m0:condition": "Primary production (photosynthesis / chemosynthesis) must exceed total consumer demand"
        },
        {
          "m0:constraintId": "c4_ap_critical_threshold",
          "m0:name": "Anthropic Pressure Critical Threshold",
          "m0:formula": "AP_crit = 0.7",
          "m0:type": "Anthropogenic (contingent)",
          "m0:condition": "For AP ≥ AP_crit, the trophic cascade becomes irreversible — m2:Entropy seals the system into an absorbing state. Recovery is no longer possible even if AP is subsequently reduced.",
          "m0:violationConsequence": "Irreversible biosphere collapse — 6th mass extinction absorbing state"
        }
      ],

      "m0:anthropicPressure": {
        "m0:definition": "Anthropic Pressure (AP) — a normalised scalar ∈ [0.0, 1.0] representing the combined intensity of fossil fuel exploitation and extractive mining on trophic biodiversity. AP = 0.0 corresponds to a pre-industrial natural pyramid; AP = 1.0 corresponds to maximum exploitation and total biosphere collapse. Conceptually grounded in Meadows et al. (1972) 'Limits to Growth' (Club of Rome): AP operationalises the 'overshoot and collapse' scenario as a single trophic pressure parameter.",
        "m0:limitsToGrowthReference": {
          "source": "Meadows D.H., Meadows D.L., Randers J., Behrens W.W. (1972) — The Limits to Growth, Club of Rome / Universe Books, New York",
          "relevance": "The 'standard run' (Business As Usual) scenario of Limits to Growth predicts resource depletion and pollution overshoot leading to civilisation collapse by mid-21st century. AP maps this trajectory onto the trophic pyramid: AP ≈ 0.46 (2024 baseline), AP → 0.85+ (BAU 2050), crossing AP_crit = 0.70 triggers irreversible trophic collapse — the biological expression of the Limits to Growth overshoot.",
          "scenarios": {
            "BAU": "AP → 0.85 by 2050 (Business As Usual — fossil fuel exploitation continues)",
            "stabilised": "AP stabilises at ~0.50 (aggressive decarbonisation + rewilding)",
            "recovery": "AP reduced to ~0.35 by 2100 (full energy transition + ecosystem restoration)"
          }
        },
        "m0:currentValue_2024": 0.46,
        "m0:scenario_BAU_2050": 0.85,
        "m0:criticalThreshold": 0.70,
        "m0:drivers": [
          "Fossil fuel extraction (CO₂/CH₄ → ocean acidification, global warming → habitat loss, species range shifts)",
          "Extractive mining (direct habitat destruction, freshwater pollution → local food chain collapse)"
        ],
        "m0:biomassImpactFormulas": {
          "m0:note": "B_n(AP) = relative biomass of trophic level n under Anthropic Pressure AP. B_n = 1.0 at AP = 0 (natural baseline). Impact is top-down: Level 4 collapses first.",
          "L4_apex":       "B4(AP) = max(0,  1.0 − 3.0 × AP)",
          "L3_carnivores": "B3(AP) = max(0,  1.0 − 2.0 × AP)",
          "L2_herbivores": "B2(AP) = (1 + 0.5 × AP) × max(0, 1.0 − 1.8 × AP)",
          "L1_producers":  "B1(AP) = max(0,  1.0 − 1.0 × AP)",
          "decomposers":   "Bd(AP) = (1 + 0.8 × AP) × max(0, 1.0 − 3.0 × max(0, AP − 0.6))"
        },
        "m0:collapseSequence": [
          "AP = 0.33 → L4 Apex reaches zero (first collapse — large slow-reproducing species)",
          "AP = 0.46 → Current situation (2024): L4 severely reduced, L3 declining, L2 in irruption",
          "AP = 0.50 → L3 Carnivores reach zero; L2 Herbivores at irruption peak",
          "AP = 0.55 → L2 Herbivores begin collapse (habitat loss overrides predation release)",
          "AP = 0.60 → Decomposers begin rapid collapse (detrital substrate exhausted)",
          "AP = 0.70 → CRITICAL THRESHOLD (AP_crit): irreversible absorbing state — m2:Entropy seals cascade",
          "AP = 1.00 → Full pyramid collapse; all B_n = 0"
        ],
        "m0:decomposersSpecialBehaviour": "Decomposers exhibit counter-intuitive irruption under moderate AP (more dead biomass available as substrate) before collapsing rapidly above AP = 0.60. This non-monotonic response is captured by the (1 + 0.8×AP) amplification term followed by the hard cutoff.",
        "m0:visualisationConvention": "In simulation: pyramid base is bisected vertically into two compartments — LEFT: Level 1 Producers (width ∝ B1(AP)), RIGHT: Decomposers (width ∝ Bd(AP)). The total base width is fixed; each compartment rescales dynamically with AP. This represents the transversal nature of decomposers (cross-cutting all levels) while keeping the pyramid as a unified geometric form."
      }
    },

    {
      "@id": "m0:TrophicLevel",
      "@type": "owl:Class",
      "rdfs:label": "Trophic Level",
      "rdfs:comment": "A stable, ordered positional partition in the trophic hierarchy — an instance of m2:Layer. Each level has characteristic content (I: metabolic role), positional attractor (A: rank in the energy cascade), and contributes to StratifiedDissipation.",
      "rdfs:subClassOf": { "@id": "m2:Layer" },
      "m2:characterizedBy": ["m2:Layer", "m2:Dissipation", "m2:Context"]
    },

    {
