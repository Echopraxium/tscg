      "rdfs:label": "Butterfly Metamorphosis Poclet - Complete Holometabolous Lifecycle",
      "rdfs:comment": "6-pole model of butterfly metamorphosis from egg to adult imago, including critical emergence phase. Demonstrates complete transformation with radical structural reorganization, hormonal regulation, and imaginal disc-based development. Validated poclet for TSCG framework.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-01-24",
      "owl:versionInfo": "1.2.0",
      "m1:domain": "m1.ext:biology:DevelopmentalBiology",
      "m0:check_following_attributes:START": "",
      "m0:status": "VALIDATED",
      "m0:poleCount": 6,
      "m0:metamorphosisType": "Holometabolous",
      "m0:asfidMean": 0.95,
      "m0:epistemicGap": 0.22,
      "rdfs:seeAlso": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_Biology.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld"
      ],
      "m0:check_following_attributes:END": "",
      "dcterms:modified": "2026-07-07",
