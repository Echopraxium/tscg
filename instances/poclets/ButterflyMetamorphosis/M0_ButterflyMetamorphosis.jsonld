    {
      "@id": "m0:asfid_structure",
      "@type": [
        "m0:ASFIDAnalysis"
      ],
      "rdfs:label": "Structure (S)",
      "m0:score": 0.98,
      "m0:dominantM3": "m3:Structure",
      "rdfs:comment": "Exceptional structural reorganization across 6 discrete morphological states. Radical restructuring via histolysis (larval tissue dissolution) and histogenesis (adult organ development from imaginal discs). Multi-level organization: molecular → cellular → tissue → organ → organism.",
      "m0:modularArchitecture": "6 discrete poles with pole-specific morphology",
      "m0:reorganizationMechanism": {
