    {
      "@id": "m0:pole_1_egg",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 1: Egg",
      "m0:poleNumber": 1,
      "m0:duration_days": "3-7",
      "rdfs:comment": "Initial embryonic state. Chorion-protected embryo with imaginal disc determination occurring. Low metabolic activity, high vulnerability to environmental extremes.",
      "m0:morphology": "Spheroid/ovoid, chorion shell, micropyle for gas exchange",
      "m0:ecologicalRole": "Dispersal (oviposition site selection by female), overwintering (some species)",
      "m0:vulnerabilities": [
        "Predation",
        "Parasitism",
        "Desiccation",
        "Temperature extremes"
      ],
      "m0:dominantASFID": {
        "A": 0.3,
        "S": 0.95,
        "F": 0.25,
        "I": 0.98,
        "D": 0.4
      },
      "rdfs:seeAlso": [
        "m1.ext:biology:Embryogenesis",
        "m1.ext:biology:ImagenalDiscDetermination"
      ]
    },
    {
      "@id": "m0:pole_2_larva",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 2: Larva (Caterpillar)",
      "m0:poleNumber": 2,
      "m0:duration_days": "14-35",
      "m0:subphases": [
        "Instar 1 (L1)",
        "Instar 2 (L2)",
        "Instar 3 (L3)",
        "Instar 4 (L4)",
        "Instar 5 (L5)"
      ],
      "rdfs:comment": "Growth phase with successive molts (ecdysis). Feeding machine optimized for biomass accumulation. Imaginal discs remain dormant, suppressed by Juvenile Hormone.",
      "m0:morphology": "Segmented body, prolegs, mandibles, tracheal system, simple eyes (ocelli)",
      "m0:ecologicalRole": "Feeding (herbivory), biomass accumulation, dispersal (limited)",
      "m0:behavior": "Voracious feeding, cryptic coloration or aposematic warning, silk production (some species)",
      "m0:vulnerabilities": [
        "Predation (birds, wasps)",
        "Parasitoids (tachinid flies, ichneumonid wasps)",
        "Disease (viral, bacterial, fungal)"
      ],
      "m0:dominantASFID": {
        "A": 0.75,
        "S": 0.98,
        "F": 0.95,
        "I": 0.9,
        "D": 0.85
      },
      "m0:hormonalControl": {
        "JuvenileHormone": "HIGH (maintains larval state)",
        "Ecdysone": "Pulsatile (triggers molting between instars)"
      },
      "rdfs:seeAlso": [
        "m1.ext:biology:Ecdysis",
        "m1.ext:biology:Instar",
        "m1.ext:biology:JuvenileHormone"
      ]
    },
    {
      "@id": "m0:pole_3_prepupa",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 3: Pre-Pupa (Chrysalis Formation)",
      "m0:poleNumber": 3,
      "m0:duration_days": "1-2",
      "rdfs:comment": "Last larval molt revealing pupal case. Larval exoskeleton (cuticle) separates from underlying epidermis which secretes pupal cuticle. Critical commitment point - no return to larval state possible.",
      "m0:morphology": "Larval skin splitting dorsally, emerging chrysalis (green or brown, species-dependent)",
      "m0:ecologicalRole": "Site selection (protected location), attachment (silk pad, cremaster)",
      "m0:behavior": "Wandering (seeking pupation site), cessation of feeding, silk spinning for attachment",
      "m0:vulnerabilities": [
        "Predation during ecdysis",
        "Attachment failure",
        "Site disturbance"
      ],
      "m0:dominantASFID": {
        "A": 0.9,
        "S": 0.96,
        "F": 0.7,
        "I": 0.92,
        "D": 0.95
      },
      "m0:hormonalControl": {
        "JuvenileHormone": "DROPPING (release from larval constraint)",
        "Ecdysone": "PEAK (triggers final larval-pupal molt)"
      },
      "m0:transitionType": "Irreversible commitment to metamorphosis",
      "rdfs:seeAlso": [
        "m1.ext:biology:Ecdysis",
        "m1.ext:biology:Cremaster"
      ]
    },
    {
      "@id": "m0:pole_4_pupa",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 4: Pupa (Chrysalis in Transformation)",
      "m0:poleNumber": 4,
      "m0:duration_days": "10-14 (variable: 7 days to 9 months depending on species, temperature, diapause)",
      "rdfs:comment": "Metamorphic transformation phase. Larval tissues undergo histolysis (except CNS, imaginal discs, tracheal system). Adult structures develop from imaginal discs via histogenesis. Externally immobile but internally dynamic.",
      "m0:morphology": "Hardened chrysalis case, varied coloration (cryptic or aposematic), spiracles for respiration",
      "m0:ecologicalRole": "Overwintering (diapause in temperate species), predator avoidance (cryptic coloration)",
      "m0:internalProcesses": {
        "histolysis": "Larval muscle, fat body, gut dissolution via apoptosis and autophagy",
        "histogenesis": "Adult organs develop from imaginal discs (wings, legs, antennae, compound eyes, reproductive organs)",
        "CNS_remodeling": "Pruning of larval neurons, growth of adult neural circuits",
        "biochemical_recycling": "Larval proteins → amino acid pools → adult protein synthesis"
      },
      "m0:vulnerabilities": [
        "Predation (immobility)",
        "Parasitoids",
        "Desiccation",
        "Fungal infection"
      ],
      "m0:dominantASFID": {
        "A": 0.98,
        "S": 1.0,
        "F": 0.88,
        "I": 0.98,
        "D": 0.92
      },
      "m0:hormonalControl": {
        "JuvenileHormone": "ABSENT (permissive for metamorphosis)",
        "20-Hydroxyecdysone": "HIGH (drives imaginal disc differentiation)"
      },
      "rdfs:seeAlso": [
        "m1.ext:biology:Histolysis",
        "m1.ext:biology:Histogenesis",
        "m1.ext:biology:ImagenalDisc",
        "m1.ext:biology:Apoptosis"
      ]
    },
    {
      "@id": "m0:pole_5_emergence",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 5: Emergence (Eclosion)",
      "m0:poleNumber": 5,
      "m0:duration_hours": "2-4",
      "rdfs:comment": "Critical transition from chrysalis to functional adult. Chrysalis splits along predetermined line (ecdysial line). Butterfly emerges wet and compressed. Hemolymph pumped into wing veins to expand wings. Wings harden via sclerotization. Maximum vulnerability window.",
      "m0:morphology": "Transitional: compressed wings unfurling, soft exoskeleton hardening, pigmentation intensifying",
      "m0:ecologicalRole": "Extreme vulnerability (cannot fly, soft cuticle, predicable timing)",
      "m0:behavior": "Wing pumping (hemolymph hydraulics), meconium expulsion (pupal waste), basking (thermoregulation for flight muscle activation)",
      "m0:physiology": {
        "wing_deployment": "Hemolymph pressure (up to 15 kPa) expands wing veins, vein sclerotization locks shape",
        "cuticle_hardening": "Sclerotization via phenolic cross-linking (hours to complete)",
        "flight_muscle_activation": "Temperature-dependent (requires ~30°C in most species)"
      },
      "m0:vulnerabilities": [
        "Predation (ants, birds, spiders)",
        "Wing deformity (disturbance during deployment)",
        "Weather (rain, wind)",
        "Thermoregulation failure"
      ],
      "m0:dominantASFID": {
        "A": 0.95,
        "S": 0.95,
        "F": 0.98,
        "I": 0.92,
        "D": 1.0
      },
      "m0:criticalEvents": [
        "Chrysalis splitting (ecdysis)",
        "Butterfly extraction from pupal case",
        "Wing unfolding (2-5 minutes)",
        "Hemolymph pumping (30-60 minutes)",
        "Wing hardening (1-3 hours)",
        "Meconium expulsion",
        "First flight (if conditions suitable)"
      ],
      "m0:uniqueness": "This pole distinguishes 6-pole model from simpler 5-pole metamorphosis models. Captures dramatic vulnerability and hydraulic wing deployment dynamics.",
      "rdfs:seeAlso": [
        "m1.ext:biology:Eclosion",
        "m1.ext:biology:Sclerotization",
        "m1.ext:biology:Hemolymph"
      ]
    },
    {
      "@id": "m0:pole_6_imago",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Pole 6: Imago (Mature Adult)",
      "m0:poleNumber": 6,
      "m0:duration_days": "14-42 (highly variable: days to months)",
      "rdfs:comment": "Reproductively active adult butterfly. Fully functional wings, compound eyes, proboscis for nectar feeding. Ecological role shifts from herbivory to pollination and reproduction. Closes lifecycle via oviposition.",
      "m0:morphology": "Wings (scales with pigments/nanostructures), compound eyes, antennae, proboscis, six legs, reproductive organs (male: claspers; female: ovipositor)",
      "m0:ecologicalRole": "Pollination, reproduction (mate seeking, oviposition), dispersal (migration in some species)",
      "m0:behavior": "Flight (powered by indirect flight muscles), nectar feeding, territorial displays (males), oviposition site selection (females), migration (Monarch, Painted Lady)",
      "m0:physiology": {
        "flight": "Indirect flight muscles (dorsal longitudinal, dorsal ventral) deform thorax → wing stroke",
        "feeding": "Proboscis (modified maxillae) uncoils via hemolymph pressure",
        "reproduction": "Courtship (visual, pheromonal), copulation, egg laying"
      },
      "m0:vulnerabilities": [
        "Predation (birds, dragonflies, mantises)",
        "Parasites (mites)",
        "Weather",
        "Senescence"
      ],
      "m0:dominantASFID": {
        "A": 1.0,
        "S": 0.98,
        "F": 0.9,
        "I": 0.95,
        "D": 0.7
      },
      "m0:lifecycle_closure": "Female oviposits → returns to Pole 1 (Egg) at population level",
      "rdfs:seeAlso": [
        "m1.ext:biology:Imago",
        "m1.ext:biology:Pollination",
        "m1.ext:biology:Oviposition"
      ]
    },
    {
