      "m0:score": 0.92,
      "m0:dominantM3": "m3:Flow",
      "rdfs:comment": "Significant material and energy flows. Larva: massive food intake → biomass. Pupa: internal recycling of larval proteins → adult tissue synthesis. Imago: nectar → flight/reproduction energy. Hormonal flows (JH, Ecdysone) control transitions. Hemolymph circulation critical during emergence (wing deployment).",
      "m0:nutrientFlows": {
        "larva": "Food intake → biomass accumulation",
        "pupa": "Larval protein recycling → adult tissue synthesis",
        "imago": "Nectar → flight/reproduction energy"
      },
      "m0:hormonalFlows": {
        "JuvenileHormone": "Maintains larval state (high) → permits metamorphosis (absent)",
        "Ecdysone": "Triggers molting (pulsatile) → drives metamorphosis (sustained)",
        "PTTH": "Brain → prothoracic gland → ecdysone release"
      },
      "m0:hemolymphDynamics": {
        "larva_pupa": "Low pressure circulation",
        "emergence": "Explosive pumping into wing veins (up to 15 kPa)",
