      "rdfs:label": "Information (I)",
      "m0:score": 0.96,
      "m0:dominantM3": "m3:Information",
      "rdfs:comment": "Exceptional genetic and developmental information. Single genome orchestrates 6 morphologically distinct stages via temporal gene expression cascades (Hox genes). Imaginal discs: embryonic determination of adult structures. Epigenetic control via chromatin remodeling. Environmental signals (photoperiod, temperature) modulate timing. CNS continuity preserves larval learning into adulthood.",
      "m0:geneticProgram": {
        "genome": "Single genome, temporally regulated expression",
        "keyGenes": "Hox genes, segment polarity genes, Broad-Complex, E93",
        "imaginalDiscDetermination": "Embryonic commitment to adult structures"
      },
      "m0:epigeneticControl": {
        "chromatinRemodeling": "Histone modifications during metamorphosis",
        "adultGeneActivation": "Derepression when JH drops"
      },
      "m0:environmentalSignals": {
        "photoperiod": "Day length → diapause triggering",
        "temperature": "Developmental rate modulation",
        "larvalNutrition": "Adult size determination"
      },
      "m0:neuralContinuity": "Larval CNS persists through pupation → adult behavior retention",
      "m0:m2_GenericConcepts": [
