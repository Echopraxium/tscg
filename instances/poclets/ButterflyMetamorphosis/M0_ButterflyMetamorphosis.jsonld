    {
      "@id": "m0:asfid_dynamics",
      "@type": [
        "m0:ASFIDAnalysis"
      ],
      "rdfs:label": "Dynamics (D)",
      "m0:score": 0.94,
      "m0:dominantM3": "m3:Dynamics",
      "rdfs:comment": "Strong temporal evolution with phase transitions. Timescale: egg (days) → larva (weeks) → pre-pupa (days) → pupa (days to months) → emergence (hours) → imago (weeks). Rate of change: EMERGENCE FASTEST (maximum dD/dt), pupa rapid (histolysis/histogenesis), larva moderate. Irreversible trajectory with sharp discontinuities at pole boundaries.",
      "m0:timescale": {
        "egg": "3-7 days",
        "larva": "14-35 days (5 instars)",
        "prepupa": "1-2 days",
        "pupa": "10-14 days (variable: 7 days to 9 months)",
        "emergence": "2-4 hours",
        "imago": "14-42 days (variable)"
      },
      "m0:rateOfChange": {
