        "moderate": "Early/mid larva (feeding-driven growth)",
        "rapid": "Pre-pupa (ecdysis), Pupa (histolysis/histogenesis)",
        "fastest": "Emergence (wing deployment, maximum dD/dt)"
      },
      "m0:phaseTransitions": "Sharp discontinuities at pole boundaries, irreversible",
      "m0:m2_GenericConcepts": [
