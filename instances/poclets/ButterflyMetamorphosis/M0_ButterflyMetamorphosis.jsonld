      "rdfs:comment": "Five-dimensional measurement of observable system phenomena: Attractor, Structure, Flow, Information, Dynamics."
    },
    {
      "@id": "m0:asfid_attractor",
      "@type": [
        "m0:ASFIDAnalysis"
      ],
      "rdfs:label": "Attractor (A)",
      "m0:score": 0.95,
      "m0:dominantM3": "m3:Attractor",
      "rdfs:comment": "Strong unidirectional attractor field toward reproductive maturity (Pole 6). Secondary attractors: larval feeding optimization, pupal transformation completion. Irreversible trajectory with no regression to earlier poles. Bifurcation points at transitions.",
      "m0:primaryAttractor": "Imago (reproductive fitness)",
      "m0:secondaryAttractors": [
        "Larval mass accumulation",
        "Pupal transformation completion"
