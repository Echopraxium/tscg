  "@graph": [
    {
      "@id": "m0:MagicColorWheelPoclet",
      "@type": "owl:Ontology",
      "dcterms:title": "Magic Color Wheel - Pentagonal Philosophical System",
      "dcterms:description": "Minimal yet complete philosophical system from Magic: The Gathering. Demonstrates pentagonal structure with allied/enemy relationships, value tensions, and emergent complexity through 5-pole dynamics.",
      "dcterms:created": "2026-01-22",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "owl:versionInfo": "1.1.0",
      "m2:changelog": [
        {
          "version": "1.1.0",
          "date": "2026-02-26",
          "changes": [
            "BREAKING: Migrated from deprecated ORIVE to canonical REVOI notation (R=Representability, E=Evolvability, V=Verifiability, O=Observability, I=Interoperability)",
            "Updated R dimension: Reproducibility → Representability (semantic decodability/encodability of color identities)",
            "Updated E dimension: Expressiveness → Evolvability (capacity of color pie to absorb new mechanics while preserving identity)",
            "Added pentagramPosition attribute to each color node (canonical W/U/B/R/G clockwise ordering)",
            "Recalculated REVOI vector: (0.90, 0.85, 0.70, 0.75, 0.90) → mean=0.82"
          ]
        },
        {
          "version": "1.0.1",
          "date": "2026-01-25",
          "changes": [
            "Added GenericConceptMobilization section with 28 M2 instantiations",
            "Added newGenericConceptCandidates: Polarity-N, Alliance, Antagonism",
            "Validated N-ary polarity (N=5) as TSCG paradigm shift"
          ]
        },
        {
          "version": "1.0.0",
          "date": "2026-01-22",
          "changes": [
            "Initial poclet creation: Magic Color Wheel pentagonal philosophical system",
            "Full ASFID analysis: (0.65, 0.80, 0.45, 0.85, 0.50)",
            "Complete 5-color model with allied/enemy dynamics (10 relationships)"
          ]
        }
      ],
