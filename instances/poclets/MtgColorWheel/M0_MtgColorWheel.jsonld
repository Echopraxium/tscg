      "m0:asfidAnalysis": {
        "description": "Eagle Eye (Territory-Space) measurement using ASFID dimensions",
        "note": "Challenging for conceptual/philosophical system - low observability, high interpretability",
        "dimensions": [
          {
            "dimension": "A (Attractor)",
            "coefficient": 0.65,
            "interpretation": "MODERATE attractor presence. Each color represents philosophical 'attractor basins' (value equilibria). Players/narratives gravitate toward color identities. However, these are conceptual attractors (philosophical tendencies) not physical equilibria.",
            "evidence": [
              "Color identity as character/deck archetype",
              "Philosophical coherence (each color internally consistent)",
              "Multicolor combinations create new attractor states",
              "Narrative arcs often show characters 'finding their color'"
            ],
            "examples": [
              "White: Attractor = 'Just society under law'",
              "Blue: Attractor = 'Perfect understanding/mastery'",
              "Black: Attractor = 'Maximum personal power'",
              "Red: Attractor = 'Absolute freedom'",
              "Green: Attractor = 'Harmony with natural order'"
            ],
            "limitations": "Attractors are normative (ought) not descriptive (is). Not physically measurable."
          },
          {
            "dimension": "S (Structure)",
            "coefficient": 0.8,
            "interpretation": "HIGH structural clarity. Pentagonal topology explicitly defined. Each color is a 'component' with clear boundaries. Allied/enemy relationships form explicit network structure. 10 edges (5 allied + 5 enemy) create rich relational architecture.",
            "evidence": [
              "Five discrete colors (vertices)",
              "Pentagon geometry (spatial metaphor)",
              "10 explicit relationships (edges)",
              "Internal structure: values → methods → excesses → lacks",
              "Mechanical identity (gameplay structure)"
            ],
            "structuralElements": [
              "Nodes: 5 colors",
              "Edges: 10 relationships (5 allied, 5 enemy)",
              "Attributes per node: Values, Methods, Excesses, Domain, Lacks",
              "Symmetry: C5 rotational (no privileged color)",
              "Hierarchy: None (flat pentagonal structure)"
            ]
          },
          {
            "dimension": "F (Flow)",
            "coefficient": 0.45,
            "interpretation": "LOW-MODERATE flow. In gameplay: mana flows, card flows, life total flows. In philosophy: No inherent 'flows' of ideas/values between colors. Flows emerge through combination (multicolor decks) but are player-constructed, not systemic.",
            "evidence": [
              "Gameplay: Mana production/consumption (resource flow)",
              "Gameplay: Card advantage (information flow)",
              "Philosophical: No intrinsic 'flow' between values",
              "Narratively: Characters can shift colors (flow of identity)",
              "Mechanically: Allied colors share mechanics (limited flow)"
            ],
            "flowTypes": [
              "Mana flow (resource economics)",
              "Ideological influence (allied pairs easier to combine)",
              "Narrative character development (color shifts)",
              "No thermodynamic/material flows (purely conceptual)"
            ],
            "limitations": "Flows are secondary/emergent, not primary structural feature"
          },
          {
            "dimension": "I (Information)",
            "coefficient": 0.85,
            "interpretation": "VERY HIGH information content. Each color encodes rich philosophical/mechanical/narrative information. 5 colors × (values + methods + excesses + lacks + philosophy + mechanics) = vast information space. Relationships encode additional information (synergies/conflicts).",
            "evidence": [
              "Philosophical richness (30+ years of narrative)",
              "Mechanical complexity (thousands of cards)",
              "Value systems explicitly codified",
              "Relationship semantics (allied/enemy distinctions)",
              "Cultural knowledge (millions of players internalized system)"
            ],
            "informationTypes": [
              "Declarative: Value statements (e.g., 'White values order')",
              "Procedural: Methods for achieving values",
              "Constraint: Lacks and limitations per color",
              "Relational: Allied/enemy semantics",
              "Mechanical: Gameplay rules per color"
            ]
          },
          {
            "dimension": "D (Dynamics)",
            "coefficient": 0.5,
            "interpretation": "MODERATE dynamics. System is stable (30+ years unchanged core). Dynamics emerge through: (1) multicolor combinations creating tension, (2) narrative shifts, (3) meta-game evolution. However, the core pentagonal structure itself is static.",
            "evidence": [
              "Core structure unchanged since 1993",
              "Dynamic: New card designs explore color boundaries",
              "Dynamic: Meta-game (which colors dominate shifts)",
              "Dynamic: Narrative character color shifts",
              "Static: Pentagon topology immutable"
            ],
            "dynamicProcesses": [
              "Combination dynamics (2-3 color decks)",
              "Conflict dynamics (color pie violations, debates)",
              "Evolution: New mechanics within color identities",
              "Meta-stability: Core unchanged, interpretations evolve"
            ]
          }
        ],
        "asfidVector": "(0.65, 0.80, 0.45, 0.85, 0.50)",
        "asfidMean": 0.65,
        "territoryQuality": "MODERATE - Conceptual system with high I/S, moderate A/D, low F",
        "stateVector": "|Ω_colorWheel⟩ = 0.65|A⟩ + 0.80|S⟩ + 0.45|F⟩ + 0.85|I⟩ + 0.50|D⟩",
        "dominantDimensions": [
          "I (Information)",
          "S (Structure)"
        ],
        "weakDimensions": [
          "F (Flow)",
          "D (Dynamics)"
        ],
        "interpretation": "Magic Color Wheel is an I-S dominant system: highly structured information architecture with moderate attractors, low flows, and moderate dynamics. This profile is typical of *conceptual/philosophical frameworks* rather than physical systems."
      },
      "m0:revoiAnalysis": {
        "description": "Sphinx Eye (Map-Space) evaluation using REVOI dimensions (R=Representability, E=Evolvability, V=Verifiability, O=Observability, I=Interoperability)",
        "note": "Magic Color Wheel is fundamentally a MAP (conceptual model) not Territory. REVOI should score very high.",
        "dimensions": [
          {
            "dimension": "R (Representability)",
            "coefficient": 0.90,
            "interpretation": "VERY HIGH representability. The color wheel's semantic encoding is exceptionally decodable: each color's philosophical identity (values, methods, mechanics) is clearly and consistently represented across 20M+ players, 11+ languages, and 30+ years. The Pentagon diagram itself is an optimal semantic representation — simple, memorable, complete.",
            "evidence": [
              "Global player base (20M+) shares same understanding of color meanings",
              "Translated to 11+ languages with no semantic loss",
              "Visual Color Pie diagram is universally recognized encoding",
              "Consistent philosophical identity across 100+ sets",
              "Digital implementations reproduce semantics perfectly"
            ],
            "representabilityMechanisms": [
              "Explicit codification (rulebooks, card text, flavor text)",
              "Visual reinforcement (color pie diagrams, mana symbols)",
              "Cultural transmission (player community, content creators)",
              "Institutional continuity (Wizards of the Coast design team)"
            ]
          },
          {
            "dimension": "E (Evolvability)",
            "coefficient": 0.85,
            "interpretation": "HIGH evolvability. The Color Pie has demonstrated remarkable capacity to absorb new mechanics, keywords, and philosophical nuances while preserving core identity. Color bleed (intentional minor violations) shows controlled evolution. New guild/clan identities (Guilds of Ravnica, Khans of Tarkir) extend the system without breaking it.",
            "evidence": [
              "Core pentagon structure unchanged since 1993 (structural stability)",
              "200+ new mechanics introduced within color identities (adaptive capacity)",
              "Color pie violations gradually absorbed and codified (evolutionary flexibility)",
              "New multicolor guild identities extend system expressiveness",
              "Color bleed as controlled evolutionary mechanism"
            ],
            "evolvabilityMechanisms": [
              "Color pie adjustments (Mark Rosewater's continuous refinement)",
              "Multicolor combinations creating new stable sub-identities",
              "Temporal evolution of what each color 'can' do",
              "Planar Chaos as experimental color mutation test"
            ]
          },
          {
            "dimension": "V (Verifiability)",
            "coefficient": 0.70,
            "interpretation": "MODERATE-HIGH verifiability. As a *descriptive model of gameplay*, highly verifiable (colors mechanically distinct and testable). As a *model of human values*, moderately verifiable (captures real tensions but oversimplifies). The model's predictions are verifiable at gameplay level, less so at philosophical level.",
            "evidence": [
              "Gameplay verifiability: Colors feel distinct (30 years of design confirms)",
              "Narrative verifiability: Generates compelling consistent stories",
              "Philosophical verifiability: Resonates with actual value conflicts",
              "Limitation: Oversimplifies (real ethics isn't pentagonal)",
              "Limitation: Western-centric philosophical assumptions"
            ],
            "verifiabilityLimitations": [
              "Not a scientific theory (not falsifiable in Popperian sense)",
              "Cultural bias (Western individualism vs collectivism framing)",
              "Oversimplification (real values are multidimensional)",
              "Prescriptive contamination (colors as ideals, not pure descriptions)"
            ]
          },
          {
            "dimension": "O (Observability)",
            "coefficient": 0.75,
            "interpretation": "HIGH observability *of the model* through gameplay, narrative, card design. However, the philosophical 'Territory' (actual value conflicts) is only indirectly observable. Map itself is crystal clear; what it maps is fuzzy.",
            "evidence": [
              "5 colors visually distinct (card backs, mana symbols, art direction)",
              "Mechanical differences observable in gameplay outcomes",
              "Allied/enemy pairs observable through deck-building constraints",
              "30+ years of design reinforces observable distinctions"
            ],
            "observabilityLayers": [
              "Mechanical layer: Perfectly observable (card rules, mana costs)",
              "Philosophical layer: Requires interpretation (reader-dependent)",
              "Narrative layer: Shown through stories/characters (indirect)",
              "Meta-layer: Community consensus on color meanings (emergent)"
            ]
          },
          {
            "dimension": "I (Interoperability)",
            "coefficient": 0.90,
            "interpretation": "VERY HIGH interoperability. Color wheel combines seamlessly with: Magic lore, gameplay mechanics, other frameworks (psychology, ethics, politics). Model is *generative* — spawns infinite narrative/strategic combinations. Multicolor cards/decks demonstrate compositional interoperability.",
            "evidence": [
              "10 two-color combinations (guilds, clans) — all stable and named",
              "10 three-color combinations (shards, wedges) — all viable",
              "5 four-color combinations (Nephilim) — functional if less prominent",
              "Mechanical synergies explicitly designed across colors",
              "Narrative cross-pollination (multicolor planeswalkers, characters)"
            ],
            "interoperabilityDimensions": [
              "Internal: Colors combine into multicolor identities (2^5-1 = 31 combinations)",
              "Narrative: Fits within larger Magic multiverse across planes",
              "Conceptual: Maps to psychological/ethical/political frameworks",
              "Mechanical: Integrates with all card types, formats, and mechanics"
            ]
          }
        ],
        "revoiVector": "(0.90, 0.85, 0.70, 0.75, 0.90)",
        "revoiMean": 0.82,
        "mapQuality": "EXCELLENT - Very high-quality conceptual model",
        "stateVector": "|M_colorWheel⟩ = 0.90|R⟩ + 0.85|E⟩ + 0.70|V⟩ + 0.75|O⟩ + 0.90|I⟩",
        "dominantDimensions": [
          "R (Representability)",
          "I (Interoperability)",
          "E (Evolvability)"
