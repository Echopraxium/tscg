  "@graph": [
    {
      "@id": "m0:KindlebergerMinsky",
      "@type": "owl:Ontology",
      "owl:imports": [
        "M3_GenesisSpace.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld",
        "M1_extensions/economics/M1_Economics.jsonld"
      ],
      "m3:ontologyType": {
        "@id": "m3:Poclet"
      },
      "rdfs:label": "Kindleberger-Minsky Financial Crisis Cycle",
      "rdfs:comment": "TSCG M0 poclet modeling the Kindleberger-Minsky 5-phase speculative cycle (Displacement → Boom → Euphoria → Distress → Revulsion). Primary M2 patterns: m2:Propagation (panic through interbank network) and m2:Narration (collective belief transformation). Includes simulation markers (date, asset price, transaction volume, dynamics) for 6 historical instances across all 5 phases.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-02-28",
      "owl:versionInfo": "1.0.0",
      "m1:domain": [ "Economics" ],
      "dcterms:modified": "2026-02-28",
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-02-28",
          "changes": "Initial version. 5 poles, 6 historical instances with full simulation markers (dateRange, assetPrice, transactionVolume, dynamics). Primary M2: Propagation + Narration. ASFID mean=0.91, REVOI mean=0.82, δΘ=0.09."
        }
      ]
    },
    {
      "@id": "m0:System",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Kindleberger-Minsky System",
      "rdfs:comment": "5-phase speculative cycle with two co-occurring M2 patterns: m2:Propagation (panic spreads through financial network) and m2:Narration (collective belief 'new paradigm' → Collapse). Validated across 6 historical instances spanning 1636–2022.",
      "m0:subdomains": [
        "Financial economics",
        "Behavioral finance",
        "Macroeconomics",
        "Systemic risk"
      ],
      "m0:theoreticalBasis": [
        "Hyman Minsky — Financial Instability Hypothesis (stability is destabilizing)",
        "Charles Kindleberger — Manias, Panics and Crashes (1978)",
        "Robert Shiller — Narrative Economics (Narration as market driver)",
        "Irving Fisher — Debt Deflation Theory (1933)",
        "Walter Bagehot — Lender of Last Resort principle (1873)"
      ],
      "m0:asfidScores": {
        "A": 0.92,
        "S": 0.85,
        "F": 0.92,
        "I": 0.9,
        "D": 0.95,
        "mean": 0.91
      },
      "m0:revoiScores": {
        "R": 0.85,
        "E": 0.78,
        "V": 0.75,
        "O": 0.82,
        "Im": 0.88,
        "mean": 0.82
      },
      "m0:epistemicGap": 0.09,
      "m0:primaryMetaconcepts": [
        {
          "@id": "m2:Propagation",
          "m0:role": "panic_spread",
          "m0:propagationRegime_byPhase": {
            "Displacement": "SubThreshold (panic R₀<<1)",
            "Boom": "SubThreshold (optimism dominant)",
            "Euphoria": "SubThreshold for panic, Supercritical for opportunity narrative",
            "Distress": "Critical → Supercritical (R₀ crosses 1 at Minsky Moment)",
            "Revulsion": "Supercritical → Saturated"
          }
        },
        {
          "@id": "m2:Narration",
          "m0:role": "collective_belief_transformation",
          "m0:narrativeTopology": "Linear",
          "m0:attractorType": "Collapse",
          "m0:narrativeArc": "'New paradigm' → 'This time is different' → 'Panic' → 'Never again'"
        }
      ],
      "m0:secondaryMetaconcepts": [
        {
          "@id": "m2:Cascade",
          "m0:role": "panic_cascade_mechanism"
        },
        {
          "@id": "m2:Bifurcation",
          "m0:role": "minsky_moment_state_change"
        },
        {
          "@id": "m2:Amplification",
          "m0:role": "leverage_amplification"
        },
        {
          "@id": "m2:Duplication",
          "m0:role": "narrative_replication"
        },
        {
          "@id": "m2:Oscillator",
          "m0:role": "financial_cycle_periodicity"
        },
        {
          "@id": "m2:Threshold",
          "m0:role": "credit_and_panic_thresholds"
        },
        {
          "@id": "m2:Network",
          "m0:role": "interbank_exposure_network"
        },
        {
          "@id": "m2:Regulation",
          "m0:role": "central_bank_lender_of_last_resort"
        },
        {
          "@id": "m2:Emergence",
          "m0:role": "systemic_risk"
        },
        {
          "@id": "m2:Memory",
          "m0:role": "institutional_forgetting"
        }
      ],
      "m0:simulationSchema": {
        "m0:description": "Schema for simulation markers present in each pole × instance combination",
        "m0:fields": {
          "dateRange": {
            "type": "object",
            "fields": {
              "start": "ISO date or year string",
              "end": "ISO date or year string",
              "duration": "human-readable duration"
            }
          },
          "assetReference": {
            "type": "object",
            "fields": {
              "name": "Name of the reference asset or index",
              "unit": "Currency or unit of measure",
              "priceStart": "Asset price at phase start (nominal)",
              "priceEnd": "Asset price at phase end (nominal)",
              "pricePeak": "Maximum price during phase (if applicable)",
              "priceTrough": "Minimum price during phase (if applicable)",
              "changePercent": "Percentage change start→end"
            }
          },
          "transactionVolume": {
            "type": "object",
            "fields": {
              "indicator": "Name of volume/activity indicator used",
              "valueStart": "Value at phase start",
              "valueEnd": "Value at phase end",
              "unit": "Unit of measure",
              "trend": "increasing | decreasing | stable | volatile"
            }
          },
          "dynamics": {
            "type": "object",
            "fields": {
              "regime": "accelerating | decelerating | stable | reversing | chaotic",
              "priceVelocity": "Approximate monthly price change rate (% per month)",
              "acceleration": "Sign and magnitude of d²Price/dt² (positive=accelerating up, negative=decelerating or reversing)",
              "volatility": "Low | Medium | High | Extreme",
              "dominantForce": "Primary driver of dynamics in this phase"
            }
          }
        }
      },
      "m0:poles": [
        "m0:Pole_Displacement",
        "m0:Pole_Boom",
        "m0:Pole_Euphoria",
        "m0:Pole_Distress",
        "m0:Pole_Revulsion"
      ],
      "m0:historicalInstances": [
        "m0:Instance_TulipMania",
        "m0:Instance_SouthSea",
        "m0:Instance_WallStreet1929",
        "m0:Instance_Dotcom",
        "m0:Instance_GFC2008",
        "m0:Instance_Crypto2021"
      ]
    },
