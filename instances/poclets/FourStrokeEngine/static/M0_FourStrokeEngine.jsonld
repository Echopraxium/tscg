      "m0:m1Contributions": {
        "description": "Domain-specific concepts contributed to M1_extensions/thermodynamics/M1_Thermodynamics.jsonld",
        "m1Target": "M1_extensions/thermodynamics/M1_Thermodynamics.jsonld",
        "concepts": [
          {
            "name": "Stroke",
            "definition": "A phase in an engine cycle (Intake, Compression, Power, Exhaust)",
            "m2Basis": "m2:Step (S⊗I⊗D) + m2:Process (D⊗F)",
            "example": "Power stroke converts combustion energy to work"
          },
          {
            "name": "CompressionRatio",
            "definition": "r = V_max / V_min — geometric parameter determining cycle efficiency",
            "m2Basis": "m2:Constraint (S⊗I)",
            "formula": "r = (V_clearance + V_displacement) / V_clearance",
            "typical": "8:1 to 12:1 for gasoline engines"
          },
          {
            "name": "OttoCycle",
            "definition": "Idealized thermodynamic cycle for 4-stroke spark-ignition engines",
            "m2Basis": "m2:Workflow (S⊗D⊗F) + m2:Transformation (D⊗S⊗I)",
            "processes": [
              "Isentropic compression",
              "Isochoric heat addition",
              "Isentropic expansion",
              "Isochoric heat rejection"
            ]
          },
          {
            "name": "ValveTiming",
            "definition": "Precise control of intake/exhaust valve opening/closing relative to crankshaft position",
            "m2Basis": "m2:Alignment (I⊗A⊗S) + m2:Constraint (S⊗I)",
            "modern": "Variable Valve Timing (VVT) optimizes for RPM/load"
          },
          {
            "name": "IgnitionTiming",
            "definition": "Crankshaft angle at which spark plug fires (typically 5-15° BTDC)",
            "m2Basis": "m2:Trigger (D⊗I) + m2:Threshold (A⊗I)",
            "optimization": "Advanced timing → higher efficiency; retarded timing → lower NOx emissions"
          },
          {
            "name": "BoreAndStroke",
            "definition": "Bore = cylinder diameter; Stroke = piston travel distance",
            "m2Basis": "m2:Component (S⊗I) [geometric parameters]",
            "ratio": "Oversquare (bore > stroke) → high RPM; undersquare (stroke > bore) → high torque"
          },
          {
            "name": "Displacement",
            "definition": "Total volume swept by all pistons in one stroke",
            "formula": "V_d = (π/4) × bore² × stroke × numberOfCylinders",
            "units": "Liters (L) or cubic inches (cu in)",
            "example": "2.0L I4 engine = 500cc per cylinder"
          },
          {
            "name": "ThermalEfficiency",
            "definition": "Ratio of work output to heat input in the Otto cycle",
            "formula": "η = 1 − (1 / r^(γ−1))",
            "m2Basis": "m2:Trade-off (A⊗I⊗F) [efficiency vs knock trade-off]",
            "note": "Domain-specific metric; relocated here from m2:Efficiency (removed from M2 v15 as non-universal)"
          }
        ]
      },
      "m0:thermodynamicEfficiency": {
        "idealOttoEfficiency": {
          "formula": "η = 1 − (1 / r^(γ−1))",
          "variables": {
            "eta": "Thermal efficiency",
            "r": "Compression ratio",
            "gamma": "Heat capacity ratio (C_p/C_v = 1.4 for air)"
          },
