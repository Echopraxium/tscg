          "rdfs:label": "Exhaust Stroke",
          "m0:sequenceNumber": 4,
          "m0:role": "Expulsion of combustion products",
          "m0:pistonMotion": "Upward (BDC → TDC)",
          "m0:intakeValve": "Closed",
          "m0:exhaustValve": "Open",
          "m0:volumeChange": "V_max → V_min (compression)",
          "m0:massFlow": "Combustion gases expelled to atmosphere",
          "m0:pressureChange": "P_4 → P_atm (return to atmospheric)",
          "m0:cycleReset": "Returns to initial state for next cycle",
          "m0:asfidContribution": {
            "F": "Mass flow of exhaust gases out via exhaust channel",
            "D": "Valve timing dynamics",
