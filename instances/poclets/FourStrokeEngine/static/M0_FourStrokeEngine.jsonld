          "m0:intakeValve": "Open",
          "m0:exhaustValve": "Closed",
          "m0:volumeChange": "V_min → V_max (expansion)",
          "m0:pressureChange": "Atmospheric pressure maintained",
          "m0:energyTransfer": "Minimal (suction work)",
          "m0:asfidContribution": {
