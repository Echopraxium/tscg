      "dcterms:modified": "2026-03-18",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "m3:ontologyCategory": {
        "@id": "m3:Poclet"
      },
      "m0:pocletType": "Cyclic",
      "m0:completeness": "All ASFID dimensions present",
      "m0:minimality": "Exactly 4 strokes (irreducible for complete cycle)",
      "m0:pedagogy": "Universal teaching tool for thermodynamics and mechanical engineering",
      "m0:observer": "Human (engineering/scientific perspective)",
      "m0:epistemicGap": 0.132,
      "m0:asfidScores": {
        "A": 0.85,
        "S": 0.9,
        "F": 0.95,
        "I": 0.8,
        "D": 0.85
      },
