      "m0:GenericConceptsMobilized": {
        "total": 20,
        "m2Version": "15.10.1",
        "m2TotalAtomicConcepts": 75,
        "percentage": "27% of M2 v15.10.1",
        "migrationNote": "m2:Cycle→(m2:Process+m2:FeedbackLoop), m2:Sequence→m2:Workflow, m2:Flow→m2:Channel, m2:Synchronization→m2:Alignment; m2:Efficiency removed (domain-specific, relocated to M1_Thermodynamics)",
        "byCategory": {
          "Structural": [
            "m2:Component (S⊗I) — 4 strokes as elementary parts",
            "m2:Composition (S⊗I⊗A) — piston + connecting rod + crankshaft assembly",
            "m2:Symmetry (S) — cylindrical geometry",
            "m2:Modularity (S⊗I) — multi-cylinder engine scalability"
          ],
          "Dynamic": [
            "m2:Process (D⊗F) — each stroke as sub-process",
            "m2:Step (S⊗I⊗D) — each stroke as elementary step in Workflow",
            "m2:Workflow (S⊗D⊗F) — strict sequential ordering of 4 strokes [replaces Sequence]",
            "m2:FeedbackLoop (Process⊗Alignment⊗Homeostasis) — periodic return to initial state [replaces Cycle]",
            "m2:Bifurcation (∂D/∂F) — rapid combustion transition at power stroke onset",
            "m2:Transformation (D⊗S⊗I) — chemical energy → thermal → mechanical work"
          ],
          "Regulatory": [
            "m2:Constraint (S⊗I) — fixed cylinder volume, compression ratio r",
            "m2:Threshold (A⊗I) — ignition point (spark timing)",
            "m2:Trigger (D⊗I) — spark plug initiates combustion",
            "m2:Alignment (I⊗A⊗S) — multi-cylinder timing coordination [replaces Synchronization]"
          ],
          "Energetic": [
            "m2:Channel (S⊗I⊗F) — air-fuel intake path + exhaust gas output conduit [replaces Flow]",
            "m2:Dissipation (F⊗D) — heat loss through cylinder walls (cooling system)",
            "m2:Gradient (⊗₂F) — pressure gradient drives piston on power stroke"
          ],
          "Teleonomic": [
            "m2:Trade-off (A⊗I⊗F) — compression ratio up → efficiency up BUT knock risk up",
            "m2:Balance (A⊗S⊗F) — valve timing / ignition timing / piston synchronization",
            "m2:Emergence (I⊗S⊗D) — continuous crankshaft rotation emerges from 4 discrete strokes"
          ]
        },
        "criticalGenericConcepts": [
          {
            "name": "m2:Workflow",
            "role": "Enforces strict ordering (Intake → Compression → Power → Exhaust)",
            "formula": "S⊗D⊗F",
            "significance": "Wrong stroke order destroys cycle functionality",
            "migration": "Replaces deprecated m2:Sequence"
          },
          {
            "name": "m2:FeedbackLoop",
            "role": "Periodic return to initial state — defines cyclicity",
            "formula": "Process⊗Alignment⊗Homeostasis",
            "significance": "Cycle completion restores system to identical initial conditions",
            "migration": "Replaces deprecated m2:Cycle"
          },
          {
            "name": "m2:Transformation",
            "role": "Chemical energy → Thermal → Mechanical work",
            "formula": "D⊗S⊗I",
            "significance": "Core purpose of the engine"
          },
          {
            "name": "m2:Bifurcation",
            "role": "Rapid combustion transition (spark → pressure spike)",
            "formula": "∂D/∂F",
            "significance": "Critical non-linear event in power stroke"
          },
          {
            "name": "m2:Emergence",
            "role": "Continuous rotation emerges from 4 discrete strokes",
            "formula": "I⊗S⊗D",
            "significance": "Whole > sum of parts: smooth rotation from jerky reciprocating motion"
          }
        ]
      },
      "m0:transdisciplinaryValidation": {
