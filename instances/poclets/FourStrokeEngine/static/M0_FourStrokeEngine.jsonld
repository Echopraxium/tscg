            "m0:connection": "Piston (small end) ↔ Crankshaft (big end)"
          },
          {
            "@id": "m0:Crankshaft",
            "rdfs:label": "Crankshaft",
            "m0:function": "Converts reciprocating motion to continuous rotation",
            "m0:output": "Rotational kinetic energy (torque × RPM)",
            "m0:revolutions": "2 full rotations per 4-stroke cycle",
            "m1coreRef": "m1core:Oscillator (crankshaft as cyclic trajectory component)"
          },
          {
            "@id": "m0:SparkPlug",
            "rdfs:label": "Spark Plug",
            "m0:function": "Initiates combustion via electrical discharge",
            "m0:timing": "Ignition at ~5-15° BTDC (Before Top Dead Center)",
            "m2ref": "m2:Trigger (D⊗I) — initiates power stroke bifurcation"
          },
          {
            "@id": "m0:IntakeValve",
            "rdfs:label": "Intake Valve",
            "m0:function": "Controls air-fuel mixture entry",
            "m0:timing": "Opens at TDC (intake), closes at BDC (compression)",
            "m2ref": "m2:Channel (S⊗I⊗F) — intake flow conduit"
          },
          {
            "@id": "m0:ExhaustValve",
            "rdfs:label": "Exhaust Valve",
            "m0:function": "Controls combustion gas expulsion",
            "m0:timing": "Opens at BDC (exhaust), closes at TDC (intake)",
            "m2ref": "m2:Channel (S⊗I⊗F) — exhaust flow conduit"
          },
          {
            "@id": "m0:Camshaft",
            "rdfs:label": "Camshaft",
            "m0:function": "Controls valve timing via cam lobes",
            "m0:gearRatio": "1:2 (1 camshaft rotation per 2 crankshaft rotations)",
            "m2ref": "m2:Alignment (I⊗A⊗S) — coordinates valve/piston timing"
          }
        ]
      },
