          "@type": "m0:Stroke",
          "rdfs:label": "Compression Stroke",
          "m0:sequenceNumber": 2,
          "m0:role": "Adiabatic compression of air-fuel mixture",
          "m0:pistonMotion": "Upward (BDC → TDC)",
          "m0:intakeValve": "Closed",
          "m0:exhaustValve": "Closed",
          "m0:volumeChange": "V_max → V_min (compression)",
          "m0:pressureChange": "P_1 → P_2 (increase by factor r^gamma)",
          "m0:temperatureChange": "T_1 → T_2 (increase)",
          "m0:compressionRatio": "r = V_max / V_min (typically 8:1 to 12:1)",
          "m0:workInput": "Negative (crankshaft does work on gas)",
          "m0:asfidContribution": {
            "S": "Volume reduction through piston motion",
            "D": "Pressure and temperature increase dynamics",
            "I": "Thermodynamic state (P, V, T) information"
          }
        },
        {
          "@id": "m0:PowerStroke",
          "@type": "m0:Stroke",
          "rdfs:label": "Power Stroke (Combustion)",
          "m0:sequenceNumber": 3,
          "m0:role": "Conversion of chemical energy to mechanical work",
          "m0:pistonMotion": "Downward (TDC → BDC)",
          "m0:intakeValve": "Closed",
          "m0:exhaustValve": "Closed",
          "m0:trigger": "Spark plug ignition",
          "m0:combustion": "Rapid oxidation of fuel (bifurcation event)",
          "m0:pressureChange": "P_2 → P_3 (rapid spike) → P_4 (expansion)",
          "m0:volumeChange": "V_min → V_max (expansion)",
          "m0:workOutput": "Positive (gas does work on piston)",
          "m0:energyTransformation": "Chemical (fuel) → Thermal (combustion) → Mechanical (piston motion)",
