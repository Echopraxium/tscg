            "m2Basis": "m2:Alignment (IÔŐŚAÔŐŚS) + m2:Constraint (SÔŐŚI)",
            "modern": "Variable Valve Timing (VVT) optimizes for RPM/load"
          },
          {
            "name": "IgnitionTiming",
            "definition": "Crankshaft angle at which spark plug fires (typically 5-15┬░ BTDC)",
            "m2Basis": "m2:Trigger (DÔŐŚI) + m2:Threshold (AÔŐŚI)",
            "optimization": "Advanced timing Ôćĺ higher efficiency; retarded timing Ôćĺ lower NOx emissions"
          },
          {
            "name": "BoreAndStroke",
            "definition": "Bore = cylinder diameter; Stroke = piston travel distance",
            "m2Basis": "m2:Component (SÔŐŚI) [geometric parameters]",
            "ratio": "Oversquare (bore > stroke) Ôćĺ high RPM; undersquare (stroke > bore) Ôćĺ high torque"
          },
          {
            "name": "Displacement",
            "definition": "Total volume swept by all pistons in one stroke",
            "formula": "V_d = (¤Ç/4) ├Ś bore┬▓ ├Ś stroke ├Ś numberOfCylinders",
            "units": "Liters (L) or cubic inches (cu in)",
            "example": "2.0L I4 engine = 500cc per cylinder"
          },
          {
            "name": "ThermalEfficiency",
