        "concepts": [
          {
            "name": "Stroke",
            "definition": "A phase in an engine cycle (Intake, Compression, Power, Exhaust)",
            "m2Basis": "m2:Step (SÔŐŚIÔŐŚD) + m2:Process (DÔŐŚF)",
            "example": "Power stroke converts combustion energy to work"
          },
          {
            "name": "CompressionRatio",
            "definition": "r = V_max / V_min ÔÇö geometric parameter determining cycle efficiency",
            "m2Basis": "m2:Constraint (SÔŐŚI)",
            "formula": "r = (V_clearance + V_displacement) / V_clearance",
            "typical": "8:1 to 12:1 for gasoline engines"
          },
          {
            "name": "OttoCycle",
            "definition": "Idealized thermodynamic cycle for 4-stroke spark-ignition engines",
            "m2Basis": "m2:Workflow (SÔŐŚDÔŐŚF) + m2:Transformation (DÔŐŚSÔŐŚI)",
            "processes": [
