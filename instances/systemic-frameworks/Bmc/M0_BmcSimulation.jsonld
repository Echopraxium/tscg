          "sim:toPhase": "Transition",
          "sim:outcome": {
            "@id": "sim:outcome.Success"
          },
          "sim:instableBlocks": [
            "VP",
            "RS",
            "KA"
          ],
          "sim:emergingFluxes": [
            "vp_cr",
            "ka_vp"
          ],
          "sim:fadingFluxes": [
            "kr_cost"
          ],
          "sim:vp": 0.62,
          "sim:conv": 0.55,
          "sim:cross": 0.1,
          "sim:net": 0.35,
          "sim:cost": 0.58,
          "sim:blockContent": {
            "VP": {
              "bullets": [
                "Managed Print Services (MPS)",
                "Pay-per-page model",
                "Outsource all printing"
              ],
              "osterwalder": {
                "valueLevel": "excellence",
                "priceLvl": "market"
              }
