                "Software (DocuShare)"
              ],
              "osterwalder": {
                "revenueType": "usage",
                "pricingMech": "dynamic"
              }
            },
            "CS": {
              "bullets": [
                "Large enterprise IT",
                "Government print fleets",
                "Healthcare (HIPAA print)"
              ],
              "osterwalder": {
                "segmentType": "segmented"
              }
