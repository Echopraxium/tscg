              "dcterms:date": "1999",
              "dcterms:publisher": "HarperBusiness"
            },
            {
              "@type": "dcterms:BibliographicResource",
              "dcterms:title": "Fumbling the Future",
              "dcterms:creator": "Douglas Smith & Robert Alexander",
              "dcterms:date": "1988",
              "dcterms:publisher": "William Morrow"
            }
          ]
        },
