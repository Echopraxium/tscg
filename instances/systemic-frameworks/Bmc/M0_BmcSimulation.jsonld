            }
          ]
        },
        {
          "@type": "sim:Transition",
          "sim:transitionIndex": 1,
          "sim:transitionLabel": "Mutation T2 — Wii Revolution: casual gaming (2006)",
          "sim:fromPhase": "Maturity",
          "sim:toPhase": "Growth",
