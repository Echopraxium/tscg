  "@graph": [
    {
      "@id": "m0.bmc:BmcSystemicFramework",
      "@type": "owl:Ontology",
      "m3:ontologyType": { "@id": "m3:SystemicFramework" },
      "rdfs:label": "Business Model Canvas (BMC)",
      "rdfs:comment": "The Business Model Canvas (Osterwalder & Pigneur, 2010) is a strategic management framework that describes how an organization creates, delivers, and captures value through 9 interconnected building blocks. As a TSCG SystemicFramework, the BMC is modeled through the bicephalous lens: the Territory (Eagle Eye / ASFID) captures the operational dynamics of real business systems; the Map (Sphinx Eye / REVOI) evaluates the BMC itself as a representational and analytical tool. SpectralClass: Coherent (δ₁=0.033). FocalClass: SlightlyHyperopic (SFE=0.811) — the BMC is a map-dominant framework: its Sphinx Eye (REVOI) strength slightly exceeds its Territory (ASFID) coverage, reflecting its nature as a visual strategic canvas rather than a dynamic simulation tool.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-06-20",
      "dcterms:modified": "2026-06-20",
      "owl:versionInfo": "1.0.0",
      "m1:domain": ["Business Strategy", "Management", "Innovation"],
      "m1:simulationTitle": "Business Model Canvas (BMC)",
      "owl:imports": [
        "M0_Common.jsonld",
        "M3_GenesisGrammar.jsonld",
        "M2_GenericConcepts.jsonld",
        "M1_CoreConcepts.jsonld",
        "M1_extensions/business-modeling/M1_BusinessModeling.jsonld"
      ],
      "m2:changelog": [
        {
          "version": "1.0.0",
          "date": "2026-06-20",
          "changes": "Initial version. 9 BMC blocks mapped to ASFID/REVOI. 15 real-world case studies (Netflix×3, AWS×2, Michelin×2, Spotify, Airbnb, Visa, Apple, Google, Amazon, IKEA, Uber). M1_BusinessModeling extension created with 9 KFCCs. v1.5 conventions: M0_Common namespace, bare numerics, enum IRIs."
        }
      ],
      "m0:scoreA": 0.85,
      "m0:scoreS": 0.90,
      "m0:scoreF": 0.78,
      "m0:scoreIt": 0.82,
      "m0:scoreD": 0.80,
      "m0:asfidMean": 0.830,
      "m0:scoreR": 0.90,
      "m0:scoreE": 0.88,
      "m0:scoreV": 0.85,
      "m0:scoreO": 0.87,
      "m0:scoreIm": 0.87,
      "m0:revoiMean": 0.874,
      "m0:epistemicGap": 0.031,
      "m0:spectralClass": { "@id": "m0:spectralClass.Coherent" },
      "m0:scoringStatus": { "@id": "m0:scoringStatus.Complete" },
      "m0:focalApplicable": true,
      "m0:stereopsicDepth": 0.85,
      "m0:focalBias": 0.044,
      "m0:focalScore": 0.813,
      "m0:focalClass": { "@id": "m0:focalClass.SlightlyHyperopic" },
      "m0:stereopsicDepthProfile": "T=0.90 (Attractor as VP convergence pole), K=0.85 (9-block architecture as structural key), Ss=0.80 (cross-industry pattern transferability), L=0.85 (mutation timelines: Netflix/AWS/Michelin)",
      "m0:scoringJustification": {
        "m0:scoreA": "Value Proposition as strong convergence attractor — all 8 other blocks are organized around VP. Network effects in platform models create super-attractor dynamics (Visa, Airbnb). Score slightly below max: VP stability varies across business model types (product vs platform vs service).",
        "m0:scoreS": "9-block architecture is formally structured with explicit directional relationships. BMC has a canonical topological layout (left=infrastructure, center=value, right=customer) that is reproducible across contexts. Near-maximum: structure is formal but not algebraically closed.",
        "m0:scoreF": "Customer flow (acquisition→retention→revenue) and cost flow (resources→activities→partners→costs) are well-articulated. Somewhat lower than structure: flow quantification requires domain-specific metrics not native to the BMC canvas itself.",
        "m0:scoreIt": "Value Proposition IS an informational construct by definition — it encodes what promise is communicated. Customer Segments define the perceptual map. Information dimension well-covered but less formalized than in VSM (Ashby's variety calculus).",
        "m0:scoreD": "Business Model Mutations (Netflix 3 states, AWS 2 states, Michelin 2 states) demonstrate rich temporal dynamics. Slightly lower: BMC is primarily a static snapshot tool — dynamic evolution requires external scenario analysis, not native to the canvas.",
        "m0:scoreR": "BMC is a universal visual standard with extraordinary reproducibility: canvas layout, color coding, and block naming are consistent across thousands of publications and practitioners in 45+ languages. Highest REVOI dimension.",
        "m0:scoreE": "Highly extensible: Lean Canvas (Ash Maurya), Value Proposition Canvas (Osterwalder), BMC+ (social enterprise variant), digital twin BMC. Compatible with adjacent frameworks (TRIZ, VSM, OKR, Balanced Scorecard).",
        "m0:scoreV": "Validated empirically across thousands of companies (Strategyzer database, HBS case studies). Predictive validity: BMC pre-analysis correlates with startup success in Y Combinator cohorts. Slightly below max: causal validation remains correlational, not experimental.",
        "m0:scoreO": "9 blocks are directly observable and instrumentable via customer interviews, financial data, contracts with partners/channels. BMC workshops are a standard observation methodology. Near-maximum: some blocks (KeyResources intangibles, CustomerRelationships) resist quantification.",
        "m0:scoreIm": "Compatible with TRIZ (contradiction → innovation → BMC redesign), VSM (viability → BMC block assignment), Lean Startup (pivot = BMC block replacement), OKR (KR = BMC metric). W3C standardization absent but de-facto standard achieved."
      },
      "m0.bmc:completeness": "All 9 BMC blocks present as TSCG components. All 5 ASFID dimensions active. All 5 REVOI dimensions evaluated.",
      "m0.bmc:minimality": "9 blocks necessary and sufficient: VP (attractor), CS (information boundary), CH (flow), CR (dynamics), RS (flow capture), KA (internal flow), KR (structural resources), KP (external structure), CS_ (cost flow). No redundancy across blocks.",
      "m0.bmc:pedagogy": "The BMC is a boundary object between business strategy, design thinking, and systems thinking. Its TSCG analysis reveals it as a structural grammar for business systems — each block corresponds to an ASFID/REVOI dimension with remarkable precision.",
      "m0.bmc:observer": "Strategic analyst, entrepreneur, business designer, management consultant. The BMC was designed for collaborative workshops — it is inherently multi-observer.",
      "m0.bmc:structuralGrammarFormula": "BMC = BusinessModeling ⊙ (A × St × F × It × D | R + E + V + O + Im)",
      "m2:hasStructuralGrammarFormula": "BMC = BusinessModeling ⊙ (A[VP] × St[9-blocks] × F[value/cost flows] × It[VP signal + CS perception] × D[mutations] | R[canvas standard] + E[framework variants] + V[empirical validation] + O[block instrumentation] + Im[cross-framework compatibility])"
    },
    {
      "@id": "m0.bmc:Block_ValueProposition",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Value Propositions (VP)",
      "rdfs:comment": "The bundle of products and services that create value for a specific Customer Segment. The attractor center of the BMC: all other blocks are designed to support, deliver, and sustain the VP.",
      "m0.bmc:bmcPosition": "center",
      "m0.bmc:asfidPrimaryDimension": "A",
      "m0.bmc:asfidContribution": {
        "A": "VP defines the equilibrium state the business targets — the 'destination' customers are attracted toward",
        "It": "VP is informational by nature: what promise is encoded and transmitted to the customer"
      },
      "m1.extensions.business-modeling:kfcc": { "@id": "m1.extensions.business-modeling:ValueProposition" },
      "m2:mobilizedGenericConcepts": ["m2:Attractor", "m2:Information", "m2:Emergence"],
      "m0.bmc:realWorldExamples": [
        "Netflix: 'Unlimited streaming, no ads, cancel anytime'",
        "AWS: 'Elastic compute at marginal cost — pay for what you use'",
        "Michelin: 'Tire performance + predictive fleet optimization'"
      ]
    },
    {
      "@id": "m0.bmc:Block_CustomerSegments",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Customer Segments (CS)",
      "rdfs:comment": "The distinct groups of people or organizations the business aims to reach and serve. Defines the information boundary: which signals (needs, behaviors, willingness-to-pay) are relevant inputs.",
      "m0.bmc:bmcPosition": "right",
      "m0.bmc:asfidPrimaryDimension": "It",
      "m0.bmc:asfidContribution": {
        "It": "Segments define the perceptual map — what customer knowledge is relevant",
        "S": "Multi-sided platforms require structural coupling between segments (Visa: cardholders ↔ merchants)"
      },
      "m1.extensions.business-modeling:kfcc": { "@id": "m1.extensions.business-modeling:CustomerSegment" },
      "m2:mobilizedGenericConcepts": ["m2:Information", "m2:Boundary", "m2:Synergy"],
      "m0.bmc:segmentTypesPresent": ["mass_market", "niche", "segmented", "diversified", "multi_sided"]
    },
    {
      "@id": "m0.bmc:Block_Channels",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Channels (CH)",
      "rdfs:comment": "How the company communicates with and reaches its Customer Segments to deliver the Value Proposition. Channels are the structural flow paths through which value moves from the company to the customer.",
      "m0.bmc:bmcPosition": "right",
      "m0.bmc:asfidPrimaryDimension": "F",
      "m0.bmc:asfidContribution": {
        "F": "Channels ARE the flow paths — they define how value physically or digitally moves to customers",
        "S": "Channel architecture creates the structural topology of VP delivery"
      },
      "m2:mobilizedGenericConcepts": ["m2:Flow", "m2:Cascade", "m2:Propagation"],
      "m0.bmc:channelPhases": ["Awareness", "Evaluation", "Purchase", "Delivery", "After-sales"],
      "m0.bmc:channelTypes": {
        "own": "Direct sales force, web sales, own stores (Apple Store, Tesla direct)",
        "partner": "Partner stores, wholesalers, distributors (traditional retail, Amazon marketplace)"
      }
    },
    {
      "@id": "m0.bmc:Block_CustomerRelationships",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Customer Relationships (CR)",
      "rdfs:comment": "The types of relationships the company establishes with specific Customer Segments. Relationships range from automated self-service to dedicated personal assistance. CR governs the dynamic of customer lifecycle management.",
      "m0.bmc:bmcPosition": "right",
      "m0.bmc:asfidPrimaryDimension": "D",
      "m0.bmc:asfidContribution": {
        "D": "CR defines the temporal dynamics of the customer relationship — acquisition, retention, churn cycles",
        "A": "Retention mechanisms create attractor dynamics: switching costs, loyalty programs, lock-in"
      },
      "m2:mobilizedGenericConcepts": ["m2:Dynamics", "m2:Feedback", "m2:Equilibrium"],
      "m0.bmc:relationshipTypes": {
        "personal_assistance": "Human interaction (dedicated account manager, after-sales support)",
        "self_service": "Automated, customer-managed (ATM, online banking, SaaS self-serve)",
        "automated": "Algorithm-driven personalization (Netflix recommendation, Spotify Discover Weekly)",
        "communities": "User communities generating mutual value (Salesforce Trailhead, Apple Developer)",
        "co_creation": "Customers contribute to product (Amazon reviews, YouTube creators, Wikipedia)"
      }
    },
    {
      "@id": "m0.bmc:Block_RevenueStreams",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Revenue Streams (RS)",
      "rdfs:comment": "The cash a company generates from each Customer Segment. RS quantifies the economic signal that the VP has achieved attractor pull. Revenue mechanism (transactional vs recurring) maps directly to the Dynamics dimension.",
      "m0.bmc:bmcPosition": "right",
      "m0.bmc:asfidPrimaryDimension": "F",
      "m0.bmc:asfidContribution": {
        "F": "Revenue IS the economic flow — the quantified return on delivered VP",
        "A": "Recurring revenues (subscription) create stable limit cycle attractors; transactional revenues create pulse dynamics"
      },
      "m1.extensions.business-modeling:kfcc": { "@id": "m1.extensions.business-modeling:RevenueStream" },
      "m2:mobilizedGenericConcepts": ["m2:Flow", "m2:Attractor", "m2:Amplification"],
      "m0.bmc:crossSubsidyPresent": true,
      "m0.bmc:crossSubsidyInstances": [
        "Google: free search subsidized by advertising revenue",
        "Spotify: free tier subsidized by premium subscriptions",
        "Gillette: razors below cost, blades above cost (razor/blade model)"
      ]
    },
    {
      "@id": "m0.bmc:Block_KeyActivities",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Key Activities (KA)",
      "rdfs:comment": "The most important actions a company must perform to make its business model work. KA defines the operational flow: what processes must execute to produce and deliver the VP.",
      "m0.bmc:bmcPosition": "left",
      "m0.bmc:asfidPrimaryDimension": "F",
      "m0.bmc:asfidContribution": {
        "F": "Activities ARE internal processes — operational flows that transform resources into VP",
        "D": "Activity configuration determines system dynamics: production rhythms, innovation cycles, service delivery cadence"
      },
      "m2:mobilizedGenericConcepts": ["m2:Process", "m2:Flow", "m2:Transformation"],
      "m0.bmc:activityCategories": {
        "production": "Creating and delivering products (manufacturing, software development)",
        "problem_solving": "Creating new solutions for individual customers (consulting, hospitals, R&D)",
        "platform_network": "Platform management, service provisioning, promotion (Visa, Airbnb, Google)"
      }
    },
    {
      "@id": "m0.bmc:Block_KeyResources",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Key Resources (KR)",
      "rdfs:comment": "The most important assets required to make a business model work. KR provides the structural substrate on which KeyActivities operate and from which VP emerges.",
      "m0.bmc:bmcPosition": "left",
      "m0.bmc:asfidPrimaryDimension": "S",
      "m0.bmc:asfidContribution": {
        "S": "Resources define the structural substrate — the 'scaffolding' on which the business rests",
        "A": "Proprietary resources create structural attractors: patents, brands, exclusive data create sustainable competitive advantage"
      },
      "m2:mobilizedGenericConcepts": ["m2:Structure", "m2:Reservoir", "m2:Modularity"],
      "m0.bmc:resourceTypes": {
        "physical": "Manufacturing facilities, logistics networks, point-of-sale systems",
        "intellectual": "Brands, patents, proprietary algorithms, customer databases, copyrights",
        "human": "Knowledge workers, engineers, scientists, creative talent",
        "financial": "Cash reserves, credit lines, stock option pools"
      }
    },
    {
      "@id": "m0.bmc:Block_KeyPartnerships",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Key Partnerships (KP)",
      "rdfs:comment": "The network of suppliers and partners that make the business model work. KP externalizes non-core activities and resources, extending the structural boundary of the firm beyond its legal boundaries.",
      "m0.bmc:bmcPosition": "left",
      "m0.bmc:asfidPrimaryDimension": "S",
      "m0.bmc:asfidContribution": {
        "S": "Partnerships extend the structural topology of the business system beyond legal firm boundaries",
        "It": "Partner selection encodes strategic information about which capabilities are core vs. commoditizable"
      },
      "m2:mobilizedGenericConcepts": ["m2:Structure", "m2:Synergy", "m2:Interoperability"],
      "m0.bmc:partnershipTypes": {
        "strategic_alliance": "Non-competitor collaboration (airline alliances, cross-industry R&D)",
        "coopetition": "Competitor cooperation in non-competitive areas (Samsung supplies Apple chips)",
        "joint_venture": "Shared entity creation for new business (Sony-Ericsson mobile JV)",
        "buyer_supplier": "Reliability and quality optimization (Toyota/supplier keiretsu)"
      },
      "m0.bmc:verticalIntegrationNexus": "The boundary between KeyPartnerships and KeyActivities+KeyResources is the locus of VerticalIntegration decisions: internalizing a partnership converts KP→KA+KR (upstream integration) or KP→CH+CS (downstream integration)."
    },
    {
      "@id": "m0.bmc:Block_CostStructure",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "Cost Structure (C$)",
      "rdfs:comment": "All costs incurred to operate a business model. The cost structure is the aggregate financial expression of KeyActivities, KeyResources, and KeyPartnerships. It stands in fundamental StrategicTension with the ValueProposition: every VP enhancement typically increases cost, and cost optimization risks VP degradation.",
      "m0.bmc:bmcPosition": "left",
      "m0.bmc:asfidPrimaryDimension": "F",
      "m0.bmc:asfidContribution": {
        "F": "Costs represent the internal resource flows consumed to produce and deliver value",
        "A": "Cost structure shapes the sustainability attractor: business models converge toward break-even or margin attractors determined by cost architecture"
      },
      "m2:mobilizedGenericConcepts": ["m2:Flow", "m2:Equilibrium", "m2:Polarity"],
      "m0.bmc:costCategories": {
        "cost_driven": "Minimize cost wherever possible (Ryanair, IKEA, Aldi) — lean structures, automation",
        "value_driven": "Focus on premium VP regardless of cost implications (luxury hotels, Nespresso)"
      },
      "m0.bmc:costProperties": {
        "fixed": "Costs independent of volume (salaries, rent, capital equipment)",
        "variable": "Costs that scale with volume (materials, fulfillment, cloud compute on-demand)",
        "economies_of_scale": "Cost per unit decreases as volume increases (manufacturing, cloud infrastructure)",
        "economies_of_scope": "Cost synergies from shared activities across multiple VPs (Amazon: logistics serves retail + marketplace + AWS delivery)"
      }
    },
    {
      "@id": "m0.bmc:GenericConceptsMobilized",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "GenericConcepts Mobilized by BMC",
      "m0.bmc:totalCount": 12,
      "m0.bmc:byCategory": {
        "Attractor_family": ["m2:Attractor", "m2:Equilibrium"],
        "Structure_family": ["m2:Structure", "m2:Modularity", "m2:Boundary"],
        "Flow_family": ["m2:Flow", "m2:Cascade", "m2:Propagation", "m2:Process"],
        "Information_family": ["m2:Information"],
        "Dynamics_family": ["m2:Dynamics", "m2:Transformation", "m2:Feedback"],
        "Cross_dimensional": ["m2:Amplification", "m2:Synergy", "m2:Polarity", "m2:Emergence"]
      },
      "m0.bmc:stereopsicGenericConcepts": ["m2:Synergy", "m2:Emergence", "m2:Amplification"],
      "m0.bmc:stereopsicNote": "3 stereopsic concepts mobilized: Synergy (PlatformDuality), Emergence (network effects in multi-sided platforms), Amplification (CrossSubsidy). These require simultaneous Eagle Eye + Sphinx Eye activation — the business model IS different when viewed from the operator's perspective vs. the strategic analyst's canvas."
    },
    {
      "@id": "m0.bmc:CaseStudies",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "BMC Real-World Case Studies",
      "rdfs:comment": "15 real-world instances demonstrating BusinessModelPattern, BusinessModelMutation, CrossSubsidy, PlatformDuality, and VerticalIntegration across diverse industries.",
      "m0.bmc:mutations": [
        {
          "company": "Netflix",
          "state0": {
            "year": 1997,
            "model": "DVD-by-mail subscription",
            "VP": "No late fees, large catalog, home delivery",
            "RS": "Monthly subscription ($15.99)",
            "KA": "Physical logistics, inventory management",
            "KP": "USPS, film studios (licensing)"
          },
          "state1": {
            "year": 2007,
            "model": "Streaming platform",
            "VP": "Instant unlimited streaming, any device",
            "RS": "Tiered subscription ($8.99-$22.99)",
            "KA": "CDN infrastructure, recommendation algorithm, licensing negotiation",
            "KP": "AWS (then internalized CDN), studios"
          },
          "state2": {
            "year": 2013,
            "model": "Content studio + streaming",
            "VP": "Original exclusive content + unlimited catalog",
            "RS": "Global subscription (190 countries)",
            "KA": "Content production, global distribution, algorithm",
            "KP": "Production houses, talent agencies, AWS (infrastructure)"
          },
          "mutationBlocks": ["VP", "KA", "KP", "RS", "KR"],
          "tscgPattern": "3 successive BusinessModelMutations across 16 years — each mutation changes ≥4 BMC blocks and shifts the attractor state qualitatively"
        },
        {
          "company": "Amazon Web Services",
          "state0": {
            "year": 2000,
            "model": "Internal IT infrastructure",
            "VP": "Internal: reliable compute for amazon.com",
            "RS": "None (cost center)",
            "KA": "Infrastructure management for e-commerce"
          },
          "state1": {
            "year": 2006,
            "model": "Public cloud utility",
            "VP": "Elastic compute at marginal cost, API-first, global",
            "RS": "Pay-per-use (S3: $0.023/GB, EC2: per-hour)",
            "KA": "Platform engineering, global datacenter operations, developer relations",
            "KP": "Intel/AMD (hardware), global fiber network providers"
          },
          "mutationBlocks": ["VP", "RS", "CS", "KA", "KR"],
          "tscgPattern": "Single massive BusinessModelMutation: internal cost center → external profit center. CrossSubsidy inverted: AWS profits now subsidize Amazon retail's logistics."
        },
        {
          "company": "Michelin",
          "state0": {
            "year": "pre-1999",
            "model": "Tire manufacturer",
            "VP": "High-performance durable tires",
            "RS": "Asset sale (tire price)",
            "KA": "Manufacturing, R&D, dealer network management"
          },
          "state1": {
            "year": 1999,
            "model": "Fleet outcome service",
            "VP": "Guaranteed cost-per-kilometer + fleet optimization",
            "RS": "Pay-per-km contract (outcome-based)",
            "KA": "IoT sensor monitoring, predictive analytics, fleet management consulting",
            "KP": "Telematics partners, fleet operators"
          },
          "mutationBlocks": ["VP", "RS", "KA", "CR"],
          "tscgPattern": "BusinessModelMutation from product to service — VP shifts from asset to outcome. VerticalIntegration downstream into fleet analytics."
        }
      ],
      "m0.bmc:additionalCaseStudies": [
        {
          "company": "Spotify",
          "pattern": "CrossSubsidy + PlatformDuality",
          "description": "Free tier (30M songs, ads) subsidized by €10.99/month premium (68M subscribers). Two-sided platform: listeners ↔ artists/labels. CrossSubsidy conversion rate ~30% free→premium."
        },
        {
          "company": "Airbnb",
          "pattern": "PlatformDuality",
          "description": "Hosts (supply) ↔ Guests (demand). Platform as trust infrastructure. No KeyResources in real estate — pure platform orchestration. Revenue: 3% host fee + 12-14% guest fee."
        },
        {
          "company": "Visa",
          "pattern": "PlatformDuality + CrossSubsidy",
          "description": "Cardholders (free, subsidized by merchant interchange) ↔ Merchants (interchange fee ~1.8%). Network effects: 4.3B cards in 200+ countries → 100M+ merchant locations. Classic multi-sided platform."
        },
        {
          "company": "Apple",
          "pattern": "VerticalIntegration + BusinessModelPattern (ecosystem)",
          "description": "Vertical integration: hardware design (Apple Silicon, M1/M2/M3), retail (500+ Apple Stores), services (App Store 30% commission). Ecosystem lock-in: iOS ↔ Mac ↔ Watch ↔ iCloud creates multi-attractor basin."
        },
        {
          "company": "Google Search",
          "pattern": "CrossSubsidy (attention economy)",
          "description": "Free search service subsidized by $224B/year advertising revenue (2023). Attention is the resource; advertisers are the customers. Users are the product. Classic two-sided market with asymmetric VP."
        },
        {
          "company": "Amazon Marketplace",
          "pattern": "PlatformDuality + VerticalIntegration",
          "description": "Buyers ↔ Third-party sellers (58% of units sold). Amazon integrates vertically into fulfillment (FBA: Fulfillment by Amazon) and advertising (Amazon Ads), capturing margin at multiple stages."
        },
        {
          "company": "IKEA",
          "pattern": "BusinessModelPattern (cost innovation)",
          "description": "CrossSubsidy inverted: customer assembles furniture (free labor subsidy to IKEA). StrategicTension resolved: low cost + high design through flat-pack manufacturing. Vertical integration in forestry (owns forests in Romania, Baltic states)."
        },
        {
          "company": "Uber",
          "pattern": "PlatformDuality + StrategicTension",
          "description": "Drivers (supply, independent contractors) ↔ Riders (demand). StrategicTension: driver income maximization vs. rider price minimization — platform mediates via dynamic pricing (surge). Network effect: density → shorter wait times → more riders → more drivers."
        }
      ]
    },
    {
      "@id": "m0.bmc:Validation",
      "@type": "owl:NamedIndividual",
      "rdfs:label": "TSCG Validation — BMC SystemicFramework",
      "m0.bmc:asfidCompleteness": {
        "A": true,
        "S": true,
        "F": true,
        "It": true,
