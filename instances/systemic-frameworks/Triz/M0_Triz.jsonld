    {
      "@id": "m0triz:CaseStudies",
      "@type": "m0triz:ApplicationExamples",
      "rdfs:label": "TRIZ Case Studies — Real-World Applications",
      "rdfs:comment": "Collection of 20 documented case studies demonstrating TRIZ principle combinations in solving real technical contradictions across multiple engineering domains",
      "m0triz:totalCaseStudies": 20,
      "m0triz:domainsCovered": [
        "Automotive Safety / Mechanical Engineering",
        "Materials Science / Nanotechnology",
        "Thermal Engineering / Electronics Cooling",
        "Safety Equipment / Marine Engineering",
        "Cookware / Materials Science",
        "Heavy Equipment / Hydraulics",
        "Optics / Safety",
        "Medical Devices / Smart Materials",
        "Plumbing / Environmental Engineering",
        "Control Systems / Automotive",
        "Marine Engineering / Composites",
        "Thermodynamics / Cooking",
        "Defense / Ballistic Protection",
        "Renewable Energy / Passive Systems",
        "Consumer Products / Mechanical Design",
        "Textile Engineering / Adhesion",
        "Chemical Engineering / Catalysis",
        "Home Appliances / Pyrolysis"
      ],
      "m0triz:inventivityLevelDistribution": {
        "level_2": 8,
        "level_3": 9,
        "level_4": 3
      },
      "m0triz:caseStudies": [
        {
          "@id": "m0triz:Case_SwissArmyKnife",
          "@type": "m0triz:CaseStudy",
          "rdfs:label": "Swiss Army Knife",
          "m0triz:problem": "User needs multiple tools (knife, scissors, screwdriver, etc.) but has limited pocket space and weight tolerance",
          "m0triz:solution": "Single handle with multiple folding tools sharing common structure. Each tool folds into compact unit (Segmentation), tools share handle (Merging), one object serves many functions (Universality).",
          "m0triz:principlesUsed": [
            {
              "@id": "m1.ext:systemic-modeling:Principle_06",
              "m0triz:principleNumber": 6,
              "m0triz:weight": 0.4
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_05",
              "m0triz:principleNumber": 5,
              "m0triz:weight": 0.35
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_01",
              "m0triz:principleNumber": 1,
              "m0triz:weight": 0.25
            }
          ],
          "m0triz:principaleCodes": [
            "UnivY",
            "Merg%",
            "Sgm#"
          ],
          "m0triz:inventivityLevel": 2,
          "m0triz:domain": "Mechanical Engineering / Consumer Products"
        },
        {
          "@id": "m0triz:Case_Airbag",
          "@type": "m0triz:CaseStudy",
          "rdfs:label": "Automotive Airbag",
          "m0triz:problem": "Protect passengers during collision without occupying space or adding weight during normal operation",
          "m0triz:solution": "Inflatable bag stored compactly, deploys rapidly using gas generator. Beforehand cushioning prepared, pneumatic inflation on demand, dynamic transformation from flat to protective.",
          "m0triz:principlesUsed": [
            {
              "@id": "m1.ext:systemic-modeling:Principle_11",
              "m0triz:principleNumber": 11,
              "m0triz:weight": 0.4
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_29",
              "m0triz:principleNumber": 29,
              "m0triz:weight": 0.35
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_15",
              "m0triz:principleNumber": 15,
              "m0triz:weight": 0.25
            }
          ],
          "m0triz:principaleCodes": [
            "B4Cus",
            "P/H$",
            "Dyn$"
          ],
          "m0triz:inventivityLevel": 3,
          "m0triz:domain": "Automotive Safety / Mechanical Engineering"
        },
        {
          "@id": "m0triz:Case_Velcro",
          "@type": "m0triz:CaseStudy",
          "rdfs:label": "Velcro Hook-and-Loop Fastener",
          "m0triz:problem": "Create strong fastener that is easily reversible without buttons, zippers, or knots",
          "m0triz:solution": "Two-part composite material (hooks + loops) that interlock mechanically. Intermediary mechanical coupling, composite material synergy, extraction separates components easily.",
          "m0triz:principlesUsed": [
            {
              "@id": "m1.ext:systemic-modeling:Principle_24",
              "m0triz:principleNumber": 24,
              "m0triz:weight": 0.35
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_40",
              "m0triz:principleNumber": 40,
              "m0triz:weight": 0.35
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_02",
              "m0triz:principleNumber": 2,
              "m0triz:weight": 0.3
            }
          ],
          "m0triz:principaleCodes": [
            "IntmY",
            "CmpM@",
            "Xtrc#"
          ],
          "m0triz:inventivityLevel": 3,
          "m0triz:domain": "Materials Science / Textile Engineering"
        },
        {
          "@id": "m0triz:Case_BimetallicThermostat",
          "@type": "m0triz:CaseStudy",
          "rdfs:label": "Bimetallic Strip Thermostat",
          "m0triz:problem": "Regulate temperature automatically without external power or complex sensors",
          "m0triz:solution": "Two metals with different thermal expansion coefficients bonded together. Strip bends with temperature (Thermal Expansion), movement triggers switch creating feedback loop (Feedback), dynamic response to conditions (Dynamics).",
          "m0triz:principlesUsed": [
            {
              "@id": "m1.ext:systemic-modeling:Principle_37",
              "m0triz:principleNumber": 37,
              "m0triz:weight": 0.45
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_23",
              "m0triz:principleNumber": 23,
              "m0triz:weight": 0.35
            },
            {
              "@id": "m1.ext:systemic-modeling:Principle_15",
              "m0triz:principleNumber": 15,
              "m0triz:weight": 0.2
            }
          ],
          "m0triz:principaleCodes": [
            "ThXp#",
            "FeedB",
            "Dyn$"
          ],
          "m0triz:inventivityLevel": 2,
          "m0triz:domain": "Thermal Control / Mechanical Engineering"
        },
        {
          "@id": "m0triz:Case_CatalyticConverter",
          "@type": "m0triz:CaseStudy",
          "rdfs:label": "Automotive Catalytic Converter",
          "m0triz:problem": "Reduce harmful exhaust emissions without significantly reducing engine performance or adding complexity",
