  "@graph": [
    {
      "@id": "m0triz:Triz_SystemicFramework",
      "@type": "owl:Ontology",
      "m3:ontologyType": {
        "@id": "m3:SystemicFramework"
      },
      "rdfs:label": "TRIZ — Theory of Inventive Problem Solving",
      "rdfs:comment": "Systematic innovation methodology developed by Genrich Altshuller based on analysis of 200,000+ patents. TRIZ identifies 40 universal inventive principles and a contradiction matrix (39×39 technical parameters) to guide problem-solving. Represents a prescriptive Map (methodology) operating on technical system Territories.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-04-20",
      "owl:versionInfo": "1.1.0",
      "owl:imports": [
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M3_GenesisSpace.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_GenericConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld",
        "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_extensions/systemic-modeling/M1_SystemicModeling.jsonld"
      ],
      "m1:domain": [ "Systems Theory", "Systems Thinking" ],
      "m0triz:frameworkAuthor": "Genrich Altshuller",
      "m0triz:frameworkOrigin": "Soviet Union, 1946-1998",
      "m0triz:empiricalBasis": "Analysis of 200,000+ patents across all engineering domains",
      "m0triz:architecture": "Option C — Hybride (M1 instances + M0 references)",
      "m0triz:coreComponents": {
        "inventive_principles": 40,
        "technical_parameters": 39,
        "contradiction_matrix_size": "39×39 = 1521 cells",
        "inventivity_levels": 5,
        "evolution_trends": 8
      },
      "m0triz:bicephalousNature": {
        "map": "TRIZ methodology itself (prescriptive framework, Sphinx Eye dominant)",
        "territory": "Technical systems being analyzed and improved (Eagle Eye targets)"
      },
      "m2:changelog": [
        {
          "version": "1.1.0",
          "date": "2026-04-24",
          "changes": "Added 20 TRIZ case studies demonstrating principle combinations across domains: automotive (Airbag, ABS), materials science (Kevlar, Aerogel, Fiberglass), thermal engineering (Heat Pipe, Pressure Cooker), safety equipment (Reflective Clothing, Life Vest), consumer products (Swiss Army Knife, Post-it Notes, Velcro), environmental (Dual-Flush Toilet, Solar Water Heater), mechanical (Hydraulic Jack), and more. Each case study includes: problem statement, solution description, 2-3 TRIZ principles used with weights, inventivity level (2-4), and domain classification."
        },
        {
          "version": "1.0.0",
          "date": "2026-04-20",
          "changes": "Initial TRIZ SystemicFramework (Option C architecture). 40 inventive principles defined as M1 instances (M1_SystemicModeling.jsonld), M0 references them. 3-5 char codes with conventions (#=tion, %=ing, Y=y, $=ics, ==Through, :=Change, &=and, *=ant, @=rial). ASFID/REVOI scoring complete. GenericConcept mapping (3 in M1_CoreConcepts, 6 in M1_SystemicModeling). Prepared for icosahedron simulation."
        }
      ]
    },
    {
      "@id": "m0triz:TRIZ_ASFID_Scores",
      "@type": "m3:eagle_eye:TerritorySpace",
      "rdfs:label": "TRIZ ASFID Scores (Eagle Eye — Territory)",
      "rdfs:comment": "ASFID evaluation of TRIZ as a methodology operating on technical systems",
      "m3:eagle_eye:Attractor": 5.0,
      "m3:eagle_eye:Structure": 5.0,
      "m3:eagle_eye:Flow": 4.0,
      "m3:eagle_eye:Information": 5.0,
      "m3:eagle_eye:Dynamics": 3.0,
      "m0triz:asfidStateVector": [
        5.0,
        5.0,
        4.0,
        5.0,
        3.0
      ],
      "m0triz:asfidNorm": 4.4,
      "m0triz:asfidJustification": {
        "A_5": "40 inventive principles as solution attractors; contradiction resolution as ultimate attractor",
        "S_5": "Triple hierarchy: 39×39 matrix + 40 principles + evolution laws",
        "F_4": "Unidirectional flow (problem→solution); no internal feedback loop",
        "I_5": "Systematic codification: 39 parameters encode problems, 40 principles encode solutions",
        "D_3": "Evolution laws present but external to framework; no autonomous dynamics"
      }
    },
    {
      "@id": "m0triz:TRIZ_REVOI_Scores",
      "@type": "m3:sphinx_eye:MapSpace",
      "rdfs:label": "TRIZ REVOI Scores (Sphinx Eye — Map)",
      "rdfs:comment": "REVOI evaluation of TRIZ as an epistemic construction (Map perspective)",
      "m3:sphinx_eye:Representability": 5.0,
      "m3:sphinx_eye:Evolvability": 4.0,
      "m3:sphinx_eye:Verifiability": 5.0,
      "m3:sphinx_eye:Observability": 5.0,
      "m3:sphinx_eye:Interoperability": 5.0,
      "m0triz:reviStateVector": [
        5.0,
        4.0,
        5.0,
        5.0,
        5.0
      ],
      "m0triz:reviNorm": 4.8,
      "m0triz:reviJustification": {
        "R_5": "Principles encode solution classes bidirectionally; matrix represents problem→solution space",
        "E_4": "Framework has evolved (TRIZ extensions); evolution driven by community, not autonomous",
        "V_5": "Massive empirical validation (200,000+ patents); cross-domain reproducibility",
        "O_5": "Principles observable in patents; applications observable in products; fully transparent methodology",
        "Im_5": "Transdisciplinary by design; compatible with other frameworks (QFD, Lean, Six Sigma)"
      }
    },
    {
      "@id": "m0triz:TRIZ_EpistemicGap",
      "@type": "m0triz:EpistemicGapAnalysis",
      "rdfs:label": "TRIZ Epistemic Gap (ΔΘ)",
      "rdfs:comment": "Distance between Eagle Eye (Territory/ASFID) and Sphinx Eye (Map/REVOI) perspectives",
      "m0triz:deltaFormula": "δ₁ = |ASFID_mean - REVOI_mean| / max(ASFID_mean, REVOI_mean)",
      "m0triz:asfidMean": 4.4,
      "m0triz:reviMean": 4.8,
      "m0triz:deltaTheta": 0.083,
      "m0triz:spectralClass": "OnCriticalLine",
      "m0triz:spectralRange": "[0.05, 0.15)",
      "m0triz:interpretation": "Low epistemic gap (δ₁=0.083): TRIZ is coherent as both Map (methodology) and Territory representation (technical systems). REVOI slightly superior to ASFID (4.8 vs 4.4) is expected for a prescriptive framework — it is primarily an epistemic construction (Map). The bicephalous AnzÛ principle is well expressed: Eagle Eye sees technical systems, Sphinx Eye sees the TRIZ methodology itself."
    },
