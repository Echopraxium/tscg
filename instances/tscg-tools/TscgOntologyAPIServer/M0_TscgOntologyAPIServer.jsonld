      ],
      "m3:ontologyType": {
        "@id": "m3:TscgTool"
      },
      "rdfs:label": "TscgOntologyAPIServer",
      "rdfs:comment": "Standalone FastAPI REST server exposing the TSCG ontology graph via SPARQL 1.1 and corpus endpoints. Uses pyoxigraph as named-graph triple store with optional persistence. Self-documenting via Swagger UI (OpenAPI). Controlled via Python CLI (tscg_api_cli.py: start/stop/restart/status/reload/export) or via the tscg-api-bridge Electron plugin in TscgOntologyExplorer. src/ layout: tscg_api_server.py, tscg_api_cli.py, tscg_api_client_example.py, requirements.txt.",
      "dcterms:creator": "Echopraxium with the collaboration of Claude AI",
      "dcterms:created": "2026-05-26",
      "owl:versionInfo": "1.1.1",
      "m1:domain": "TSCG",
      "dcterms:modified": "2026-05-29",
      "m1:simulationTitle": "TSCG Ontology API Server",
