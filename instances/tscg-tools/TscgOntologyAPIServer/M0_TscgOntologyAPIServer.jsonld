      "m0:spectralClass": "Coherent",
      "m2:changelog": [
        {
          "version": "1.1.1",
          "date": "2026-06-26",
          "changes": "ACTION3: Added m0:focalApplicable=true."
        },
        {
          "version": "1.1.0",
          "date": "2026-05-29",
          "changes": "Phase 3 implementation: tscg_api_server.py standalone (promoted from bridge_server.py Phase 2). src/ layout with tscg_api_cli.py (start/stop/restart/status/reload/export), tscg_api_client_example.py, requirements.txt. tscg-api-bridge Electron plugin replaces tscg-python-bridge in TscgOntologyExplorer."
        },
        {
          "version": "1.0.0",
          "date": "2026-05-26",
          "changes": "Initial M0 specification. 8-component architecture: FastAPI + TscgStore (pyoxigraph) + SPARQL 1.1 endpoint + Corpus endpoints + Persistence Manager + Swagger UI + CLI Controller + IRI Expander. Standalone server (Phase 3 of TscgOntologyExplorer bridge)."
        }
      ],
      "m0:scoreJustification": {
        "A_score": "Dual attractor: (1) consistent queryable ontology state converged via TscgStore; (2) server lifecycle state (running/stopped) managed by CLI. The persistence layer adds a 3rd attractor: saved TripleStore file as invariant reference state.",
        "S_score": "4-layer architecture (API → TscgStore → Persistence → CLI) with strict separation of concerns. Named graphs partition M3/M2/M1_core/M1_ext_*/M0_* layers. FastAPI auto-schema generation creates formal structural contract.",
        "F_score": "3 distinct flows: (1) HTTP request/response (inbound queries, outbound JSON-LD); (2) persistence flow (in-memory ↔ oxigraph file); (3) lifecycle flow (CLI commands → process signals → server state transitions).",
        "It_score": "Exposes complete M3→M0 ontology hierarchy. SPARQL results encode structured graph knowledge. IRI expander translates compact notations to full URIs. Swagger documents the full API surface automatically.",
        "D_score": "Event-driven async FastAPI handlers. Hot-reload triggers re-parsing of JSON-LD files into TscgStore. CLI restart = full store rebuild from persisted file. SPARQL query compilation at request time.",
        "R_score": "OpenAPI spec + Swagger = formally representable API contract. TripleStore file = diffable persistent state (text-based oxigraph format). Named graph structure reflects M3→M0 architectural hierarchy.",
        "E_score": "New endpoints addable with @router decorators. SPARQL queries extensible without code change. Backend swappable (pyoxigraph → RDFLib, Oxigraph Rust). CLI commands addable via Click/argparse. Serialization formats independent modules.",
        "V_score": "58-test suite covers IRI expansion (18), TscgStore (20), FastAPI integration (20). pyshacl validation on SPARQL output. OpenAPI contract machine-verifiable. Health endpoint testable by monitoring tools.",
        "O_score": "Swagger UI at /docs makes all endpoints browsable. /health and /info endpoints expose live server state. CLI `status` shows uptime + store stats. All SPARQL queries and responses logged.",
        "Im_score": "SPARQL 1.1 (W3C standard) + REST/HTTP + JSON-LD (W3C) + OpenAPI 3.0. Third-party clients (curl, Postman, Python requests, any SPARQL client) work without TSCG-specific code."
      },
      "m0:architecture": {
        "m0:serverStack": {
          "framework": "FastAPI (Python 3.11+)",
          "tripleStore": "pyoxigraph ≥ 0.5.0 — named-graph RDF store",
          "persistence": "oxigraph binary serialization (.oxg file)",
          "documentation": "Swagger UI at /docs, ReDoc at /redoc",
          "server": "uvicorn (ASGI)"
        },
        "m0:namedGraphs": {
          "convention": "One named graph per ontology file, IRI = file absolute URL",
          "layers": {
            "M3": "M3_GenesisGrammar.jsonld, M3_EagleEye.jsonld, M3_SphinxEye.jsonld, M3_GrammarFoundation.jsonld",
            "M2": "M2_GenericConcepts.jsonld",
            "M1_core": "M1_CoreConcepts.jsonld, M1_Domains.jsonld",
            "M1_ext": "M1_extensions/<domain>/M1_<Domain>.jsonld (13 extensions)",
            "M0": "instances/**/*.jsonld (33+ instances)"
          }
        },
        "m0:endpoints": {
          "GET /health": "Server health check — {status, uptime, graph_count, triple_count}",
          "GET /info": "Server metadata — {version, store_path, loaded_graphs}",
          "POST /corpus/load": "Load a JSON-LD file into a named graph — body: {file_path: str}",
          "GET /corpus/list": "List all loaded named graphs with triple counts",
          "POST /corpus/sparql": "Execute SPARQL SELECT/CONSTRUCT/ASK — body: {query: str, format?: str}",
          "POST /corpus/reload": "Reload all ontology files from disk (hot-reload)",
          "DELETE /corpus/graph": "Remove a named graph — body: {graph_iri: str}",
          "GET /corpus/layers": "List ontology layers M3/M2/M1/M0 with graph counts",
          "GET /corpus/export": "Export full store as JSON-LD or Turtle"
        },
        "m0:persistence": {
          "format": "oxigraph binary store (serialized to .oxg file)",
          "loadOnStartup": "Server loads persisted store on startup if .oxg file exists",
          "saveOnReload": "Store auto-saved after successful corpus reload",
          "manualSave": "POST /corpus/save endpoint triggers explicit save"
        },
        "m0:cli": {
          "tool": "Python script (tscg_api_server.py) with argparse",
          "commands": {
            "start": "Start server (--host, --port, --store-path, --ontology-dir)",
            "stop": "Stop running server (sends SIGTERM to PID file)",
            "restart": "Stop + Start (rebuilds store from ontology files)",
            "status": "Show server status, uptime, graph count",
            "reload": "Trigger hot-reload via POST /corpus/reload",
            "export": "Export store to JSON-LD or Turtle file"
          }
        }
      },
      "m0:components": [
        {
          "@id": "m0:FastAPIApp",
          "rdfs:label": "FastAPI Application",
          "m0:role": "HTTP Server + Router",
          "m0:function": "Receives HTTP requests, routes to handlers, serializes responses. Auto-generates OpenAPI schema and serves Swagger UI at /docs. Async handlers via uvicorn ASGI.",
          "m0:asfidContribution": {
            "A": "Defines the API contract as a stable attractor — all clients converge to this interface",
            "S": "Route hierarchy structures the API surface; auto-schema generates formal structural documentation",
            "F": "Primary HTTP flow engine: request routing, middleware chain, response serialization",
            "It": "Swagger UI exposes all API information; auto-validation of request/response types"
          }
        },
        {
          "@id": "m0:TscgStore",
          "rdfs:label": "TscgStore (pyoxigraph)",
          "m0:role": "Named-Graph Triple Store",
          "m0:function": "Wraps pyoxigraph NamedGraph store. Provides load_graph(path), query_sparql(q), list_graphs(), get_layer_graphs(layer). Each ontology file = one named graph. In-memory for performance; persistence managed by PersistenceManager.",
          "m0:asfidContribution": {
            "A": "Central attractor: the canonical TSCG knowledge state. All queries converge here.",
            "S": "Named graph partitioning = structural organization of M3/M2/M1/M0 layers",
            "It": "Stores and indexes all ontological information (M3→M0 hierarchy)",
            "D": "Dynamic: graphs added/removed at runtime; SPARQL compiled on-demand"
          }
        },
        {
          "@id": "m0:SPARQLEndpoint",
          "rdfs:label": "SPARQL 1.1 Endpoint",
          "m0:role": "Query Interface",
          "m0:function": "POST /corpus/sparql — accepts SPARQL SELECT, CONSTRUCT, ASK, DESCRIBE. Returns JSON (application/sparql-results+json), Turtle, or JSON-LD depending on Accept header.",
          "m0:asfidContribution": {
            "F": "Primary query flow: SPARQL string → compiled query → pyoxigraph execution → serialized results",
            "It": "Exposes full graph information via standard query language",
            "Im": "SPARQL 1.1 = W3C standard — any SPARQL client works without TSCG-specific code"
          }
        },
        {
          "@id": "m0:CorpusEndpoints",
          "rdfs:label": "Corpus Endpoints (/corpus/*)",
          "m0:role": "Ontology Management API",
          "m0:function": "CRUD operations on named graphs: load JSON-LD file, list graphs, reload all from disk, delete graph, export. Bridges filesystem ontology files with in-memory TscgStore.",
          "m0:asfidContribution": {
            "S": "Structural management: maps filesystem M3/M2/M1/M0 hierarchy to named graph structure",
            "F": "Load flow: JSON-LD file → rdflib parser → pyoxigraph triples → named graph",
            "D": "Dynamic: hot-reload rebuilds store without server restart"
          }
        },
        {
          "@id": "m0:PersistenceManager",
          "rdfs:label": "Persistence Manager",
          "m0:role": "Store Serialization Layer",
          "m0:function": "Serializes pyoxigraph TripleStore to .oxg file on disk. Loads from file on startup (fast bootstrap, avoids re-parsing all JSON-LD). Triggers auto-save after reload operations.",
          "m0:asfidContribution": {
            "A": "Creates a durable attractor: server state preserved across restarts",
            "D": "Lifecycle dynamics: load-on-start, save-on-reload, explicit save via CLI",
            "V": "Verifiable: .oxg file = auditable state snapshot"
          }
        },
        {
          "@id": "m0:SwaggerUI",
          "rdfs:label": "Swagger UI / OpenAPI Documentation",
          "m0:role": "Self-Documenting Interface",
          "m0:function": "Auto-generated from FastAPI schema. Served at /docs (Swagger) and /redoc (ReDoc). Provides interactive API explorer — any endpoint testable from browser without code.",
          "m0:asfidContribution": {
            "It": "Makes full API information visible and explorable",
            "R": "OpenAPI spec = formal machine-readable representation of the API contract",
            "O": "Every endpoint observable and testable from the browser"
          }
        },
        {
          "@id": "m0:CLIController",
          "rdfs:label": "CLI Controller (tscg_api_server.py)",
          "m0:role": "Server Lifecycle Manager",
          "m0:function": "Python argparse CLI. start: launches uvicorn process + writes PID file. stop: reads PID file + sends SIGTERM. restart: stop + rebuild store + start. status: queries /health. reload: POST /corpus/reload. export: GET /corpus/export.",
          "m0:asfidContribution": {
            "A": "Controls lifecycle attractors: running ↔ stopped ↔ reloading",
            "F": "CLI command flow: user input → argparse → subprocess/HTTP → server state",
            "D": "Primary dynamics controller: start/stop/restart sequences"
          }
        },
        {
          "@id": "m0:IRIExpander",
          "rdfs:label": "IRI Expander",
          "m0:role": "Prefix Resolution Service",
          "m0:function": "Resolves compact TSCG IRIs (m3:eagle_eye:Attractor, m1:extension:biology:CellularCommunication) to full absolute URIs. 3 strategies: (1) context-based, (2) known-prefix table, (3) base-relative. Tested by 18 dedicated tests.",
          "m0:asfidContribution": {
            "S": "Structural: maps TSCG 3-level namespace hierarchy to resolvable IRIs",
            "It": "Information transformation: compact notation → dereferenceable URI",
            "Im": "Essential for interoperability: external clients use full URIs, TSCG uses compact notation"
          }
        }
      ],
      "m0:genericConceptsMobilized": {
        "total": 8,
        "concepts": [
          {
            "name": "Processor",
            "structuralFormula": "Fm2(Process, Structure, Information) | V",
            "role": "FastAPI application as a whole — transforms HTTP requests (D) through defined structure (S) and routing (F) into SPARQL-validated (V) JSON-LD responses"
          },
          {
            "name": "Interface",
            "structuralFormula": "S × It",
            "role": "REST API boundary — structural (S) contract that mediates information (It) exchange between TscgStore and third-party clients"
          },
          {
            "name": "Pipeline",
            "structuralFormula": "S × F × It",
            "role": "Request processing pipeline — route (S) → handler → TscgStore query (F) → serialize (It) → response"
          },
          {
            "name": "Mediator",
            "structuralFormula": "S × It × F | Im",
            "role": "IRIExpander + CorpusEndpoints bridge — mediates between JSON-LD compact notation (TSCG-specific) and SPARQL/URI representations (W3C standard)"
          },
          {
            "name": "Adapter",
            "structuralFormula": "S × It",
            "role": "Multi-format serializer — adapts same graph information to JSON-LD, Turtle, or N-Triples depending on Accept header"
          },
          {
            "name": "FeedbackLoop",
            "structuralFormula": "A × S × F × It × D",
            "role": "Hot-reload mechanism — filesystem changes (D) detected and fed back into TscgStore (A), triggering re-parsing pipeline (F) maintaining ontology state coherence (It)"
          },
          {
            "name": "Memory",
            "structuralFormula": "A × It | R",
            "role": "PersistenceManager — preserves TscgStore state as durable memory (A × It). Oxigraph .oxg file is representable (R) and survives server restarts"
          },
          {
            "name": "Context",
            "structuralFormula": "S × It × A",
            "role": "Named graph management — each ontology layer has its own named graph context (M3/M2/M1/M0), maintaining structural integrity and enabling layer-filtered SPARQL queries"
          }
        ]
      },
      "m0:reflexivityNote": "TscgOntologyAPIServer is doubly reflexive: (1) it exposes its own M0 specification via /corpus/load, making itself queryable through SPARQL; (2) it serves the ontology that defines TscgTools, including itself. The server can answer: SELECT ?tool WHERE { ?tool a m3:TscgTool }",
      "rdfs:seeAlso": "instances/tscg-tools/TscgOntologyAPIServer/M0_TscgOntologyAPIServer_README.md",
      "m0:focalApplicable": true
    }
  ]
}
