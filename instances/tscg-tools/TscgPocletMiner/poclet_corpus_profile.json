  "invariants": {
    "description": "Criteria that ALL 21 validated poclets satisfy — used for candidate screening",
    "criteria": [
      {
        "id": "INV-01",
        "label": "Real observable system",
        "question": "Is the candidate a real, observable system (not a pure abstraction)?",
        "weight": 1.0,
        "examples_ok":   ["RAAS", "Transistor", "ButterflyMetamorphosis"],
        "examples_fail": ["Pure mathematics", "Philosophical concept", "Vague metaphor"]
      },
      {
        "id": "INV-02",
        "label": "Identifiable Attractor (A)",
        "question": "Does the system tend toward a stable state or equilibrium?",
        "weight": 0.9,
        "examples_ok":   ["Blood pressure homeostasis", "Transistor Q-point", "Clot formation"],
        "examples_fail": ["Pure random process with no attractor"]
      },
      {
        "id": "INV-03",
        "label": "Identifiable Structure (S)",
        "question": "Does the system have clearly delimited components and boundaries?",
        "weight": 1.0,
        "examples_ok":   ["RAAS (renin, angiotensin, aldosterone)", "Transistor (B, C, E terminals)"],
        "examples_fail": ["Fuzzy concept with no clear components"]
      },
      {
        "id": "INV-04",
        "label": "Identifiable Flow (F)",
        "question": "Does the system involve flows of matter, energy, or information?",
        "weight": 0.9,
        "examples_ok":   ["Hormonal flow in RAAS", "Electron flow in transistor", "Signal cascade in immunity"],
        "examples_fail": ["Static classification with no flow"]
      },
      {
        "id": "INV-05",
        "label": "Non-trivial regulation or dynamics (D)",
        "question": "Does the system exhibit feedback, adaptation, or non-trivial dynamics?",
        "weight": 0.85,
        "examples_ok":   ["Negative feedback in blood pressure", "Switching dynamics in transistor"],
        "examples_fail": ["Trivial linear process, no regulation"]
      },
      {
        "id": "INV-06",
        "label": "Delimited domain",
        "question": "Does the candidate belong to a clearly named discipline or domain?",
        "weight": 0.8,
        "examples_ok":   ["Biology", "Electronics", "Economics", "Mythology"],
        "examples_fail": ["Everything / too vague"]
      },
      {
        "id": "INV-07",
        "label": "Web-documentable",
        "question": "Is the system documented in Wikipedia, academic papers, or reliable web sources?",
        "weight": 0.9,
        "examples_ok":   ["RAAS (extensive medical literature)", "Transistor (IEEE, textbooks)"],
        "examples_fail": ["Proprietary unpublished system", "Invented concept"]
      },
      {
        "id": "INV-08",
        "label": "Domain gap",
        "question": "Does this candidate add a new domain OR a meaningfully distinct system within an existing domain?",
        "weight": 0.7,
        "examples_ok":   ["SIR model (epidemiology)", "Harmonic oscillator (music)"],
        "examples_fail": ["Another hormonal feedback loop too similar to RAAS"]
      },
      {
        "id": "INV-09",
        "label": "Type discriminant",
        "question": "Is the candidate a Poclet (single domain), TransDisclet (natively multi-domain), or SystemicFramework?",
        "weight": 0.8,
        "options": {
          "Poclet":            "Single domain, empirically validated",
          "TransDisclet":      "Natively exists in 2+ disciplines simultaneously (structural homology required)",
          "SystemicFramework": "Established external methodology (VSM, Cynefin, etc.)"
        }
      }
    ]
  },

