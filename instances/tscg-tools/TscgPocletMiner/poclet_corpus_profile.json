  "scoring_thresholds": {
    "asfid_min_for_acceptance": 0.6,
    "invariants_min_satisfied": 6,
    "invariants_total": 9,
    "verdict": {
      "strong_candidate": { "invariants_min": 8, "asfid_min": 0.75 },
      "candidate":        { "invariants_min": 6, "asfid_min": 0.60 },
