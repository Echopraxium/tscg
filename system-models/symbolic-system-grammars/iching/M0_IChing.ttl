@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m0: <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/system-models/symbolic-grammars/M0_IChing.jsonld#> .
@prefix m2: <M2_MetaConcepts.jsonld#> .
@prefix m3: <M3_GenesisSpace.jsonld#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

m0:GrammarLevel a owl:Class ;
    rdfs:label "Grammar Level" ;
    rdfs:comment "Hierarchical level within the I Ching generative grammar. Level 0 = primitives (2), Level 1 = trigrams (8), Level 2 = hexagrams (64)." .

m0:IChing a owl:Ontology ;
    rdfs:label "I Ching (易經) — Symbolic System Grammar" ;
    m3:ontologyType <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M3_GenesisSpace.jsonld#SymbolicSystemGrammar> ;
    m3:semanticSignature "finite_primitives(Yin,Yang) + combination_rules(trigram_stacking) + multiple_legitimate_interpretations(symbolic_arbitration)" ;
    dcterms:created "2026-02-20" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:description "Formal ontology of the I Ching as a SymbolicSystemGrammar. Models the binary grammar (Yin/Yang) that generates 8 trigram archetypes and 64 hexagrams via a systematic combinatorial grammar. Captures the four semantic layers (Judgment, Image, Line texts, Ten Wings) and the changing-line transformation mechanism. First instance of m3:SymbolicSystemGrammar in the TSCG framework." ;
    dcterms:modified "2026-02-20" ;
    dcterms:title "I Ching — Book of Changes" ;
    rdfs:comment "The I Ching is a 3000-year-old Chinese divination and philosophical system. Its power lies in a minimal binary grammar (2 primitives: Yin and Yang) that generates 8 trigram archetypes and 64 hexagrams via systematic stacking. Each hexagram is a unique symbolic signature of a situation, admitting multiple legitimate interpretations. The changing-line mechanism encodes temporal dynamics — the transformation from one hexagram to another." ;
    owl:imports "M1_CoreConcepts.jsonld",
        "M1_extensions/mythology/M1_Mythology.jsonld",
        "M2_MetaConcepts.jsonld",
        "M3_GenesisSpace.jsonld" ;
    owl:versionInfo "1.1.0" ;
    m0:archetypeCount 8 ;
    m0:asfidMean 8.3e-01 ;
    m0:changelog [ ] ;
    m0:combinationCount 64 ;
    m0:domain "Symbolic divination, Chinese cosmology, comparative mythology, decision theory" ;
    m0:dynamicMechanism "changing lines (动爻) → hexagram transformation" ;
    m0:epistemicGap 3.8e-01 ;
    m0:grammarLevel 3 ;
    m0:primitiveCount 2 ;
    m0:revoiMean 8e-01 ;
    m0:status "VALIDATED" .

m0:asfid_attractor a m0:ASFIDAnalysis ;
    rdfs:label "Attractor (A)" ;
    rdfs:comment "Each hexagram functions as a local attractor — a named stable state that 'draws' interpretive energy around a recognizable situation. The 64 attractors form a discrete dynamic space covering the full range of human situations. Changing lines create trajectories between attractors, with the derived hexagram as the next attractor. No single global attractor: the system is cyclically ergodic (all 64 states reachable from any starting hexagram via transformation)." ;
    m0:attractor_topology "Discrete lattice of 64 nodes with transformation edges (changing lines)" ;
    m0:cyclic_structure "Yin→Yang→Yin cycles encoded at every scale (line, trigram, hexagram)" ;
    m0:dominantM3 "m3:Attractor" ;
    m0:globalAttractor "None — cyclical ergodicity (Ji Ji #63 ↔ Wei Ji #64 cycle)" ;
    m0:localAttractors "64 hexagrams as named, stable symbolic states" ;
    m0:m2_metaconcepts "m2:Attractor",
        "m2:FeedbackLoop",
        "m2:State",
        "m2:Trajectory" ;
    m0:score 8.5e-01 .

m0:asfid_dynamics a m0:ASFIDAnalysis ;
    rdfs:label "Dynamics (D)" ;
    rdfs:comment "The I Ching encodes dynamics through two mechanisms: (1) Line polarity dynamics — every line carries temporal polarity (Young = stable, Old = changing → inversion imminent); (2) Inter-hexagram dynamics — the 4096 possible transitions (64×64) via changing lines form a complete directed graph on the symbolic state space. The Book of Changes (易經) is fundamentally a system of change: the static hexagram is a snapshot; the changing lines make it a trajectory. The final two hexagrams (#63 After Completion, #64 Before Completion) encode the meta-dynamic: every completed state seeds the next incompleteness." ;
    m0:dominantM3 "m3:Dynamics" ;
    m0:dynamicMechanisms [ ] ;
    m0:m2_metaconcepts "m2:ButterflyEffect",
        "m2:FeedbackLoop",
        "m2:Polarity",
        "m2:Trajectory",
        "m2:Transformation" ;
    m0:metaDynamic "Hexagram #64 (Before Completion) as terminal state: the system never reaches final equilibrium — incompletion is the generative principle" ;
    m0:score 8e-01 ;
    m0:stateSpaceDynamics [ ] .

m0:asfid_flow a m0:ASFIDAnalysis ;
    rdfs:label "Flow (F)" ;
    rdfs:comment "Two distinct flows operate in the I Ching: (1) the divinatory flow — the procedural sequence by which a hexagram is generated (coin/yarrow stalk ritual → 6 line determinations → hexagram construction); (2) the transformative flow — the movement from primary to derived hexagram via changing lines, representing the temporal evolution of a situation. The flows are asymmetric: the divinatory flow is procedural/physical; the transformative flow is symbolic/temporal." ;
    m0:divinationFlow [ ] ;
    m0:dominantM3 "m3:Flow" ;
    m0:flowAsymmetry "Divination flow: random → structured (coins → hexagram). Transformative flow: structured → structured (hexagram → hexagram)." ;
    m0:m2_metaconcepts "m2:Process",
        "m2:Transformation",
        "m2:Trigger",
        "m2:Workflow" ;
    m0:score 7.2e-01 ;
    m0:transformativeFlow "Primary hexagram → (changing lines) → Derived hexagram = symbolic trajectory" .

m0:asfid_information a m0:ASFIDAnalysis ;
    rdfs:label "Information (I)" ;
    rdfs:comment "The I Ching carries information at four nested layers: (1) Binary code layer — 6-bit address (log₂(64) = 6 bits per hexagram, maximum Shannon entropy for 64 states); (2) Archetype layer — trigram names encode cultural semantic fields; (3) Judgment/Image layer — textual interpretive content attributed to King Wen; (4) Philosophical layer — the Ten Wings (Confucian commentary elevating the system to cosmological model). The information is not empirical but symbolic: the same hexagram legitimately generates multiple interpretations depending on context and reader." ;
    m0:changingLineInformation "Δ(H_primary → H_derived) = symbolic information delta encoding situational evolution" ;
    m0:crossDomainMapping [ ] ;
    m0:dominantM3 "m3:Information" ;
    m0:informationEntropy "log₂(64) = 6 bits per hexagram — maximal for 64-state system" ;
    m0:interpretiveMultiplicity "Each hexagram: 1 Judgment + 1 Image + 6 Line texts + 10 Wings sections = ~18 interpretive channels per hexagram" ;
    m0:m2_metaconcepts "m2:Code",
        "m2:Language",
        "m2:Pattern",
        "m2:Representation",
        "m2:Signature" ;
    m0:score 9.1e-01 ;
    m0:semanticLayers 4 .

m0:asfid_structure a m0:ASFIDAnalysis ;
    rdfs:label "Structure (S)" ;
    rdfs:comment "Exceptionally clear 3-level hierarchical grammar with strict combinatorial rules. Level 0: 2 primitives (Yin/Yang binary alphabet). Level 1: 8 trigrams (3-line combinations, 2³ = 8 named archetypes). Level 2: 64 hexagrams (2-trigram combinations, 8² = 64 named states). Each level is fully enumerable. The binary encoding gives each hexagram a unique 6-bit address — the system is mathematically closed and exhaustive." ;
    m0:binaryIsomorphism "I Ching ≅ 6-bit binary space {0,1}⁶ — bijection between hexagrams and binary integers 0-63" ;
    m0:dominantM3 "m3:Structure" ;
    m0:fourPolarityPairs "8 trigrams = 4 polar pairs (Qian/Kun, Zhen/Xun, Kan/Li, Gen/Dui)" ;
    m0:hierarchyLevels [ ] ;
    m0:m2_metaconcepts "m2:Code",
        "m2:Composition",
        "m2:Hierarchy",
        "m2:Modularity",
        "m2:Symmetry" ;
    m0:score 9.7e-01 ;
    m0:structuralSymmetries "Inverse hexagram (all lines flipped) → polarity complement",
        "Nuclear hexagram (inner 4 lines) → related hexagram",
        "Reversed hexagram (read upside down) → perspective inversion" .

m0:bicephalous_synthesis a m0:BicephalousPerspective ;
    rdfs:label "Eagle-Sphinx Synthesis" ;
    rdfs:comment "The I Ching presents a distinctive bicephalous profile: the Territory (ASFID) is strong on Structure (0.97) and Information (0.91) — the grammar is clear and the encoding is explicit. The Map (REVOI) is strongest on Representability (0.95) and Interoperability (0.90), but Verifiability is deliberately low (0.50) — this is not a flaw but the defining characteristic of symbolic arbitration. The epistemic gap (0.38) is higher than for empirical poclets precisely because the Territory→Map bridge is intentionally loose, enabling interpretive multiplicity." ;
    m0:distinctiveSSGFeature "The epistemic gap is a FEATURE, not a bug: loose Territory→Map coupling enables the interpretive multiplicity that is the SSG's purpose. High Verifiability would constrain interpretation to a single reading — destroying the generative power." ;
    m0:epistemicGap 3.8e-01 ;
    m0:gapAnalysis [ ] ;
    m0:keyCouplings "A ⊗ V: 0.55 (attractors are not empirically verifiable — intentional)",
        "D ⊗ E: 0.84 (dynamics well-served by built-in evolution mechanism)",
        "I ⊗ I: 0.91 (information richness ↔ interoperability across domains)",
        "S ⊗ O: 0.88 (structural observability — hexagrams are visually distinct)",
        "S ⊗ R: 0.97 (structural grammar is maximally representable)" ;
    m0:mapStrength 8e-01 ;
    m0:territoryStrength 8.5e-01 .

m0:candidate_generative_exhaustion a m0:M2Candidates ;
    rdfs:label "NOTE: Generative Exhaustion → reclassified as m2:Representation.spaceCoverage = 1.0" ;
    m0:distinction "Different from Composition (which is the operation) — Generative Exhaustion describes the property of closure: the grammar generates precisely its intended universe" ;
    m0:rationale "GenerativeExhaustion is the limit case RSC=1.0 of RepresentationSpaceCoverage — a continuous attribute [0,1] of m2:Representation. The gradient formulation (RSC ∈ [0,1]) is architecturally richer than a binary M2 metaconcept." ;
    m0:status "RECLASSIFIED — not a standalone M2 metaconcept. Integrated as special case (RSC=1.0) of the spaceCoverage ValueSpace attribute on m2:Representation (M2_MetaConcepts.jsonld v15.4.0)." .

m0:candidate_symbolic_arbitration a m0:M2Candidates ;
    rdfs:label "NOTE: SymbolicArbitration → reclassified as m2:Observer attribute" ;
    m0:distinction "Different from Verifiability (which concerns empirical checking) — Symbolic Arbitration describes the mode of validation itself: communal, contextual, hermeneutic" ;
    m0:rationale "SymbolicArbitration describes how the Observer validates the Map, not a systemic phenomenon independent of the Observer. Architectural home: m2:Observer.validationMode = 'symbolic' or as ValueSpace enrichment of m2:Verifiability." ;
    m0:status "RECLASSIFIED — not a standalone M2 metaconcept. Belongs to the Map construction toolbox of m2:Observer as a validationMode attribute (empirical | symbolic | formal | consensual)." .

m0:hexagram_grammar_table a m0:HexagramCombination ;
    rdfs:label "Hexagram Generation Table (8×8 Grammar Matrix)" ;
    m0:coverageProof "64 hexagrams = 2⁶ = complete partition of all 6-bit binary strings → exhaustive representation of any situation" ;
    m0:formula "H(lower, upper) = T_lower ⊗ T_upper" ;
    m0:generativeStructure [ ] ;
    m0:note "Hexagrams #63 and #64 are the final pair: After Completion and Before Completion. The I Ching ends with Before Completion (#64) — a profound statement that the cycle is never finished, only transformed." ;
    m0:orderProperty "H(T_i, T_j) ≠ H(T_j, T_i) in general — inner/outer asymmetry is semantically significant" ;
    m0:selectedExamples [ ],
        [ ],
        [ ],
        [ ],
        [ ],
        [ ],
        [ ],
        [ ] .

m0:layer_image a m0:SemanticLayer ;
    rdfs:label "Image (象辞 Xiàng Cí)" ;
    m0:example "Hexagram 11 Image: 'Heaven and Earth unite — this is Peace. The ruler divides and completes the proper course of Heaven and Earth.'" ;
    m0:function "Metaphorical evocation — translates the trigram combination into a natural image that guides action" ;
    m0:scope "The natural scene formed by the two trigrams" .

m0:layer_judgment a m0:SemanticLayer ;
    rdfs:label "Judgment (彖辞 Tuàn Cí)" ;
    m0:example "Hexagram 1 Judgment: 'The Creative works sublime success, furthering through perseverance.'" ;
    m0:function "Overall appraisal of the situation — the oracular statement attributed to King Wen (c. 1000 BCE)" ;
    m0:scope "Entire hexagram" .

m0:layer_line_texts a m0:SemanticLayer ;
    rdfs:label "Line Texts (爻辞 Yáo Cí)" ;
    m0:activation "Active only for changing lines in a given reading — provides specificity within the general hexagram situation" ;
    m0:function "Fine-grained reading — each line receives its own text; changing lines select the relevant lines" ;
    m0:scope "Each of the 6 individual lines" .

m0:layer_ten_wings a m0:SemanticLayer ;
    rdfs:label "Ten Wings (十翼 Shí Yì)" ;
    m0:content "Commentary on the Images (× 2)",
        "Commentary on the Judgments (× 2)",
        "Discussion of the Gua",
        "Explanation of the Trigrams",
        "Great Treatise (Dazhuan × 2)",
        "Miscellaneous Notes",
        "Sequence of Hexagrams" ;
    m0:function "Philosophical commentary attributed to Confucius — elevates the I Ching from divination tool to cosmological philosophy" ;
    m0:scope "The entire canonical text" .

m0:m2_composition a m0:M2MetaconceptActivation ;
    rdfs:comment "The core grammar rule IS Composition: hexagram = trigram ⊗ trigram. The I Ching demonstrates that a small alphabet (2 primitives) combined through systematic composition generates a complete symbolic universe (64 states). Decomposition is equally present: any hexagram can be decomposed into its constituent trigrams, revealing inner/outer dimensional structure." ;
    m0:dominance 9.8e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Composition> ;
    m0:spaceCoverage [ a <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#ValueSpace> ;
            m2:attribute "m2:Representation.spaceCoverage" ;
            m2:interpretation "Generative Exhaustion — 64 hexagrams = {Yin,Yang}⁶, complete partition of 6-bit binary space. No hexagram missing, no duplication. RSC = 1.0 by construction, not by enumeration." ;
            m2:note "Same RSC=1.0 achieved independently by DNA codons (4³=64), Boolean NAND completeness, and 12-tone chromatic scale — strong transdisciplinary validation of this limit case." ;
            m2:value 1e+00 ] ;
    m0:tensorFormula "S ⊗ I (Composition/Decomposition)" .

m0:m2_feedbackloop a m0:M2MetaconceptActivation ;
    rdfs:comment "The I Ching divination process is a feedback loop: (1) Formulate question about current situation; (2) Generate hexagram via ritual (coins/stalks); (3) Interpret reading; (4) Take action; (5) Observe outcome → reformulate next question. The changing-line mechanism explicitly encodes positive/negative feedback: Yang at maximum (Old Yang) feeds back into Yin; Yin at maximum (Old Yin) feeds back into Yang." ;
    m0:dominance 8.2e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#FeedbackLoop> ;
    m0:tensorFormula "Process ⊗ Alignment ⊗ Homeostasis" .

m0:m2_hierarchy a m0:M2MetaconceptActivation ;
    rdfs:comment "Three-level strict hierarchy: primitive → trigram → hexagram. Each level is fully determined by the combination rules applied to the level below. The hierarchy is non-arbitrary: each level adds qualitatively new semantic content (a trigram is not just 3 lines — it is a named archetype; a hexagram is not just 2 trigrams — it is a situated context)." ;
    m0:dominance 9.5e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Hierarchy> ;
    m0:tensorFormula "S ⊗ A" .

m0:m2_language a m0:M2MetaconceptActivation ;
    rdfs:comment "The I Ching is a complete symbolic language: alphabet (Yin/Yang), morphology (trigrams), syntax (hexagram stacking), semantics (interpretation layers), and pragmatics (divinatory application). It satisfies the criteria for a formal language: finite alphabet, explicit combination rules, generative grammar producing 64 well-formed expressions, each with assigned meaning." ;
    m0:dominance 9.6e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Language> ;
    m0:tensorFormula "I ⊗ S ⊗ F" .

m0:m2_pattern a m0:M2MetaconceptActivation ;
    rdfs:comment "The 8 trigrams and 64 hexagrams are patterns in the strict TSCG sense: structural regularities that recur across domains and are reusable for recognition and categorization. The trigrams function as 8 universal pattern archetypes applicable across natural phenomena, psychological states, social situations, and strategic contexts." ;
    m0:dominance 9e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Pattern> ;
    m0:tensorFormula "S → I → A" .

m0:m2_polarity a m0:M2MetaconceptActivation ;
    rdfs:comment "The I Ching is the archetype of N=2 polarity. Every element is defined by Yin/Yang opposition. The 8 trigrams form 4 polar pairs. The 64 hexagrams encode dynamic tension between inner and outer, past and future, stable and changing. Polarity here is not binary opposition but generative complementarity — each pole produces the other." ;
    m0:dominance 9.9e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Polarity> ;
    m0:tensorFormula "S ⊗ I ⊗ A" .

m0:m2_signature a m0:M2MetaconceptActivation ;
    rdfs:comment "Each hexagram is a unique situational signature: a 6-bit binary string that identifies a position in the full symbolic space. The hexagram name, number, trigram combination, and 6-line pattern together constitute a minimal sufficient identity — no two hexagrams share the same signature. The I Ching is a 64-element signature space for human situations." ;
    m0:dominance 9.7e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Signature> ;
    m0:tensorFormula "I ⊗ S" .

m0:m2_transformation a m0:M2MetaconceptActivation ;
    rdfs:comment "The changing-line mechanism is a formal transformation system: H_primary → H_derived. The Book of Changes encodes transformation as its central concern — not the 64 states as static entities but the 4096 possible transitions between them. Transformation is the grammar's dynamic dimension." ;
    m0:dominance 9.3e-01 ;
    m0:metaconcept <https://raw.githubusercontent.com/aladas-org/cryptocalc/master/ontology/M2_MetaConcepts.jsonld#Transformation> ;
    m0:tensorFormula "D ⊗ S ⊗ I" .

m0:polarity_heaven_earth a m0:TrigramPolarities ;
    rdfs:label "Heaven ☰ / Earth ☷ — Primary Polarity" ;
    m0:binaryCodes "111 / 000" ;
    m0:pair "m0:trigram_kun",
        "m0:trigram_qian" ;
    m0:principle "Creative force vs. receptive sustenance — the foundational polarity of all existence" .

m0:polarity_mountain_lake a m0:TrigramPolarities ;
    rdfs:label "Mountain ☶ / Lake ☱ — Repose Polarity" ;
    m0:binaryCodes "100 / 011" ;
    m0:pair "m0:trigram_dui",
        "m0:trigram_gen" ;
    m0:principle "Containing stillness vs. joyful openness — inward summit vs. outward surface" .

m0:polarity_thunder_wind a m0:TrigramPolarities ;
    rdfs:label "Thunder ☳ / Wind ☴ — Action Polarity" ;
    m0:binaryCodes "001 / 110" ;
    m0:pair "m0:trigram_xun",
        "m0:trigram_zhen" ;
    m0:principle "Sudden initiation vs. gradual penetration — two modes of initiating change" .

m0:polarity_water_fire a m0:TrigramPolarities ;
    rdfs:label "Water ☵ / Fire ☲ — Substance Polarity" ;
    m0:binaryCodes "010 / 101" ;
    m0:pair "m0:trigram_kan",
        "m0:trigram_li" ;
    m0:principle "Hidden strength in danger vs. radiant beauty clinging to source — depth vs. brilliance" .

m0:primitive_yang a m0:Primitive ;
    rdfs:label "Yang — Undivided Line (⚊)" ;
    rdfs:comment "Yang is the active, bright, creative primitive. In divinatory practice, coins/yarrow stalks generate Young Yang (stable) or Old Yang (changing → Yin). Old Yang marks the dynamic tension of maximum yang about to invert." ;
    m0:binaryValue "1" ;
    m0:chineseName "陽" ;
    m0:cosmologicalCorrespondences "Fire",
        "Heaven",
        "Male",
        "Strength",
        "Sun" ;
    m0:grammarLevel 0 ;
    m0:nature "solid, undivided, active, creative, light" ;
    m0:oldForm "Old Yang (老陽, marked ×) — unstable, changes to Yin" ;
    m0:symbol "⚊" ;
    m0:youngForm "Young Yang (少陽) — stable, non-changing" .

m0:primitive_yin a m0:Primitive ;
    rdfs:label "Yin — Divided Line (⚋)" ;
    rdfs:comment "Yin is the receptive, dark, yielding primitive. Old Yin carries the maximum yin tension about to invert into Yang, encoding the cyclical cosmology where opposites generate each other." ;
    m0:binaryValue "0" ;
    m0:chineseName "陰" ;
    m0:cosmologicalCorrespondences "Earth",
        "Female",
        "Moon",
        "Receptivity",
        "Water" ;
    m0:grammarLevel 0 ;
    m0:nature "broken, divided, receptive, yielding, dark" ;
    m0:oldForm "Old Yin (老陰, marked ×) — unstable, changes to Yang" ;
    m0:symbol "⚋" ;
    m0:youngForm "Young Yin (少陰) — stable, non-changing" .

m0:revoi_evolvability a m0:REVOIAnalysis ;
    rdfs:label "Evolvability (E)" ;
    rdfs:comment "The I Ching is designed for evolvability. The changing-line mechanism is an intrinsic evolution engine: every reading generates not just the present state but the vector of change. The text has evolved over ~3000 years through accumulation of interpretive layers (Judgment → Image → Ten Wings → Neo-Confucian commentary → Jungian psychology → modern applications). The binary grammar is translation-invariant: the core combinatorial structure has survived 3 millennia of cultural change with zero structural modification." ;
    m0:builtInEvolutionMechanism "Changing lines — every reading encodes its own transformation vector" ;
    m0:culturalEvolution "1923 CE: Richard Wilhelm translation — Western diffusion",
        "1949 CE: C.G. Jung — synchronicity and archetypal interpretation",
        "1973 CE: Terence McKenna — Timewave Zero (mathematical extension)",
        "960-1279 CE: Neo-Confucians — philosophical systematization",
        "~1000 BCE: King Wen — Judgments layer",
        "~500 BCE: Confucius — Ten Wings layer" ;
    m0:dominantM3 "m3:Evolvability" ;
    m0:m2_metaconcepts "m2:Adaptation",
        "m2:Memory",
        "m2:Self-Organization" ;
    m0:score 8.8e-01 ;
    m0:structuralEvolution "Grammar frozen since ~800 BCE; interpretive layers continuously evolving" .

m0:revoi_interoperability a m0:REVOIAnalysis ;
    rdfs:label "Interoperability (I)" ;
    rdfs:comment "The I Ching has achieved extraordinary cross-domain interoperability across 3 millennia, making it one of the most interoperable symbolic systems ever created. Its binary grammar maps directly to binary mathematics (Leibniz, 1703). Its Yin/Yang duality resonates with complementarity in quantum mechanics (Bohr), wave/particle duality, attractor/repellor pairs, and cybernetic feedback. The hexagram space has been applied to Jungian archetypes, Chinese medicine (Five Elements extension), feng shui, strategic management (I Ching as decision framework), software architecture (hexagonal architecture), and chaos theory." ;
    m0:dominantM3 "m3:Interoperability" ;
    m0:m2_metaconcepts "m2:KnowledgeField",
        "m2:Language",
        "m2:Mediator" ;
    m0:mathematicalInterop "Leibniz: I Ching binary ↔ binary arithmetic; hexagram space ↔ 6-bit integers" ;
    m0:medicineInterop "Chinese medicine: Yin/Yang ↔ physiological balance; trigrams ↔ organ systems" ;
    m0:physicsInterop "Bohr: Yin/Yang ↔ complementarity; Tai Chi as coat of arms" ;
    m0:psychologyInterop "Jung: hexagrams as archetypes; synchronicity as non-causal connecting principle" ;
    m0:score 9e-01 ;
    m0:systemsThinkingInterop "Cybernetics: changing lines ↔ feedback; hexagram transformation ↔ state machine" ;
    m0:tscgInterop [ m2:Composition "hexagram = trigram ⊗ trigram (tensor composition)" ;
            m2:FeedbackLoop "changing lines = transformative feedback" ;
            m2:Hierarchy "3-level grammar (primitive→trigram→hexagram)" ;
            m2:Polarity "Yin/Yang = archetypal N=2 polarity" ;
            m2:Signature "hexagram = unique 6-bit situational signature" ] .

m0:revoi_observability a m0:REVOIAnalysis ;
    rdfs:label "Observability (O)" ;
    rdfs:comment "The I Ching has two observability modes: (1) Structural observability — HIGH: the 64 hexagrams, 8 trigrams, and binary grammar are fully explicit and enumerable; each hexagram has a unique visual form (6-line pattern), name, and number; (2) Interpretive observability — MEDIUM: the four semantic layers are textually defined but their application to a specific situation requires hermeneutic judgment; (3) Outcome observability — LOW: the transformation from primary to derived hexagram is observable as a formal operation, but whether the predicted transformation matches real events cannot be directly observed." ;
    m0:dominantM3 "m3:Observability" ;
    m0:interpretiveObservability "MEDIUM — reading requires hermeneutic competence; same hexagram observed differently by different readers" ;
    m0:m2_metaconcepts "m2:Observer",
        "m2:Signal",
        "m2:State" ;
    m0:outcomeObservability "LOW — the prophetic dimension is not directly observable" ;
    m0:score 7.8e-01 ;
    m0:structuralObservability "HIGH — 64 hexagram symbols are fully enumerable and visually distinct" .

m0:revoi_representability a m0:REVOIAnalysis ;
    rdfs:label "Representability (R)" ;
    rdfs:comment "The I Ching claims exhaustive representability: the 64 hexagrams cover all possible human situations. The 6-bit binary space is complete — no situation lies outside the 64-state symbolic universe. The grammar's minimality (2 primitives) combined with its depth (6 levels) achieves maximal expressiveness from minimal means. The four interpretive layers further amplify representability: the same hexagram generates radically different yet valid readings across temporal, psychological, strategic, and cosmological contexts." ;
    m0:coverageClaim "Exhaustive by construction: {Yin,Yang}⁶ = 2⁶ = 64 = complete binary space" ;
    m0:dominantM3 "m3:Representability" ;
    m0:expressiveLevels "Binary (formal) → Archetype (symbolic) → Judgment/Image (situational) → Philosophy (cosmological)" ;
    m0:m2_metaconcepts "m2:Representation",
        "m2:Scope",
        "m2:ValueSpace" ;
    m0:representationStrength "HIGH — any human situation can be mapped to one of 64 hexagrams; changing lines add temporal resolution" ;
    m0:score 9.5e-01 .

m0:revoi_verifiability a m0:REVOIAnalysis ;
    rdfs:label "Verifiability (V)" ;
    rdfs:comment "The I Ching occupies a unique epistemic position: low empirical verifiability, high internal consistency verifiability. The oracular claims (hexagram X predicts outcome Y) are not empirically falsifiable — interpretation is always retroactively validatable. The grammar itself is perfectly verifiable: the 64-hexagram space is mathematically proven exhaustive, the trigram combinations are formally derivable, the changing-line rules are deterministic. The symbolic arbitration clause defines the interpretive domain: verification belongs to symbolic coherence, not empirical prediction." ;
    m0:dominantM3 "m3:Verifiability" ;
    m0:empiricalVerifiability "LOW — oracular predictions not empirically testable (symbolic, not predictive)" ;
    m0:epistemicStatus "Symbolic truth: a reading is 'true' if it generates coherent, actionable insight — not if it matches measurable outcomes" ;
    m0:formalVerifiability "HIGH — binary grammar, trigram combinations, and 64-hexagram completeness are mathematically provable" ;
    m0:internalConsistency "HIGH — 3000 years of commentary has built a dense web of cross-referencing interpretation" ;
    m0:m2_metaconcepts "m2:Constraint",
        "m2:Invariant",
        "m2:Signature" ;
    m0:score 5e-01 .

m0:rule_changing_lines a m0:GrammarRule ;
    rdfs:label "Changing Lines Rule (Dynamic Transformation)" ;
    rdfs:comment "The changing-line mechanism is the dynamic grammar of the I Ching. It transforms the static hexagram into a trajectory — from present to future — making the I Ching not just a taxonomy of 64 situations but a grammar of 64×64 = 4096 possible transitions." ;
    m0:formula "H_primary →(changing lines)→ H_derived" ;
    m0:interpretationLayers [ ] ;
    m0:rule "Old Yang (×) → Young Yin; Old Yin (×) → Young Yang" ;
    m0:semantics "The primary hexagram describes the present situation; the derived hexagram describes the emerging future state" ;
    m0:tscgMapping "δΘ(H_primary, H_derived) = epistemic gap between present Map and future Territory" .

m0:rule_hexagram_formation a m0:GrammarRule ;
    rdfs:label "Hexagram Formation Rule (Main Grammar Rule)" ;
    rdfs:comment "The central grammar rule: any situation is representable as a combination of two trigrams. The lower trigram encodes the inner/hidden/subjective dimension; the upper trigram encodes the outer/manifest/objective dimension. This inner-outer duality is the semantic engine of hexagram interpretation." ;
    m0:coverageProperty "exhaustive — the 64 hexagrams partition the entire 6-bit binary space {0,1}⁶" ;
    m0:formalExpression "H(i,j) = T_i ⊗ T_j where i,j ∈ {1..8}, resulting in 8×8 = 64 unique hexagrams" ;
    m0:formula "Hexagram = Trigram_lower ⊗ Trigram_upper" ;
    m0:readingOrder "lower trigram = inner situation (lines 1-3), upper trigram = outer situation (lines 4-6)" ;
    m0:resultCount 64 ;
    m0:rule "Stack 2 trigrams (lower inner + upper outer) to form a hexagram" ;
    m0:symmetryNote "H(i,j) ≠ H(j,i) in general — order matters (lower=inner, upper=outer)" .

m0:rule_trigram_formation a m0:GrammarRule ;
    rdfs:label "Trigram Formation Rule" ;
    rdfs:comment "A trigram (卦 gua) is an ordered triple of Yin/Yang lines read bottom-to-top. The 8 trigrams are the named archetypes of the I Ching grammar, each corresponding to a natural phenomenon and family role." ;
    m0:formula "{Yin, Yang}³ → 2³ = 8 distinct trigrams" ;
    m0:readingOrder "bottom line first (line 1), then middle (line 2), then top (line 3)" ;
    m0:resultCount 8 ;
    m0:rule "Stack 3 primitives (bottom → middle → top) to form a trigram" .

m0:ssg_validation_result a m0:SSGValidation ;
    rdfs:label "SSG Validation Result" ;
    m0:contributions [ ] ;
    m0:criterion_combination_rules "VALIDATED — 2 explicit rules: (1) stack 3 primitives → trigram, (2) stack 2 trigrams → hexagram. Both rules are deterministic, enumerable, and closed." ;
    m0:criterion_finite_primitives "VALIDATED — exactly 2 primitives (Yin, Yang), irreducible and exhaustive" ;
    m0:criterion_multiple_interpretations "VALIDATED — 4 semantic layers (Judgment, Image, Line texts, Ten Wings) generate systematically distinct interpretations of the same hexagram. 3000 years of commentary demonstrates interpretive diversity without consensus collapse." ;
    m0:criterion_symbolic_arbitration "VALIDATED — interpretive validity is determined by symbolic coherence, cultural resonance, and contextual pertinence, never by empirical prediction. No physical law arbitrates between readings." ;
    m0:distinctionFromPoclet "The I Ching does NOT model an observable real-world system — it IS a symbolic universe. Where a Poclet validates an empirical system's ASFID dimensions, the I Ching generates the symbolic space within which any situation can be represented." ;
    m0:distinctionFromSystemicFramework "Unlike TRIZ or VSM, the I Ching does not converge toward a solution. It generates interpretive multiplicity — the same hexagram legitimately guides toward different actions depending on reader and context." ;
    m0:overallStatus "VALIDATED — Canonical SymbolicSystemGrammar instance. ASFID: 0.85, REVOI: 0.80, δΘ: 0.38 (intentional gap = interpretive generativity)" .

