m0:Transition_MeltingFreezing a tscg:PhaseTransition ;
    rdfs:label "Melting / Freezing" ;
    rdfs:comment "First-order phase transition between solid and liquid at the melting point; discontinuous volume and entropy; latent heat absorbed/released" ;
    tscg:clausiusClapeyron "dP/dT = L_fus / (T * Delta_V_fus)" ;
    tscg:direction "Solid -> Liquid (melting, endothermic) | Liquid -> Solid (freezing, exothermic)" ;
    tscg:fromPhase "Solid" ;
    tscg:latentHeat "Heat of fusion L_fus (J/mol) absorbed or released at constant T" ;
    tscg:orderOfTransition "First-order" ;
    tscg:signature "Latent heat plateau in heating/cooling curve; volume discontinuity" ;
    tscg:symmetryBreaking "YES (Freezing direction) — spontaneous descent from continuous translational symmetry (liquid) to discrete lattice symmetry (crystal). Primary physical instance of SymmetryBreaking M2 candidate." ;
    tscg:toPhase "Liquid" ;
    m0:m2basis "m2:Switch",
        "m2:Threshold",
        "m2:Transformation" .

m0:Transition_SublimationDeposition a tscg:PhaseTransition ;
    rdfs:label "Sublimation / Deposition" ;
    rdfs:comment "Direct solid-to-gas transition bypassing liquid phase; occurs when P < P_triple; notable in iodine and camphor at standard conditions" ;
    tscg:condition "Pressure < P_triple_point of substance" ;
    tscg:direction "Solid -> Gas (sublimation, endothermic) | Gas -> Solid (deposition, exothermic)" ;
    tscg:fromPhase "Solid" ;
    tscg:latentHeat "L_sub = L_fus + L_vap (Hess's law)" ;
    tscg:notableExamples "CO2 (dry ice) at 1 atm",
        "Camphor: triple point at 6.6 kPa",
        "Iodine: triple point at 11.7 kPa (above 1 atm vapor pressure at RT)" ;
    tscg:symmetryBreaking "YES (Deposition direction) — gas directly acquires crystalline order. Combines Switch and SymmetryBreaking in a single step." ;
    tscg:toPhase "Gas" ;
    m0:m2basis "m2:Switch",
        "m2:Threshold",
        "m2:Transformation" .

m0:Transition_VaporizationCondensation a tscg:PhaseTransition ;
    rdfs:label "Vaporization / Condensation" ;
    rdfs:comment "First-order transition between liquid and gas at boiling point; ideal gas law applies in gas phase; vapor pressure follows Clausius-Clapeyron" ;
    tscg:clausiusClapeyron "dP/dT = L_vap / (T * Delta_V_vap) approx L_vap * P / (R * T^2)" ;
    tscg:direction "Liquid -> Gas (vaporization, endothermic) | Gas -> Liquid (condensation, exothermic)" ;
    tscg:fromPhase "Liquid" ;
    tscg:idealGasLink "Vapor pressure: ln(P) = -L_vap/(R*T) + const" ;
    tscg:latentHeat "Heat of vaporization L_vap (J/mol); typically 5-10x L_fus" ;
    tscg:orderOfTransition "First-order below critical point; continuous (second-order) above critical point" ;
    tscg:symmetryBreaking "NO — both liquid and gas share continuous translational symmetry. Transition is pure Switch/Threshold without symmetry breaking (density discontinuity only)." ;
    tscg:toPhase "Gas" ;
    m0:m2basis "m2:Gradient",
        "m2:Switch",
        "m2:Threshold" .

