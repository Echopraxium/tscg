@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix m2: <https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M2_MetaConcepts.jsonld#> .
@prefix ns1: <m0:fire_triangle:> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FireTrianglePoclet a owl:NamedIndividual,
        "m1:chemistry:Combustion",
        "m1:core:Poclet" ;
    rdfs:label "Fire Triangle (Poclet)" ;
    dcterms:created "2026-01-17" ;
    dcterms:creator "Echopraxium with the collaboration of Claude AI" ;
    dcterms:references "Fire science textbooks (standard reference)",
        "NFPA (National Fire Protection Association) materials",
        "OSHA fire safety training" ;
    rdfs:comment "Minimal yet complete system representation of combustion. Demonstrates all 5 ASFID dimensions and mobilizes 22 M2 metaconcepts. Canonical example for TSCG framework validation." ;
    rdfs:seeAlso "m1:chemistry:Combustion",
        "m2:Component",
        "m2:Composition",
        "m2:Synergy" ;
    owl:imports "https://raw.githubusercontent.com/Echopraxium/tscg/main/ontology/M1_CoreConcepts.jsonld" ;
    m2:changelog "2026-02-20: Audit vs README - added mapSpace.asfidState (A:0.75,S:0.90,F:0.60,I:0.80,D:0.50) derived from epistemicGap; added Relational:Synergy to metaconceptsMobilized.byCategory (count now consistent at 22)",
        "2026-02-20: Fixed dcterms:creator label; standardized oriveAnalysis → revoi; corrected Heat @type (m0:Energy → m1:chemistry:Energy); fixed mapSpace to use REVOI basis; corrected metaconcept count to 22/58",
        "2026-02-24: Added flameColorByTemperature property to Heat component (dark red → red → orange → yellow → white progression with temperature thresholds in °C)" ;
    ns1:alternativeObservers [ ],
        [ ],
        [ ] ;
    ns1:completeness "All ASFID dimensions present" ;
    ns1:components ns1:Fuel,
        ns1:Heat,
        ns1:Oxidizer ;
    ns1:constraints [ ],
        [ ],
        [ ],
        [ ] ;
    ns1:domain "Chemistry" ;
    ns1:epistemicGap [ ] ;
    ns1:extensions [ ] ;
    ns1:extinguishmentStrategies [ ] ;
    ns1:historicalContext [ ] ;
    ns1:mapSpace [ ] ;
    ns1:metaconceptsMobilized [ ] ;
    ns1:minimality "Exactly 3 components (irreducible)" ;
    ns1:observer "Human (Western scientific perspective)" ;
    ns1:pedagogy "Entry point for fire science and systems theory" ;
    ns1:pocletType "Composite" ;
    ns1:process [ ] ;
    ns1:revoi [ ] ;
    ns1:synergyPrinciple [ ] ;
    ns1:territorySpace [ ] ;
    ns1:transdisciplinaryAnalogy [ ] ;
    ns1:validation [ ] .

ns1:Fuel a <m1:chemistry:ChemicalSpecies> ;
    rdfs:label "Fuel (Combustible)" ;
    ns1:asfidContribution [ ] ;
    ns1:chemicalNature "Typically hydrocarbons or organic matter" ;
    ns1:examples "Gasoline",
        "Natural gas",
        "Paper",
        "Wood" ;
    ns1:function "Provides chemical potential energy" ;
    ns1:role "Energy source" ;
    ns1:stateOfMatter "Solid, Liquid, or Gas" .

ns1:Heat a <m1:chemistry:Energy> ;
    rdfs:label "Heat (Activation Energy)" ;
    ns1:asfidContribution [ ] ;
    ns1:flameColorByTemperature [ ] ;
    ns1:function "Initiates and sustains reaction above ignition temperature" ;
    ns1:role "Activation threshold" ;
    ns1:sources "Friction",
        "Hot surface",
        "Lightning",
        "Match",
        "Spark" ;
    ns1:sustainment "Once ignited, combustion generates own heat (positive feedback)" ;
    ns1:threshold "T_ignition (fuel-dependent)" .

ns1:Oxidizer a <m1:chemistry:ChemicalSpecies> ;
    rdfs:label "Oxidizer (Comburant)" ;
    ns1:alternativeOxidizers "ClO₄⁻",
        "Cl₂",
        "F₂",
        "NO₃⁻" ;
    ns1:asfidContribution [ ] ;
    ns1:concentration "Typically > 16% in air for sustained combustion" ;
    ns1:function "Enables oxidation reaction" ;
    ns1:primaryExample "O₂ (atmospheric oxygen)" ;
    ns1:role "Electron acceptor" .

